@implements IDisposable
@inject NavigationManager Navigation
@inject ITenantAdminService TenantsSvc
@inject ISubscriptionAdminService SubsSvc
@inject IPlanAdminService PlansSvc
@inject IServiceScopeFactory ScopeFactory
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.EntityFrameworkCore
@using Ecorex.Application.MenuConfig
@using Ecorex.Domain.Enums

@if (_showAdmin)
{
    @* Consola de plataforma: marca configurable (Super Admin -> Marca) con icono de tablero. *@
    <div class="ecorex-brand">
        <div class="ecorex-logo">
            @if (!string.IsNullOrWhiteSpace(_brandLogoUrl))
            {
                <img src="@_brandLogoUrl" alt="@(_brandName ?? "Logo")" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;" />
            }
            else
            {
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="3"/><path d="m7.5 12 2 2 4-4.5"/><path d="M16.5 16h.01"/></svg>
            }
        </div>
        <div>
            @if (string.IsNullOrWhiteSpace(_brandName) || _brandName == "ECOREX.tareas")
            {
                <div class="ecorex-brand-name">ECOREX<span>.tareas</span></div>
            }
            else
            {
                <div class="ecorex-brand-name">@_brandName</div>
            }
            <div class="ecorex-brand-sub">@(_brandTagline ?? "Sistema de Tareas")</div>
        </div>
    </div>
}
else
{
    @* Cabecera del workspace (fuente ECOREX.dc.html): tile 36px radio 11 con fondo
       var(--ink) + inicial, nombre 14.5/700 y "{plan} (punto medio) ECOREX" (el nombre del plan
       ya trae la palabra "Plan"; separador punto medio como el prototipo). *@
    <div class="ecorex-ws-head">
        <div class="ecorex-ws-row" title="@(_tenantName ?? "Mi empresa")">
            <div class="ecorex-tenant-tile">@TenantInitial</div>
            <div style="flex:1;min-width:0;">
                <div class="ecorex-tenant-name">@(_tenantName ?? "Mi empresa")</div>
                <div class="ecorex-tenant-sub">@(_planName is null ? "ECOREX Sistema de Tareas" : $"{_planName} \u00b7 ECOREX")</div>
            </div>
            <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg>
        </div>
    </div>
}

@* Buscador global del prototipo (Cmd/Ctrl+K). Placeholder: se activa junto con el contenido real. *@
<div class="ecorex-search" title="Busqueda global (proximamente)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    <input type="search" placeholder="Buscar" disabled />
    <span class="kbd">Ctrl K</span>
</div>

@if (_showAdmin)
{
    <div class="ecorex-agency">
        <div class="lbl">Plataforma</div>
        <div class="name">ECOREX.tareas</div>
        <div class="meta">Consola de gobierno</div>
    </div>
}

<nav class="ecorex-nav">
    @if (_showTenant && _menu is not null)
    {
        @* ===== Menu DATA-DRIVEN (Ola 1 del menu por perfil): el arbol resuelto viene de
               IMenuConfigService.GetMenuForTenantUserAsync segun la vista del usuario (o la
               IsDefault). El LOOK es identico al del prototipo: quick-links, label "Modulos",
               secciones acordeon con icono/contador/chevron, items con codigo legacy y el
               subgrupo anidado. data-acc = slug del nodo (Route) para persistir apertura. ===== *@
        @foreach (var quick in _menu.Roots.Where(n => n.Kind == MenuNodeKind.QuickLink))
        {
            <NavLink class="ecorex-nav-link" href="@quick.Route">
                @MenuIcons.Render(quick.IconKey)
                <span>@quick.Name</span>
                @if (string.Equals(quick.Route, "anuncios", StringComparison.Ordinal))
                {
                    @* Placeholder del contador de no leidos: se conecta cuando exista el modulo. *@
                    <span class="ecorex-nav-badge" title="Anuncios sin leer (placeholder)">0</span>
                }
            </NavLink>
        }

        <div class="ecorex-nav-label">Modulos</div>

        @foreach (var section in _menu.Roots.Where(n => n.Kind == MenuNodeKind.Section))
        {
            var slug = section.Route ?? section.Id.ToString();
            <details class="ecorex-acc @SectionTone(slug)" data-acc="@slug" open="@IsGroupOpen(slug)">
                <summary>
                    <span class="ecorex-acc-ico">@MenuIcons.Render(section.IconKey)</span>
                    <span class="ecorex-acc-name">@section.Name</span>
                    @if (section.IsProcessGroup)
                    {
                        <span title="Este grupo despliega los procesos (actividades tipo proceso)" style="margin-left:6px;font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.03em;padding:1px 6px;border-radius:999px;background:rgba(124,92,255,.16);color:#7c5cff;">procesos</span>
                    }
                    <span class="ecorex-acc-count">@section.VisibleChildCount</span>
                    <svg class="ecorex-acc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                </summary>
                <div class="ecorex-acc-body">
                    @* Ola 4: grupo dinamico "Mis Procesos" -> categoria -> subcategoria (proceso,
                       con flujo) desde el catalogo de Conceptos. Click abre el wizard con la
                       categoria/subcategoria fijadas (crear-actividad?sub=). *@
                    @if (section.IsProcessGroup)
                    {
                        @* Las categorias-proceso dinamicas van agrupadas bajo un nodo "Procesos". *@
                        <details class="ecorex-acc-sub" data-acc="grp-procesos" open="@IsGroupOpen("grp-procesos")">
                            <summary>
                                <span class="ecorex-acc-name">Procesos</span>
                                <span class="ecorex-acc-count">@_procesoCats.Count</span>
                                <svg class="ecorex-acc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                            </summary>
                            <div class="ecorex-acc-sub-body">
                                @foreach (var pc in _procesoCats)
                                {
                                    <details class="ecorex-acc-sub" data-acc="@pc.Slug" open="@IsGroupOpen(pc.Slug)">
                                        <summary>
                                            <span class="ecorex-acc-name">@pc.Nombre</span>
                                            <span class="ecorex-acc-count">@pc.Subs.Count</span>
                                            <svg class="ecorex-acc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                                        </summary>
                                        <div class="ecorex-acc-sub-body">
                                            @foreach (var s in pc.Subs)
                                            {
                                                <NavLink class="ecorex-acc-item" href="@($"actividades?sub={s.Id}")">
                                                    <span class="lbl">@s.Nombre</span>
                                                    @if (!s.Publicado)
                                                    {
                                                        @* Ola C1 (D3): el flujo del concepto aun esta en borrador. Se
                                                           muestra igual (se avisa, no se oculta); el chip lo advierte. *@
                                                        <span class="code" title="El flujo de este proceso aun no esta publicado" style="background:var(--t-amber-bg, rgba(245,158,11,.16));color:var(--t-amber, #f59e0b)">borrador</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="code" title="Actividad tipo proceso">proc</span>
                                                    }
                                                </NavLink>
                                            }
                                        </div>
                                    </details>
                                }
                                @if (_procesoCats.Count == 0)
                                {
                                    <div style="padding:8px 12px;font-size:11.5px;color:var(--ink-3)">Sin actividades tipo proceso. Vincula un flujo a una subcategoria en Conceptos.</div>
                                }
                            </div>
                        </details>
                    }
                    @foreach (var child in section.Children)
                    {
                        if (child.Kind == MenuNodeKind.Subgroup)
                        {
                            var subSlug = child.Route ?? child.Id.ToString();
                            <details class="ecorex-acc-sub" data-acc="@subSlug" open="@IsGroupOpen(subSlug)">
                                <summary>
                                    <span class="ecorex-acc-name">@child.Name</span>
                                    <span class="ecorex-acc-count">@child.VisibleChildCount</span>
                                    <svg class="ecorex-acc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                                </summary>
                                <div class="ecorex-acc-sub-body">
                                    @foreach (var leaf in child.Children.Where(n => n.Kind == MenuNodeKind.Item))
                                    {
                                        <NavLink class="ecorex-acc-item" href="@leaf.Route">
                                            <span class="lbl">@leaf.Name</span>
                                        </NavLink>
                                    }
                                </div>
                            </details>
                        }
                        else
                        {
                            <NavLink class="ecorex-acc-item" href="@child.Route">
                                <span class="lbl">@child.Name</span>
                            </NavLink>
                        }
                    }
                </div>
            </details>
        }
    }

