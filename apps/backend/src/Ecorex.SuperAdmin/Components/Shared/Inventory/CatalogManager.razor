@using Ecorex.Application.Inventory
@inject IInventoryCatalogService CatalogSvc

@* Componente generico de catalogo de inventario (marcas 000502, grupos 000506, subgrupos
   000606, tipos 000498). Grid + busqueda + modal crear/editar + activar/archivar. Los
   subgrupos agregan un select de grupo. Tokens del workspace, claro/oscuro. *@

@* Con ShowHeader=false (dentro del modal de /inventario-configuracion) se omite el
   encabezado del modulo, porque el modal ya pone su propio titulo. *@
@if (ShowHeader)
{
    <div class="module-head">
        <div>
            <div class="module-eyebrow">
                <div class="module-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-9" /><path d="M14 17H5" /><circle cx="17" cy="17" r="3" /><circle cx="7" cy="7" r="3" /></svg>
                </div>
                <span>Modulo @LegacyCode &#183; Sistema &#183; Inventarios</span>
            </div>
            <h1 class="page-title" style="margin-top:12px;">@Title</h1>
            <p class="page-sub" style="margin-bottom:0;">@Subtitle</p>
        </div>
        <div>
            <button class="btn btn-primary" @onclick="@(() => OpenEditor(null))">+ @NewLabel</button>
        </div>
    </div>
}

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div style="display:flex;gap:10px;align-items:center;margin-bottom:14px;flex-wrap:wrap;">
        <input class="form-control" style="max-width:280px;" placeholder="Buscar @Title.ToLowerInvariant()..." @bind="_search" @bind:event="oninput" />
        @if (!ShowHeader)
        {
            <button class="btn btn-primary" @onclick="@(() => OpenEditor(null))">+ @NewLabel</button>
        }
        <label class="pl-toggle" style="margin-left:auto;">
            <input type="checkbox" checked="@_includeInactive" @onchange="@(async e => { _includeInactive = (bool)e.Value!; await LoadAsync(); })" />
            Ver archivados
        </label>
    </div>

    @if (Filtered.Count == 0)
    {
        <div class="coming-soon" style="padding:40px 24px;">
            <h3>Sin registros todavia</h3>
            <p>Crea el primer registro de @Title.ToLowerInvariant().</p>
            <button class="btn btn-primary" style="margin-top:14px;" @onclick="@(() => OpenEditor(null))">+ @NewLabel</button>
        </div>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Nombre</th>
                    @if (Kind == CatalogKind.ItemSubgroup)
                    {
                        <th>Grupo</th>
                    }
                    <th>Descripcion</th>
                    <th style="text-align:center;">Items</th>
                    <th style="text-align:center;">Estado</th>
                    <th style="text-align:right;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Filtered)
                {
                    <tr class="@(c.IsActive ? "" : "inactive-row")">
                        <td><strong>@c.Name</strong></td>
                        @if (Kind == CatalogKind.ItemSubgroup)
                        {
                            <td>@(c.GroupName ?? "-")</td>
                        }
                        <td class="muted-cell">@(string.IsNullOrWhiteSpace(c.Description) ? "-" : c.Description)</td>
                        <td style="text-align:center;font-variant-numeric:tabular-nums;">@c.ItemCount</td>
                        <td style="text-align:center;">
                            <span class="tk-status @(c.IsActive ? "st-done" : "st-closed")">@(c.IsActive ? "Activo" : "Archivado")</span>
                        </td>
                        <td style="text-align:right;white-space:nowrap;">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => OpenEditor(c))">Editar</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="@(() => ToggleActiveAsync(c))" disabled="@_busy">
                                @(c.IsActive ? "Archivar" : "Restaurar")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    @if (_pageError is not null)
    {
        <div class="tk-field-error">@_pageError</div>
    }
}

@if (_showEditor)
{
    <div class="modal-overlay" @onclick="@(() => _showEditor = false)">
        <div class="modal-dialog" style="max-width:520px;" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>@(_editing is null ? NewLabel : $"Editar {_editing.Name}")</h3>
                <button class="modal-close" @onclick="@(() => _showEditor = false)">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Nombre *</label>
                    <input class="form-control" @bind="_fName" maxlength="150" />
                </div>
                @if (Kind == CatalogKind.ItemSubgroup)
                {
                    <div class="field">
                        <label class="form-label">Grupo *</label>
                        <select class="form-control" @bind="_fGroupId">
                            <option value="">-- Selecciona un grupo --</option>
                            @foreach (var g in _groups)
                            {
                                <option value="@g.Id">@g.Name</option>
                            }
                        </select>
                    </div>
                }
                <div class="row g-2">
                    <div class="col-md-6 field">
                        <label class="form-label">Orden</label>
                        <input type="number" class="form-control" @bind="_fSortOrder" />
                    </div>
                </div>
                <div class="field">
                    <label class="form-label">Descripcion</label>
                    <textarea class="form-control" rows="2" maxlength="600" @bind="_fDescription"></textarea>
                </div>
                @if (_editorError is not null)
                {
                    <div class="tk-field-error">@_editorError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="@(() => _showEditor = false)" disabled="@_busy">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_busy">@(_editing is null ? "Crear" : "Guardar")</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public CatalogKind Kind { get; set; }
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter, EditorRequired] public string Subtitle { get; set; } = "";
    [Parameter, EditorRequired] public string NewLabel { get; set; } = "";
    [Parameter, EditorRequired] public string LegacyCode { get; set; } = "";

    /// <summary>false dentro del modal de configuracion: el modal ya pone su propio titulo.</summary>
    [Parameter] public bool ShowHeader { get; set; } = true;

    private bool _loading = true;
    private bool _busy;
    private bool _includeInactive;
    private string _search = "";
    private string? _pageError;

    private IReadOnlyList<CatalogEntryDto> _entries = [];
    private IReadOnlyList<CatalogEntryDto> _groups = [];

    private bool _showEditor;
    private CatalogEntryDto? _editing;
    private string _fName = "";
    private string _fGroupId = "";
    private string? _fDescription;
    private int _fSortOrder;
    private string? _editorError;

    private List<CatalogEntryDto> Filtered => _entries
        .Where(c => string.IsNullOrWhiteSpace(_search)
            || c.Name.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase))
        .ToList();

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        _entries = await CatalogSvc.ListAsync(Kind, _includeInactive);
        if (Kind == CatalogKind.ItemSubgroup)
        {
            _groups = await CatalogSvc.ListAsync(CatalogKind.ItemGroup);
        }
    }

    private void OpenEditor(CatalogEntryDto? entry)
    {
        _editing = entry;
        _fName = entry?.Name ?? "";
        _fGroupId = entry?.GroupId?.ToString() ?? "";
        _fDescription = entry?.Description;
        _fSortOrder = entry?.SortOrder ?? 0;
        _editorError = null;
        _showEditor = true;
    }

    private async Task SaveAsync()
    {
        _busy = true;
        _editorError = null;
        var request = new SaveCatalogRequest(
            _fName,
            _fDescription,
            _fSortOrder,
            Guid.TryParse(_fGroupId, out var groupId) ? groupId : null);
        var result = _editing is null
            ? await CatalogSvc.CreateAsync(Kind, request)
            : await CatalogSvc.UpdateAsync(Kind, _editing.Id, request);
        if (!result.IsOk)
        {
            _editorError = result.Error;
        }
        else
        {
            _showEditor = false;
            await LoadAsync();
        }
        _busy = false;
    }

    private async Task ToggleActiveAsync(CatalogEntryDto entry)
    {
        _busy = true;
        _pageError = null;
        var result = await CatalogSvc.SetActiveAsync(Kind, entry.Id, !entry.IsActive);
        if (!result.IsOk)
        {
            _pageError = result.Error;
        }
        else
        {
            await LoadAsync();
        }
        _busy = false;
    }
}
