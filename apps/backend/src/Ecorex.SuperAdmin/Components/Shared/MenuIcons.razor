        "home", "megaphone", "list", "briefcase", "automation", "robot", "cube",
        "check-square", "users", "crm", "gear", "folder", "chart", "flow", "form",
        "rule", "bell", "shield", "file", "tag", "link", "database", "layout", "sparkles"
    };

    /// <summary>Etiqueta legible para el tooltip del selector (ASCII).</summary>
