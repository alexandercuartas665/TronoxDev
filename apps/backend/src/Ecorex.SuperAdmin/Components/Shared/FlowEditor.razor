    private async Task OpenJumpAsync()
    {
        _jumpQuery = "";
        _jumpSelected = null;
        _jumpFlows = (await DesignSvc.ListForIndexAsync()).Cards
            .Where(c => c.ProcessCode != _canvas?.ProcessCode)
            .ToList();
        _jumpOpen = true;
    }

    private IEnumerable<FlowCardDto> JumpOptions
        => string.IsNullOrWhiteSpace(_jumpQuery)
            ? _jumpFlows
            : _jumpFlows.Where(f => f.Name.Contains(_jumpQuery.Trim(), StringComparison.OrdinalIgnoreCase)
                || f.ProcessCode.Contains(_jumpQuery.Trim(), StringComparison.OrdinalIgnoreCase));

    private void ConfirmJump()
    {
        _jumpOpen = false;
        _notice = "TODO: el vinculo real entre flujos (call activity) esta pendiente en el motor.";
    }

    private async Task CloseAsync()
    {
        await DestroyCanvasAsync();
        await OnClose.InvokeAsync();
    }

    private async Task DestroyCanvasAsync()
    {
        if (_bpmn is not null)
        {
            try { await _bpmn.InvokeVoidAsync("destroy", CanvasId); }
            catch { /* circuito ya cerrado */ }
        }
        _bpmnReady = false;
    }

    public async ValueTask DisposeAsync()
    {
        await DestroyCanvasAsync();
        if (_bpmn is not null)
        {
            try { await _bpmn.DisposeAsync(); }
            catch { /* circuito ya cerrado */ }
        }
        _selfRef?.Dispose();
        _dbGate.Dispose();
    }
