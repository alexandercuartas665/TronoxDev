            if (!result.IsOk)
            {
                _error = result.Error ?? "No se pudo publicar.";
                return;
            }
            _canvas = await DesignSvc.GetCanvasAsync(DefinitionId);
            _notice = $"Version {_canvas!.Version} publicada.";
        }
        finally
        {
            _dbGate.Release();
            _busy = false;
        }
    }

    private async Task EnsureDraftAsync()
