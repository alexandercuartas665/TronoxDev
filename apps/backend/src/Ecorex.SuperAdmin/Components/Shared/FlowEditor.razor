    // Acordeon 4: Reglas de notificacion (placeholder, motor de notificaciones pendiente).
    private RenderFragment NotifBody => __builder =>
    {
        <div class="fe-chips">
            <span class="fe-chip static">Correo al aprobador</span>
            <span class="fe-chip static">Push SignalR</span>
        </div>
        <div class="fe-todo">TODO: motor de notificaciones por nodo pendiente (los chips son ilustrativos del prototipo).</div>
    };

    // Acordeon 5: Reglas de salida (ConditionExpression de las aristas salientes).
    private RenderFragment ExitBody => __builder =>
    {
        if (Selected is not FlowCanvasNodeDto node)
        {
            <div class="fe-acc-empty">Selecciona un nodo guardado del canvas.</div>
            return;
        }
        var outgoing = _canvas!.Edges.Where(e => e.SourceNodeId == node.Id).ToList();
        if (outgoing.Count == 0)
        {
            <div class="fe-acc-empty">El nodo no tiene conexiones de salida.</div>
            return;
        }
        <div class="fe-rows">
            @foreach (var edge in outgoing)
            {
                var target = _canvas!.Nodes.FirstOrDefault(n => n.Id == edge.TargetNodeId);
                <div class="fe-exit-row">
                    <input class="fe-input sm mono" placeholder="Sin condicion (rama default)"
                           value="@(edge.ConditionExpression ?? "")"
                           disabled="@(!_canvas!.IsEditable)"
                           @onchange="@(e => SetEdgeConditionAsync(edge, e))" />
                    <span class="fe-exit-arrow">-&gt;</span>
                    <span class="fe-exit-target">@(target is null ? "?" : NodeLabel(target))</span>
                    @if (_canvas!.IsEditable)
                    {
                        <span class="fe-row-x" @onclick="@(() => DeleteEdgeAsync(edge))">x</span>
                    }
                </div>
            }
        </div>
        <div class="fe-acc-note">Formato del motor: approval == 'Approved' (vacio = rama por defecto).</div>
    };

    private static string RuleTone(RuleStatus status) => status switch
    {
        RuleStatus.Active => "var(--t-green)",
        RuleStatus.Development => "var(--t-amber)",
        _ => "var(--ink-3)"
    };

    private static string RuleStatusLabel(RuleStatus status) => status switch
    {
        RuleStatus.Active => "Activa",
        RuleStatus.Development => "Desarrollo",
        _ => "Inactiva"
    };

    private bool RequireEditable()
    {
        if (_canvas is null) { return false; }
        if (_canvas.IsEditable) { return true; }
        _error = "El grafo publicado no se edita: usa 'Editar (crear version borrador)'.";
        return false;
    }

    /// <summary>Refresca el canvas GUARDADO desde la BD y re-importa el XML en bpmn-js.</summary>
    private async Task RefreshAndReimportAsync()
    {
        _canvas = await DesignSvc.GetCanvasAsync(DefinitionId);
        if (_bpmnReady && _bpmn is not null)
        {
            var xml = await DesignSvc.GetBpmnXmlAsync(DefinitionId) ?? "";
            await _bpmn.InvokeVoidAsync("importXml", CanvasId, xml);
            await ApplyNodeAppearanceAsync();
        }
    }

    // ---- Acciones de acordeones ----

    private async Task OnRestartChangedAsync(FlowCanvasNodeDto node, ChangeEventArgs e)
    {
        Guid? restartId = Guid.TryParse(e.Value?.ToString(), out var parsed) ? parsed : null;
        await GuardAsync(async () =>
        {
            var result = await DesignSvc.SetNodeConfigAsync(node.Id, node.AllowsAssignment, restartId);
            if (!result.IsOk) { _error = result.Error; }
            _canvas = await DesignSvc.GetCanvasAsync(DefinitionId);
        });
    }

    private async Task OnAllowsAssignmentChangedAsync(FlowCanvasNodeDto node, ChangeEventArgs e)
    {
        var allows = e.Value is bool b && b;
        var result = await DesignSvc.SetNodeConfigAsync(node.Id, allows, node.RestartNodeId);
        if (!result.IsOk) { _error = result.Error; }
        _canvas = await DesignSvc.GetCanvasAsync(DefinitionId);
    }

    private async Task OnNodeColorAsync(FlowCanvasNodeDto node, string? key)
        => await SetAppearanceAsync(node, key, node.Note);

    private async Task OnNodeNoteAsync(FlowCanvasNodeDto node, string? note)
        => await SetAppearanceAsync(node, node.Color, note);

    private async Task SetAppearanceAsync(FlowCanvasNodeDto node, string? color, string? note)
    {
        _error = null;
        var result = await DesignSvc.SetNodeAppearanceAsync(node.Id, color, note);
        if (!result.IsOk) { _error = result.Error; return; }
        // Refresca el canvas (para que el swatch/nota activos reflejen lo guardado) y repinta el lienzo.
        _canvas = await DesignSvc.GetCanvasAsync(DefinitionId);
        await ApplyNodeAppearanceAsync();
    }

    private async Task OpenFormPickerAsync()
    {
        _formPickerQuery = "";
        _forms = (await FormsSvc.ListAsync(includeArchived: false))
            .Where(f => f.Status == FormStatus.Active)
            .ToList();
        _formPickerOpen = true;
    }

    private IEnumerable<FormDefinitionListItemDto> FilteredForms
        => string.IsNullOrWhiteSpace(_formPickerQuery)
            ? _forms
            : _forms.Where(f => f.Title.Contains(_formPickerQuery.Trim(), StringComparison.OrdinalIgnoreCase)
                || f.Code.Contains(_formPickerQuery.Trim(), StringComparison.OrdinalIgnoreCase));

    private async Task LinkFormAsync(Guid formDefinitionId)
    {
        if (Selected is not FlowCanvasNodeDto node) { return; }
        var result = await DesignSvc.SetNodeFormAsync(node.Id, formDefinitionId);
        if (!result.IsOk) { _error = result.Error; }
        _formPickerOpen = false;
        _canvas = await DesignSvc.GetCanvasAsync(DefinitionId);
    }

    private async Task UnlinkFormAsync(FlowCanvasNodeDto node)
    {
        var result = await DesignSvc.RemoveNodeFormAsync(node.Id);
        if (!result.IsOk) { _error = result.Error; }
        _canvas = await DesignSvc.GetCanvasAsync(DefinitionId);
    }

    private async Task OpenRulePickerAsync()
    {
        _ruleCatalog = await DesignSvc.ListRuleCatalogAsync();
        _rulePickerOpen = true;
    }

    private IEnumerable<FlowRuleCatalogItemDto> AvailableRules
        => Selected is FlowCanvasNodeDto node
            ? _ruleCatalog.Where(r => node.Rules.All(l => l.RuleId != r.RuleId))
            : [];

    private async Task LinkRuleAsync(Guid ruleId)
    {
        if (Selected is not FlowCanvasNodeDto node) { return; }
        var result = await DesignSvc.AddNodeRuleAsync(node.Id, ruleId);
        if (!result.IsOk) { _error = result.Error; }
        _rulePickerOpen = false;
        _canvas = await DesignSvc.GetCanvasAsync(DefinitionId);
    }

    private async Task UnlinkRuleAsync(FlowNodeRuleDto rule)
    {
        var result = await DesignSvc.RemoveNodeRuleAsync(rule.LinkId);
        if (!result.IsOk) { _error = result.Error; }
        _canvas = await DesignSvc.GetCanvasAsync(DefinitionId);
    }

    private async Task SetEdgeConditionAsync(FlowCanvasEdgeDto edge, ChangeEventArgs e)
    {
        if (!RequireEditable()) { return; }
        var result = await DesignSvc.SetEdgeConditionAsync(edge.Id, e.Value?.ToString());
        if (!result.IsOk) { _error = result.Error; }
        await RefreshAndReimportAsync();
    }

    private async Task DeleteEdgeAsync(FlowCanvasEdgeDto edge)
    {
        if (!RequireEditable()) { return; }
        var result = await DesignSvc.DeleteEdgeAsync(edge.Id);
        if (!result.IsOk) { _error = result.Error; }
        await RefreshAndReimportAsync();
    }

    private async Task ToggleRuleAutonomousAsync(FlowNodeRuleDto rule, ChangeEventArgs e)
    {
        var isAutonomous = e.Value is bool b && b;
        var result = await DesignSvc.SetNodeRuleAutonomousAsync(rule.LinkId, isAutonomous);
        if (!result.IsOk) { _error = result.Error; }
        _canvas = await DesignSvc.GetCanvasAsync(DefinitionId);
    }

    // ---- Header: guardar / publicar / props / io / draft ----

    /// <summary>
    /// Guarda el grafo dibujado: exporta el XML de bpmn-js y lo re-sincroniza
    /// (SaveBpmnAsync = EnsureDraft + resync de nodos/aristas/layout). Guarda tambien las
    /// props (nombre/categoria/descripcion). Si se derivo un borrador nuevo, cambia a el.
    /// </summary>
    private async Task SaveAsync()
    {
        if (_canvas is null || _bpmn is null) { return; }
        _busy = true;
        _error = null;
        _notice = null;
        await _dbGate.WaitAsync();
        try
        {
            var xml = _bpmnReady ? await _bpmn.InvokeAsync<string?>("exportXml", CanvasId) : null;
            if (string.IsNullOrWhiteSpace(xml))
            {
                _error = "No se pudo leer el diagrama del editor.";
                return;
            }

            var saved = await DesignSvc.SaveBpmnAsync(_canvas.DefinitionId, xml);
            if (!saved.IsOk || saved.Value is null)
            {
                _error = saved.Error ?? "No se pudo guardar el diagrama.";
                return;
            }

            // Props (nombre/categoria/descripcion) sobre la definicion resultante.
            var props = await DesignSvc.UpdateDefinitionPropsAsync(
                saved.Value.DefinitionId, _name, _categoryValue, _description);
            if (!props.IsOk)
            {
                _error = props.Error ?? "No se pudieron guardar las propiedades.";
            }

            if (saved.Value.DefinitionId != _canvas.DefinitionId)
            {
                // Se derivo un borrador (la definicion abierta estaba publicada): cambiar a el.
                _notice = "Cambios guardados en la nueva version borrador.";
                await OnDefinitionSwitched.InvokeAsync(saved.Value.DefinitionId);
                return;
            }

            await RefreshAndReimportAsync();
            _notice = "Cambios guardados.";
        }
        finally
        {
            _dbGate.Release();
            _busy = false;
        }
    }

    private async Task PublishAsync()
    {
        if (_canvas is null) { return; }
        _busy = true;
        _error = null;
        await _dbGate.WaitAsync();
        try
        {
