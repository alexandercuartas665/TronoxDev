    // Acordeon 0: Configuracion basica (tipo + reinicio + permite asignacion).
    private RenderFragment ConfigBody => __builder =>
    {
        if (Selected is not FlowCanvasNodeDto node)
        {
            <div class="fe-acc-empty">Selecciona un nodo guardado del canvas.</div>
            return;
        }
        <div class="fe-field">
            <label>Tipo de actividad</label>
            <div class="fe-field-ro">@NodeTypeLabel(node.NodeType)</div>
        </div>
        <div class="fe-field">
            <label>Reinicio (abre un ciclo nuevo en...)</label>
            <select class="fe-input sm" value="@(node.RestartNodeId?.ToString() ?? "")"
                    disabled="@(!_canvas!.IsEditable)"
                    @onchange="@(e => OnRestartChangedAsync(node, e))">
                <option value="">Sin reinicio</option>
                @foreach (var other in _canvas!.Nodes.Where(n => n.Id != node.Id))
                {
                    <option value="@other.Id">@NodeLabel(other)</option>
                }
            </select>
        </div>
        <label class="fe-check">
            <input type="checkbox" checked="@node.AllowsAssignment"
                   disabled="@(!_canvas!.IsEditable)"
                   @onchange="@(e => OnAllowsAssignmentChangedAsync(node, e))" />
            Permite asignacion manual del paso
        </label>

        @* Apariencia del nodo (restaurado del canvas propio): color de paleta + nota post-it. Son
           metadatos (no viajan en el XML), asi que se pueden editar tambien sobre una publicada. *@
        <div class="fe-field" style="margin-top:10px;">
            <label>Color del nodo</label>
            <div class="fe-swatches">
                <button type="button" class="fe-swatch fe-swatch-none @(string.IsNullOrEmpty(node.Color) ? "on" : "")"
                        title="Sin color" @onclick="@(() => OnNodeColorAsync(node, null))">&times;</button>
                @foreach (var key in NodeColorKeys)
                {
                    var k = key;
                    <button type="button" class="fe-swatch @(string.Equals(node.Color, k, StringComparison.OrdinalIgnoreCase) ? "on" : "")"
                            style="background:@SwatchFill(k);border-color:@SwatchStroke(k)"
                            title="@k" @onclick="@(() => OnNodeColorAsync(node, k))"></button>
                }
            </div>
        </div>
        <div class="fe-field">
            <label>Nota (se muestra en el lienzo)</label>
            <textarea class="fe-input" rows="3" placeholder="Nota del paso..."
                      value="@node.Note" @onchange="@(e => OnNodeNoteAsync(node, e.Value?.ToString()))"></textarea>
        </div>
    };

    // Paleta de colores del nodo (misma que el JS del editor); el valor guardado es la CLAVE.
    private static readonly string[] NodeColorKeys = { "violet", "blue", "green", "amber", "rose", "slate" };
    private static readonly Dictionary<string, (string Fill, string Stroke)> SwatchColors = new(StringComparer.Ordinal)
    {
        ["violet"] = ("#ede9ff", "#7c5cff"),
        ["blue"] = ("#e6f0ff", "#2f6bff"),
        ["green"] = ("#e3f6ec", "#16a34a"),
        ["amber"] = ("#fdf1d6", "#d98a00"),
        ["rose"] = ("#fde7ec", "#e11d48"),
        ["slate"] = ("#eef1f5", "#64748b"),
    };
    private static string SwatchFill(string k) => SwatchColors.TryGetValue(k, out var c) ? c.Fill : "transparent";
    private static string SwatchStroke(string k) => SwatchColors.TryGetValue(k, out var c) ? c.Stroke : "var(--line-2)";

    // Acordeon 1: Asignar usuarios (asignacion por nodo REAL, ADR-0035). Dependencias/Cargos
    // del organigrama atienden el paso; el resolver expande a los funcionarios candidatos.
    // Vinculo por nodo (no viaja en el XML): permitido tambien sobre publicadas (como formulario/regla).
    private RenderFragment UsersBody => __builder =>
    {
        if (Selected is not FlowCanvasNodeDto node)
        {
            <div class="fe-acc-empty">Selecciona un nodo guardado del canvas.</div>
            return;
        }
        if (node.NodeType != WorkflowNodeType.Task || !node.AllowsAssignment)
        {
            <div class="fe-acc-empty">Este nodo no admite asignacion (solo tareas con "Permite asignacion manual").</div>
            return;
        }
        <div class="fe-rows">
            @foreach (var policy in _nodePolicies)
            {
                <div class="fe-row">
                    <span class="fe-row-dot" style="background:@ClassifierTone(policy.Classifier)"></span>
                    <span class="fe-row-verb">@policy.OrgUnitName</span>
                    <span class="fe-row-badge" style="color:@ClassifierTone(policy.Classifier)">@ClassifierLabel(policy.Classifier)</span>
                    <span class="fe-row-auto" title="Funcionarios que resolveria esta unidad">@policy.CandidateCount cand.</span>
                    <span class="fe-row-x" @onclick="@(() => RemoveNodePolicyAsync(policy))">x</span>
                </div>
            }
            @if (_nodePolicies.Count == 0)
            {
                <div class="fe-acc-empty">Sin dependencias ni cargos asignados.</div>
            }
        </div>
        <div class="fe-field" style="margin-top:8px;">
            <select class="fe-input sm" @bind="_assignUnitId">
                <option value="">-- Dependencia / Cargo --</option>
                @foreach (var u in _assignableUnits)
                {
                    <option value="@u.Id">@(new string(' ', u.Depth * 2))@u.Name (@ClassifierLabel(u.Classifier))</option>
                }
            </select>
        </div>
        <button class="fe-add-dashed" @onclick="AddNodePolicyAsync"
                disabled="@(string.IsNullOrEmpty(_assignUnitId))">+ Asignar</button>
        <div class="fe-acc-note">@_resolvedCandidates funcionarios atenderan este paso (asignacion por dependencia/cargo, ADR-0035).</div>
    };

    private static string ClassifierTone(OrgUnitClassifier classifier) => classifier switch
    {
        OrgUnitClassifier.Dependencia => "var(--t-violet)",
        OrgUnitClassifier.Cargo => "var(--t-blue)",
        _ => "var(--ink-3)"
    };

    private static string ClassifierLabel(OrgUnitClassifier classifier) => classifier switch
    {
        OrgUnitClassifier.Dependencia => "Dependencia",
        OrgUnitClassifier.Cargo => "Cargo",
        _ => "Funcionario"
    };

    // Acordeon 2: Recursos y componentes (formulario del nodo, WorkflowNodeForm real).
    private RenderFragment ResourcesBody => __builder =>
    {
        if (Selected is not FlowCanvasNodeDto node)
        {
            <div class="fe-acc-empty">Selecciona un nodo guardado del canvas.</div>
            return;
        }
        <div class="fe-chips">
            @if (node.FormDefinitionId is not null)
