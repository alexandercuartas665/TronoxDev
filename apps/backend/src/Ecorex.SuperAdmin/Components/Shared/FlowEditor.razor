        {
            <div class="fe-acc-note">El paso no exige formulario. Un nodo admite a lo sumo un formulario (ADR-0015).</div>
        }
    };

    // Acordeon 3: Reglas (WorkflowNodeRule real contra el catalogo, toggle autonoma).
    private RenderFragment RulesBody => __builder =>
    {
        if (Selected is not FlowCanvasNodeDto node)
        {
            <div class="fe-acc-empty">Selecciona un nodo guardado del canvas.</div>
            return;
        }
        <div class="fe-rows">
            @foreach (var rule in node.Rules)
            {
                <div class="fe-row">
                    <span class="fe-row-dot" style="background:@RuleTone(rule.Status)"></span>
                    <span class="fe-row-verb">@rule.VerbName</span>
                    <span class="fe-row-badge" style="color:@RuleTone(rule.Status)">@RuleStatusLabel(rule.Status)</span>
