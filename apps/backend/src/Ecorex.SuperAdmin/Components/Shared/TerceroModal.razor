    private void SelectConcepto(Ecorex.Application.Crm.ConceptoActividadDto c)
    {
        _noteConcepto = c;
        _noteText = "";
        _procTitulo = "";
        _procValor = "";
        _procFecha = null;
        _noteError = null;
