@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@using Ecorex.Application.Tenancy
@using Ecorex.Domain.Enums
@inject IChatService ChatSvc
@inject IMessageTemplateService TemplatesSvc
@inject IWhatsAppLineService LinesSvc
@inject IWebHostEnvironment Env
@inject NavigationManager Nav
@inject IJSRuntime JS

@*
    Chat real de WhatsApp con el cliente, reutilizable (portado del Pipeline). Envia por Evolution API,
    soporta mensajes pregrabados (plantillas) y recibe en vivo por SignalR. Se abre por TELEFONO del
    contacto (parametro Phone); no depende de Lead. Reusa las clases CSS pl-chat-* del proyecto.
*@
<div class="pl-chat">
    <div class="pl-chat-head">
        <div class="pl-chat-avatar">@Initials(ContactName)</div>
        <div style="flex:1;min-width:0;">
            <div class="nm">@(string.IsNullOrWhiteSpace(ContactName) ? "Cliente" : ContactName)</div>
            <div class="sub">WhatsApp</div>
            @if (_chatLines.Count > 0)
            {
                <div class="pl-chat-line">
                    <select @bind="_chatLineId" title="Linea WhatsApp para responder">
                        @foreach (var ln in _chatLines)
                        {
                            <option value="@ln.Id">@(string.IsNullOrWhiteSpace(ln.PhoneNumber) ? ln.InstanceName : $"{ln.InstanceName} ({ln.PhoneNumber})")</option>
                        }
                    </select>
                </div>
            }
        </div>
    </div>

    <div class="pl-chat-bodywrap" style="flex:1;min-height:0;">
        <div class="pl-chat-body">
            @if (string.IsNullOrWhiteSpace(Phone))
            {
                <div class="pl-chat-empty">Agrega un telefono al cliente para iniciar la conversacion por WhatsApp.</div>
            }
            else if (_chatLines.Count == 0)
            {
                <div class="pl-chat-empty">No hay lineas WhatsApp conectadas. Conecta una en el modulo Lineas.</div>
            }
            else if (_messages.Count == 0)
            {
                <div class="pl-chat-empty">Aun no hay mensajes. Escribe el primero abajo.</div>
            }
            else
            {
                DateTime? lastDay = null;
                @foreach (var m in _messages)
                {
                    var day = m.SentAt.LocalDateTime.Date;
                    if (lastDay != day)
                    {
                        lastDay = day;
                        <div class="pl-date-divider">@day.ToString("dd 'DE' MMMM").ToUpperInvariant()</div>
                    }
                    <div class="pl-bubble @(m.Direction == MessageDirection.Outbound ? "out" : "in")">
                        @switch (m.MediaType)
                        {
                            case MessageMediaType.Image:
                                <img class="pl-media-img" src="@m.MediaUrl" alt="imagen" />
                                break;
                            case MessageMediaType.Video:
                                <video class="pl-media-img" src="@m.MediaUrl" controls></video>
                                break;
                            case MessageMediaType.Audio:
                                <audio src="@m.MediaUrl" controls style="max-width:220px;"></audio>
                                break;
                            case MessageMediaType.Document:
                                <a class="pl-media-doc" href="@m.MediaUrl" target="_blank">Documento adjunto</a>
                                break;
                            case MessageMediaType.Location:
                                <a class="pl-media-doc" href="@MapsLink(m.MediaUrl)" target="_blank">Ver ubicacion en el mapa</a>
                                break;
                        }
                        @if (!string.IsNullOrWhiteSpace(m.Body))
                        {
                            <div>@m.Body</div>
                        }
                        <div class="t">
                            @if (m.Direction == MessageDirection.Outbound && !string.IsNullOrWhiteSpace(m.SentByName))
                            {
                                <span>@m.SentByName &middot; </span>
                            }
                            @m.SentAt.LocalDateTime.ToString("hh:mm tt")
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Phone) && _chatLines.Count > 0)
    {
        <div class="pl-chat-quick">
            <div class="pl-qr-head">
                <span>Mensajes pregrabados</span>
                <div class="pl-qr-tabs">
                    @foreach (var cat in QrCategories)
                    {
                        <button class="pl-qr-tab @(cat.Key == _qrCategory ? "active" : "")" @onclick="() => _qrCategory = cat.Key">@cat.Label</button>
                    }
                </div>
            </div>
            <div class="pl-qr-list">
                @foreach (var tpl in CurrentTemplates())
                {
                    var filled = FillTemplate(tpl.Body);
                    var label = tpl.MediaType == MessageMediaType.None ? filled : $"{MediaIcon(tpl.MediaType)} {(string.IsNullOrWhiteSpace(filled) ? tpl.MediaType.ToString() : filled)}";
                    <button class="pl-quick-chip" title="@filled" @onclick="() => UseTemplateAsync(tpl)">@label</button>
                }
                @if (CurrentTemplates().Count == 0)
                {
                    <span class="text-muted" style="font-size:11px;">Sin pregrabados en esta categoria.</span>
                }
            </div>
        </div>
        <div class="pl-chat-input">
            <div class="pl-attach">
                <button class="pl-attach-btn" title="Adjuntar" @onclick="() => _attachOpen = !_attachOpen" disabled="@_chatBusy">+</button>
                @if (_attachOpen)
                {
                    <div class="pl-attach-menu">
                        <label class="pl-attach-item">Imagen<InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Image))" accept="image/*" style="display:none;" /></label>
                        <label class="pl-attach-item">Video<InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Video))" accept="video/*" style="display:none;" /></label>
                        <label class="pl-attach-item">Audio<InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Audio))" accept="audio/*" style="display:none;" /></label>
                        <label class="pl-attach-item">Documento<InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Document))" accept="*/*" style="display:none;" /></label>
                    </div>
                }
            </div>
            <input placeholder="Escribe un mensaje..." @bind="_chatDraft" @bind:event="oninput" @onkeydown="ChatKeyDown" disabled="@_chatBusy" />
            <button class="pl-chat-send" @onclick="SendChatAsync" disabled="@(_chatBusy || string.IsNullOrWhiteSpace(_chatDraft))" title="Enviar">Enviar</button>
        </div>
        @if (_chatError is not null)
        {
            <div class="text-danger small" style="padding:0 12px 8px;">@_chatError</div>
        }
    }
</div>

@code {
    [Parameter] public string? Phone { get; set; }
    [Parameter] public string? ContactName { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private ConversationDto? _conversation;
    private List<MessageDto> _messages = new();
    private List<WhatsAppLineDto> _chatLines = new();
    private List<MessageTemplateDto> _templates = new();
    private Guid _chatLineId;
    private string? _chatDraft;
    private string? _chatError;
    private bool _chatBusy;
    private bool _attachOpen;
    private string _qrCategory = "saludo";
    private bool _scrollChatPending;

    private HubConnection? _hub;
    private string? _joinedConversation;
    private string? _loadedPhone;

    // Recarga el chat cuando cambia el telefono (al abrir el modal, elegir/cambiar de cliente).
    protected override async Task OnParametersSetAsync()
    {
        var digits = Digits(Phone);
        if (digits == _loadedPhone) { return; }
        _loadedPhone = digits;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _conversation = null; _messages = new(); _chatLines = new();
        _chatDraft = null; _chatError = null; _qrCategory = "saludo";
        if (string.IsNullOrWhiteSpace(Phone)) { return; }

        _chatLines = (await LinesSvc.ListAsync()).Where(l => l.Status == WhatsAppLineStatus.Connected).ToList();
        if (_chatLines.Count == 0) { return; }

        _conversation = await ChatSvc.GetOrCreateForPhoneAsync(Phone!, ContactName);
        if (_conversation is null) { return; }

        _messages = (await ChatSvc.ListMessagesAsync(_conversation.Id)).ToList();
        _scrollChatPending = true;
        _chatLineId = _conversation.WhatsAppLineId is Guid lid && _chatLines.Any(l => l.Id == lid) ? lid : _chatLines[0].Id;

        await TemplatesSvc.SeedDefaultsAsync();
        _templates = (await TemplatesSvc.ListAsync()).ToList();

        await JoinConversationRealtimeAsync(_conversation.Id);
    }

    private async Task ChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) { await SendChatAsync(); }
    }

    private async Task SendChatAsync()
    {
        _chatError = null;
        if (_conversation is null || string.IsNullOrWhiteSpace(_chatDraft) || _chatLineId == Guid.Empty) { return; }
        _chatBusy = true;
        try
        {
            var result = await ChatSvc.SendViaLineAsync(_conversation.Id, _chatLineId, _chatDraft!.Trim(), await ActorAsync());
            if (!result.Ok) { _chatError = result.Error ?? "No se pudo enviar el mensaje."; return; }
            if (result.Message is not null) { _messages.Add(result.Message); _scrollChatPending = true; }
            _chatDraft = null;
        }
        finally { _chatBusy = false; }
    }

    private async Task UseTemplateAsync(MessageTemplateDto t)
    {
        _chatError = null;
        if (t.MediaType == MessageMediaType.None) { _chatDraft = FillTemplate(t.Body); return; }
        if (_conversation is null || _chatLineId == Guid.Empty || t.MediaUrl is null) { return; }
        _chatBusy = true;
        try
        {
            var b64 = await ReadLocalBase64Async(t.MediaUrl);
            if (b64 is null) { _chatError = "No se encontro el archivo del pregrabado."; return; }
            var caption = FillTemplate(t.Body);
            var r = await ChatSvc.SendMediaViaLineAsync(_conversation.Id, _chatLineId, t.MediaType, b64, t.MediaUrl, t.MediaMimeType, System.IO.Path.GetFileName(t.MediaUrl), caption, await ActorAsync());
            if (!r.Ok) { _chatError = r.Error; return; }
            if (r.Message is not null) { _messages.Add(r.Message); _scrollChatPending = true; }
        }
        finally { _chatBusy = false; }
    }

    private async Task OnAttachAsync(InputFileChangeEventArgs e, MessageMediaType type)
    {
        _attachOpen = false; _chatError = null;
        if (_conversation is null || _chatLineId == Guid.Empty) { return; }
        var saved = await SaveChatFileAsync(e.File, type);
        if (saved is null) { _chatError = "Archivo invalido o supera 16 MB."; return; }
        _chatBusy = true;
        try
        {
            var caption = string.IsNullOrWhiteSpace(_chatDraft) ? null : _chatDraft!.Trim();
            var r = await ChatSvc.SendMediaViaLineAsync(_conversation.Id, _chatLineId, type, saved.Value.Base64, saved.Value.Url, saved.Value.Mime, saved.Value.Name, caption, await ActorAsync());
            if (!r.Ok) { _chatError = r.Error; return; }
            if (r.Message is not null) { _messages.Add(r.Message); _scrollChatPending = true; }
            _chatDraft = null;
        }
        finally { _chatBusy = false; }
    }

    private async Task<(string Url, string Base64, string Mime, string Name)?> SaveChatFileAsync(IBrowserFile file, MessageMediaType type)
    {
        const long max = 16L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { return null; }
        using var ms = new MemoryStream();
        await file.OpenReadStream(max).CopyToAsync(ms);
        var bytes = ms.ToArray();
        var ext = System.IO.Path.GetExtension(file.Name);
        if (string.IsNullOrWhiteSpace(ext))
        {
            ext = type switch { MessageMediaType.Image => ".jpg", MessageMediaType.Video => ".mp4", MessageMediaType.Audio => ".ogg", _ => ".bin" };
        }
        var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", "chat");
        System.IO.Directory.CreateDirectory(dir);
        var name = $"chat-{Guid.NewGuid():N}{ext}";
        await System.IO.File.WriteAllBytesAsync(System.IO.Path.Combine(dir, name), bytes);
        var mime = string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType;
        return ($"/uploads/chat/{name}", Convert.ToBase64String(bytes), mime, file.Name);
    }

    private async Task<string?> ReadLocalBase64Async(string localUrl)
    {
        var rel = localUrl.TrimStart('/').Replace('/', System.IO.Path.DirectorySeparatorChar);
        var path = System.IO.Path.Combine(Env.WebRootPath, rel);
        if (!System.IO.File.Exists(path)) { return null; }
        return Convert.ToBase64String(await System.IO.File.ReadAllBytesAsync(path));
    }

    // ===== SignalR en vivo =====
    private async Task EnsureHubAsync()
    {
        if (_hub is not null) { return; }
        try
        {
            _hub = new HubConnectionBuilder().WithUrl(Nav.ToAbsoluteUri("/hubs/chat")).WithAutomaticReconnect().Build();
            _hub.On<MessageDto>("MessageAdded", async msg =>
            {
                if (_conversation is null || msg.ConversationId != _conversation.Id) { return; }
                if (_messages.Any(m => m.Id == msg.Id)) { return; }
                _messages.Add(msg);
                _scrollChatPending = true;
                await InvokeAsync(StateHasChanged);
            });
            await _hub.StartAsync();
        }
        catch { /* el tiempo real es complemento; si falla, el chat sigue funcionando */ }
    }

    private async Task JoinConversationRealtimeAsync(Guid conversationId)
    {
        await EnsureHubAsync();
        if (_hub is null) { return; }
        try
        {
            if (_joinedConversation is not null && _joinedConversation != conversationId.ToString())
            {
                await _hub.SendAsync("LeaveConversation", _joinedConversation);
            }
            await _hub.SendAsync("JoinConversation", conversationId.ToString());
            _joinedConversation = conversationId.ToString();
        }
        catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_scrollChatPending)
        {
            _scrollChatPending = false;
            try { await JS.InvokeVoidAsync("ecorexScrollChat"); } catch { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null) { try { await _hub.DisposeAsync(); } catch { } }
    }

    // ===== Plantillas / pregrabados =====
    private List<(string Key, string Label)> QrCategories
    {
        get
        {
            var keys = MessageTemplateCategories.All.Select(c => c.Key).ToList();
            foreach (var t in _templates)
            {
                if (!keys.Contains(t.Category)) { keys.Add(t.Category); }
            }
            return keys.Select(k => (k, CategoryLabel(k))).ToList();
        }
    }

    private List<MessageTemplateDto> CurrentTemplates()
        => _templates.Where(t => t.Category == _qrCategory).OrderBy(t => t.SortOrder).ToList();

    private static string CategoryLabel(string key)
    {
        var lbl = MessageTemplateCategories.Label(key);
        if (lbl == key && key.Length > 0) { return char.ToUpperInvariant(key[0]) + key[1..]; }
        return lbl;
    }

    // Rellena placeholders de la plantilla. {cliente} = nombre del cliente.
    private string FillTemplate(string template)
    {
        var cliente = string.IsNullOrWhiteSpace(ContactName) ? "" : ContactName!.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "";
        return template.Replace("{cliente}", cliente).Replace("{asesor}", "").Replace("{destino}", "");
    }

    private static string MediaIcon(MessageMediaType t) => t switch
    {
        MessageMediaType.Image => "Imagen",
        MessageMediaType.Video => "Video",
        MessageMediaType.Audio => "Audio",
        MessageMediaType.Document => "Doc",
        MessageMediaType.Location => "Ubicacion",
        _ => ""
    };

    private static string MapsLink(string? coords) => $"https://www.google.com/maps?q={coords}";

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private static string Digits(string? s) => string.IsNullOrEmpty(s) ? "" : new string(s.Where(char.IsDigit).ToArray());

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) { return "C"; }
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1
            ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant()
            : $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
    }
}
