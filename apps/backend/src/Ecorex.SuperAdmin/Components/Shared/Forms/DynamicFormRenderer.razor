@using Ecorex.Application.Forms
@using Ecorex.Application.Forms.Calc
@using Ecorex.Application.Forms.Lookups
@using Ecorex.Application.Rules
@using Ecorex.Domain.Enums
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Ecorex.SuperAdmin.Auth
@implements IDisposable
@inject IFormDefinitionService DefinitionsSvc
@inject IFormResponseService ResponsesSvc
@inject IFormRuleDispatcher RulesDispatcher
@inject IFormLookupService LookupSvc
@inject IJSRuntime JS
@inject Ecorex.SuperAdmin.Services.CircuitFormGate FormGate

@* =====================================================================================
   DynamicFormRenderer (FASE 4 ola 2, ADR-0015): motor de render de formularios dinamicos.
   Renderiza el arbol contenedores -> preguntas en orden con los controles Tier 1
   (Text, TextArea, Heading, Select, MultiCheck, Radio, Toggle, Number, Date, Literal),
   respetando GridCol (grid bootstrap). Validacion cliente inmediata con el MISMO
   FormFieldValidator del servidor + errores del servidor bajo cada campo. En modo Fill:
   autosave del borrador cada 30 segundos y boton Enviar. AmbientTenantId permite al visor
   publico /f/{token} fijar el tenant del token en cada llamada (AmbientTenantContext).
   ===================================================================================== *@

@if (_loading)
{
    <p><em>Cargando formulario...</em></p>
}
else if (_definition is null)
{
    <div class="dfr-msg">El formulario no esta disponible.</div>
}
else
{
    <div class="dfr-root">
        @if (ShowHeader)
        {
            <div class="dfr-head">
                <h3 class="dfr-title">@_definition.Title</h3>
                @if (!string.IsNullOrWhiteSpace(_definition.Description))
                {
                    <p class="dfr-sub">@_definition.Description</p>
                }
                <div class="dfr-meta">
                    <span class="dfr-chip">@_definition.Code</span>
                    <span class="dfr-chip">rev @_definition.Revision</span>
                    @if (!string.IsNullOrWhiteSpace(_response?.Reference))
                    {
                        <span class="dfr-chip">ref @_response!.Reference</span>
                    }
                    @* Registro transaccional (ola F3): numero y estado tras confirmar. *@
                    @if (!string.IsNullOrWhiteSpace(_response?.RecordNumber))
                    {
                        <span class="dfr-chip dfr-chip-record">@_response!.RecordNumber</span>
                    }
                    else if (_definition.IsTransactional)
                    {
                        @* D2: el consecutivo se emite al confirmar (no se reserva en borrador, para no
                           dejar huecos). Se previsualiza para que se sepa que el numero llegara. *@
                        <span class="dfr-chip dfr-chip-pending" title="El consecutivo se asigna al guardar">N.o por asignar</span>
                    }
                    @if (_response?.RecordStatus == FormRecordStatus.Voided)
                    {
                        <span class="dfr-chip dfr-chip-void">Anulado</span>
                    }
                </div>
            </div>
        }

        @if (_globalError is not null)
        {
            <div class="dfr-alert">@_globalError</div>
        }

        @{ var rootQuestions = QuestionsOf(null); }
        @if (rootQuestions.Count > 0)
        {
            <div class="row g-3">
                @foreach (var q in rootQuestions)
                {
                    @RenderQuestion(q)
                }
            </div>
        }
        @foreach (var container in ChildrenOf(null))
        {
            @RenderContainer(container)
        }

        @if (Mode == FormRenderMode.Fill && _response is not null)
        {
            @* Decision de aprobacion (ADR-0037): cuando el nodo del paso tiene una compuerta
               adelante, se pide la salida modelada (Aprobada/Rechazada) JUNTO al formulario y
               se propaga al enviar; sin ella el submit queda deshabilitado. *@
            @if (ApprovalOptions is { Count: > 0 } && !IsSubmitted)
            {
                <div class="dfr-decision">
                    <label class="form-label dfr-label">Decision <span class="dfr-req">*</span></label>
                    <div class="dfr-options">
                        @foreach (var option in ApprovalOptions)
                        {
                            var opt = option;
                            <label class="dfr-check">
                                <input type="radio" name="dfr-approval" checked="@(_approvalChoice == opt)"
                                       disabled="@_busy" @onchange="@(() => _approvalChoice = opt)" />
                                <span>@opt</span>
                            </label>
                        }
                    </div>
                </div>
            }
            <div class="dfr-foot">
                <span class="dfr-autosave">
                    @(_lastSavedAt is null ? "Borrador sin guardar" : $"Borrador guardado {_lastSavedAt:HH:mm:ss}")
                </span>
                @* Anular registro transaccional confirmado (ola F3). *@
                @if (_response?.RecordStatus == FormRecordStatus.Confirmed)
                {
                    @if (_voiding)
                    {
                        <input class="form-control dfr-void-reason" placeholder="Motivo de anulacion"
                               value="@_voidReason" @oninput="@(e => _voidReason = e.Value?.ToString())" />
                        <button class="btn btn-outline-danger" @onclick="VoidAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_voidReason))">Confirmar anulacion</button>
                        <button class="btn btn-outline-secondary" @onclick="@(() => _voiding = false)" disabled="@_busy">Cancelar</button>
                    }
                    else
                    {
                        <button class="btn btn-outline-danger" @onclick="@(() => _voiding = true)" disabled="@_busy">Anular</button>
                    }
                }
                @* Impresion basica (ola F6): abre el registro en un documento limpio + dialogo nativo del
                   navegador (Imprimir / Guardar PDF). Solo en sesion logueada (el visor publico no tiene tenant). *@
                @if (AmbientTenantId is null)
                {
                    <a class="btn btn-outline-secondary" href="@($"/formularios/imprimir/{_response!.Id}")" target="_blank" rel="noopener">Imprimir</a>
                }
                <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@(_busy || IsSubmitted || (ApprovalOptions is { Count: > 0 } && string.IsNullOrEmpty(_approvalChoice)))">
                    @(IsSubmitted ? "Enviado" : "Enviar")
                </button>
            </div>
        }
    </div>
}

@code {
    /// <summary>Definicion a renderizar.</summary>
    [Parameter, EditorRequired] public Guid DefinitionId { get; set; }
    /// <summary>Referencia externa del borrador (ej. numero de tarea) en modo Fill.</summary>
    [Parameter] public string? Reference { get; set; }
    [Parameter] public FormRenderMode Mode { get; set; } = FormRenderMode.Design;
    /// <summary>Respuesta concreta a cargar (si no, en Fill se resuelve GetOrCreateDraft).</summary>
    [Parameter] public Guid? ResponseId { get; set; }
    /// <summary>TenantUser que envia (para SubmittedBy y para completar el paso del flujo).</summary>
    [Parameter] public Guid? SubmittedByTenantUserId { get; set; }
    /// <summary>
    /// Tenant a fijar como ambient en CADA llamada a servicios. SOLO lo usa el visor
    /// publico /f/{token}: el tenant viene del token validado, no de la sesion.
    /// </summary>
    [Parameter] public Guid? AmbientTenantId { get; set; }
    [Parameter] public EventCallback<FormResponseDto> OnSubmitted { get; set; }
    [Parameter] public bool ShowHeader { get; set; } = true;
    /// <summary>
    /// Opciones de decision de la compuerta adelante (ADR-0037). Si trae valores, el renderer
    /// pide elegir una (radio) y la propaga como approvalResult al enviar; el submit se
    /// deshabilita hasta que haya eleccion. Vacio/null = paso sin compuerta adelante.
    /// </summary>
    [Parameter] public IReadOnlyList<string>? ApprovalOptions { get; set; }
    /// <summary>Rol del usuario (tenant_role) para permisos por campo (ola F6). Null en el visor publico.</summary>
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private string? _currentRole;
    // Nombre del usuario logueado (para el default dinamico "usuario actual": se muestra el NOMBRE, no el Guid).
    private string? _currentUserName;

    private FormDefinitionDetailDto? _definition;
    private FormResponseDto? _response;
    private readonly Dictionary<string, string?> _values = new(StringComparer.Ordinal);
    private readonly Dictionary<string, string> _errors = new(StringComparer.Ordinal);
    // RulesEngine (FASE 4 ola 3, ADR-0016): campos con reglas vinculadas y estado de UI
    // derivado de las acciones (ocultos por regla / overrides de obligatoriedad).
    private IReadOnlySet<string> _ruleTriggerFields = new HashSet<string>(StringComparer.Ordinal);
    private FormRuleUiState _ruleUiState = new();
    // Decision elegida para la compuerta adelante (ADR-0037); null hasta que el usuario elige.
    private string? _approvalChoice;
    // Anulacion de registro transaccional (ola F3).
    private bool _voiding;
    private string? _voidReason;
    private bool _loading = true;
    private bool _busy;
    private bool _dirty;
    private string? _globalError;
    private DateTimeOffset? _lastSavedAt;
    private System.Threading.Timer? _autosaveTimer;
    private Guid _loadedKey;
    // Reentrancy guard de OnParametersSetAsync: true mientras una carga esta en curso, para que
    // un cambio de parametro del padre no dispare una segunda carga concurrente sobre el DbContext.
    private bool _loadInProgress;

    // Serializa TODO acceso al DbContext del circuito desde este componente
    // (despacho de reglas, autosave y guardado/submit). Blazor solo garantiza
    // exclusion hasta el primer await: dos onchange rapidos sobre campos con
    // reglas (o un autosave cruzado con un submit) interleaban operaciones y
    // tumbaban el circuito con "a second operation was started on this context"
    // (bug real destapado por la suite E2E, PROGRESO.md sesion 13).
    // Gate COMPARTIDO por circuito (servicio scoped): serializa el DbContext entre TODOS los
    // renderers del circuito, no solo las operaciones de esta instancia. Ver CircuitFormGate.
    private SemaphoreSlim _dbGate => FormGate.Gate;

    private bool IsSubmitted => _response?.Status == FormResponseStatus.Submitted;
    private bool IsDisabled => _busy || Mode != FormRenderMode.Fill || IsSubmitted;

    protected override async Task OnParametersSetAsync()
    {
        // Evita recargas si los parametros no cambiaron (re-render del padre) Y evita la
        // RE-ENTRADA mientras una carga de la misma definicion sigue en curso: pasar un
        // parametro nuevo (p.ej. ApprovalOptions) re-dispara OnParametersSetAsync antes de que
        // el primer await termine y, sin este guard, dos cargas concurrentes usaban el MISMO
        // DbContext del circuito y lo tumbaban con "a second operation was started on this
        // context" (mismo bug que _dbGate ya cubre en autosave/reglas/submit).
        var key = DefinitionId;
        // Ya cargado para esta definicion (re-render del padre) -> nada que hacer.
        // Carga en curso para esta definicion (re-entrada por parametro nuevo) -> NO reentrar.
        if ((_loadedKey == key && !_loading) || _loadInProgress)
        {
            return;
        }
        _loadedKey = key;
        _loading = true;
        _loadInProgress = true;
        try
        {
            // Permisos por campo (ola F6): rol del usuario (null en el visor publico -> sin restriccion).
            if (AuthState is not null)
            {
                var user = (await AuthState).User;
                _currentRole = user.FindFirst("tenant_role")?.Value;
                _currentUserName = user.Identity?.Name;
            }
            // Toma el gate del circuito para TODA la carga: impide que otro renderer (o un autosave/
            // regla/submit de este) toque el DbContext a la vez -> sin "second operation".
            await _dbGate.WaitAsync();
            try
            {
            using var ambient = BeginAmbient();
            _definition = await DefinitionsSvc.GetAsync(DefinitionId);
            _response = null;
            _values.Clear();
            _errors.Clear();
            _ruleUiState = new FormRuleUiState();
            // Campos disparadores de reglas (una sola consulta por carga, no por onchange).
            _ruleTriggerFields = _definition is null
                ? new HashSet<string>(StringComparer.Ordinal)
                : await RulesDispatcher.GetTriggerFieldCodesAsync(DefinitionId);
            if (_definition is not null)
            {
                if (ResponseId is Guid rid)
                {
                    _response = await ResponsesSvc.GetAsync(rid);
                }
                else if (Mode == FormRenderMode.Fill)
                {
                    var draft = await ResponsesSvc.GetOrCreateDraftAsync(DefinitionId, Reference);
                    if (!draft.IsOk)
                    {
                        _globalError = draft.Error;
                    }
                    _response = draft.Value;
                }
                if (_response is not null)
                {
                    foreach (var (fieldCode, field) in _response.Data)
                    {
                        _values[fieldCode] = field.Value;
                    }
                }
                // Valor por defecto del disenador (ADR-0021): solo en Fill, solo campos de
                // captura reales y sin valor previo en el borrador.
                if (Mode == FormRenderMode.Fill && !IsSubmitted)
                {
                    foreach (var q in _definition.Questions)
                    {
                        if (!FormFieldValidator.IsNonInput(q.ControlType)
                            && !FormFieldValidator.IsPlaceholderCapture(q.ControlType)
                            && q.ControlType != FormControlType.GridDetail
                            && string.IsNullOrEmpty(_values.GetValueOrDefault(q.FieldCode)))
                        {
                            // Default DINAMICO (ola F6, doc 01 D8) gana sobre el literal DefaultValue.
                            var dyn = ResolveDynamicDefault(q.DefaultDynamic);
                            var def = dyn ?? (string.IsNullOrWhiteSpace(q.DefaultValue) ? null : q.DefaultValue);
                            if (def is not null)
                            {
                                _values[q.FieldCode] = def;
                                _dirty = true;
                            }
                        }
                    }
                }
                // Lookup (ola F1): resuelve las etiquetas de los ids ya guardados para mostrar
                // el nombre en vez del Guid (dentro del ambient de la carga).
                await ResolveLookupDisplaysAsync();
                // Calculo (ola F2): valor inicial de grids (calc por fila + totales/roll-up) y campos calculados.
                RecomputeGrids();
                RecomputeCalculatedFields();
                // Maestro-detalle (ola F5): registros hijos de los subformularios.
                await LoadSubformChildrenAsync();
            }
            }
            finally { _dbGate.Release(); }
        }
        finally
        {
            _loading = false;
            _loadInProgress = false;
        }

        // Autosave del borrador cada 30 segundos (solo Fill y solo si hay cambios).
        _autosaveTimer?.Dispose();
        _autosaveTimer = null;
        if (Mode == FormRenderMode.Fill && _response is not null && !IsSubmitted)
        {
            _autosaveTimer = new System.Threading.Timer(
                _ => _ = InvokeAsync(AutosaveTickAsync),
                null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        }
    }

    /// <summary>Inicializa el trazo de los canvas de firma tras cada render (idempotente en JS).</summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_definition is null || IsDisabled) { return; }
        foreach (var q in _definition.Questions.Where(x => x.ControlType == FormControlType.Signature))
        {
            try { await JS.InvokeVoidAsync("ecorexFormCapture.initSignature", $"sig-{q.Id}"); }
            catch (JSException) { /* JS aun no disponible: se reintenta en el siguiente render */ }
        }
    }

    // ---- Arbol ----

    private List<FormContainerDto> ChildrenOf(Guid? parentId)
        => _definition!.Containers.Where(c => c.ParentId == parentId).OrderBy(c => c.SortOrder).ToList();

    private List<FormQuestionDto> QuestionsOf(Guid? containerId)
        => _definition!.Questions.Where(q => q.ContainerId == containerId).OrderBy(q => q.SortOrder).ToList();

    // Pestana activa por contenedor Tabs (estado de UI del renderer).
    private readonly Dictionary<Guid, int> _activeTab = new();

    private static IReadOnlyList<string> ParseTabs(string? tabsJson)
    {
        if (string.IsNullOrWhiteSpace(tabsJson))
        {
            return [];
        }
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<string>>(tabsJson) ?? [];
        }
        catch (System.Text.Json.JsonException)
        {
            return [];
        }
    }

    private RenderFragment RenderContainer(FormContainerDto container) => __builder =>
    {
        @* Contenedores ocultos por el disenador: ni el nodo ni su subarbol se pintan. *@
        if (container.IsHidden)
        {
            return;
        }
        @* Tabs (ADR-0021): cada contenedor hijo directo es una pestana navegable; los
           nombres salen de TabsJson (por indice) con fallback al nombre del contenedor. *@
        if (container.ContainerType == FormContainerType.Tabs)
        {
            var panels = ChildrenOf(container.Id).Where(c => !c.IsHidden).ToList();
            var names = ParseTabs(container.TabsJson);
            var active = Math.Clamp(_activeTab.GetValueOrDefault(container.Id), 0, Math.Max(panels.Count - 1, 0));
            <div class="dfr-segment dfr-tabs" style="@container.Style">
                <div class="dfr-segment-head">@container.Name</div>
                @if (panels.Count > 0)
                {
                    <div class="dfr-tabbar" role="tablist">
                        @for (var i = 0; i < panels.Count; i++)
                        {
                            var index = i;
                            <button type="button" role="tab" class="dfr-tab @(index == active ? "on" : "")"
                                    @onclick="@(() => { _activeTab[container.Id] = index; })">
                                @(index < names.Count && !string.IsNullOrWhiteSpace(names[index]) ? names[index] : panels[index].Name)
                            </button>
                        }
                    </div>
                }
                @{ var tabRootQuestions = QuestionsOf(container.Id); }
                @if (tabRootQuestions.Count > 0)
                {
                    <div class="row g-3">
                        @foreach (var q in tabRootQuestions)
                        {
                            @RenderQuestion(q)
                        }
                    </div>
                }
                @if (panels.Count > 0)
                {
                    @RenderContainerBody(panels[active])
                }
            </div>
            return;
        }

        @* Row: grupo transparente, hijos lado a lado en la grilla de 12.
           Col: grupo transparente, hijos apilados (fila completa).
           Segment/Section/Table y Modal (TODO ADR-0021: dialogo real): seccion con titulo. *@
        if (container.ContainerType is FormContainerType.Row or FormContainerType.Col)
        {
            <div class="dfr-group @(container.ContainerType == FormContainerType.Row ? "dfr-row" : "dfr-col")"
                 style="@(WidthStyle(container) + container.Style)">
                @if (!string.IsNullOrWhiteSpace(container.Name))
                {
                    <div class="dfr-group-head">@container.Name</div>
                }
                @RenderContainerChildren(container, stack: container.ContainerType == FormContainerType.Col)
            </div>
            return;
        }

        <div class="dfr-segment" style="@(WidthStyle(container) + container.Style)">
            <div class="dfr-segment-head">@container.Name</div>
            @RenderContainerChildren(container, stack: false)
        </div>
    };

    /// <summary>Cuerpo de una pestana: mismo render que un contenedor normal, sin duplicar el marco.</summary>
    private RenderFragment RenderContainerBody(FormContainerDto container) => __builder =>
    {
        <div class="dfr-tabpanel" role="tabpanel">
            @if (container.ContainerType is FormContainerType.Row or FormContainerType.Col)
            {
                @RenderContainerChildren(container, stack: container.ContainerType == FormContainerType.Col)
            }
            else
            {
                @RenderContainerChildren(container, stack: false)
            }
        </div>
    };

    private RenderFragment RenderContainerChildren(FormContainerDto container, bool stack) => __builder =>
    {
        var questions = QuestionsOf(container.Id);
        @if (questions.Count > 0)
        {
            <div class="row g-3">
                @foreach (var q in questions)
                {
                    @RenderQuestion(q, forceFullWidth: stack)
                }
            </div>
        }
        @foreach (var child in ChildrenOf(container.Id))
        {
            @RenderContainer(child)
        }
    };

    private static string WidthStyle(FormContainerDto container)
        => container.Width is >= 1 and < 12
            ? $"width:{Math.Round(container.Width / 12d * 100, 2).ToString(System.Globalization.CultureInfo.InvariantCulture)}%;"
            : "";

    private RenderFragment RenderQuestion(FormQuestionDto q, bool forceFullWidth = false) => __builder =>
    {
        @* Campos ocultos por regla, por el disenador (ADR-0021) O por permiso de rol (ola F6). *@
        if (_ruleUiState.IsHidden(q.FieldCode) || q.IsHidden || IsFieldHidden(q))
        {
            return;
        }
        <div class="@(forceFullWidth ? "col-12" : string.IsNullOrWhiteSpace(q.GridCol) ? "col-12" : q.GridCol)">
            @switch (q.ControlType)
            {
                case FormControlType.Paragraph:
                    @* Documento (ADR-0021): el texto del parrafo vive en DefaultValue. *@
                    <div class="dfr-paragraph">@(string.IsNullOrWhiteSpace(q.DefaultValue) ? q.Label : q.DefaultValue)</div>
                    break;
                case FormControlType.Divider:
                    <div class="dfr-divider" role="separator"></div>
                    break;
                case FormControlType.Spacer:
                    @* Documento (ADR-0021): el alto en px vive en DefaultValue (default 24). *@
                    <div class="dfr-spacer" style="height:@(int.TryParse(q.DefaultValue, out var h) && h > 0 ? h : 24)px"></div>
                    break;
                case FormControlType.Heading:
                    <h4 class="dfr-heading">@Prefixed(q)</h4>
                    @if (!string.IsNullOrWhiteSpace(q.Caption))
                    {
                        <p class="dfr-caption">@q.Caption</p>
                    }
                    break;
                case FormControlType.Literal:
                    <div class="dfr-literal">
                        <div>@Prefixed(q)</div>
                        @if (!string.IsNullOrWhiteSpace(q.Caption))
                        {
                            <div class="dfr-caption" style="margin-top:4px;">@q.Caption</div>
                        }
                    </div>
                    break;
                default:
                    <label class="form-label dfr-label" title="@q.HelpText">
                        @Prefixed(q)
                        @if (_ruleUiState.IsRequired(q.FieldCode, q.Required))
                        {
                            <span class="dfr-req">*</span>
                        }
                    </label>
                    @if (!string.IsNullOrWhiteSpace(q.Caption))
                    {
                        <div class="dfr-caption">@q.Caption</div>
                    }
                    @* Solo lectura por rol (ola F6): fieldset disabled deshabilita el control sin tocar RenderInput. *@
                    @if (IsFieldReadonly(q))
                    {
                        <fieldset disabled class="dfr-ro">@RenderInput(q)</fieldset>
                    }
                    else
                    {
                        @RenderInput(q)
                    }
                    @if (!string.IsNullOrWhiteSpace(q.HelpText))
                    {
                        <div class="dfr-help">@q.HelpText</div>
                    }
                    @if (_errors.TryGetValue(q.FieldCode, out var error))
                    {
                        <div class="tk-field-error">@error</div>
                    }
                    break;
            }
        </div>
    };

    private RenderFragment RenderInput(FormQuestionDto q) => __builder =>
    {
        var value = _values.GetValueOrDefault(q.FieldCode);
        // Campo calculado (ola F2, doc 01 D5): solo lectura, valor recomputado por el evaluador.
        // Con formato (ola F6) se muestra formateado (moneda/%/...).
        if (!string.IsNullOrWhiteSpace(q.CalcExpression))
        {
            <input class="form-control dfr-calc" value="@FormatValue(q.Format, value)" tabindex="-1" readonly disabled />
            return;
        }
        // Origen de datos / lookup (ola F1, doc 01 D4): si el campo tiene una fuente de datos,
        // se pinta el control de autocompletar/lista/buscador en vez del control base.
        if (q.SourceKind != FormSourceKind.Options)
        {
            @RenderLookup(q, value)
            return;
        }
        switch (q.ControlType)
        {
            case FormControlType.Text:
                <input class="form-control" value="@(string.IsNullOrEmpty(q.Format) ? value : MaskInput(q.Format, value))"
                       disabled="@IsDisabled" placeholder="@q.PlaceholderText"
                       @onchange="@(e => SetValue(q, e.Value?.ToString()))" />
                break;
            case FormControlType.TextArea:
                <textarea class="form-control" rows="3" disabled="@IsDisabled" placeholder="@q.PlaceholderText"
                          @onchange="@(e => SetValue(q, e.Value?.ToString()))">@value</textarea>
                break;
            case FormControlType.Number:
                <input type="number" step="any" class="form-control" value="@value" disabled="@IsDisabled" placeholder="@q.PlaceholderText"
                       @onchange="@(e => SetValue(q, e.Value?.ToString()))" />
                break;
            case FormControlType.Date:
                <input type="date" class="form-control" value="@value" disabled="@IsDisabled"
                       @onchange="@(e => SetValue(q, e.Value?.ToString()))" />
                break;
            case FormControlType.Time:
                <input type="time" class="form-control" value="@value" disabled="@IsDisabled"
                       @onchange="@(e => SetValue(q, e.Value?.ToString()))" />
                break;
            case FormControlType.DateTime:
                <input type="datetime-local" class="form-control" value="@value" disabled="@IsDisabled"
                       @onchange="@(e => SetValue(q, e.Value?.ToString()))" />
                break;
            case FormControlType.Toggle:
                <label class="dfr-toggle">
                    <input type="checkbox" checked="@(value == "true")" disabled="@IsDisabled"
                           @onchange="@(e => SetValue(q, (bool)e.Value! ? "true" : "false"))" />
                    <span>@(value == "true" ? "Si" : "No")</span>
                </label>
                break;
            case FormControlType.Select:
                <select class="form-control" disabled="@IsDisabled"
                        @onchange="@(e => SetValue(q, e.Value?.ToString()))">
                    <option value="" selected="@string.IsNullOrEmpty(value)">-- Selecciona --</option>
                    @foreach (var option in FormFieldValidator.ParseOptions(q.OptionsJson))
                    {
                        <option value="@option.Id" selected="@(option.Id == value)">@option.Label</option>
                    }
                </select>
                break;
            case FormControlType.Radio:
                <div class="dfr-options">
                    @foreach (var option in FormFieldValidator.ParseOptions(q.OptionsJson))
                    {
                        <label class="dfr-check">
                            <input type="radio" name="@($"dfr-{q.Id}")" checked="@(option.Id == value)"
                                   disabled="@IsDisabled"
                                   @onchange="@(() => SetValue(q, option.Id))" />
                            <span>@option.Label</span>
                        </label>
                    }
                </div>
                break;
            case FormControlType.MultiCheck:
                var selected = FormFieldValidator.ParseMultiValues(value).ToHashSet(StringComparer.Ordinal);
                <div class="dfr-options">
                    @foreach (var option in FormFieldValidator.ParseOptions(q.OptionsJson))
                    {
                        <label class="dfr-check">
                            <input type="checkbox" checked="@selected.Contains(option.Id)" disabled="@IsDisabled"
                                   @onchange="@(e => ToggleMulti(q, option.Id, (bool)e.Value!))" />
                            <span>@option.Label</span>
                        </label>
                    }
                </div>
                break;
            case FormControlType.GridDetail:
                @* Tabla FUNCIONAL (ADR-0021): columnas en OptionsJson [{id,label}] y el
                   valor del campo es un arreglo JSON de filas [{colId:"valor"}]. *@
                @RenderGrid(q, value)
                break;
            case FormControlType.Subform:
                @* Maestro-detalle (ola F5, doc 01 D7): registros HIJOS de otra definicion. *@
                @RenderSubform(q)
                break;
            case FormControlType.Signature:
                @* Captura Tier 2 real (ola F6): trazo en canvas -> dataURL guardado inline. *@
                @RenderSignature(q, value)
                break;
            case FormControlType.Photo:
            case FormControlType.Image:
                @* Captura Tier 2 real (ola F6): foto/imagen -> data-URI inline (limite de tamano). *@
                @RenderFileCapture(q, value, accept: "image/*", capture: q.ControlType == FormControlType.Photo, label: "Tomar / subir imagen")
                break;
            case FormControlType.Gps:
                @* Captura Tier 2 real (ola F6): geolocalizacion del navegador. *@
                @RenderGps(q, value)
                break;
            case FormControlType.File:
                @* Captura Tier 2 real (ola F6): archivo -> data-URI inline (limite de tamano). *@
                @RenderFileCapture(q, value, accept: null, capture: false, label: "Subir archivo")
                break;
            case FormControlType.Audio:
                @RenderCapturePlaceholder(q, "dashed", "M12 3a3 3 0 0 1 3 3v6a3 3 0 0 1-6 0V6a3 3 0 0 1 3-3ZM5 11a7 7 0 0 0 14 0M12 18v3", "Grabar audio")
                break;
            case FormControlType.Barcode:
                @RenderCapturePlaceholder(q, "solid", "M4 5v14M7 5v14M10 5v14M14 5v14M17 5v14M20 5v14", "Escanear")
                break;
            default:
                @* Tipos sin componente aun (Button, Chart, Html): placeholder informativo. *@
                <div class="dfr-unsupported">Control @q.ControlType disponible en una ola posterior.</div>
                break;
        }
    };

    /// <summary>
    /// Placeholder visual del prototipo para multimedia SIN captura real (ADR-0021):
    /// deshabilitado, no bloquea el submit (la validacion ignora Required en estos tipos).
    /// </summary>
    private RenderFragment RenderCapturePlaceholder(FormQuestionDto q, string frame, string iconPath, string caption) => __builder =>
    {
        <div class="dfr-capture @(frame == "dashed" ? "dashed" : "")" aria-disabled="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="@iconPath" /></svg>
            <span>@caption</span>
            <span class="dfr-capture-soon">captura disponible proximamente</span>
        </div>
    };

    // ---- Captura Tier 2 real (ola F6, doc 01 D9): firma, foto/imagen, GPS, archivo ----
    // Todo se guarda INLINE (data-URI / coordenadas) con tope de 1 MB; el almacenamiento de
    // objetos para adjuntos grandes es un incremento posterior documentado en el vault.

    private readonly Dictionary<string, string> _captureError = new(StringComparer.Ordinal);

    private RenderFragment RenderSignature(FormQuestionDto q, string? value) => __builder =>
    {
        var hasVal = !string.IsNullOrEmpty(value);
        <div class="dfr-sign">
            @if (IsDisabled)
            {
                @if (hasVal)
                {
                    <img class="dfr-sign-preview" src="@value" alt="Firma" />
                }
                else
                {
                    <div class="dfr-capture" aria-disabled="true"><span>Sin firma</span></div>
                }
            }
            else
            {
                <canvas id="@($"sig-{q.Id}")" class="dfr-sign-canvas" width="320" height="120"></canvas>
                <div class="dfr-sign-actions">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="@(() => ClearSignatureAsync(q))">Limpiar</button>
                    <button type="button" class="btn btn-sm btn-primary" @onclick="@(() => SaveSignatureAsync(q))">Guardar firma</button>
                    @if (hasVal)
                    {
                        <span class="dfr-capture-ok">Firma capturada</span>
                    }
                </div>
            }
        </div>
    };

    private RenderFragment RenderGps(FormQuestionDto q, string? value) => __builder =>
    {
        <div class="dfr-gps">
            <input class="form-control" readonly value="@value" placeholder="Sin ubicacion" />
            @if (!IsDisabled)
            {
                <button type="button" class="btn btn-sm btn-outline-primary" disabled="@_busy" @onclick="@(() => CaptureGpsAsync(q))">Capturar ubicacion</button>
            }
        </div>
    };

    private RenderFragment RenderFileCapture(FormQuestionDto q, string? value, string? accept, bool capture, string label) => __builder =>
    {
        var hasVal = !string.IsNullOrEmpty(value);
        <div class="dfr-file">
            @if (!IsDisabled)
            {
                @if (capture)
                {
                    <InputFile OnChange="@(e => OnFileSelectedAsync(q, e))" accept="@accept" capture="environment" />
                }
                else
                {
                    <InputFile OnChange="@(e => OnFileSelectedAsync(q, e))" accept="@accept" />
                }
            }
            @if (_captureError.TryGetValue(q.FieldCode, out var cerr))
            {
                <div class="tk-field-error">@cerr</div>
            }
            @if (hasVal)
            {
                <div class="dfr-file-chosen">
                    @if (IsImageDataUri(value))
                    {
                        <img class="dfr-file-preview" src="@value" alt="adjunto" />
                    }
                    <span class="dfr-capture-ok">@(MimeOf(value) ?? "archivo adjunto")</span>
                    @if (!IsDisabled)
                    {
                        <button type="button" class="dfr-lookup-clear" title="Quitar" @onclick="@(() => SetValue(q, null))">&times;</button>
                    }
                </div>
            }
        </div>
    };

    private static bool IsImageDataUri(string? v)
        => v is not null && v.StartsWith("data:image", StringComparison.OrdinalIgnoreCase);

    private static string? MimeOf(string? v)
    {
        if (string.IsNullOrEmpty(v) || !v.StartsWith("data:", StringComparison.Ordinal)) { return null; }
        var semi = v.IndexOf(';');
        return semi > 5 ? v[5..semi] : null;
    }

    private async Task SaveSignatureAsync(FormQuestionDto q)
    {
        try
        {
            var data = await JS.InvokeAsync<string>("ecorexFormCapture.signatureData", $"sig-{q.Id}");
            if (!string.IsNullOrEmpty(data)) { await SetValue(q, data); }
        }
        catch (JSException) { /* JS no disponible (prerender): sin captura */ }
    }

    private async Task ClearSignatureAsync(FormQuestionDto q)
    {
        try { await JS.InvokeVoidAsync("ecorexFormCapture.clearSignature", $"sig-{q.Id}"); }
        catch (JSException) { }
        await SetValue(q, null);
    }

    private async Task CaptureGpsAsync(FormQuestionDto q)
    {
        try
        {
            var coords = await JS.InvokeAsync<string>("ecorexFormCapture.geolocate");
            await SetValue(q, coords);
        }
        catch (JSException) { }
    }

    private async Task OnFileSelectedAsync(FormQuestionDto q, InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) { return; }
        const long max = 1024 * 1024; // 1 MB inline; objetos grandes = incremento posterior.
        if (file.Size > max)
        {
            _captureError[q.FieldCode] = $"El archivo supera 1 MB ({file.Size / 1024} KB). El almacenamiento de objetos para adjuntos grandes llega en un incremento posterior.";
            return;
        }
        _captureError.Remove(q.FieldCode);
        try
        {
            await using var stream = file.OpenReadStream(max);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var b64 = Convert.ToBase64String(ms.ToArray());
            var mime = string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType;
            await SetValue(q, $"data:{mime};base64,{b64}");
        }
        catch (Exception ex)
        {
            _captureError[q.FieldCode] = $"No se pudo leer el archivo: {ex.Message}";
        }
    }

    // ---- Lookup / autocompletado (ola F1, doc 01 D4) ----

    // Estado de UI del lookup por campo (fieldCode).
    private readonly Dictionary<string, string?> _lookupDisplay = new(StringComparer.Ordinal); // etiqueta del id elegido
    private readonly Dictionary<string, string?> _lookupQuery = new(StringComparer.Ordinal);   // texto tecleado
    private readonly Dictionary<string, IReadOnlyList<FormLookupItem>> _lookupResults = new(StringComparer.Ordinal);
    private readonly HashSet<string> _lookupOpen = new(StringComparer.Ordinal);
    private readonly HashSet<string> _lookupBusy = new(StringComparer.Ordinal);

    private RenderFragment RenderLookup(FormQuestionDto q, string? value) => __builder =>
    {
        var display = _lookupDisplay.GetValueOrDefault(q.FieldCode) ?? value;
        var results = _lookupResults.GetValueOrDefault(q.FieldCode);

        if (q.Presentation == FormFieldPresentation.Dropdown)
        {
            <select class="form-control" disabled="@IsDisabled"
                    @onclick="@(() => LookupSearchAsync(q, null))"
                    @onchange="@(e => LookupChooseByValueAsync(q, e.Value?.ToString()))">
                <option value="" selected="@string.IsNullOrEmpty(value)">-- Selecciona --</option>
                @if (results is not null)
                {
                    @foreach (var it in results)
                    {
                        <option value="@it.Value" selected="@(it.Value == value)">@it.Display</option>
                    }
                }
                else if (!string.IsNullOrEmpty(value))
                {
                    <option value="@value" selected="true">@display</option>
                }
            </select>
            return;
        }

        @* Autocomplete y Modal: input de busqueda + panel de resultados. *@
        <div class="dfr-lookup @(q.Presentation == FormFieldPresentation.Modal ? "is-modal" : "")">
            <div class="dfr-lookup-box">
                <input class="form-control" disabled="@IsDisabled"
                       placeholder="@(string.IsNullOrWhiteSpace(q.PlaceholderText) ? "Buscar..." : q.PlaceholderText)"
                       value="@(_lookupQuery.TryGetValue(q.FieldCode, out var typed) ? typed : display)"
                       @oninput="@(e => LookupTypeAsync(q, e.Value?.ToString()))"
                       @onfocus="@(() => LookupSearchAsync(q, _lookupQuery.GetValueOrDefault(q.FieldCode)))" />
                @if (!string.IsNullOrEmpty(value) && !IsDisabled)
                {
                    <button type="button" class="dfr-lookup-clear" title="Quitar" @onclick="@(() => LookupClearAsync(q))">&times;</button>
                }
            </div>
            @if (!string.IsNullOrEmpty(value) && !string.IsNullOrEmpty(display))
            {
                <div class="dfr-lookup-chosen">Seleccionado: <strong>@display</strong></div>
            }
            @if (_lookupOpen.Contains(q.FieldCode))
            {
                <div class="dfr-lookup-panel">
                    @if (_lookupBusy.Contains(q.FieldCode))
                    {
                        <div class="dfr-lookup-empty"><em>Buscando...</em></div>
                    }
                    else if (results is null || results.Count == 0)
                    {
                        <div class="dfr-lookup-empty">
                            <span>Sin resultados.</span>
                            <a class="dfr-lookup-create" href="@CreateLink(q.SourceKind)" target="_blank" rel="noopener">Crear en el modulo</a>
                        </div>
                    }
                    else
                    {
                        @foreach (var it in results)
                        {
                            var item = it;
                            <button type="button" class="dfr-lookup-opt" @onclick="@(() => LookupChooseAsync(q, item))">@item.Display</button>
                        }
                    }
                </div>
            }
        </div>
    };

    /// <summary>Campos de la fuente que hay que traer: el de mostrar + los origenes del mapa de autollenado.</summary>
    private static IReadOnlyList<string> LookupFields(FormQuestionDto q)
    {
        var set = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        if (!string.IsNullOrWhiteSpace(q.DisplayField)) { set.Add(q.DisplayField!); }
        foreach (var src in ParseAutofillMap(q.AutofillMapJson).Keys) { set.Add(src); }
        return set.ToList();
    }

    /// <summary>AutofillMapJson: { "campoFuente": "campoFormulario" }. Defensivo ante JSON invalido.</summary>
    private static IReadOnlyDictionary<string, string> ParseAutofillMap(string? json)
    {
        var map = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(json)) { return map; }
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.ValueKind != System.Text.Json.JsonValueKind.Object) { return map; }
            foreach (var p in doc.RootElement.EnumerateObject())
            {
                var target = p.Value.ValueKind == System.Text.Json.JsonValueKind.String ? p.Value.GetString() : null;
                if (!string.IsNullOrWhiteSpace(target)) { map[p.Name] = target!; }
            }
        }
        catch (System.Text.Json.JsonException) { /* mapa invalido: se ignora */ }
        return map;
    }

    private static string CreateLink(FormSourceKind kind) => kind switch
    {
        FormSourceKind.Tercero => "/directorio-general",
        FormSourceKind.Item => "/inventario-items",
        FormSourceKind.DataContainer => "/contenedor-datos",
        _ => "#",
    };

    private async Task LookupTypeAsync(FormQuestionDto q, string? text)
    {
        _lookupQuery[q.FieldCode] = text;
        await LookupSearchAsync(q, text);
    }

    private async Task LookupSearchAsync(FormQuestionDto q, string? text)
    {
        if (IsDisabled) { return; }
        _lookupOpen.Add(q.FieldCode);
        _lookupBusy.Add(q.FieldCode);
        await _dbGate.WaitAsync();
        try
        {
            using var ambient = BeginAmbient();
            var page = await LookupSvc.SearchAsync(new FormLookupRequest(
                q.SourceKind, q.SourceRef, text, q.FilterJson, q.DisplayField, LookupFields(q), Skip: 0, Take: 20));
            _lookupResults[q.FieldCode] = page.Items;
        }
        catch (Exception ex)
        {
            _lookupResults[q.FieldCode] = Array.Empty<FormLookupItem>();
            _globalError = $"No se pudo buscar en la fuente: {ex.Message}";
        }
        finally
        {
            _dbGate.Release();
            _lookupBusy.Remove(q.FieldCode);
        }
    }

    private async Task LookupChooseAsync(FormQuestionDto q, FormLookupItem item)
    {
        // Guarda el ID (ValueField) en data y COPIA (snapshot) los campos mapeados a sus destinos.
        _lookupDisplay[q.FieldCode] = item.Display;
        _lookupQuery[q.FieldCode] = item.Display;
        _lookupOpen.Remove(q.FieldCode);
        await SetValue(q, item.Value);

        var map = ParseAutofillMap(q.AutofillMapJson);
        foreach (var (source, target) in map)
        {
            _values[target] = item.Fields.TryGetValue(source, out var v) ? v : null;
            var targetQ = _definition!.Questions.FirstOrDefault(x => x.FieldCode == target);
            if (targetQ is not null) { ValidateField(targetQ); }
        }
        RecomputeCalculatedFields();
        _dirty = true;
    }

    private async Task LookupChooseByValueAsync(FormQuestionDto q, string? val)
    {
        if (string.IsNullOrEmpty(val)) { await LookupClearAsync(q); return; }
        var results = _lookupResults.GetValueOrDefault(q.FieldCode);
        var item = results?.FirstOrDefault(i => i.Value == val);
        if (item is not null) { await LookupChooseAsync(q, item); }
        else { await SetValue(q, val); }
    }

    private async Task LookupClearAsync(FormQuestionDto q)
    {
        _lookupDisplay.Remove(q.FieldCode);
        _lookupQuery[q.FieldCode] = null;
        _lookupOpen.Remove(q.FieldCode);
        await SetValue(q, null);
    }

    /// <summary>Al cargar, resuelve la etiqueta de cada id ya guardado (para mostrar nombre, no el Guid).</summary>
    private async Task ResolveLookupDisplaysAsync()
    {
        if (_definition is null) { return; }
        foreach (var q in _definition.Questions.Where(x => x.SourceKind != FormSourceKind.Options))
        {
            var value = _values.GetValueOrDefault(q.FieldCode);
            if (string.IsNullOrEmpty(value)) { continue; }
            try
            {
                var item = await LookupSvc.ResolveAsync(q.SourceKind, q.SourceRef ?? "", value, LookupFields(q));
                if (item is not null) { _lookupDisplay[q.FieldCode] = item.Display; }
            }
            catch (Exception) { /* la resolucion de etiqueta nunca rompe la carga */ }
        }
    }

    // ---- Tabla (GridDetail) funcional + totales (ola F2, doc 01 D5 / doc 02 s4) ----

    // Parseo/agregado/recompute de tablas: helper COMPARTIDO con el servidor (FormGridCalculator),
    // para que cliente y servidor calculen igual (fuente de verdad = servidor).
    private static List<FormGridColumn> GridColumnsOf(FormQuestionDto q)
        => FormGridCalculator.ParseColumns(q.OptionsJson).ToList();

    /// <summary>
    /// Recalcula todas las tablas (ola F2): formula por fila + roll-up de columnas al encabezado,
    /// via el helper compartido. Persiste las filas computadas en _values.
    /// </summary>
    private void RecomputeGrids()
    {
        if (_definition is null) { return; }
        foreach (var q in _definition.Questions.Where(x => x.ControlType == FormControlType.GridDetail))
        {
            var cols = GridColumnsOf(q);
            if (cols.Count == 0) { continue; }
            var (rows, rollups) = FormGridCalculator.Recompute(GridRowsOf(q), cols);
            _values[q.FieldCode] = rows.Count == 0 ? null : System.Text.Json.JsonSerializer.Serialize(rows);
            foreach (var (field, total) in rollups) { _values[field] = total; }
        }
    }

    private RenderFragment RenderGrid(FormQuestionDto q, string? value) => __builder =>
    {
        var columns = GridColumnsOf(q);
        var rows = FormFieldValidator.ParseGridRows(value).Select(r => new Dictionary<string, string?>(r, StringComparer.Ordinal)).ToList();
        @if (columns.Count == 0)
        {
            <div class="dfr-unsupported">La tabla no tiene columnas definidas.</div>
            return;
        }
        var hasTotals = columns.Any(c => c.Agg != FormAggregate.None);
        <div class="dfr-grid">
            <table class="dfr-grid-table">
                <thead>
                    <tr>
                        @foreach (var col in columns)
                        {
                            <th>@col.Label</th>
                        }
                        @if (!IsDisabled)
                        {
                            <th class="dfr-grid-x"></th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (rows.Count == 0)
                    {
                        <tr>
                            <td class="dfr-grid-empty" colspan="@(columns.Count + (IsDisabled ? 0 : 1))">Sin filas todavia.</td>
                        </tr>
                    }
                    @for (var r = 0; r < rows.Count; r++)
                    {
                        var rowIndex = r;
                        <tr>
                            @foreach (var col in columns)
                            {
                                var colId = col.Id;
                                var cell = rows[rowIndex].GetValueOrDefault(colId);
                                <td>
                                    @if (col.Calc is not null)
                                    {
                                        @* Columna calculada por fila (ola F2): solo lectura. *@
                                        <input class="form-control form-control-sm dfr-calc" tabindex="-1" readonly disabled
                                               value="@cell" />
                                    }
                                    else if (col.IsSelect)
                                    {
                                        @* D3: columna de lista. El valor guardado sigue siendo el id de la opcion. *@
                                        <select class="form-control form-control-sm" disabled="@IsDisabled"
                                                @onchange="@(e => SetGridCell(q, rowIndex, colId, e.Value?.ToString()))">
                                            <option value="" selected="@string.IsNullOrEmpty(cell)">--</option>
                                            @foreach (var opt in col.Options ?? Array.Empty<FormOption>())
                                            {
                                                <option value="@opt.Id" selected="@(opt.Id == cell)">@opt.Label</option>
                                            }
                                        </select>
                                    }
                                    else
                                    {
                                        <input class="form-control form-control-sm" disabled="@IsDisabled"
                                               value="@cell"
                                               @onchange="@(e => SetGridCell(q, rowIndex, colId, e.Value?.ToString()))" />
                                    }
                                </td>
                            }
                            @if (!IsDisabled)
                            {
                                <td class="dfr-grid-x">
                                    <button type="button" class="dfr-grid-del" title="Quitar fila"
                                            @onclick="@(() => RemoveGridRow(q, rowIndex))">&times;</button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
                @if (hasTotals && rows.Count > 0)
                {
                    <tfoot>
                        <tr class="dfr-grid-total">
                            @foreach (var col in columns)
                            {
                                var total = col.Agg == FormAggregate.None ? null
                                    : FormGridCalculator.Aggregate(col.Agg, rows.Select(r => r.GetValueOrDefault(col.Id)));
                                <td>@(total?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")</td>
                            }
                            @if (!IsDisabled)
                            {
                                <td class="dfr-grid-x"></td>
                            }
                        </tr>
                    </tfoot>
                }
            </table>
            @if (!IsDisabled)
            {
                <button type="button" class="dfr-grid-add" @onclick="@(() => AddGridRow(q))">+ Agregar fila</button>
            }
        </div>
    };

    // ---- Maestro-detalle / subformulario (ola F5, doc 01 D7) ----

    private readonly Dictionary<string, IReadOnlyList<FormRecordListItemDto>> _subformChildren = new(StringComparer.Ordinal);
    private string? _activeChildField;
    private Guid? _activeChildResponseId;

    private RenderFragment RenderSubform(FormQuestionDto q) => __builder =>
    {
        if (q.SubformDefinitionId is not Guid childDef)
        {
            <div class="dfr-unsupported">Subformulario sin definicion hija configurada.</div>
            return;
        }
        var children = _subformChildren.GetValueOrDefault(q.FieldCode) ?? Array.Empty<FormRecordListItemDto>();
        <div class="dfr-subform">
            <table class="dfr-grid-table">
                <thead>
                    <tr><th>Registro</th><th>Estado</th><th>Referencia</th>@if (!IsDisabled) { <th class="dfr-grid-x"></th> }</tr>
                </thead>
                <tbody>
                    @if (children.Count == 0)
                    {
                        <tr><td class="dfr-grid-empty" colspan="@(IsDisabled ? 3 : 4)">Sin registros hijos todavia.</td></tr>
                    }
                    @foreach (var c in children)
                    {
                        var childId = c.Id;
                        <tr>
                            <td>@(c.RecordNumber ?? "(borrador)")</td>
                            <td>@(c.RecordStatus == FormRecordStatus.Confirmed ? "Confirmado" : c.RecordStatus == FormRecordStatus.Voided ? "Anulado" : "Borrador")</td>
                            <td>@(c.Reference ?? "-")</td>
                            @if (!IsDisabled)
                            {
                                <td class="dfr-grid-x">
                                    <button type="button" class="dfr-grid-del" title="Quitar del padre" @onclick="@(() => RemoveSubformChildAsync(q, childId))">&times;</button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
            @if (!IsDisabled && _activeChildField != q.FieldCode)
            {
                <button type="button" class="dfr-grid-add" @onclick="@(() => AddSubformChildAsync(q))">+ Agregar registro</button>
            }
            @if (_activeChildField == q.FieldCode && _activeChildResponseId is Guid activeChild)
            {
                <div class="dfr-subform-child">
                    <div class="dfr-subform-childhead">Nuevo registro hijo</div>
                    <DynamicFormRenderer DefinitionId="childDef" ResponseId="activeChild" Mode="FormRenderMode.Fill"
                                         SubmittedByTenantUserId="SubmittedByTenantUserId" AmbientTenantId="AmbientTenantId"
                                         ShowHeader="false" OnSubmitted="@(_ => OnSubformChildSubmittedAsync(q))" />
                </div>
            }
        </div>
    };

    private async Task LoadSubformChildrenAsync()
    {
        if (_definition is null || _response is null) { return; }
        foreach (var q in _definition.Questions.Where(x => x.ControlType == FormControlType.Subform))
        {
            _subformChildren[q.FieldCode] = await ResponsesSvc.ListChildrenAsync(_response.Id, q.FieldCode);
        }
    }

    private async Task AddSubformChildAsync(FormQuestionDto q)
    {
        if (_response is null || q.SubformDefinitionId is not Guid childDef) { return; }
        await _dbGate.WaitAsync();
        try
        {
            using var ambient = BeginAmbient();
            var result = await ResponsesSvc.AddChildAsync(_response.Id, q.FieldCode, childDef);
            if (result.IsOk)
            {
                _activeChildField = q.FieldCode;
                _activeChildResponseId = result.Value;
            }
            else { _globalError = result.Error; }
        }
        finally { _dbGate.Release(); }
    }

    private async Task OnSubformChildSubmittedAsync(FormQuestionDto q)
    {
        _activeChildField = null;
        _activeChildResponseId = null;
        await _dbGate.WaitAsync();
        try
        {
            using var ambient = BeginAmbient();
            _subformChildren[q.FieldCode] = await ResponsesSvc.ListChildrenAsync(_response!.Id, q.FieldCode);
        }
        finally { _dbGate.Release(); }
    }

    private async Task RemoveSubformChildAsync(FormQuestionDto q, Guid childId)
    {
        if (_response is null) { return; }
        await _dbGate.WaitAsync();
        try
        {
            using var ambient = BeginAmbient();
            await ResponsesSvc.UnlinkChildAsync(_response.Id, q.FieldCode, childId);
            _subformChildren[q.FieldCode] = await ResponsesSvc.ListChildrenAsync(_response.Id, q.FieldCode);
        }
        finally { _dbGate.Release(); }
    }

    private List<Dictionary<string, string?>> GridRowsOf(FormQuestionDto q)
        => FormFieldValidator.ParseGridRows(_values.GetValueOrDefault(q.FieldCode))
            .Select(r => new Dictionary<string, string?>(r, StringComparer.Ordinal))
            .ToList();

    private async Task SetGridCell(FormQuestionDto q, int rowIndex, string colId, string? cellValue)
    {
        var rows = GridRowsOf(q);
        if (rowIndex < 0 || rowIndex >= rows.Count)
        {
            return;
        }
        rows[rowIndex][colId] = cellValue;
        await SetValue(q, System.Text.Json.JsonSerializer.Serialize(rows));
    }

    private async Task AddGridRow(FormQuestionDto q)
    {
        var rows = GridRowsOf(q);
        var row = new Dictionary<string, string?>(StringComparer.Ordinal);
        // Se parsea igual que el render (GridColumnsOf), no con ParseOptions: si una columna Select o
        // calculada solo existiera en uno de los dos parseos, la fila nueva y la tabla se desincronizarian.
        foreach (var col in GridColumnsOf(q))
        {
            row[col.Id] = null;
        }
        rows.Add(row);
        await SetValue(q, System.Text.Json.JsonSerializer.Serialize(rows));
    }

    private async Task RemoveGridRow(FormQuestionDto q, int rowIndex)
    {
        var rows = GridRowsOf(q);
        if (rowIndex < 0 || rowIndex >= rows.Count)
        {
            return;
        }
        rows.RemoveAt(rowIndex);
        await SetValue(q, rows.Count == 0 ? null : System.Text.Json.JsonSerializer.Serialize(rows));
    }

    private static string Prefixed(FormQuestionDto q)
        => string.IsNullOrWhiteSpace(q.Numeral) ? q.Label : $"{q.Numeral}. {q.Label}";

    // ---- Estado y validacion cliente ----

    private async Task SetValue(FormQuestionDto q, string? value)
    {
        _values[q.FieldCode] = value;
        _dirty = true;
        RecomputeGrids();
        RecomputeCalculatedFields();
        ValidateField(q);
        await DispatchFieldRulesAsync(q);
    }

    // ---- Transversales (ola F6, doc 01 D8) ----

    // Permisos por campo (ola F6, doc 01 D8): FieldVisibilityJson = { "hide":[...], "readonly":[...] }.
    private bool IsFieldHidden(FormQuestionDto q) => FieldRoleMatch(q.FieldVisibilityJson, "hide");
    private bool IsFieldReadonly(FormQuestionDto q) => FieldRoleMatch(q.FieldVisibilityJson, "readonly");

    private bool FieldRoleMatch(string? json, string key)
    {
        if (string.IsNullOrWhiteSpace(json) || _currentRole is null) { return false; }
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.ValueKind != System.Text.Json.JsonValueKind.Object
                || !doc.RootElement.TryGetProperty(key, out var arr)
                || arr.ValueKind != System.Text.Json.JsonValueKind.Array) { return false; }
            foreach (var r in arr.EnumerateArray())
            {
                if (string.Equals(r.GetString(), _currentRole, StringComparison.OrdinalIgnoreCase)) { return true; }
            }
        }
        catch (System.Text.Json.JsonException) { }
        return false;
    }

    /// <summary>Resuelve un valor por defecto dinamico al abrir el formulario (Hoy / Usuario actual).</summary>
    private string? ResolveDynamicDefault(FormDefaultDynamic d) => d switch
    {
        FormDefaultDynamic.Today => DateTimeOffset.Now.ToString("yyyy-MM-dd"),
        // Usuario actual: se muestra el NOMBRE del usuario logueado (no el Guid). Si no hay identidad
        // con nombre (p.ej. visor publico por token), cae al id como ultimo recurso.
        FormDefaultDynamic.CurrentUser => string.IsNullOrWhiteSpace(_currentUserName)
            ? SubmittedByTenantUserId?.ToString()
            : _currentUserName,
        _ => null,
    };

    /// <summary>Aplica el formato de presentacion (moneda/%/entero) para MOSTRAR (no altera el valor guardado).</summary>
    private static string FormatValue(string? format, string? value)
    {
        if (string.IsNullOrWhiteSpace(format) || string.IsNullOrWhiteSpace(value)) { return value ?? ""; }
        var ci = System.Globalization.CultureInfo.InvariantCulture;
        if (!decimal.TryParse(value.Replace(" ", "").Replace(",", ""), System.Globalization.NumberStyles.Any, ci, out var num))
        {
            return value;
        }
        return format.Trim().ToLowerInvariant() switch
        {
            "currency" => "$ " + num.ToString("#,##0", ci),
            "percent" => num.ToString("0.##", ci) + " %",
            "integer" => Math.Round(num).ToString("#,##0", ci),
            "decimal" => num.ToString("#,##0.00", ci),
            "document" => num.ToString("#,##0", ci),
            _ => value,
        };
    }

    /// <summary>Mascara de ENTRADA (ola F6): reformatea el valor tecleado al perder el foco. Para campos
    /// de texto (telefono) usa los digitos; para numericos reusa <see cref="FormatValue"/>.</summary>
    private static string MaskInput(string? format, string? value)
    {
        if (string.IsNullOrWhiteSpace(format) || string.IsNullOrWhiteSpace(value)) { return value ?? ""; }
        if (format.Trim().ToLowerInvariant() == "phone")
        {
            var d = new string(value.Where(char.IsDigit).ToArray());
            if (d.Length == 10) { return $"({d[..3]}) {d[3..6]}-{d[6..]}"; }
            if (d.Length == 7) { return $"{d[..3]}-{d[3..]}"; }
            return value;
        }
        return FormatValue(format, value);
    }

    /// <summary>
    /// Recalcula en cliente todos los campos con CalcExpression (ola F2, doc 01 D5) con el MISMO
    /// evaluador tipado del servidor. Se invoca ante cualquier cambio de valor; el servidor
    /// revalida al guardar (fuente de verdad, el cliente no es confiable para montos).
    /// </summary>
    private void RecomputeCalculatedFields()
    {
        if (_definition is null) { return; }
        foreach (var q in _definition.Questions.Where(x => !string.IsNullOrWhiteSpace(x.CalcExpression)))
        {
            var result = FormExpressionEvaluator.Evaluate(q.CalcExpression, _values);
            _values[q.FieldCode] = result?.ToString(System.Globalization.CultureInfo.InvariantCulture);
        }
    }

    /// <summary>
    /// RulesEngine (ADR-0016): si el campo cambiado tiene reglas vinculadas, las ejecuta
    /// (FormFieldRule en SortOrder) y aplica las acciones devueltas: SetFieldValue sobre
    /// _values y Hide/Show/SetRequired sobre el estado de UI. Encapsulado en el
    /// IFormRuleDispatcher para no acoplar el renderer al motor.
    /// </summary>
    private async Task DispatchFieldRulesAsync(FormQuestionDto q)
    {
        if (Mode != FormRenderMode.Fill || IsSubmitted || !_ruleTriggerFields.Contains(q.FieldCode))
        {
            return;
        }
        await _dbGate.WaitAsync();
        FormFieldRulesOutcome outcome;
        try
        {
            using var ambient = BeginAmbient();
            outcome = await RulesDispatcher.OnFieldChangedAsync(
                DefinitionId, q.FieldCode, _values, _response?.Id, SubmittedByTenantUserId);
        }
        finally
        {
            _dbGate.Release();
        }
        if (outcome.Actions.Count == 0)
        {
            return;
        }
        _ruleUiState.Apply(outcome.Actions, _values);
        _dirty = true;
        // Revalida los campos tocados por las acciones (ocultos limpian su error).
        foreach (var fieldCode in outcome.Actions.Select(a => a.FieldCode).Distinct(StringComparer.Ordinal))
        {
            var touched = _definition!.Questions.FirstOrDefault(x => x.FieldCode == fieldCode);
            if (touched is not null)
            {
                ValidateField(touched);
            }
        }
    }

    private async Task ToggleMulti(FormQuestionDto q, string optionId, bool on)
    {
        var selected = FormFieldValidator.ParseMultiValues(_values.GetValueOrDefault(q.FieldCode))
            .ToList();
        if (on && !selected.Contains(optionId, StringComparer.Ordinal))
        {
            selected.Add(optionId);
        }
        else if (!on)
        {
            selected.RemoveAll(s => string.Equals(s, optionId, StringComparison.Ordinal));
        }
        _values[q.FieldCode] = selected.Count == 0
            ? null
            : System.Text.Json.JsonSerializer.Serialize(selected);
        _dirty = true;
        RecomputeCalculatedFields();
        ValidateField(q);
        await DispatchFieldRulesAsync(q);
    }

    /// <summary>
    /// Validacion cliente inmediata con el MISMO validador del servidor. Los campos ocultos
    /// por regla no se validan (tampoco como requeridos) y la obligatoriedad respeta los
    /// overrides SetRequired de las reglas.
    /// </summary>
    private void ValidateField(FormQuestionDto q)
    {
        if (_ruleUiState.IsHidden(q.FieldCode))
        {
            _errors.Remove(q.FieldCode);
            return;
        }
        var error = FormFieldValidator.Validate(
            q.ControlType, _ruleUiState.IsRequired(q.FieldCode, q.Required),
            _values.GetValueOrDefault(q.FieldCode),
            FormFieldValidator.ParseOptions(q.OptionsJson),
            FormFieldValidator.ParseRules(q.ValidationJson),
            q.OptionsJson);
        if (error is null)
        {
            _errors.Remove(q.FieldCode);
        }
        else
        {
            _errors[q.FieldCode] = error;
        }
    }

    private IReadOnlyDictionary<string, FormFieldValue> BuildDocument()
        => _definition!.Questions
            .Where(q => !FormFieldValidator.IsNonInput(q.ControlType))
            .Where(q => _values.GetValueOrDefault(q.FieldCode) is not null)
            .ToDictionary(
                q => q.FieldCode,
                q => new FormFieldValue(_values[q.FieldCode], q.ControlType.ToString()),
                StringComparer.Ordinal);

    // ---- Guardado ----

    private async Task AutosaveTickAsync()
    {
        if (!_dirty || _busy || _response is null || IsSubmitted || Mode != FormRenderMode.Fill)
        {
            return;
        }
        await SaveAsync(submit: false);
        StateHasChanged();
    }

    /// <summary>Anula el registro transaccional confirmado (ola F3): llama a VoidAsync con el motivo.</summary>
    private async Task VoidAsync()
    {
        if (_response is null || string.IsNullOrWhiteSpace(_voidReason)) { return; }
        _busy = true;
        await _dbGate.WaitAsync();
        try
        {
            using var ambient = BeginAmbient();
            var result = await ResponsesSvc.VoidAsync(_response.Id, _voidReason!, SubmittedByTenantUserId);
            if (result.IsOk && result.Value is not null)
            {
                _response = result.Value;
                _voiding = false;
                _voidReason = null;
            }
            else
            {
                _globalError = result.Error ?? "No se pudo anular el registro.";
            }
        }
        finally
        {
            _dbGate.Release();
            _busy = false;
        }
    }

    private async Task SubmitAsync()
    {
        // Valida todo en cliente primero (feedback inmediato); el servidor re-valida igual.
        _errors.Clear();
        foreach (var q in _definition!.Questions)
        {
            ValidateField(q);
        }
        if (_errors.Count > 0)
        {
            _globalError = "Revisa los campos marcados antes de enviar.";
            return;
        }
        await SaveAsync(submit: true);
    }

    private async Task SaveAsync(bool submit)
    {
        if (_response is null)
        {
            return;
        }
        _busy = true;
        _globalError = null;
        // Diferido para invocar al padre FUERA del gate (ver nota abajo).
        FormResponseDto? submitted = null;
        await _dbGate.WaitAsync();
        try
        {
            using var ambient = BeginAmbient();
            var result = await ResponsesSvc.SaveAsync(
                _response.Id, BuildDocument(), submit, SubmittedByTenantUserId,
                approvalResult: submit ? _approvalChoice : null,
                hiddenFieldCodes: _ruleUiState.HiddenFields);
            if (result.Status == FormServiceStatus.ValidationFailed && result.FieldErrors is not null)
            {
                // Errores del servidor bajo cada campo (fuente de verdad).
                foreach (var (fieldCode, message) in result.FieldErrors)
                {
                    _errors[fieldCode] = message;
                }
                _globalError = "Revisa los campos marcados antes de enviar.";
                return;
            }
            if (!result.IsOk || result.Value is null)
            {
                _globalError = result.Error ?? "No se pudo guardar la respuesta.";
                return;
            }
            _response = result.Value;
            _dirty = false;
            _lastSavedAt = DateTimeOffset.Now;
            if (submit)
            {
                _autosaveTimer?.Dispose();
                _autosaveTimer = null;
                submitted = result.Value;
            }
        }
        finally
        {
            _dbGate.Release();
            _busy = false;
        }

        // OnSubmitted se invoca FUERA del critical section: el callback del visor publico
        // (/f/{token}) muestra la pantalla de gracias y destruye este componente, lo que
        // ejecuta Dispose() -> _dbGate.Dispose(). Hacerlo dentro del try dejaba el
        // Release() del finally corriendo sobre un semaforo ya disposed
        // (ObjectDisposedException que tumbaba el circuito tras el submit). Liberado el
        // gate primero, ya no hay Release pendiente cuando el padre nos destruye.
        if (submitted is not null)
        {
            await OnSubmitted.InvokeAsync(submitted);
        }
    }

    /// <summary>Fija el tenant ambient del visor publico; no-op con sesion normal.</summary>
    private IDisposable? BeginAmbient()
        => AmbientTenantId is Guid tenantId ? AmbientTenantContext.Begin(tenantId) : null;

    public void Dispose()
    {
        _autosaveTimer?.Dispose();
        // NO se hace _dbGate.Dispose(): el semaforo lo posee el servicio scoped CircuitFormGate y
        // lo comparten los demas renderers del circuito; disponerlo aqui los tumbaria.
    }
}
