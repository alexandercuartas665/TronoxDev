                            <div style="flex:1;display:flex;align-items:center;gap:8px;padding:11px 12px;border:1px solid var(--line);border-radius:11px;background:var(--surface)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--ink-3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 9.5 12 18a4 4 0 0 1-6-6l8-8a2.5 2.5 0 0 1 4 4l-8 8a1 1 0 0 1-1.5-1.5L16 7"></path></svg><div><div style="font-size:15px;font-weight:800;line-height:1">0</div><div style="font-size:10px;color:var(--ink-3)">Archivos</div></div></div>
                            <div style="flex:1;display:flex;align-items:center;gap:8px;padding:11px 12px;border:1px solid var(--line);border-radius:11px;background:var(--surface)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--ink-3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg><div><div style="font-size:15px;font-weight:800;line-height:1">@_ccEmails.Count</div><div style="font-size:10px;color:var(--ink-3)">Copia a</div></div></div>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    [Parameter] public EventCallback<TaskItemDetailDto> OnCreated { get; set; }

    private static readonly string[] Steps = { "Informacion", "Contacto", "Formulario", "Documentos" };

    // ---- Estilos inline (tokens del prototipo) ----
    private const string CardStyle = "background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:20px 22px;box-shadow:var(--sh-sm)";
    private const string SelStyle = "width:100%;height:40px;padding:0 12px;border:1px solid var(--line-2);border-radius:10px;background:var(--surface-2);font:inherit;font-size:13.5px;color:var(--ink);outline:none;cursor:pointer";
    private const string InStyle = "width:100%;height:40px;padding:0 12px;border:1px solid var(--line-2);border-radius:10px;background:var(--surface-2);font:inherit;font-size:13.5px;color:var(--ink);outline:none";
    private const string LblStyle = "display:block;font-size:11.5px;font-weight:600;color:var(--ink-2);margin-bottom:6px";
    private const string ErrStyle = "color:var(--t-red, #dc2626);font-size:12px;margin-top:5px";

    private bool _visible;
    private bool _busy;
    private int _step = 1;
    private readonly Dictionary<string, string> _errors = new();

    // Datos
    private List<EntidadOptionDto> _entidades = new();
    private List<ActividadCategoriaDto> _categorias = new();
    private List<ActividadSubcategoriaDto> _subcategorias = new();
    private List<TenantUserDto> _users = new();
    private List<ProjectDto> _projects = new();
    private List<TaskItemTagDto> _allTags = new();
    private IReadOnlyList<Guid> _encargadoIds = Array.Empty<Guid>();

    // Paso 1
    private Guid? _entidadId;
    private Guid? _categoriaId;
    private Guid? _subcategoriaId;
    private Guid? _assigneeId;
    private DateTime? _dueDate;
    private string _title = "";
    private string _description = "";
    private TaskPriority _priority = TaskPriority.Medium;
    private readonly List<TaskItemTagDto> _tags = new();
    private string _tagInput = "";

    // Paso 2
    private string _requesterName = "";
    private string _requesterDoc = "";
    private string _requesterEmail = "";
    private string _requesterPhone = "";
    private readonly List<string> _ccEmails = new();
    private string _ccInput = "";
    private Guid? _projectId;
    private Guid? _presetProjectId;
    private Guid? _presetBoardId;
    private Guid? _presetColumnId;
    // Proyectos P3: hito del proyecto elegido (se cargan al elegir proyecto).
    private Guid? _milestoneId;
    private List<ProjectMilestoneDto> _milestones = new();

    // Ola A2: el paso 1 del flujo de la subcategoria (nodo + cargo + candidatos), resuelto por
    // IWorkflowStartService sin ejecutar el motor. Null si la actividad no es un proceso.
    private FirstStepDto? _firstStep;
    // true cuando el combo de Encargado esta acotado al cargo del primer nodo (D2: el flujo manda).
    private bool _encargadoRestringido;

    private ActividadSubcategoriaDto? SelectedSub => _subcategorias.FirstOrDefault(s => s.Id == _subcategoriaId);
    private bool HasForm => SelectedSub?.FormDefinitionId is not null;

    // Restringido: SOLO los candidatos del cargo del nodo (aunque la lista quede vacia).
    // Libre: los cargos del concepto, y si el concepto no acota ningun cargo, todos los usuarios.
    private IEnumerable<TenantUserDto> EncargadoOptions =>
        _encargadoRestringido || _encargadoIds.Count > 0
            ? _users.Where(u => _encargadoIds.Contains(u.Id))
            : _users;

    /// <summary>El primer paso del flujo se resolvio: sabemos que cargo lo atiende.</summary>
    private bool TienePasoResuelto => _firstStep is { Status: FirstStepStatus.Ok or FirstStepStatus.SinCandidatos };

    /// <summary>
    /// Ola C1 (D3): aviso ambar cuando el concepto tiene flujo pero NO es utilizable. Null si todo
    /// bien (o no es proceso). Devuelve HTML (se pinta como MarkupString).
    /// </summary>
    private string? ProcesoAviso => _firstStep?.Status switch
    {
        FirstStepStatus.FlujoNoPublicado =>
            "El flujo de este proceso <strong>aun no esta publicado</strong>. La actividad se creara <strong>sin proceso</strong> (no arrancara el flujo ni enrutara el primer paso).",
        FirstStepStatus.SinNodoTask =>
            "El flujo de este proceso <strong>no tiene ningun paso</strong> que atender. Revisalo en el editor de flujos antes de usarlo.",
        FirstStepStatus.SinCargo =>
            "El primer paso del flujo <strong>no tiene un cargo asignado</strong>: la actividad nacera <strong>sin encargado</strong>. Asigna el cargo en el editor de flujos.",
        _ => null,
    };

    /// <summary>Etiqueta del paso que dicta el encargado, ej. "Paso 1 - Cotizar - Comprador".</summary>
    private string? PasoLabel
    {
        get
        {
            if (!TienePasoResuelto) { return null; }
            var nodo = string.IsNullOrWhiteSpace(_firstStep!.NodeName) ? "Primer paso" : _firstStep.NodeName;
            var cargo = _firstStep.CargoPrincipal;
            return string.IsNullOrWhiteSpace(cargo) ? $"Paso 1 - {nodo}" : $"Paso 1 - {nodo} - {cargo}";
        }
    }

    private string? SumEmpresa => _entidades.FirstOrDefault(e => e.Id == _entidadId)?.Label;
    private string? SumProceso => _categorias.FirstOrDefault(c => c.Id == _categoriaId)?.Nombre;
    private string? SumActividad => SelectedSub?.Nombre;
    private string? SumEncargado => _users.FirstOrDefault(u => u.Id == _assigneeId) is TenantUserDto u ? TaskUi.UserLabel(u) : null;
    private string TitlePlaceholder => SelectedSub?.TituloAuto is { Length: > 0 } ? "Titulo (automatico del concepto si lo dejas vacio)" : "Titulo de la actividad";

    /// <summary>
    /// Abre el wizard limpio. Opcionalmente preselecciona proyecto (detalle de proyecto),
    /// concepto (menu Mis Procesos -&gt; categoria/subcategoria) y/o entidad.
    /// </summary>
    public async Task OpenAsync(Guid? presetProjectId = null, Guid? presetSubcategoriaId = null,
        Guid? presetCategoriaId = null, Guid? presetEntidadId = null,
        Guid? presetBoardId = null, Guid? presetColumnId = null)
    {
        ResetAll();
        _presetProjectId = presetProjectId;
        _projectId = presetProjectId;
        _entidadId = presetEntidadId;
        // Al crear desde un tablero, la actividad debe caer EN ese tablero/columna (no solo por concepto).
        _presetBoardId = presetBoardId;
        _presetColumnId = presetColumnId;

        _entidades = (await EntidadSvc.ListOptionsAsync()).ToList();
        _categorias = (await CatalogoSvc.ListCategoriasAsync(includeArchived: false)).ToList();
        _users = (await TenantUsersSvc.ListAsync()).ToList();
        _projects = (await ProjectsSvc.ListAsync()).ToList();
        _allTags = (await TasksSvc.ListTagsAsync()).ToList();
        // Proyectos P3: si viene proyecto preseleccionado, cargar sus hitos.
        if (_projectId is Guid presetPid) { _milestones = (await ProjectsSvc.ListMilestonesAsync(presetPid)).ToList(); }

        // Preseleccion de concepto (camino Mis Procesos).
        _categoriaId = presetCategoriaId;
        if (presetSubcategoriaId is Guid presetSub)
        {
            var sub = await CatalogoSvc.GetSubcategoriaAsync(presetSub);
            if (sub is not null)
            {
                _categoriaId = sub.CategoriaId;
            }
        }
        if (_categoriaId is Guid catId)
        {
            _subcategorias = (await CatalogoSvc.ListSubcategoriasAsync(catId, includeArchived: false)).ToList();
            _subcategoriaId = presetSubcategoriaId;
            await ResolveEncargadoAsync();
        }

        _visible = true;
        StateHasChanged();
    }

    private void ResetAll()
    {
        _step = 1; _busy = false; _errors.Clear();
        _entidadId = null; _categoriaId = null; _subcategoriaId = null; _assigneeId = null;
        _dueDate = null; _title = ""; _description = ""; _priority = TaskPriority.Medium;
        _tags.Clear(); _tagInput = "";
        _requesterName = ""; _requesterDoc = ""; _requesterEmail = ""; _requesterPhone = "";
        _ccEmails.Clear(); _ccInput = ""; _projectId = null; _presetProjectId = null;
        _presetBoardId = null; _presetColumnId = null;
        _milestoneId = null; _milestones = new();
        _subcategorias = new(); _encargadoIds = Array.Empty<Guid>();
        _firstStep = null; _encargadoRestringido = false;
    }

    /// <summary>Limpia el borrador conservando la clasificacion (Empresa/Tipo/Actividad/Encargado).</summary>
    private void ClearDraft()
    {
        _title = ""; _description = ""; _priority = TaskPriority.Medium;
        _tags.Clear(); _tagInput = ""; _dueDate = null;
        _requesterName = ""; _requesterDoc = ""; _requesterEmail = ""; _requesterPhone = "";
        _ccEmails.Clear(); _ccInput = "";
        if (_presetProjectId is null) { _projectId = null; _milestones = new(); }
        _milestoneId = null;
        _errors.Clear();
        _step = 1;
    }

    private void Close()
    {
        if (_busy) { return; }
        _visible = false;
    }

    private async Task GoStep(int n)
    {
        if (n < _step) { _step = n; return; }
        // Avanzar por NextStep (valida cada paso y, en form-first, crea la tarea al entrar al 3).
        while (_step < n)
        {
            var before = _step;
            await NextStep();
            if (_step == before) { return; } // validacion bloqueo o fallo la creacion
        }
    }

    private void OnEntidadChanged(ChangeEventArgs e)
        => _entidadId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;

    // Proyectos P3: al elegir proyecto, cargar sus hitos y resetear el hito seleccionado.
    private async Task OnProjectChanged(ChangeEventArgs e)
    {
        _projectId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        _milestoneId = null;
        _milestones = _projectId is Guid pid ? (await ProjectsSvc.ListMilestonesAsync(pid)).ToList() : new();
    }

    private async Task OnCategoriaChanged(ChangeEventArgs e)
    {
        _categoriaId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        _subcategoriaId = null;
        _assigneeId = null;
        _encargadoIds = Array.Empty<Guid>();
        _firstStep = null;
        _encargadoRestringido = false;
        _subcategorias = _categoriaId is Guid catId
            ? (await CatalogoSvc.ListSubcategoriasAsync(catId, includeArchived: false)).ToList()
            : new();
    }

    private async Task OnSubcategoriaChanged(ChangeEventArgs e)
    {
        _subcategoriaId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        await ResolveEncargadoAsync();
    }

    /// <summary>
    /// Ola A2: de donde sale el ENCARGADO.
    ///
    /// - Actividad-PROCESO (la subcategoria tiene flujo): lo DICTA EL FLUJO, no el usuario
    ///   (decision D2). Se piden los candidatos del cargo del PRIMER NODO del BPMN via
    ///   IWorkflowStartService (Ola A1) -- NO los cargos del concepto. El combo queda RESTRINGIDO
    ///   a esos candidatos y, si hay uno solo, se PRESELECCIONA.
    /// - Actividad simple (sin flujo), o flujo aun no utilizable (borrador / sin nodo Task / sin
    ///   cargo): se cae al comportamiento de siempre (cargos del concepto). El aviso de "nacera sin
    ///   proceso" lo pondra la Ola C1.
    /// </summary>
    private async Task ResolveEncargadoAsync()
    {
        // Si el encargado actual lo habia DICTADO un flujo, no se arrastra al cambiar de actividad:
        // no lo eligio el usuario, y en otra actividad (u otro flujo) no tiene por que valer.
        var veniaDelFlujo = _encargadoRestringido;

        _firstStep = null;
        _encargadoRestringido = false;

        var sub = SelectedSub;
        if (sub is null)
        {
            _encargadoIds = Array.Empty<Guid>();
            return;
        }

        if (sub.WorkflowDefinitionId is not null)
        {
            _firstStep = await StartSvc.ResolveFirstStepAsync(sub.Id);

            // Solo cuando el cargo del primer paso se pudo resolver mandamos nosotros el combo.
            // (SinCandidatos tambien restringe: el cargo existe pero esta vacante -> no hay a quien
            //  asignar, y ofrecer "cualquier usuario" seria justo lo que D2 prohibe.)
            if (_firstStep.Status is FirstStepStatus.Ok or FirstStepStatus.SinCandidatos)
            {
                _encargadoIds = _firstStep.CandidateUserIds;
                _encargadoRestringido = true;
                _assigneeId = _firstStep.TieneCandidatoUnico ? _firstStep.CandidateUserIds[0] : null;
                return;
            }
        }

        if (veniaDelFlujo) { _assigneeId = null; }

        _encargadoIds = await CatalogoSvc.ListEncargadoUserIdsAsync(sub.CargoIds);
        // Si el encargado elegido ya no esta entre las opciones, se limpia.
        if (_assigneeId is Guid a && _encargadoIds.Count > 0 && !_encargadoIds.Contains(a))
        {
            _assigneeId = null;
        }
    }

    private void OnAddTag(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") { return; }
        var name = _tagInput.Trim();
        if (name.Length == 0) { return; }
        var existing = _allTags.FirstOrDefault(t => string.Equals(t.Name, name, StringComparison.OrdinalIgnoreCase));
        var tag = existing ?? new TaskItemTagDto(Guid.Empty, name, null);
        if (!_tags.Any(t => string.Equals(t.Name, name, StringComparison.OrdinalIgnoreCase)))
        {
            _tags.Add(tag);
        }
        _tagInput = "";
    }

    private void OnAddCc(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") { return; }
        var value = _ccInput.Trim();
        if (value.Length == 0) { return; }
        if (!TaskUi.IsValidEmail(value)) { _errors["cc"] = $"'{value}' no es un correo valido."; return; }
        _errors.Remove("cc");
        if (!_ccEmails.Contains(value, StringComparer.OrdinalIgnoreCase)) { _ccEmails.Add(value); }
        _ccInput = "";
    }

    private async Task NextStep()
    {
        if (!ValidateStep(_step)) { return; }
        // Ola B2: avanzar de paso NO crea nada. (Hasta B1, pasar al paso Formulario creaba la tarea
        // por adelantado -- parche de la Ola 5 --, asi que un formulario invalido dejaba una tarea
        // huerfana con su flujo ya arrancado. El arranque form-first ahora vive en FormFirstStarter,
        // que crea la actividad SOLO cuando el servidor valida el formulario.)
        _step++;
    }

    /// <summary>Construye el request y crea la tarea (con broadcast). No cierra ni notifica OnCreated.</summary>
    private async Task<TaskCoreResult<TaskItemDetailDto>> CreateTaskCoreAsync()
    {
        var actor = await ActorAsync();
        var actorName = await ActorNameAsync();
        DateTimeOffset? due = _dueDate is null
            ? null
            : new DateTimeOffset(_dueDate.Value.Date.AddHours(23).AddMinutes(59), DateTimeOffset.Now.Offset).ToUniversalTime();
        var tagIds = await ResolveTagIdsAsync();

        var request = new CreateTaskItemRequest(
            Title: _title.Trim(),
            ActivityTypeId: null,
            Description: string.IsNullOrWhiteSpace(_description) ? null : _description.Trim(),
            Priority: _priority,
            AssigneeTenantUserId: _assigneeId,
            DueDate: due,
            RequesterName: string.IsNullOrWhiteSpace(_requesterName) ? null : _requesterName.Trim(),
            RequesterEmail: string.IsNullOrWhiteSpace(_requesterEmail) ? null : _requesterEmail.Trim(),
            RequesterPhone: string.IsNullOrWhiteSpace(_requesterPhone) ? null : _requesterPhone.Trim(),
            CcEmails: _ccEmails.Count == 0 ? null : _ccEmails.ToList(),
            ProjectId: _projectId,
            Color: null,
            TagIds: tagIds.Count == 0 ? null : tagIds,
            SubcategoriaId: _subcategoriaId,
            EntidadId: _entidadId,
            MilestoneId: _milestoneId,
            BoardId: _presetBoardId,
            ColumnId: _presetColumnId);

        var result = await TasksSvc.CreateAsync(request, actor, actorName);
        if (result.IsOk && await TenantIdAsync() is Guid tenantId)
        {
            await Broadcaster.TaskChangedAsync(tenantId, result.Value!.Item.Id, result.Value.Item.Status);
        }
        return result;
    }

    private bool ValidateStep(int step)
    {
        _errors.Clear();
        if (step == 1)
        {
            if (_subcategoriaId is null) { _errors["sub"] = "Selecciona la actividad (concepto)."; }
            // D2 (el flujo manda): en una actividad-proceso el encargado tiene que ocupar el cargo
            // del primer nodo. El servidor lo revalida al crear (Ola A3); esto es solo el atajo de UI.
            if (_encargadoRestringido && _assigneeId is Guid asg && !_encargadoIds.Contains(asg))
            {
                _errors["assignee"] = "El encargado debe ocupar el cargo del primer paso del flujo.";
            }
            var hasAutoTitle = SelectedSub?.TituloAuto is { Length: > 0 };
            if (string.IsNullOrWhiteSpace(_title) && !hasAutoTitle) { _errors["title"] = "El titulo es obligatorio (o elige un concepto con titulo automatico)."; }
            else if (_title.Trim().Length > 200) { _errors["title"] = "El titulo no puede superar 200 caracteres."; }
            if (_dueDate is not null && _dueDate.Value.Date < DateTime.Now.Date) { _errors["due"] = "La fecha de entrega no puede estar en el pasado."; }
        }
        else if (step == 2)
        {
            if (!string.IsNullOrWhiteSpace(_requesterEmail) && !TaskUi.IsValidEmail(_requesterEmail)) { _errors["email"] = "El email no tiene un formato valido."; }
            if (!string.IsNullOrWhiteSpace(_ccInput)) { _errors["cc"] = "Presiona Enter para agregar el correo CC (o borra el texto)."; }
        }
        return _errors.Count == 0;
    }

    private async Task SaveAsync(bool keepOpen)
    {
        if (!ValidateStep(1)) { _step = 1; return; }
        if (!ValidateStep(2)) { _step = 2; return; }
        _busy = true;
        try
        {
            var result = await CreateTaskCoreAsync();
            if (!result.IsOk)
            {
                _errors["create"] = result.Error ?? "No se pudo crear la actividad.";
                return;
            }
            await OnCreated.InvokeAsync(result.Value!);

            if (keepOpen)
            {
                // "Guardar y crear otra": conserva la clasificacion, limpia el resto.
                ClearDraft();
                _allTags = (await TasksSvc.ListTagsAsync()).ToList();
            }
            else
            {
                _visible = false;
            }
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>Resuelve/crea las etiquetas por nombre y devuelve sus ids.</summary>
    private async Task<List<Guid>> ResolveTagIdsAsync()
    {
        var ids = new List<Guid>();
        foreach (var tag in _tags)
        {
            if (tag.Id != Guid.Empty) { ids.Add(tag.Id); continue; }
            var existing = _allTags.FirstOrDefault(t => string.Equals(t.Name, tag.Name, StringComparison.OrdinalIgnoreCase));
            if (existing is not null) { ids.Add(existing.Id); continue; }
            var created = await TasksSvc.CreateTagAsync(tag.Name, null);
            if (created.IsOk) { ids.Add(created.Value!.Id); _allTags.Add(created.Value); }
        }
        return ids;
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private async Task<string> ActorNameAsync()
    {
        if (AuthState is null) { return "Usuario"; }
        var st = await AuthState;
        return st.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Usuario";
    }

    private async Task<Guid?> TenantIdAsync()
    {
        if (AuthState is null) { return null; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst("tenant_id")?.Value, out var id) ? id : null;
    }

    private static string PrioColor(TaskPriority p) => p switch
    {
        TaskPriority.High => "var(--t-red, #dc2626)",
        TaskPriority.Low => "var(--t-green, #0f7a58)",
        _ => "var(--t-amber, #b45309)"
    };
    private static string PrioSoft(TaskPriority p) => p switch
    {
        TaskPriority.High => "var(--t-red-bg, rgba(220,38,38,.12))",
        TaskPriority.Low => "var(--t-green-bg, rgba(20,160,120,.14))",
        _ => "var(--t-amber-bg, rgba(245,158,11,.14))"
    };
}
