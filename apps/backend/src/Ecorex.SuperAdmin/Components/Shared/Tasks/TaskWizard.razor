@using Ecorex.Application.Tenancy
@using Ecorex.Application.Actividades
@using Ecorex.Application.Entidades
@using Ecorex.Application.Forms
@using Ecorex.Application.Workflows
@using Ecorex.Domain.Enums
@using Ecorex.SuperAdmin.Components.Shared.Forms
@inject ITaskItemService TasksSvc
@inject IEntidadService EntidadSvc
@inject IActividadCatalogoService CatalogoSvc
@inject ITenantUserService TenantUsersSvc
@inject IProjectService ProjectsSvc
@inject IWorkflowStartService StartSvc
@inject ITaskBroadcaster Broadcaster

@* ===== Wizard "Nueva actividad" (Ola 3): 4 pasos, milimetrico al prototipo ECOREX.dc.html =====
   Clasifica por CONCEPTO (Empresa/Area -> Tipo/categoria -> Actividad/subcategoria -> Encargado). *@
@if (_visible)
{
    <div class="tk-wizard" style="position:fixed;inset:0;z-index:1060;background:rgba(15,15,18,.5);backdrop-filter:blur(5px);display:flex;align-items:center;justify-content:center;padding:3vh 2vw" @onclick="Close">
        <div style="width:min(1100px,97vw);height:90vh;background:var(--surface);border:1px solid var(--line-2);border-radius:20px;box-shadow:var(--sh-lg);overflow:hidden;display:flex;flex-direction:column" @onclick:stopPropagation="true">
            @* header *@
            <div style="display:flex;align-items:center;gap:14px;padding:18px 26px;border-bottom:1px solid var(--line);flex:none">
                <div style="width:38px;height:38px;flex:none;border-radius:11px;background:var(--brand);display:grid;place-items:center;color:var(--on-brand)">
                    <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="13" rx="2"></rect><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                </div>
                <div style="flex:1;min-width:0">
                    <div style="font-size:11px;color:var(--ink-3);font-weight:600;letter-spacing:.03em">ECOREX &#183; Actividades</div>
                    <div style="font-weight:800;font-size:16px;letter-spacing:-.01em">Nueva actividad</div>
                </div>
                <button @onclick="Close" style="width:34px;height:34px;flex:none;border-radius:9px;border:1px solid var(--line);background:var(--surface);display:grid;place-items:center;cursor:pointer;color:var(--ink-2)">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
                </button>
            </div>

            @* body: left column + summary aside *@
            <div class="tk-wz-body" style="flex:1;display:flex;min-height:0">
                <div style="flex:1;display:flex;flex-direction:column;min-width:0;border-right:1px solid var(--line)">
                    @* steps nav *@
                    <div style="display:flex;align-items:center;gap:8px;padding:16px 26px;border-bottom:1px solid var(--line);flex:none;flex-wrap:wrap">
                        @for (var i = 0; i < Steps.Length; i++)
                        {
                            var n = i + 1;
                            var isOn = _step == n;
                            var isDone = _step > n;
                            <div style="display:flex;align-items:center;gap:9px;cursor:pointer" @onclick="@(() => GoStep(n))">
                                <span style="width:24px;height:24px;border-radius:50%;display:grid;place-items:center;font-size:12px;font-weight:700;@(isOn ? "background:var(--brand);color:var(--on-brand)" : isDone ? "background:var(--brand-soft);color:var(--brand)" : "background:var(--surface-3);color:var(--ink-3)")">
                                    @(isDone ? (MarkupString)"&#10003;" : (MarkupString)n.ToString())
                                </span>
                                <span style="font-size:13px;@(isOn ? "color:var(--ink);font-weight:700" : "color:var(--ink-3);font-weight:600")">@Steps[i]</span>
                            </div>
                            @if (i < Steps.Length - 1)
                            {
                                <span style="width:22px;height:1px;background:var(--line-2)"></span>
                            }
                        }
                    </div>

                    @* body *@
                    <div style="flex:1;overflow-y:auto;padding:16px;background:var(--surface-2)">
                        @if (_step == 1)
                        {
                            <div style="display:flex;flex-direction:column;gap:16px;width:100%">
                                @* Ola C1 (decision D3): el concepto tiene flujo, pero no es utilizable. La
                                   hoja igual se ofrece en el menu; aqui se AVISA. Se ataca el silencio, no
                                   la visibilidad. Cubre tres casos que dan un arranque roto o degradado. *@
                                @if (ProcesoAviso is { Length: > 0 } aviso)
                                {
                                    <div style="background:var(--t-amber-bg, rgba(245,158,11,.12));border:1px solid var(--t-amber, #f59e0b);border-radius:12px;padding:12px 14px;font-size:12.5px;color:var(--ink-2);display:flex;align-items:flex-start;gap:10px">
                                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--t-amber, #f59e0b)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex:none;margin-top:1px"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"></path><path d="M12 9v4M12 17h.01"></path></svg>
                                        <span>@((MarkupString)aviso)</span>
                                    </div>
                                }
                                @* Clasificacion y asignacion *@
                                <div style="@CardStyle">
                                    <div style="display:flex;align-items:center;gap:11px;margin-bottom:4px">
                                        <span style="width:30px;height:30px;border-radius:9px;background:var(--t-blue-bg, rgba(59,130,246,.14));color:var(--t-blue);display:grid;place-items:center"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="13" rx="2"></rect><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg></span>
                                        <div style="font-weight:700;font-size:15px">Clasificacion y asignacion</div>
                                    </div>
                                    <p style="font-size:12.5px;color:var(--ink-3);margin:0 0 16px 41px">Define a que proceso pertenece la actividad, quien la atiende y para cuando.</p>
                                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:12px">
                                        <div>
                                            <label style="@LblStyle">Empresa / Area</label>
                                            <select style="@SelStyle" value="@(_entidadId?.ToString() ?? "")" @onchange="OnEntidadChanged">
                                                <option value="">Selecciona la Empresa/Area</option>
                                                @foreach (var e in _entidades) { <option value="@e.Id">@e.Label</option> }
                                            </select>
                                        </div>
                                        <div>
                                            <label style="@LblStyle">Proceso / Tipo</label>
                                            <select style="@SelStyle" value="@(_categoriaId?.ToString() ?? "")" @onchange="OnCategoriaChanged">
                                                <option value="">Selecciona Tipo</option>
                                                @foreach (var c in _categorias) { <option value="@c.Id">@c.Nombre</option> }
                                            </select>
                                        </div>
                                        <div>
                                            <label style="@LblStyle">Actividad</label>
                                            <select style="@SelStyle" value="@(_subcategoriaId?.ToString() ?? "")" @onchange="OnSubcategoriaChanged" disabled="@(_categoriaId is null)">
                                                <option value="">Selecciona Actividad</option>
                                                @foreach (var s in _subcategorias) { <option value="@s.Id">@s.Nombre</option> }
                                            </select>
                                            @if (_errors.TryGetValue("sub", out var subErr)) { <div style="@ErrStyle">@subErr</div> }
                                        </div>
                                    </div>
                                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                                        <div>
                                            <label style="@LblStyle">
                                                Encargado
                                                @if (PasoLabel is { Length: > 0 } paso)
                                                {
                                                    @* El encargado no lo elige el usuario: lo dicta el flujo (D2). *@
                                                    <span style="margin-left:7px;font-size:10px;font-weight:700;letter-spacing:.02em;padding:2px 7px;border-radius:6px;background:var(--t-violet-bg, rgba(124,92,255,.14));color:var(--t-violet, #7c5cff)">@paso</span>
                                                }
                                            </label>
                                            <select style="@SelStyle" value="@(_assigneeId?.ToString() ?? "")" @onchange="@(e => _assigneeId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null)" disabled="@(_encargadoRestringido && !EncargadoOptions.Any())">
                                                <option value="">Selecciona Encargado</option>
                                                @foreach (var u in EncargadoOptions) { <option value="@u.Id">@TaskUi.UserLabel(u)</option> }
                                            </select>
                                            @if (_errors.TryGetValue("assignee", out var asgErr)) { <div style="@ErrStyle">@asgErr</div> }
                                            else if (_firstStep?.Status == FirstStepStatus.SinCandidatos)
                                            {
                                                <div style="@ErrStyle">El cargo "@_firstStep.CargoPrincipal" del primer paso no tiene ocupantes. Asignalo en Dependencias.</div>
                                            }
                                            else if (_encargadoRestringido)
                                            {
                                                <div style="font-size:11.5px;color:var(--ink-3);margin-top:5px">Lo dicta el flujo: solo el cargo "@_firstStep!.CargoPrincipal" atiende este paso.</div>
                                            }
                                        </div>
                                        <div>
                                            <label style="@LblStyle">Fecha de entrega</label>
                                            <input type="date" style="@InStyle" @bind="_dueDate" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                            @if (_errors.TryGetValue("due", out var dueErr)) { <div style="@ErrStyle">@dueErr</div> }
                                        </div>
                                    </div>
                                </div>

                                @* Descripcion *@
                                <div style="@CardStyle">
                                    <div style="display:flex;align-items:center;gap:11px;margin-bottom:4px">
                                        <span style="width:30px;height:30px;border-radius:9px;background:var(--t-violet-bg, rgba(124,92,255,.14));color:var(--t-violet);display:grid;place-items:center"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"></path></svg></span>
                                        <div style="font-weight:700;font-size:15px">Descripcion de la actividad</div>
                                    </div>
                                    <p style="font-size:12.5px;color:var(--ink-3);margin:0 0 16px 41px">Detalla que se va a hacer y el contexto necesario para ejecutarla.</p>
                                    <input placeholder="@TitlePlaceholder" style="@InStyle;margin-bottom:12px" @bind="_title" @bind:event="oninput" maxlength="200" autocomplete="off" />
                                    @if (_errors.TryGetValue("title", out var titleErr)) { <div style="@ErrStyle;margin:-6px 0 10px">@titleErr</div> }
                                    <textarea placeholder="Descripcion / detalle" style="width:100%;min-height:96px;padding:12px 13px;border:1px solid var(--line-2);border-radius:10px;background:var(--surface-2);font:inherit;font-size:13.5px;color:var(--ink);resize:vertical;outline:none" @bind="_description"></textarea>
                                </div>

                                @* Prioridad + Etiquetas *@
                                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                                    <div style="@CardStyle">
                                        <div style="display:flex;align-items:center;gap:11px;margin-bottom:4px">
                                            <span style="width:30px;height:30px;border-radius:9px;background:var(--t-amber-bg, rgba(245,158,11,.14));color:var(--t-amber);display:grid;place-items:center"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1Z"></path><path d="M4 22v-7"></path></svg></span>
                                            <div style="font-weight:700;font-size:15px">Prioridad</div>
                                        </div>
                                        <p style="font-size:12.5px;color:var(--ink-3);margin:0 0 16px 41px">Que tan urgente es?</p>
                                        <div style="display:flex;gap:10px;flex-wrap:wrap">
                                            @foreach (var p in new[] { TaskPriority.High, TaskPriority.Medium, TaskPriority.Low })
                                            {
                                                var on = _priority == p;
                                                <button type="button" @onclick="@(() => _priority = p)" style="height:34px;padding:0 15px;border-radius:9px;font:inherit;font-weight:600;font-size:13px;cursor:pointer;@(on ? $"border:1px solid {PrioColor(p)};background:{PrioSoft(p)};color:{PrioColor(p)}" : "border:1px solid var(--line-2);background:var(--surface-2);color:var(--ink-2)")">@TaskUi.PriorityLabel(p)</button>
                                            }
                                        </div>
                                    </div>
                                    <div style="@CardStyle">
                                        <div style="display:flex;align-items:center;gap:11px;margin-bottom:4px">
                                            <span style="width:30px;height:30px;border-radius:9px;background:var(--t-green-bg, rgba(20,160,120,.14));color:var(--t-green);display:grid;place-items:center"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v5l9 9 7-7-9-9H3Z"></path><circle cx="7.5" cy="7.5" r="1.3"></circle></svg></span>
                                            <div style="font-weight:700;font-size:15px">Etiquetas</div>
                                        </div>
                                        <p style="font-size:12.5px;color:var(--ink-3);margin:0 0 14px 41px">Enter para agregar.</p>
                                        <div style="display:flex;flex-wrap:wrap;gap:7px;align-items:center">
                                            @foreach (var t in _tags)
                                            {
                                                <span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;padding:4px 8px 4px 11px;border-radius:8px;background:var(--brand-soft);color:var(--brand)">#@t.Name<span style="cursor:pointer;font-weight:700" @onclick="@(() => _tags.Remove(t))">&times;</span></span>
                                            }
                                            <input @bind="_tagInput" @bind:event="oninput" @onkeydown="OnAddTag" placeholder="etiqueta..." style="flex:1;min-width:100px;height:34px;padding:0 11px;border:1px solid var(--line-2);border-radius:9px;background:var(--surface-2);font:inherit;font-size:13px;color:var(--ink);outline:none" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else if (_step == 2)
                        {
                            <div style="display:flex;flex-direction:column;gap:16px;width:100%">
                                <div style="@CardStyle">
                                    <div style="font-weight:700;font-size:15px;margin-bottom:16px">Informacion del contacto</div>
                                    <input placeholder="Nombre completo del solicitante" style="@InStyle;margin-bottom:12px" @bind="_requesterName" />
                                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px">
                                        <input placeholder="Identificacion" style="@InStyle" @bind="_requesterDoc" />
                                        <input placeholder="Email" style="@InStyle" @bind="_requesterEmail" @bind:event="oninput" />
                                    </div>
                                    @if (_errors.TryGetValue("email", out var emailErr)) { <div style="@ErrStyle;margin:-6px 0 10px">@emailErr</div> }
                                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px">
                                        <input placeholder="Telefono" style="@InStyle" @bind="_requesterPhone" />
                                        <input placeholder="Numero de actividad (se asigna al crear)" style="@InStyle;opacity:.7" disabled />
                                    </div>
                                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                                        <select style="@SelStyle" value="@(_projectId?.ToString() ?? "")" @onchange="OnProjectChanged" disabled="@(_presetProjectId is not null)">
                                            <option value="">Proyecto...</option>
                                            @foreach (var p in _projects) { <option value="@p.Id">@p.Code - @p.Name</option> }
                                        </select>
                                        <select style="@SelStyle" value="@(_milestoneId?.ToString() ?? "")"
                                                @onchange="@(e => _milestoneId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null)"
                                                disabled="@(_projectId is null || _milestones.Count == 0)">
                                            <option value="">@(_projectId is null ? "Hito del proyecto..." : _milestones.Count == 0 ? "Sin hitos" : "Hito del proyecto...")</option>
                                            @foreach (var m in _milestones) { <option value="@m.Id">@m.Name</option> }
                                        </select>
                                    </div>
                                </div>
                                <div style="@CardStyle">
                                    <div style="font-weight:700;font-size:15px;margin-bottom:14px">Copiar a correos</div>
                                    <div style="display:flex;flex-wrap:wrap;gap:7px;align-items:center">
                                        @foreach (var cc in _ccEmails)
                                        {
                                            <span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;padding:4px 8px 4px 11px;border-radius:8px;background:var(--surface-3);color:var(--ink-2)">@cc<span style="cursor:pointer;font-weight:700" @onclick="@(() => _ccEmails.Remove(cc))">&times;</span></span>
                                        }
                                        <input @bind="_ccInput" @bind:event="oninput" @onkeydown="OnAddCc" placeholder="correo@@ejemplo.com y Enter" style="flex:1;min-width:160px;height:34px;padding:0 11px;border:1px solid var(--line-2);border-radius:9px;background:var(--surface-2);font:inherit;font-size:13px;color:var(--ink);outline:none" />
                                    </div>
                                    @if (_errors.TryGetValue("cc", out var ccErr)) { <div style="@ErrStyle">@ccErr</div> }
                                </div>
                            </div>
                        }
                        else if (_step == 3)
                        {
                            @* Ola B2: el wizard YA NO crea la tarea aqui. El arranque form-first (concepto
                               marcado "inicia modulo") lo atiende FormFirstStarter (Ola B1), que abre el
                               formulario DIRECTO y crea la actividad recien al validarlo. Aqui el formulario
                               es solo informativo: se diligencia desde el detalle de la tarea (ADR-0038). *@
                            <div style="width:100%">
                                @if (HasForm)
                                {
                                    <div style="@CardStyle">
                                        <div style="font-weight:700;font-size:15px;margin-bottom:6px">Formulario dinamico</div>
                                        <p style="font-size:12.5px;color:var(--ink-3);margin-bottom:16px">Esta actividad tiene un formulario asociado: se diligencia desde el detalle de la actividad, una vez creada.</p>
                                        <div style="display:flex;align-items:center;gap:10px;padding:14px 16px;border:1px dashed var(--line-2);border-radius:12px;color:var(--ink-2);font-size:13px">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2.5"></rect><path d="M9 8h6M9 12h6M9 16h3"></path></svg>
                                            Formulario del proceso disponible.
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div style="text-align:center;padding:60px 24px;color:var(--ink-3)">
                                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 14px;display:block;opacity:.5"><rect x="5" y="3" width="14" height="18" rx="2.5"></rect><path d="M9 8h6M9 12h6M9 16h3"></path></svg>
                                        <div style="font-size:14px">Esta actividad no tiene formulario asociado.</div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div style="width:100%">
                                <div style="@CardStyle">
                                    <div style="font-weight:700;font-size:15px;margin-bottom:14px">Archivos adjuntos</div>
                                    <p style="font-size:12.5px;color:var(--ink-3);margin-bottom:14px">Podras adjuntar archivos desde el detalle una vez creada la actividad.</p>
                                    <div style="border:2px dashed var(--line-2);border-radius:14px;padding:40px 24px;text-align:center;color:var(--ink-3)">
                                        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 12px;display:block"><path d="M12 16V4M5 11l7-7 7 7M5 20h14"></path></svg>
                                        <div style="font-size:14px;font-weight:600">Arrastra tus archivos aqui o haz clic para elegir</div>
                                        <div style="font-size:12px;margin-top:4px">PDF, imagenes, hojas de calculo</div>
                                    </div>
                                </div>
                            </div>
                        }
                        @if (_errors.TryGetValue("create", out var createErr)) { <div style="@ErrStyle;margin-top:12px">@createErr</div> }
                    </div>

                    @* footer -- Ola B2: un solo camino. La tarea se crea SOLO al pulsar "Guardar
                       actividad" (o "Guardar y crear otra"); ningun paso la crea por adelantado. *@
                    <div style="display:flex;align-items:center;gap:10px;padding:16px 26px;border-top:1px solid var(--line);flex:none">
                        @if (_step > 1)
                        {
                            <button @onclick="@(() => _step--)" disabled="@_busy" style="height:40px;padding:0 15px;border-radius:11px;border:1px solid var(--line-2);background:var(--surface);font:inherit;font-weight:600;font-size:13.5px;color:var(--ink-2);cursor:pointer">&larr; Atras</button>
                        }
                        <button @onclick="ClearDraft" disabled="@_busy" style="height:40px;padding:0 15px;border-radius:11px;border:none;background:none;font:inherit;font-weight:600;font-size:13.5px;color:var(--ink-3);cursor:pointer">Limpiar</button>
                        <div style="flex:1"></div>
                        <button @onclick="@(() => SaveAsync(keepOpen: true))" disabled="@_busy" style="height:40px;padding:0 16px;border-radius:11px;border:1px solid var(--line-2);background:var(--surface);font:inherit;font-weight:600;font-size:13.5px;color:var(--ink-2);cursor:pointer">Guardar y crear otra</button>
                        @if (_step >= Steps.Length)
                        {
                            <button @onclick="@(() => SaveAsync(keepOpen: false))" disabled="@_busy" style="height:40px;padding:0 20px;border-radius:11px;border:none;background:var(--brand);color:var(--on-brand);font:inherit;font-weight:600;font-size:13.5px;cursor:pointer">@(_busy ? "Guardando..." : "Guardar actividad")</button>
                        }
                        else
                        {
                            <button @onclick="NextStep" disabled="@_busy" style="height:40px;padding:0 20px;border-radius:11px;border:none;background:var(--brand);color:var(--on-brand);font:inherit;font-weight:600;font-size:13.5px;cursor:pointer">@(_busy ? "..." : "Siguiente →")</button>
                        }
                    </div>
                </div>

                @* summary aside *@
                <aside class="tk-wz-aside" style="width:280px;flex:none;background:var(--surface-2);overflow-y:auto;padding:20px 22px;display:flex;flex-direction:column;gap:18px">
                    <div style="display:flex;align-items:center;justify-content:space-between">
                        <span style="display:inline-flex;align-items:center;gap:7px;font-size:11.5px;font-weight:600;padding:4px 11px;border-radius:8px;background:var(--t-amber-bg, rgba(245,158,11,.14));color:var(--t-amber)"><span style="width:7px;height:7px;border-radius:50%;background:var(--t-amber)"></span>Borrador</span>
                        <span style="font-size:11.5px;color:var(--ink-3)">Sin guardar</span>
                    </div>
                    <div>
