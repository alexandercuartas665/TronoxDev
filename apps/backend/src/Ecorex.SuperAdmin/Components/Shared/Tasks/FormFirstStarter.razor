@using Ecorex.Application.Tenancy
@using Ecorex.Application.Actividades
@using Ecorex.Application.Forms
@using Ecorex.Application.Workflows
@using Ecorex.Domain.Enums
@using Ecorex.SuperAdmin.Components.Shared.Forms
@inject ITaskItemService TasksSvc
@inject IActividadCatalogoService CatalogoSvc
@inject ITenantUserService TenantUsersSvc
@inject IFormDefinitionService FormDefsSvc
@inject IFormResponseService FormResponsesSvc
@inject IWorkflowStartService StartSvc
@inject ITaskBroadcaster Broadcaster

@* ===== Arranque FORM-FIRST (Ola B1) =====
   Cuando el concepto esta marcado "Inicia modulo al crear la tarea" (IniciaModulo + FormDefinitionId),
   la actividad NO arranca por el wizard de 4 pasos: arranca por el FORMULARIO.

   Orden correcto (y esto es lo que cambia respecto de la Ola 5): el formulario se diligencia PRIMERO,
   el servidor lo valida, y SOLO ENTONCES nace la actividad. Antes la tarea se creaba al entrar al paso
   3 del wizard, asi que un formulario invalido dejaba una tarea huerfana (y su flujo arrancado). *@

@if (_visible)
{
    <div class="tk-formfirst" style="position:fixed;inset:0;z-index:1060;background:rgba(15,15,18,.5);backdrop-filter:blur(5px);display:flex;align-items:center;justify-content:center;padding:3vh 2vw" @onclick="Close">
        <div style="width:min(880px,96vw);max-height:92vh;background:var(--surface);border:1px solid var(--line-2);border-radius:20px;box-shadow:var(--sh-lg);overflow:hidden;display:flex;flex-direction:column" @onclick:stopPropagation="true">

            @* header *@
            <div style="display:flex;align-items:center;gap:14px;padding:18px 22px;border-bottom:1px solid var(--line)">
                <span style="width:38px;height:38px;border-radius:12px;background:var(--ink);color:var(--surface);display:grid;place-items:center;flex:none">
                    <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"></path><path d="M14 2v6h6"></path><path d="M9 13h6M9 17h4"></path></svg>
                </span>
                <div style="flex:1;min-width:0">
                    <div style="font-size:11px;font-weight:600;letter-spacing:.05em;color:var(--ink-3)">ECOREX &middot; NUEVA ACTIVIDAD</div>
                    <div style="font-size:17px;font-weight:800;letter-spacing:-.01em">@(_sub?.Nombre ?? "Proceso")</div>
                </div>
                <button @onclick="Close" disabled="@_busy" style="width:34px;height:34px;border-radius:10px;border:1px solid var(--line-2);background:var(--surface);color:var(--ink-2);cursor:pointer;display:grid;place-items:center;flex:none">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
                </button>
            </div>

            @* cuerpo *@
            <div style="flex:1;overflow-y:auto;padding:20px 22px;background:var(--surface-2)">

                @if (_createdNumber is not null)
                {
                    @* Exito: la actividad nacio DESPUES de validar el formulario. *@
                    <div style="background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:26px 22px;text-align:center">
                        <div style="width:46px;height:46px;border-radius:14px;margin:0 auto 12px;background:var(--t-green-bg, rgba(34,197,94,.14));color:var(--t-green, #16a34a);display:grid;place-items:center">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                        </div>
                        <div style="font-size:17px;font-weight:800;margin-bottom:5px">Actividad @_createdNumber creada</div>
                        <p style="font-size:13px;color:var(--ink-3);margin:0 0 4px">El formulario quedo enviado y enlazado a la actividad.</p>
                        @if (_firstStep is { Status: FirstStepStatus.Ok })
                        {
                            <p style="font-size:13px;color:var(--ink-3);margin:0">El proceso arranco: el paso <strong>@_firstStep.NodeName</strong> quedo en manos de <strong>@_assigneeLabel</strong>.</p>
                        }
                    </div>
                }
                else
                {
                    @* Resumen de lo que el sistema ya resolvio SOLO: el usuario no vuelve a elegirlo. *@
                    <div style="background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:14px 16px;margin-bottom:16px;display:flex;flex-wrap:wrap;gap:18px;align-items:center">
                        <div>
                            <div style="font-size:10.5px;font-weight:600;letter-spacing:.05em;color:var(--ink-3)">TABLERO</div>
                            <div style="font-size:13px;font-weight:600">@(_sub?.TaskBoardId is null ? "Sin tablero" : "Del concepto")</div>
                        </div>
                        @if (_firstStep is { Status: FirstStepStatus.Ok or FirstStepStatus.SinCandidatos })
                        {
                            <div>
                                <div style="font-size:10.5px;font-weight:600;letter-spacing:.05em;color:var(--ink-3)">PRIMER PASO</div>
                                <div style="font-size:13px;font-weight:600">@_firstStep.NodeName <span style="font-weight:500;color:var(--ink-3)">&middot; @_firstStep.CargoPrincipal</span></div>
                            </div>
                            <div>
                                <div style="font-size:10.5px;font-weight:600;letter-spacing:.05em;color:var(--ink-3)">ENCARGADO</div>
                                <div style="font-size:13px;font-weight:600;@(_assigneeId is null ? "color:var(--ink-3)" : "")">@(_assigneeLabel ?? "Sin ocupantes del cargo")</div>
                            </div>
                        }
                    </div>

                    @if (_firstStep is { Status: FirstStepStatus.FlujoNoPublicado })
                    {
                        @* Decision D3: se avisa, no se oculta. *@
                        <div style="background:var(--t-amber-bg, rgba(245,158,11,.12));border:1px solid var(--t-amber, #f59e0b);border-radius:12px;padding:12px 14px;margin-bottom:16px;font-size:12.5px;color:var(--ink-2)">
                            El flujo de este proceso <strong>aun no esta publicado</strong>. La actividad se creara <strong>sin proceso</strong>.
                        </div>
                    }

                    @if (_error is { Length: > 0 })
                    {
                        <div style="background:var(--t-red-bg, rgba(220,38,38,.1));border:1px solid var(--t-red, #dc2626);border-radius:12px;padding:12px 14px;margin-bottom:16px;font-size:12.5px;color:var(--t-red, #dc2626)">@_error</div>
                    }

                    @if (_definitionId is Guid defId)
                    {
                        <div style="background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:20px 22px">
                            <DynamicFormRenderer DefinitionId="@defId"
                                                 Mode="FormRenderMode.Fill"
                                                 ShowHeader="true"
                                                 OnSubmitted="OnFormSubmittedAsync" />
                        </div>
                        <p style="font-size:11.5px;color:var(--ink-3);margin:12px 2px 0">
                            La actividad se creara <strong>al enviar</strong> el formulario. Si algun campo no valida, no se crea nada.
                        </p>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    /// <summary>Se emite cuando la actividad nacio (tras validar el formulario).</summary>
    [Parameter] public EventCallback<TaskItemDetailDto> OnCreated { get; set; }

    private bool _visible;
    private bool _busy;
    private string? _error;

    private ActividadSubcategoriaDto? _sub;
    private Guid? _definitionId;
    private FirstStepDto? _firstStep;
    private Guid? _assigneeId;
    private string? _assigneeLabel;
    private string? _createdNumber;

    /// <summary>
    /// Intenta abrir el arranque form-first del concepto.
    /// Devuelve <c>false</c> si el concepto NO es form-first o si su formulario no es utilizable
    /// (inexistente / inactivo / archivado): en ese caso el llamador debe caer al wizard normal
    /// (escape hatch). Nunca revienta por configuracion incompleta.
    /// </summary>
    public async Task<bool> TryOpenAsync(Guid subcategoriaId)
    {
        Reset();

        var sub = await CatalogoSvc.GetSubcategoriaAsync(subcategoriaId);
        if (sub is null || !sub.IniciaModulo || sub.FormDefinitionId is not Guid defId)
        {
            return false; // no es form-first -> wizard
        }

        var def = await FormDefsSvc.GetAsync(defId);
        if (def is null || def.Status != FormStatus.Active || def.IsArchived)
        {
            return false; // el formulario no sirve -> wizard, con lo que el usuario igual puede crear
        }

        _sub = sub;
        _definitionId = defId;

        // El encargado lo dicta el flujo (Olas A1/A2/D2), igual que en el wizard.
        _firstStep = await StartSvc.ResolveFirstStepAsync(subcategoriaId);
        if (_firstStep.TieneCandidatoUnico)
        {
            _assigneeId = _firstStep.CandidateUserIds[0];
            _assigneeLabel = await ResolveUserLabelAsync(_assigneeId.Value);
        }

        _visible = true;
        StateHasChanged();
        return true;
    }

    /// <summary>
    /// El formulario se envio y el servidor lo VALIDO. Recien ahora nace la actividad (con su flujo
    /// y su primer paso ya asignado, Ola A3) y se ancla la respuesta a su numero.
    /// </summary>
    private async Task OnFormSubmittedAsync(FormResponseDto response)
    {
        if (_busy || _sub is null) { return; }
        _busy = true;
        _error = null;

        try
        {
            var actor = await ActorAsync();
            var actorName = await ActorNameAsync();

            // Titulo/detalle salen del CONCEPTO (TituloAuto/DetalleAuto): en form-first el usuario no
            // los escribe. El tablero/columna tambien los deriva el servicio desde la subcategoria.
            var result = await TasksSvc.CreateAsync(
                new CreateTaskItemRequest(
                    Title: "",
                    ActivityTypeId: null,
                    AssigneeTenantUserId: _assigneeId,
                    SubcategoriaId: _sub.Id),
                actor, actorName);

            if (!result.IsOk || result.Value is null)
            {
                _error = result.Error ?? "No se pudo crear la actividad.";
                return;
            }

            var detail = result.Value;
            _createdNumber = detail.Item.Number;

            // Ancla la respuesta (ya enviada) al numero de la actividad recien nacida.
            await FormResponsesSvc.SetReferenceAsync(response.Id, detail.Item.Number);

            if (await TenantIdAsync() is Guid tenantId)
            {
                await Broadcaster.TaskChangedAsync(tenantId, detail.Item.Id, detail.Item.Status);
            }

            await OnCreated.InvokeAsync(detail);
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private void Close()
    {
        if (_busy) { return; }
        _visible = false;
    }

    private void Reset()
    {
        _visible = false; _busy = false; _error = null;
        _sub = null; _definitionId = null; _firstStep = null;
        _assigneeId = null; _assigneeLabel = null; _createdNumber = null;
    }

    private async Task<string?> ResolveUserLabelAsync(Guid tenantUserId)
    {
        var user = (await TenantUsersSvc.ListAsync()).FirstOrDefault(u => u.Id == tenantUserId);
        return user is null ? null : TaskUi.UserLabel(user);
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private async Task<string> ActorNameAsync()
    {
        if (AuthState is null) { return "Usuario"; }
        var st = await AuthState;
        return st.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Usuario";
    }

    private async Task<Guid?> TenantIdAsync()
    {
        if (AuthState is null) { return null; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst("tenant_id")?.Value, out var id) ? id : null;
    }
}
