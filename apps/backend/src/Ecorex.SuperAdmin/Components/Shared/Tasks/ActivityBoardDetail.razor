@* Mis Procesos (?sub=): el WIZARD grande "Crear actividad" precargado con el concepto (ADR-0038). *@
<TaskWizard @ref="_wizard" OnCreated="OnWizardCreatedAsync" />

@* Ola B1: si el concepto es FORM-FIRST (IniciaModulo), la actividad arranca por el FORMULARIO,
   no por el wizard. Si el formulario no sirve, TryOpenAsync devuelve false y se cae al wizard. *@
<FormFirstStarter @ref="_formFirst" OnCreated="OnWizardCreatedAsync" />

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    [Parameter] public Guid BoardId { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    /// <summary>Concepto preseleccionado al llegar desde "Mis Procesos" (?sub=): incluye el concepto
    /// (aunque sea de proceso) en el modal rapido y lo AUTO-ABRE precargado al aterrizar (paso corto).</summary>
    [Parameter] public Guid? PresetSubcategoriaId { get; set; }

    private ActivityBoardDetailDto? _detail;
    private List<ActivityBoardMemberDto> _members = new();
    private List<TaskItemTagDto> _boardTags = new();
    private List<TenantUserDto> _users = new();
    private List<TaskItemTagDto> _tags = new();
    private List<ActivityTypeDto> _types = new();
    private List<ActividadSubcategoriaDto> _freeSubs = new();
    private Guid? _meTenantUserId;
    private Guid _loadedBoardId;

    // Filtros combinables (chips del prototipo).
    private readonly HashSet<Guid> _fColumns = new();
    private readonly HashSet<Guid> _fUsers = new();
    private string? _fDue; // "hoy" | "manana" | "fecha"
    private DateTime? _fDueOn;
    private readonly HashSet<Guid> _fTags = new();
    private ActivityBoardScope _scope = ActivityBoardScope.Team;
    private bool _filtersVisible = true;
    private string _view = "tablero";

    // Drag and drop nativo HTML5 (mismo patron del kanban por estado).
    private Guid? _dragTaskId;
    private Guid? _dragOverColumnId;

    // Menus "..." de columna y de tarjeta (popovers estilo ab-dd del fuente).
    private Guid? _colMenuId;
    private Guid? _cardMenuId;
    private bool _cardMoveOpen;
    private bool _cardArchiveConfirm;

    // Renombrar / marcar final / agregar columna (delega en ITaskBoardService existente).
    private bool _rcOpen;
    private Guid _rcColumnId;
    private string _rcName = "";
    private string? _rcColor;
    private bool _rcIsDone;
    private bool _acOpen;
    private string _acName = "";
    private bool _acIsDone;

    // Vistas Calendario (mes navegable) y Gantt (ventana de 14 dias navegable).
    private DateTime _calMonth = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _ganttStart = DefaultGanttStart();
    private static readonly string[] CalWeekdays = ["Lun", "Mar", "Mie", "Jue", "Vie", "Sab", "Dom"];

    /// <summary>
    /// Ventana inicial del gantt: el bloque de 14 dias del mes actual que CONTIENE a hoy
    /// (dias 1-14, 15-28 o 29+), para que la linea de HOY siempre arranque visible.
    /// </summary>
    private static DateTime DefaultGanttStart()
    {
        var today = DateTime.Today;
        return new DateTime(today.Year, today.Month, 1).AddDays(14 * ((today.Day - 1) / 14));
    }

    // Creacion rapida.
    private bool _qcOpen;
    private Guid _qcColumnId;
    private string _qcTitle = "";
    private string _qcDesc = "";
    private TaskPriority _qcPriority = TaskPriority.Medium;
    private string _qcAssignee = "";
    private DateTime? _qcDue;
    private readonly HashSet<Guid> _qcTagIds = new();
    private string _qcTypeId = "";
    private string _qcSubId = "";
    private string? _qcError;

    // Editar tablero.
    private bool _ebOpen;
    private string _ebName = "";
    private string _ebDesc = "";
    private TaskBoardStatus _ebStatus = TaskBoardStatus.InProgress;
    private DateTime? _ebDue;
    private string? _ebError;

    private bool _busy;
    private TaskToasts? _toasts;
    private TaskDetailModal? _taskDetail;
    private HubConnection? _hub;
    private string? _tenantId;

    private int FilterCount =>
        _fColumns.Count + _fUsers.Count + _fTags.Count + (_fDue is null ? 0 : 1);

    // Scope EF propio + semaforo (mismo patron de TaskKanban): el reload puede
    // dispararse por el hub (TaskChanged de otra sesion o el eco propio) mientras el
    // modal de detalle tiene una consulta en vuelo sobre el DbContext del circuito;
    // sin aislamiento EF lanza "second operation on this context".
    private readonly SemaphoreSlim _reloadLock = new(1, 1);

    // Mis Procesos (?sub=): abrir el arranque precargado con el concepto.
    private TaskWizard? _wizard;
    private FormFirstStarter? _formFirst;
    private bool _openWizardPending;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Los @ref existen recien tras el primer render; aqui abrimos el arranque UNA vez.
        if (_openWizardPending && _wizard is not null && _formFirst is not null
            && PresetSubcategoriaId is Guid presetSub)
        {
            _openWizardPending = false;

            // Ola B1: los conceptos marcados "Inicia modulo al crear la tarea" arrancan por el
            // FORMULARIO, no por el wizard de 4 pasos. TryOpenAsync devuelve false si el concepto no
            // es form-first o si su formulario no es utilizable -> escape hatch al wizard de siempre.
            if (await _formFirst.TryOpenAsync(presetSub))
            {
                return;
            }

            await _wizard.OpenAsync(presetSubcategoriaId: presetSub);
        }
    }

    /// <summary>El wizard creo la actividad: refrescar el tablero para que aparezca la tarjeta.</summary>
    private async Task OnWizardCreatedAsync(TaskItemDetailDto _)
        => await ReloadAsync();

    /// <summary>Crear actividad desde el tablero: SIEMPRE el WIZARD grande (4 pasos), con este tablero y
    /// columna preseleccionados para que la actividad caiga aqui. Reemplaza al modal rapido.</summary>
    private async Task OpenWizardOnBoardAsync(Guid? columnId = null)
    {
        if (_wizard is null) { return; }
        await _wizard.OpenAsync(presetBoardId: BoardId, presetColumnId: columnId);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedBoardId == BoardId) { return; }
        _loadedBoardId = BoardId;
        _fColumns.Clear(); _fUsers.Clear(); _fTags.Clear();
        _fDue = null; _fDueOn = null;
        _scope = ActivityBoardScope.Team;
        _view = "tablero";
        _calMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        _ganttStart = DefaultGanttStart();
        CloseMenus();
        await ResolveTenantAsync();
        _users = (await TenantUsersSvc.ListAsync()).ToList();
        _tags = (await TasksSvc.ListTagsAsync()).ToList();
        _types = (await TypesSvc.ListAsync()).ToList();
        // Ola 6: actividades SIN proceso (subcategorias sin flujo) para el crear-desde-tablero rapido.
        _freeSubs = (await CatalogoSvc.ListSubcategoriasAsync(includeArchived: false))
            .Where(s => s.WorkflowDefinitionId is null)
            .OrderBy(s => s.Nombre).ToList();
        _meTenantUserId = await MeTenantUserIdAsync();
        await LoadMembersAsync();
        await ReloadAsync();
        // Mis Procesos (?sub=): al aterrizar, abrir el WIZARD grande "Crear actividad" (4 pasos, form-first)
        // precargado con el concepto -> NO el modal rapido. Se dispara en OnAfterRenderAsync, cuando el
        // @ref del wizard ya existe.
        _openWizardPending = PresetSubcategoriaId is not null;
        await EnsureHubAsync();
    }

    private async Task ResolveTenantAsync()
    {
        if (AuthState is null) { return; }
        var st = await AuthState;
        _tenantId = st.User.FindFirst("tenant_id")?.Value;
    }

    /// <summary>
    /// Miembros del tablero para los chips "Asignados": vienen del INDICE
    /// (ActivityBoardSummaryDto.Members = encargados/asignados distintos).
    /// </summary>
    private async Task LoadMembersAsync()
    {
        await _reloadLock.WaitAsync();
        try
        {
            ActivityBoardIndexDto index;
            if (Guid.TryParse(_tenantId, out var tenantGuid))
            {
                using var ambient = Ecorex.SuperAdmin.Auth.AmbientTenantContext.Begin(tenantGuid, await ActorAsync());
                await using var scope = ScopeFactory.CreateAsyncScope();
                var boardsSvc = scope.ServiceProvider.GetRequiredService<IActivityBoardService>();
                index = await boardsSvc.ListBoardsAsync(new ActivityBoardIndexFilter(IncludeArchived: true));
            }
            else
            {
                index = await BoardsSvc.ListBoardsAsync(new ActivityBoardIndexFilter(IncludeArchived: true));
            }
            _members = index.Boards.FirstOrDefault(b => b.Id == BoardId)?.Members.ToList() ?? new List<ActivityBoardMemberDto>();
        }
        finally
        {
            _reloadLock.Release();
        }
    }

    private async Task ReloadAsync()
    {
        var due = _fDue switch
        {
            "hoy" => ActivityDueFilter.Today,
            "manana" => ActivityDueFilter.Tomorrow,
            "fecha" when _fDueOn is not null => ActivityDueFilter.OnDate,
            _ => ActivityDueFilter.Any
        };
        var filter = new ActivityBoardDetailFilter(
            ColumnIds: _fColumns.Count == 0 ? null : _fColumns.ToList(),
            AssigneeTenantUserIds: _fUsers.Count == 0 ? null : _fUsers.ToList(),
            Due: due,
            DueOn: _fDueOn is DateTime d ? new DateTimeOffset(d.Date, TimeSpan.Zero) : null,
            TagIds: _fTags.Count == 0 ? null : _fTags.ToList(),
            Scope: _scope,
            CurrentTenantUserId: _meTenantUserId);
        await _reloadLock.WaitAsync();
        try
        {
            TaskCoreResult<ActivityBoardDetailDto> result;
            if (Guid.TryParse(_tenantId, out var tenantGuid))
            {
                using var ambient = Ecorex.SuperAdmin.Auth.AmbientTenantContext.Begin(tenantGuid, await ActorAsync());
                await using var scope = ScopeFactory.CreateAsyncScope();
                var boardsSvc = scope.ServiceProvider.GetRequiredService<IActivityBoardService>();
                result = await boardsSvc.GetBoardDetailAsync(BoardId, filter);
            }
            else
            {
                result = await BoardsSvc.GetBoardDetailAsync(BoardId, filter);
            }
            if (result.IsOk)
            {
                _detail = result.Value;
                // Cache de etiquetas del tablero: solo del primer load SIN filtros,
                // para que los chips no desaparezcan al filtrar.
                if (FilterCount == 0 && _scope == ActivityBoardScope.Team)
                {
                    _boardTags = _detail!.Columns.SelectMany(c => c.Cards).SelectMany(c => c.Tags)
                        .GroupBy(t => t.Id).Select(g => g.First()).OrderBy(t => t.Name).ToList();
                }
            }
        }
        finally
        {
            _reloadLock.Release();
        }
        StateHasChanged();
    }

    // ---- Toggles de filtro ----

    private async Task ToggleColumnFilterAsync(Guid columnId)
    {
        if (!_fColumns.Remove(columnId)) { _fColumns.Add(columnId); }
        await ReloadAsync();
    }

    private async Task ToggleUserFilterAsync(Guid tenantUserId)
    {
        if (!_fUsers.Remove(tenantUserId)) { _fUsers.Add(tenantUserId); }
        await ReloadAsync();
    }

    private async Task ToggleDueFilterAsync(string key)
    {
        if (_fDue == key)
        {
            _fDue = null;
            _fDueOn = null;
        }
        else
        {
            _fDue = key;
            if (key != "fecha") { _fDueOn = null; }
        }
        await ReloadAsync();
    }

    private async Task OnDueOnChangedAsync(ChangeEventArgs e)
    {
        _fDueOn = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : null;
        await ReloadAsync();
    }

    private async Task ToggleTagFilterAsync(Guid tagId)
    {
        if (!_fTags.Remove(tagId)) { _fTags.Add(tagId); }
        await ReloadAsync();
    }

    private async Task ClearFiltersAsync()
    {
        _fColumns.Clear(); _fUsers.Clear(); _fTags.Clear();
        _fDue = null; _fDueOn = null;
        await ReloadAsync();
    }

    private async Task SetScopeAsync(ActivityBoardScope scope)
    {
        _scope = scope;
        await ReloadAsync();
    }

    // ---- Helpers de tarjeta ----

    private static List<ActivityBoardMemberDto> CardPeople(ActivityCardDto card)
    {
        var people = new List<ActivityBoardMemberDto>();
        if (card.Assignee is not null) { people.Add(card.Assignee); }
        foreach (var m in card.TeamAssignees)
        {
            if (people.All(p => p.TenantUserId != m.TenantUserId)) { people.Add(m); }
        }
        return people;
    }

    private IEnumerable<(ActivityBoardColumnDto Column, int ColIdx, ActivityCardDto Card)> ListRows()
    {
        if (_detail is null) { yield break; }
        foreach (var (col, idx) in _detail.Columns.Select((c, i) => (c, i)))
        {
            foreach (var card in col.Cards)
            {
                yield return (col, idx, card);
            }
        }
    }

    private static string Truncate(string text, int max)
        => text.Length <= max ? text : text[..max].TrimEnd() + "...";

    private async Task OpenTaskAsync(Guid taskId)
    {
        if (_taskDetail is not null) { await _taskDetail.OpenAsync(taskId); }
    }

    // ---- Drag and drop -> MoveTaskAsync (el sortOrder es el INDICE de drop) ----

    /// <summary>Drop sobre el cuerpo de la columna: la tarjeta va al FINAL.</summary>
    private async Task OnDropAsync(ActivityBoardColumnDto target)
    {
        _dragOverColumnId = null;
        if (_dragTaskId is not Guid taskId || _detail is null) { return; }
        _dragTaskId = null;
        var current = _detail.Columns.SelectMany(c => c.Cards).FirstOrDefault(c => c.Id == taskId);
        if (current is null) { return; }
        if (current.ColumnId == target.Id && target.Cards.Count > 0 && target.Cards[^1].Id == taskId)
        {
            return; // ya es la ultima de su columna
        }
        await MoveAsync(taskId, target, target.Cards.Count(x => x.Id != taskId));
    }

    /// <summary>
    /// Drop sobre una tarjeta: inserta ANTES de esa tarjeta (reorden intra columna o
    /// entre columnas). El indice se calcula sin contar la tarjeta arrastrada, igual
    /// que la re-secuenciacion del servicio.
    /// </summary>
    private async Task OnDropOnCardAsync(ActivityBoardColumnDto target, ActivityCardDto over)
    {
        _dragOverColumnId = null;
        if (_dragTaskId is not Guid taskId || _detail is null) { return; }
        _dragTaskId = null;
        if (taskId == over.Id) { return; }
        var remaining = target.Cards.Where(x => x.Id != taskId).ToList();
        var index = remaining.FindIndex(x => x.Id == over.Id);
        if (index < 0) { index = remaining.Count; }
        await MoveAsync(taskId, target, index);
    }

    private async Task MoveAsync(Guid taskId, ActivityBoardColumnDto target, int sortOrder)
    {
        var result = await BoardsSvc.MoveTaskAsync(taskId, target.Id, sortOrder, await ActorAsync(), await ActorNameAsync());
        if (!result.IsOk)
        {
            _toasts?.Error(result.Error ?? "No se pudo mover la tarea.");
            return;
        }
        if (result.Value!.StatusNote is string note)
        {
            _toasts?.Success(note);
        }
        await BroadcastAsync(taskId, result.Value!.Status);
        await ReloadAsync();
    }

