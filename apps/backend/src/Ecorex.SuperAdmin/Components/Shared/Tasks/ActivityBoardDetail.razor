    // ---- SignalR ----

    private async Task EnsureHubAsync()
    {
        if (_hub is not null || AuthState is null) { return; }
        var st = await AuthState;
        _tenantId = st.User.FindFirst("tenant_id")?.Value;
        if (_tenantId is null) { return; }
        try
        {
            _hub = new HubConnectionBuilder()
                .WithUrl(Nav.ToAbsoluteUri("/hubs/tasks"))
                .WithAutomaticReconnect()
                .Build();
            _hub.On<string, string>("TaskChanged", async (_, _) => await InvokeAsync(ReloadAsync));
            await _hub.StartAsync();
            await _hub.SendAsync("JoinTenant", _tenantId);
        }
        catch
        {
            _hub = null; // sin tiempo real el tablero sigue funcionando con recargas manuales
        }
    }

    private async Task BroadcastAsync(Guid taskId, TaskItemStatus status)
    {
        if (AuthState is null) { return; }
        var st = await AuthState;
        if (Guid.TryParse(st.User.FindFirst("tenant_id")?.Value, out var tenantId))
        {
            await Broadcaster.TaskChangedAsync(tenantId, taskId, status);
        }
    }

    private async Task<Guid?> MeTenantUserIdAsync()
    {
        var actor = await ActorAsync();
        return _users.FirstOrDefault(u => u.PlatformUserId == actor)?.Id;
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private async Task<string> ActorNameAsync()
    {
        if (AuthState is null) { return "Usuario"; }
        var st = await AuthState;
        return st.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Usuario";
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            try
            {
                if (_tenantId is not null) { await _hub.SendAsync("LeaveTenant", _tenantId); }
                await _hub.DisposeAsync();
            }
            catch { /* circuito cerrado */ }
        }
    }
