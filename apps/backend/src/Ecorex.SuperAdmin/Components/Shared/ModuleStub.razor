@* Cuerpo comun de los stubs del workspace del tenant (hoja de ruta "Organizar el menu del sistema").
   Muestra breadcrumb simple, cabecera estilo prototipo y la tarjeta "pendiente por fase" con la
   referencia discreta al codigo del modulo legacy (MODULO 000XXX). *@

<PageTitle>@Title - ECOREX.tareas</PageTitle>

<nav class="ecorex-breadcrumb" aria-label="Ruta de navegacion">
    <a href="/inicio">Workspace</a>
    <span class="sep">/</span>
    <span>@Section</span>
    <span class="sep">/</span>
    <span class="cur">@Title</span>
</nav>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">@Icon</div>
            <span>@Section</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">@Title</h1>
        <p class="page-sub" style="margin-bottom:0;">@Description</p>
    </div>
    @if (!string.IsNullOrWhiteSpace(LegacyCode))
    {
        <span class="stub-legacy" title="Codigo del modulo en el sistema legacy">Modulo @LegacyCode</span>
    }
</div>

<div class="coming-soon">
    <div class="coming-soon-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76Z"/></svg>
    </div>
    <h3>@PendingHeadingText</h3>
    <p>@PendingBodyText</p>
    @if (!string.IsNullOrWhiteSpace(LegacyCode))
    {
        <p class="stub-legacy-note">@(LegacyNote ?? $"Referencia: modulo legacy {LegacyCode}.")</p>
    }
</div>

@code {
    /// <summary>Icono del modulo (svg) para el eyebrow de la cabecera.</summary>
    [Parameter] public RenderFragment? Icon { get; set; }

    /// <summary>Seccion del menu a la que pertenece (Principal / Modulos / Sistema).</summary>
    [Parameter] public string Section { get; set; } = "Modulos";

    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;

    /// <summary>Fase de la hoja de ruta en la que se construye, ej. "Fase 4 (WorkflowEngine BPMN)".</summary>
    [Parameter] public string? Phase { get; set; }

    /// <summary>Codigo del modulo en el sistema legacy (ej. 000042). Se muestra como chip discreto.</summary>
    [Parameter] public string? LegacyCode { get; set; }

    /// <summary>Texto alternativo para la referencia legacy (ej. varios codigos).</summary>
    [Parameter] public string? LegacyNote { get; set; }

    /// <summary>Overrides opcionales para items sin fase asignada (ej. Anuncios).</summary>
    [Parameter] public string? PendingHeading { get; set; }
    [Parameter] public string? PendingText { get; set; }

    private string PendingHeadingText => PendingHeading ?? (Phase is null ? "Proximamente" : $"Pendiente {Phase}");
    private string PendingBodyText => PendingText ?? (Phase is null
        ? "Este modulo se construye en una fase posterior segun la hoja de ruta."
        : $"Este modulo se construye en la {Phase} segun la hoja de ruta.");
}
