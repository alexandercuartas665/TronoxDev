@* Nuevo contacto: reusa EL MISMO modal de tercero de Directorio General (un contacto ES un
   cliente; ambos modulos comparten los registros Tercero). Se abre in-place por @@ref. *@
<TerceroModal @ref="_terceroModal" OnChanged="ReloadAllAsync" CrmWiring="true" />

@code {
    private enum Tab { Prospectos, Bolsa, Oportunidades, Agenda }

    // ---- Nuevo contacto: reusa el MISMO modal de tercero de Directorio General (un contacto ES un
    // cliente; ambos modulos se alimentan de los registros Tercero). El modal es el componente
    // compartido TerceroModal; aqui solo lo abrimos por @ref y refrescamos al recibir OnChanged. ----
    private TerceroModal? _terceroModal;

    private async Task OpenNewContact()
    {
        if (_terceroModal is not null) { await _terceroModal.OpenCreate(); }
    }

    private bool _loading = true;
    private bool _busy;
    private Tab _tab = Tab.Prospectos;

    private GestorKpisDto _kpis = new(0, 0, 0, 0, 0m);
    private List<FiltroDto> _filtros = new();
    private List<BolsaColumnaDto> _columnas = new();
    private List<BolsaTerceroDto> _bolsa = new();
    private List<OportunidadDto> _oportunidades = new();
    private List<OportunidadEstadoDto> _estados = new();
    private List<CitaDto> _citas = new();
    private List<ProspectoDto> _prospectos = new();

    // Sidebar filtros
    private bool _filtrosOpen = true;
    private Guid? _filtroMenu;

    // Prospectos
    private string? _prospFuente;

    // Bolsa
    private static readonly string[] BolsaFiltros = { "Todos", "Cartera", "Visita cliente", "Gestion", "Oportunidades" };
    private string _bolsaFiltro = "Todos";
    private Guid? _dragTerceroId;

    // Oportunidades
    // Vista del pipeline: Tablero (kanban por etapa, la principal), Cliente (agrupado) o Tabla.
    private enum OppView { Tablero, Cliente, Tabla }
    private OppView _oppView = OppView.Tablero;
    // Arrastrar y soltar del kanban.
    private Guid? _dragOppId;
    private Guid? _dragOverEstadoId;
    // Serializa los movimientos de etapa: dos cambios seguidos (arrastres rapidos o selects en
    // rafaga) usaban el MISMO DbContext del circuito y uno se perdia en silencio.
    private bool _movingOpp;
    private bool _oppShowResp = true;
    private bool _oppShowValor = true;

    // Agenda
    private static readonly string[] Weekdays = { "Lun", "Mar", "Mie", "Jue", "Vie", "Sab", "Dom" };
    private int _agAnio = DateTime.Today.Year;
    private int _agMes = DateTime.Today.Month;

    protected override async Task OnInitializedAsync()
    {
        // Etapas CONFIGURABLES del pipeline (000740): garantiza los defaults y las carga para
        // pintar las columnas/selectores. Un contacto y su pipeline viven en el mismo tenant.
        await EstadosSvc.EnsureDefaultsAsync();
        _estados = (await EstadosSvc.ListAsync()).ToList();
        await ReloadAllAsync();
        _loading = false;
    }

    private async Task ReloadAllAsync()
    {
        _kpis = await GestorSvc.GetKpisAsync();
        _filtros = (await GestorSvc.ListFiltrosAsync()).ToList();
        _columnas = (await GestorSvc.ListColumnasAsync()).ToList();
        _bolsa = (await GestorSvc.ListBolsaAsync()).ToList();
        _oportunidades = (await GestorSvc.ListOportunidadesAsync()).ToList();
        _citas = (await GestorSvc.ListCitasAsync(_agAnio, _agMes)).ToList();
        _prospectos = (await GestorSvc.ListProspectosAsync(_prospFuente)).ToList();
        _contactos = (await TerceroSvc.ListAsync(new TerceroListFilter())).ToList();
    }

    // ================= CONTACTOS (scrapeados + directorio) =================
    // La pestana muestra TODOS los contactos del tenant, vengan de scraping o cargados a
    // mano en el Directorio General: son la misma agenda comercial vista desde el CRM.
    private List<TerceroListItemDto> _contactos = new();

    private sealed record ContactoRow(
        Guid? TerceroId, Guid? ProspectoId, string Nombre, string Sub,
        string Empresa, string Ciudad, string Fuente, string Metrica,
        string? Badge, bool Promovido);

    private List<ContactoRow> ContactosFiltrados
    {
        get
        {
            var rows = new List<ContactoRow>();
            if (_prospFuente is null || !string.Equals(_prospFuente, FuenteDirectorio, StringComparison.Ordinal))
            {
                rows.AddRange(_prospectos.Select(p => new ContactoRow(
                    null, p.Id, p.NombreCompleto,
                    string.IsNullOrWhiteSpace(p.Cargo) ? "Contacto" : p.Cargo,
                    p.Empresa ?? "", p.Ciudad ?? "", p.Fuente, p.Metrica ?? "",
                    p.Badge, p.Promovido)));
            }
            if (_prospFuente is null || string.Equals(_prospFuente, FuenteDirectorio, StringComparison.Ordinal))
            {
                rows.AddRange(_contactos.Select(t => new ContactoRow(
                    t.Id, null, t.Nombre,
                    t.EsEmpresa ? "Empresa" : "Persona",
                    t.EsEmpresa ? "" : (t.Sub ?? ""), t.Ciudad ?? "",
                    FuenteDirectorio, t.Identificacion,
                    null, false)));
            }
            return rows;
        }
    }

    private async Task SetProspFuenteAsync(string? fuente)
    {
        _prospFuente = fuente;
        // "Directorio" no es una fuente de scraping: pedir prospectos con ese filtro
        // devolveria vacio, asi que solo se recargan cuando la fuente es de scraping.
        if (!string.Equals(fuente, FuenteDirectorio, StringComparison.Ordinal))
        {
