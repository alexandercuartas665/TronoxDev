    private async Task SaveColumnaAsync(Guid? id)
    {
        _colError = null;
        string nombre, color;
        if (id is Guid gid)
        {
            var orig = _columnas.First(c => c.Id == gid);
            nombre = ColNombre(gid, orig.Nombre).Trim();
            color = ColColor(gid, orig.Color).Trim();
        }
        else
        {
            nombre = _newColNombre.Trim();
            color = string.IsNullOrWhiteSpace(_newColColor) ? "--t-blue" : _newColColor.Trim();
        }
        if (nombre.Length == 0)
        {
            _colError = "El nombre del estado es obligatorio.";
            return;
        }
        _busy = true;
        var res = await GestorSvc.SaveColumnaAsync(id, nombre, color);
        _busy = false;
        if (!res.IsOk)
        {
            _colError = res.Error;
            return;
        }
