    // El compositor suelto de oportunidad (estado + OpenOpp + SaveOportunidadAsync + el callback del
    // aside) se RETIRO: toda oportunidad nace de una gestion por concepto en Contacto Cliente, que la
    // crea ligada a su gestion, con titulo y valor, y en la primera etapa configurable del pipeline.

    // ================= CITA (alta) =================
    private bool _citaOpen;
    private string _citaTitulo = "";
    private CitaTipo _citaTipo = CitaTipo.Reunion;
    private Guid? _citaTercero;
    private DateTime _citaFecha = DateTime.Today;
    private string _citaHora = "09:00";
    private int _citaDuracion = 60;
    private string? _citaError;

    private void OpenCita(DateTime fecha)
    {
        _citaTitulo = "";
        _citaTipo = CitaTipo.Reunion;
        _citaTercero = null;
        _citaFecha = fecha;
        _citaHora = "09:00";
        _citaDuracion = 60;
        _citaError = null;
        _citaOpen = true;
    }

    private async Task SaveCitaAsync()
    {
        _citaError = null;
        var titulo = _citaTitulo.Trim();
        if (titulo.Length == 0)
        {
            _citaError = "El titulo de la cita es obligatorio.";
            return;
        }
        var inicio = CombineInicio(_citaFecha, _citaHora);
        var req = new SaveCitaRequest(_citaTercero, null, titulo, _citaTipo, inicio, _citaDuracion);
        _busy = true;
        var res = await GestorSvc.CreateCitaAsync(req);
        _busy = false;
        if (!res.IsOk)
        {
            _citaError = res.Error;
            return;
        }
        _citaOpen = false;
        _citas = (await GestorSvc.ListCitasAsync(_agAnio, _agMes)).ToList();
    }

    private static DateTimeOffset CombineInicio(DateTime fecha, string hora)
    {
        var t = TimeSpan.TryParse(hora, out var ts) ? ts : new TimeSpan(9, 0, 0);
        var dt = fecha.Date + t;
        return new DateTimeOffset(dt, DateTimeOffset.Now.Offset).ToUniversalTime();
    }


