    // ================= OPORTUNIDADES =================
    // Abierta = etapa configurable con Tipo Abierta cuando existe; si la oportunidad aun no tiene
    // etapa configurable (EstadoTipo null), cae al enum heredado (no Ganada/Perdida).
    private static bool IsOpen(OportunidadDto o) => o.EstadoTipo is OportunidadEstadoTipo tipo
        ? tipo == OportunidadEstadoTipo.Abierta
        : o.Etapa != OportunidadEtapa.Ganada && o.Etapa != OportunidadEtapa.Perdida;

    private decimal PipelineAbierto => _oportunidades.Where(IsOpen).Sum(o => o.Valor);

    private async Task MoverEstadoAsync(Guid id, object? value)
    {
        if (!Guid.TryParse(value?.ToString(), out var estadoId)) { return; }
        await MoverAEstadoAsync(id, estadoId);
    }

    /// <summary>Suelta la tarjeta arrastrada en la columna de una etapa.</summary>
    private async Task OnDropOppAsync(Guid estadoId)
    {
        var oppId = _dragOppId;
        _dragOppId = null;
        _dragOverEstadoId = null;
        if (oppId is Guid id) { await MoverAEstadoAsync(id, estadoId); }
    }

    /// <summary>
    /// Mueve la oportunidad de etapa. SERIALIZADO con _movingOpp: dos movimientos solapados
    /// (arrastres rapidos o selects en rafaga) compartian el DbContext del circuito y uno se perdia
    /// en silencio; ahora el segundo se ignora hasta que el primero termina.
    /// </summary>
    private async Task MoverAEstadoAsync(Guid id, Guid estadoId)
    {
        if (_movingOpp) { return; }
        _movingOpp = true;
        try
        {
            var res = await GestorSvc.MoverEstadoAsync(id, estadoId);
            if (res.IsOk)
            {
                _oportunidades = (await GestorSvc.ListOportunidadesAsync()).ToList();
                _kpis = await GestorSvc.GetKpisAsync();
            }
        }
        finally { _movingOpp = false; }
    }

    /// <summary>Chip (fondo/texto) de una etapa configurable, para la cabecera de su columna.</summary>
    private static (string Bg, string Fg) EstadoChip(OportunidadEstadoDto e)
    {
        var c = e.Color;
        if (!string.IsNullOrWhiteSpace(c) && c.StartsWith("--t-", StringComparison.Ordinal))
        {
            return ($"var({c}-bg)", $"var({c})");
        }
        return string.IsNullOrWhiteSpace(c)
            ? ("var(--surface-3)", "var(--ink-2)")
            : ("var(--surface-3)", c);
    }

    // Etiqueta de la etapa: nombre de la etapa configurable cuando existe; si no, el enum heredado.
    private static string OppEstadoLabel(OportunidadDto o)
        => string.IsNullOrWhiteSpace(o.EstadoNombre) ? EtapaLabel(o.Etapa) : o.EstadoNombre!;

    // Chip (fondo/texto) de la etapa: usa el color de la etapa configurable; si no, el del enum.
    private static (string Bg, string Fg) OppChip(OportunidadDto o)
    {
        if (!string.IsNullOrWhiteSpace(o.EstadoColor))
        {
            var c = o.EstadoColor!.Trim();
            if (c.StartsWith("--t-")) { return ($"var({c}-bg)", $"var({c})"); }
            if (c.StartsWith("--")) { return ("var(--surface-3)", $"var({c})"); }
            return ("var(--surface-3)", c); // hex u otro
        }
        var oi = EtapaInfo(o.Etapa);
        return ($"var({oi.Bg})", $"var({oi.Color})");
    }

    // Color del borde izquierdo de la fila (tabla).
    private static string OppBorder(OportunidadDto o)
    {
        if (!string.IsNullOrWhiteSpace(o.EstadoColor)) { return ColorOf(o.EstadoColor); }
        return ColorVar(EtapaInfo(o.Etapa).Color);
    }

