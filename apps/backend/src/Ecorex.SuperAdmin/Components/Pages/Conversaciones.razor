@* ===== Vaciar todo el historial (doble confirmacion) ===== *@
@if (_clearOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:480px;">
            <div class="modal-head">
                <h3>Vaciar todo el historial</h3>
                <button class="modal-close" @onclick="() => _clearOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                @if (_clearStep == 1)
                {
                    <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:12px;color:#991b1b;">
                        <strong>Esta accion borra TODAS las conversaciones y sus mensajes</strong> de esta empresa (activas y archivadas),
                        incluyendo el contexto del agente de IA. <strong>Es irreversible.</strong>
                    </div>
                    <p class="text-muted" style="font-size:12px;margin-top:10px;">No se borran los leads, y no afecta WhatsApp: solo el historial guardado aqui.</p>
                }
                else
                {
                    <p style="margin-top:0;">Para confirmar, escribe <strong>VACIAR</strong> en mayusculas:</p>
                    <input class="form-control" @bind="_clearText" @bind:event="oninput" placeholder="VACIAR" autocomplete="off" />
                    @if (_clearError is not null) { <div class="text-danger small" style="margin-top:8px;">@_clearError</div> }
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _clearOpen = false" disabled="@_clearBusy">Cancelar</button>
                @if (_clearStep == 1)
                {
                    <button class="btn" style="background:#dc2626;color:#fff;border:none;" @onclick="() => _clearStep = 2">Entiendo, continuar</button>
                }
                else
                {
                    <button class="btn" style="background:#dc2626;color:#fff;border:none;@(_clearBusy || !ClearConfirmed ? "opacity:.5;" : "")" @onclick="ConfirmClearAsync" disabled="@(_clearBusy || !ClearConfirmed)">@(_clearBusy ? "Vaciando..." : "Vaciar definitivamente")</button>
                }
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    // Vaciar todo el historial (doble confirmacion: paso 1 advertencia + paso 2 escribir "VACIAR").
    private bool _clearOpen;
    private int _clearStep = 1;
    private string _clearText = "";
    private bool _clearBusy;
    private string? _clearError;
    private string? _clearDone;
    private bool ClearConfirmed => string.Equals(_clearText?.Trim(), "VACIAR", StringComparison.OrdinalIgnoreCase);

    private void OpenClearModal()
    {
        _clearOpen = true; _clearStep = 1; _clearText = ""; _clearError = null; _clearDone = null;
    }

    private async Task ConfirmClearAsync()
    {
        if (!ClearConfirmed) { _clearError = "Escribe VACIAR para confirmar."; return; }
        _clearBusy = true; _clearError = null;
        try
        {
            var r = await ChatSvc.ClearAllConversationsAsync(await ActorAsync());
            _active = null; _activeLead = null; _showArchived = false; _archived = new();
            await ReloadConversationsAsync();
            _clearOpen = false;
            _clearDone = $"Historial vaciado: {r.Conversations} conversaciones y {r.Messages} mensajes eliminados.";
        }
        finally { _clearBusy = false; }
    }

    private bool _loading = true;
    private string? _tenantId;
    private string _search = string.Empty;
    // Filtros de la bandeja: vista archivados, filtro de pipeline y busqueda por texto de mensaje (con debounce).
    private bool _showArchived;
    private List<ConversationDto> _archived = new();
    private string _pipeFilter = "all";
    private HashSet<Guid>? _msgMatchIds;
    private CancellationTokenSource? _searchCts;
    // Eliminar mensaje para todos.
    private bool _deleteMsgOpen;
    private bool _deleteMsgBusy;
    private MessageDto? _deleteMsgTarget;
    private string? _deleteMsgError;

    private List<WhatsAppLineDto> _lines = new();
    private List<ConversationDto> _conversations = new();
    private IReadOnlyDictionary<string, LeadChatStateDto> _unread = new Dictionary<string, LeadChatStateDto>();

    private ConversationDto? _active;
    private LeadDto? _activeLead;
    private List<MessageDto> _messages = new();
    private Guid _lineId;
    private string? _draft;
    private string? _chatError;
    private bool _sending;

    private HubConnection? _hub;
    private string? _joinedConversation;

    private List<PipelineStageDto> _stages = new();
    private bool _convertOpen;
    private bool _converting;
    private string? _convertError;
    private ConvertForm _cv = new();

    // Pregrabados + adjuntos
    private string? _myName;
    private string _qrCategory = "saludo";
    private List<MessageTemplateDto> _templates = new();
    private bool _attachOpen;
    private bool _tplManagerOpen;
    private bool _tplBusy;
    private string? _tplFormError;
    private Guid? _tplEditId;
    private string _tplFormCategory = "saludo";
    private string? _tplFormName;
    private string? _tplFormBody;
    private MessageMediaType _tplFormMediaType = MessageMediaType.None;
    private string? _tplFormMediaUrl;
    private string? _tplFormMediaMime;
    private bool _locationOpen;
    private string? _locName;
    private string? _locLat;
    private string? _locLng;
    private string? _locError;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _tenantId = state.User.FindFirst("tenant_id")?.Value;
            _myName = state.User.Identity?.Name;
        }

        var lines = await LinesSvc.ListAsync();
        _lines = lines.Where(l => l.Status == WhatsAppLineStatus.Connected).ToList();
        _lineId = _lines.FirstOrDefault()?.Id ?? Guid.Empty;

        _stages = (await PipelineSvc.ListStagesAsync()).ToList();

        if (_lines.Count > 0)
        {
            await ReloadConversationsAsync();
            await TemplatesSvc.SeedDefaultsAsync();
            _templates = (await TemplatesSvc.ListAsync()).ToList();
            await EnsureHubAsync();
        }
        _loading = false;
    }

    private async Task ReloadConversationsAsync()
    {
        _conversations = (await ChatSvc.ListConversationsAsync())
            .OrderByDescending(c => c.LastMessageAt ?? DateTimeOffset.MinValue)
            .ToList();
        _unread = await ChatSvc.GetUnansweredByPhoneAsync();
    }

    private List<ConversationDto> FilteredConversations()
    {
        IEnumerable<ConversationDto> q = _showArchived ? _archived : _conversations;
        // Filtro por pipeline.
        if (_pipeFilter == "sin") { q = q.Where(c => c.LeadId is null); }
        else if (_pipeFilter == "con") { q = q.Where(c => c.LeadId is not null); }
        // Busqueda por nombre/telefono o por texto de mensaje (ids precargados con debounce).
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(c =>
                (c.ContactName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (c.ContactPhone?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                || (_msgMatchIds?.Contains(c.Id) ?? false));
        }
        return q.ToList();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? string.Empty;
        _searchCts?.Cancel();
        var term = _search.Trim();
        if (term.Length < 2) { _msgMatchIds = null; return; }
        var cts = new CancellationTokenSource();
        _searchCts = cts;
        try
        {
            await Task.Delay(300, cts.Token);
            var ids = await ChatSvc.SearchConversationIdsByMessageAsync(term, cts.Token);
            _msgMatchIds = ids.ToHashSet();
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { /* tecleo siguiente cancelo esta busqueda */ }
    }

    private void ShowActiveView()
    {
        if (!_showArchived) { return; }
        _showArchived = false;
        _active = null; _activeLead = null;
    }

    private async Task ShowArchivedView()
    {
        if (_showArchived) { return; }
        _showArchived = true;
        _active = null; _activeLead = null;
        _archived = (await ChatSvc.ListArchivedConversationsAsync())
            .OrderByDescending(c => c.LastMessageAt ?? DateTimeOffset.MinValue).ToList();
    }

    private async Task ArchiveAsync(ConversationDto c, bool archived)
    {
        await ChatSvc.SetConversationArchivedAsync(c.Id, archived);
        if (_active?.Id == c.Id) { _active = null; _activeLead = null; }
        await ReloadConversationsAsync();
        if (_showArchived)
        {
            _archived = (await ChatSvc.ListArchivedConversationsAsync())
                .OrderByDescending(c2 => c2.LastMessageAt ?? DateTimeOffset.MinValue).ToList();
        }
    }

    private static string FilterChipStyle(bool on) =>
        on ? "background:var(--primary,#2563eb);color:#fff;border-color:var(--primary,#2563eb);"
           : "background:transparent;";

    private void OpenDeleteMsg(MessageDto m)
    {
        _deleteMsgTarget = m;
        _deleteMsgError = null;
        _deleteMsgOpen = true;
    }

    private async Task ConfirmDeleteMsgAsync()
    {
        if (_deleteMsgTarget is null) { return; }
        _deleteMsgBusy = true;
        try
        {
            var actor = await ActorAsync();
            var r = await ChatSvc.DeleteMessageForEveryoneAsync(_deleteMsgTarget.Id, actor);
            if (!r.Ok) { _deleteMsgError = r.Error ?? "No se pudo eliminar."; return; }
            _messages.RemoveAll(m => m.Id == _deleteMsgTarget.Id);
            _deleteMsgOpen = false;
            _deleteMsgTarget = null;
            await ReloadConversationsAsync();
        }
        finally { _deleteMsgBusy = false; }
    }

    private static string Trunc(string s, int max) => s.Length <= max ? s : s[..max] + "...";

    private async Task SelectAsync(ConversationDto c)
    {
        _active = c;
        _chatError = null;
        _draft = null;
        if (c.WhatsAppLineId is Guid lid && _lines.Any(l => l.Id == lid)) { _lineId = lid; }
        _messages = (await ChatSvc.ListMessagesAsync(c.Id)).ToList();
        _activeLead = c.LeadId is Guid leadId ? (await LeadsSvc.GetAsync(leadId))?.Lead : null;
        await JoinConversationRealtimeAsync(c.Id);
    }

    private async Task SendAsync()
    {
        _chatError = null;
        if (_active is null || string.IsNullOrWhiteSpace(_draft) || _lineId == Guid.Empty) { return; }
        _sending = true;
        try
        {
            var actor = await ActorAsync();
            var result = await ChatSvc.SendViaLineAsync(_active.Id, _lineId, _draft!.Trim(), actor);
            if (!result.Ok)
            {
                _chatError = result.Error ?? "No se pudo enviar el mensaje.";
                return;
            }
            if (result.Message is not null) { _messages.Add(result.Message); }
            _draft = null;
            await ReloadConversationsAsync();
        }
        finally { _sending = false; }
    }

    private async Task ChatKeyDown(KeyboardEventArgs e)
    {
        // Si el popup de comandos "/" esta abierto, las flechas/Enter/Esc lo manejan a el.
        var slash = SlashItems();
        if (slash.Count > 0)
        {
            if (e.Key == "ArrowDown") { _slashSel = Math.Min(_slashSel + 1, slash.Count - 1); return; }
            if (e.Key == "ArrowUp") { _slashSel = Math.Max(_slashSel - 1, 0); return; }
            if (e.Key == "Escape") { _slashDismissed = true; return; }
            if (e.Key == "Enter" && !e.ShiftKey)
            {
                await PickSlashAsync(slash[Math.Clamp(_slashSel, 0, slash.Count - 1)]);
                return;
            }
        }
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendAsync();
        }
    }

    // ===== Comando "/" en el composer =====
    // Si el borrador empieza por "/", devuelve los pregrabados que coinciden con el nombre escrito
    // tras la barra (los que no tienen nombre se buscan por su texto). Lista vacia = sin popup.
    private int _slashSel;
    private string _slashQuery = "\0";
    private bool _slashDismissed;

    private List<MessageTemplateDto> SlashItems()
    {
        var d = _draft;
        if (string.IsNullOrEmpty(d) || d[0] != '/')
        {
            _slashQuery = "\0";
            _slashDismissed = false;
            return new();
        }
        var rest = d.Substring(1);
        var nl = rest.IndexOf('\n');
        if (nl >= 0) { rest = rest.Substring(0, nl); }
        var q = rest.Trim();
        if (q != _slashQuery) { _slashQuery = q; _slashSel = 0; _slashDismissed = false; }
        if (_slashDismissed) { return new(); }
        var items = _templates
            .Where(t => SlashMatch(t, q))
            .OrderByDescending(t => (t.Name ?? "").StartsWith(q, StringComparison.OrdinalIgnoreCase))
            .ThenBy(t => t.SortOrder)
            .Take(8)
            .ToList();
        if (_slashSel >= items.Count) { _slashSel = Math.Max(0, items.Count - 1); }
        return items;
    }

    private static bool SlashMatch(MessageTemplateDto t, string q)
    {
        if (string.IsNullOrEmpty(q)) { return true; }
        var cmp = StringComparison.OrdinalIgnoreCase;
        if (!string.IsNullOrWhiteSpace(t.Name)) { return t.Name!.Contains(q, cmp); }
        return t.Body?.Contains(q, cmp) ?? false;
    }

    private async Task PickSlashAsync(MessageTemplateDto t)
    {
        _draft = null;            // quita el "/consulta" del cuadro
        _slashQuery = "\0";
        _slashSel = 0;
        _slashDismissed = false;
        await UseTemplateAsync(t); // texto: rellena el cuadro; media: lo envia (igual que un chip)
    }

    private async Task EnsureHubAsync()
    {
        if (_hub is not null) { return; }
        try
        {
            _hub = new HubConnectionBuilder()
                .WithUrl(Nav.ToAbsoluteUri("/hubs/chat"))
                .WithAutomaticReconnect()
                .Build();

            _hub.On<MessageDto>("MessageAdded", async msg =>
            {
                if (_active is not null && msg.ConversationId == _active.Id && _messages.All(m => m.Id != msg.Id))
                {
                    _messages.Add(msg);
                }
                await InvokeAsync(StateHasChanged);
            });

            _hub.On("BoardChanged", async () =>
            {
                await ReloadConversationsAsync();
                await InvokeAsync(StateHasChanged);
            });

            await _hub.StartAsync();
            if (!string.IsNullOrEmpty(_tenantId))
            {
                await _hub.SendAsync("JoinTenant", _tenantId);
            }
        }
        catch { /* el tiempo real es complemento; la bandeja funciona sin el */ }
    }

    private async Task JoinConversationRealtimeAsync(Guid conversationId)
    {
        if (_hub is null) { return; }
        try
        {
            if (_joinedConversation is not null && _joinedConversation != conversationId.ToString())
            {
                await _hub.SendAsync("LeaveConversation", _joinedConversation);
            }
            await _hub.SendAsync("JoinConversation", conversationId.ToString());
            _joinedConversation = conversationId.ToString();
        }
        catch { }
    }

    private LeadChatStateDto? UnreadFor(ConversationDto c)
    {
        if (string.IsNullOrWhiteSpace(c.ContactPhone)) { return null; }
        var key = new string(c.ContactPhone.Where(char.IsDigit).ToArray());
        return _unread.TryGetValue(key, out var st) ? st : null;
    }

    private string LineLabel(Guid? lineId)
    {
        if (lineId is Guid id)
        {
            var ln = _lines.FirstOrDefault(l => l.Id == id);
            if (ln is not null) { return string.IsNullOrWhiteSpace(ln.PhoneNumber) ? ln.InstanceName : ln.PhoneNumber!; }
        }
        return "WhatsApp";
    }

    private static string LastSnippet(ConversationDto c) => "Toca para ver la conversacion";

    private void OpenConvert()
    {
        if (_active is null) { return; }
        _convertError = null;
        _cv = new ConvertForm
        {
            ContactName = _active.ContactName ?? _active.ContactPhone,
            ContactPhone = _active.ContactPhone,
            StageId = _stages.FirstOrDefault()?.Id ?? Guid.Empty
        };
        _convertOpen = true;
    }

    private async Task ConfirmConvertAsync()
    {
        if (_active is null) { return; }
        if (string.IsNullOrWhiteSpace(_cv.ContactName))
        {
            _convertError = "El nombre del contacto es obligatorio.";
            return;
        }
        _converting = true;
        try
        {
            var actor = await ActorAsync();
            var req = new CreateLeadRequest(
                _cv.ContactName.Trim(),
                _cv.ContactPhone,
                string.IsNullOrWhiteSpace(_cv.Destination) ? null : _cv.Destination!.Trim(),
                _cv.EstimatedValue,
                string.IsNullOrWhiteSpace(_cv.Currency) ? null : _cv.Currency!.Trim(),
                _cv.StageId == Guid.Empty ? null : _cv.StageId);
            var lead = await LeadsSvc.CreateAsync(req, actor);
            if (lead is null)
            {
                _convertError = "No se pudo crear el lead.";
                return;
            }
            // Vincula la conversacion actual al nuevo lead (match por telefono).
            await ChatSvc.GetOrCreateForLeadAsync(lead.Id);
            _activeLead = lead;
            await ReloadConversationsAsync();
            _active = _conversations.FirstOrDefault(c => c.Id == _active!.Id) ?? _active;
            _convertOpen = false;
        }
        finally { _converting = false; }
    }

    // ===== Pregrabados =====
    private List<(string Key, string Label)> QrCategories
    {
        get
        {
            var keys = MessageTemplateCategories.All.Select(c => c.Key).ToList();
            foreach (var t in _templates)
            {
                if (!keys.Contains(t.Category)) { keys.Add(t.Category); }
            }
            return keys.Select(k => (k, CategoryLabel(k))).ToList();
        }
    }

    private static string CategoryLabel(string key)
    {
        var lbl = MessageTemplateCategories.Label(key);
        if (lbl == key && key.Length > 0) { return char.ToUpperInvariant(key[0]) + key[1..]; }
        return lbl;
    }

    private List<MessageTemplateDto> CurrentTemplates()
        => _templates.Where(t => t.Category == _qrCategory).OrderBy(t => t.SortOrder).ToList();

    private string FillTemplate(string template)
    {
        var destino = string.IsNullOrWhiteSpace(_activeLead?.Destination)
            ? "tu destino"
            : _activeLead!.Destination!.Split('→', '>').Last().Trim();
        var asesor = string.IsNullOrWhiteSpace(_myName)
            ? "tu asesor"
            : (_myName!.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "tu asesor");
        return template.Replace("{destino}", destino).Replace("{asesor}", asesor);
    }

    private static string MediaIcon(MessageMediaType t) => t switch
    {
        MessageMediaType.Image => "Imagen",
        MessageMediaType.Video => "Video",
        MessageMediaType.Audio => "Audio",
        MessageMediaType.Document => "Doc",
        MessageMediaType.Location => "Ubicacion",
        _ => ""
    };

    private async Task UseTemplateAsync(MessageTemplateDto t)
    {
        _chatError = null;
        if (t.MediaType == MessageMediaType.None)
        {
            _draft = FillTemplate(t.Body);
            return;
        }
        if (_active is null || _lineId == Guid.Empty || t.MediaUrl is null) { return; }
        _sending = true;
        try
        {
            var b64 = await ReadLocalBase64Async(t.MediaUrl);
            if (b64 is null) { _chatError = "No se encontro el archivo del pregrabado."; return; }
            var actor = await ActorAsync();
            var caption = FillTemplate(t.Body);
            var r = await ChatSvc.SendMediaViaLineAsync(_active.Id, _lineId, t.MediaType, b64, t.MediaUrl, t.MediaMimeType, System.IO.Path.GetFileName(t.MediaUrl), caption, actor);
            if (!r.Ok) { _chatError = r.Error; return; }
            if (r.Message is not null) { _messages.Add(r.Message); }
        }
        finally { _sending = false; }
    }

    // ===== Adjuntos =====
    private async Task OnAttachAsync(InputFileChangeEventArgs e, MessageMediaType type)
    {
        _attachOpen = false;
        _chatError = null;
        if (_active is null || _lineId == Guid.Empty) { return; }
        var saved = await SaveChatFileAsync(e.File, type);
        if (saved is null) { _chatError = "Archivo invalido o supera 16 MB."; return; }
        _sending = true;
        try
        {
            var actor = await ActorAsync();
            var caption = string.IsNullOrWhiteSpace(_draft) ? null : _draft!.Trim();
            var r = await ChatSvc.SendMediaViaLineAsync(_active.Id, _lineId, type, saved.Value.Base64, saved.Value.Url, saved.Value.Mime, saved.Value.Name, caption, actor);
            if (!r.Ok) { _chatError = r.Error; return; }
            if (r.Message is not null) { _messages.Add(r.Message); }
            _draft = null;
        }
        finally { _sending = false; }
    }

    private void OpenLocation()
    {
        _attachOpen = false;
        _locName = null; _locLat = null; _locLng = null; _locError = null;
        _locationOpen = true;
    }

    private async Task SendLocationAsync()
    {
        _locError = null;
        var ci = System.Globalization.CultureInfo.InvariantCulture;
        if (!double.TryParse(_locLat, System.Globalization.NumberStyles.Any, ci, out var lat)
            || !double.TryParse(_locLng, System.Globalization.NumberStyles.Any, ci, out var lng))
        {
            _locError = "Latitud y longitud invalidas.";
            return;
        }
        if (_active is null || _lineId == Guid.Empty) { _locError = "Selecciona una linea."; return; }
        _sending = true;
        try
        {
            var actor = await ActorAsync();
            var r = await ChatSvc.SendLocationViaLineAsync(_active.Id, _lineId, lat, lng, _locName, actor);
            if (!r.Ok) { _locError = r.Error; return; }
            if (r.Message is not null) { _messages.Add(r.Message); }
            _locationOpen = false;
        }
        finally { _sending = false; }
    }

