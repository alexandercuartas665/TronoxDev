@page "/conversaciones"
@attribute [Authorize]
@* prerender:false: el chat usa SignalR y DbContext scoped; evitamos doble ejecucion SSR + circuito. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using Ecorex.Application.Tenancy
@using Ecorex.Domain.Enums
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject IChatService ChatSvc
@inject IWhatsAppLineService LinesSvc
@inject ILeadService LeadsSvc
@inject IPipelineService PipelineSvc
@inject IMessageTemplateService TemplatesSvc
@inject IWebHostEnvironment Env
@inject NavigationManager Nav

<PageTitle>Conversaciones - ECOREX.tareas</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9a2 2 0 0 1-2 2H6l-4 4V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2z"/><path d="M18 9h2a2 2 0 0 1 2 2v11l-4-4h-6a2 2 0 0 1-2-2v-1"/></svg>
            </div>
            <span>Comercial Conversacional</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Bandeja <span>unificada</span></h1>
        <p class="page-sub" style="margin-bottom:0;">WhatsApp multi-linea con asignacion de asesores, contexto del lead y sugerencias del copiloto.</p>
    </div>
    <button class="btn btn-outline-danger" style="align-self:flex-start;white-space:nowrap;" @onclick="OpenClearModal" title="Borra todas las conversaciones y mensajes de la empresa">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;margin-right:4px;"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
        Vaciar historial
    </button>
</div>

@if (_clearDone is not null)
{
    <div class="cv-warn" style="background:#ecfdf5;border-color:#a7f3d0;color:#065f46;display:flex;justify-content:space-between;align-items:center;">
        <span>@_clearDone</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _clearDone = null">Cerrar</button>
    </div>
}

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else if (_lines.Count == 0)
{
    <div class="cv-warn">No hay lineas WhatsApp conectadas. Conecta una linea en el modulo <a href="lineas">Lineas WhatsApp</a> para empezar a conversar.</div>
}
else
{
    <div class="cv-grid @(_active is null ? "" : "cv-has-active")">
        @* ===== Columna 1: lista de chats ===== *@
        <div class="cv-list-col">
            <div class="cv-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input placeholder="Buscar chat o texto de mensaje..." value="@_search" @oninput="OnSearchInput" />
            </div>
            <div class="cv-filters" style="display:flex;gap:6px;flex-wrap:wrap;padding:0 10px 8px;">
                <button class="cv-fchip @(_showArchived ? "" : "on")" style="@FilterChipStyle(!_showArchived)" @onclick="ShowActiveView">Activas</button>
                <button class="cv-fchip @(_showArchived ? "on" : "")" style="@FilterChipStyle(_showArchived)" @onclick="ShowArchivedView">Archivados</button>
                <span style="width:1px;background:var(--border);margin:2px 2px;"></span>
                <button class="cv-fchip" style="@FilterChipStyle(_pipeFilter == "all")" @onclick="@(() => _pipeFilter = "all")">Todos</button>
                <button class="cv-fchip" style="@FilterChipStyle(_pipeFilter == "sin")" @onclick="@(() => _pipeFilter = "sin")">Sin pipeline</button>
                <button class="cv-fchip" style="@FilterChipStyle(_pipeFilter == "con")" @onclick="@(() => _pipeFilter = "con")">En pipeline</button>
            </div>
            <div class="cv-list">
                @if (FilteredConversations().Count == 0)
                {
                    <div class="cv-empty">@(_showArchived ? "No hay conversaciones archivadas." : "No hay conversaciones todavia.")</div>
                }
                else
                {
                    @foreach (var c in FilteredConversations())
                    {
                        var pend = UnreadFor(c);
                        <button class="cv-item @(_active?.Id == c.Id ? "on" : "")" @onclick="() => SelectAsync(c)">
                            <span class="cv-avatar">@Initials(c.ContactName ?? c.ContactPhone)</span>
                            <span class="cv-item-main">
                                <span class="cv-item-top">
                                    <span class="cv-item-name">@(c.ContactName ?? c.ContactPhone)</span>
                                    <span class="cv-item-time">@TimeLabel(c.LastMessageAt)</span>
                                </span>
                                <span class="cv-item-last">@(LastSnippet(c))</span>
                                <span class="cv-item-tags">
                                    <span class="cv-line-tag">@LineLabel(c.WhatsAppLineId)</span>
                                    @if (pend is { } p && p.UnansweredCount > 0)
                                    {
                                        <span class="cv-unread">@p.UnansweredCount</span>
                                    }
                                </span>
                            </span>
                            <span class="cv-item-arch" role="button" title="@(_showArchived ? "Restaurar" : "Archivar")"
                                  @onclick="() => ArchiveAsync(c, !_showArchived)" @onclick:stopPropagation="true">
                                @if (_showArchived)
                                {
                                    <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v5h5"/><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/></svg>
                                }
                                else
                                {
                                    <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="5" x="2" y="3" rx="1"/><path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/><path d="M10 12h4"/></svg>
                                }
                            </span>
                        </button>
                    }
                }
            </div>
        </div>

        @* ===== Columna 2: hilo de chat ===== *@
        <div class="cv-thread-col">
            @if (_active is null)
            {
                <div class="cv-thread-empty">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9a2 2 0 0 1-2 2H6l-4 4V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2z"/><path d="M18 9h2a2 2 0 0 1 2 2v11l-4-4h-6a2 2 0 0 1-2-2v-1"/></svg>
                    <p>Selecciona una conversacion para ver los mensajes.</p>
                </div>
            }
            else
            {
                <div class="cv-thread-head">
                    <button class="cv-back" @onclick="() => { _active = null; _activeLead = null; }" aria-label="Volver a la lista">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
                    </button>
                    <span class="cv-avatar lg">@Initials(_active.ContactName ?? _active.ContactPhone)</span>
                    <div style="flex:1;min-width:0;">
                        <div class="cv-th-name">@(_active.ContactName ?? _active.ContactPhone)</div>
                        <div class="cv-th-sub">@MaskPhone(_active.ContactPhone) &middot; @LineLabel(_active.WhatsAppLineId)</div>
                    </div>
                    @if (_activeLead is null)
                    {
                        <button class="btn btn-primary btn-sm" @onclick="OpenConvert" title="Crear un lead en el embudo a partir de esta conversacion">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;margin-right:4px;"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                            Llevar a Pipeline
                        </button>
                    }
                    @if (_lines.Count > 1)
                    {
                        <select class="cv-line-select" @bind="_lineId" title="Linea para responder">
                            @foreach (var ln in _lines)
                            {
                                <option value="@ln.Id">@(string.IsNullOrWhiteSpace(ln.PhoneNumber) ? ln.InstanceName : ln.PhoneNumber)</option>
                            }
                        </select>
                    }
                </div>

                <div class="cv-body">
                    @if (_messages.Count == 0)
                    {
                        <div class="pl-chat-empty">Aun no hay mensajes. Escribe el primero abajo.</div>
                    }
                    else
                    {
                        DateTime? lastDay = null;
                        @foreach (var m in _messages)
                        {
                            var day = m.SentAt.LocalDateTime.Date;
                            if (lastDay != day)
                            {
                                lastDay = day;
                                <div class="pl-date-divider">@day.ToString("dd 'DE' MMMM").ToUpperInvariant()</div>
                            }
                            <div class="pl-bubble @(m.Direction == MessageDirection.Outbound ? "out" : "in")">
                                @switch (m.MediaType)
                                {
                                    case MessageMediaType.Image:
                                        <img class="pl-media-img" src="@m.MediaUrl" alt="imagen" />
                                        <a class="cv-dl" href="@m.MediaUrl" download target="_blank">Descargar imagen</a>
                                        break;
                                    case MessageMediaType.Video:
                                        <video class="pl-media-img" src="@m.MediaUrl" controls></video>
                                        <a class="cv-dl" href="@m.MediaUrl" download target="_blank">Descargar video</a>
                                        break;
                                    case MessageMediaType.Audio:
                                        <audio src="@m.MediaUrl" controls style="max-width:220px;"></audio>
                                        <a class="cv-dl" href="@m.MediaUrl" download target="_blank">Descargar audio</a>
                                        break;
                                    case MessageMediaType.Document:
                                        <a class="pl-media-doc" href="@m.MediaUrl" download target="_blank">Documento adjunto</a>
                                        break;
                                    case MessageMediaType.Location:
                                        <a class="pl-media-doc" href="@MapsLink(m.MediaUrl)" target="_blank">Ver ubicacion en el mapa</a>
                                        break;
                                }
                                @if (!string.IsNullOrWhiteSpace(m.Body))
                                {
                                    <div>@m.Body</div>
                                }
                                <div class="t">
                                    @if (m.Direction == MessageDirection.Outbound && !string.IsNullOrWhiteSpace(m.SentByName))
                                    {
                                        <span>@m.SentByName &middot; </span>
                                    }
                                    @m.SentAt.LocalDateTime.ToString("hh:mm tt")
                                    @if (m.Direction == MessageDirection.Outbound)
                                    {
                                        <button class="cv-msg-del" title="Eliminar para todos" @onclick="() => OpenDeleteMsg(m)">
                                            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                        </button>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(m.Reaction))
                                {
                                    <span class="cv-bubble-reaction" title="Reaccion">@m.Reaction</span>
                                }
                            </div>
                        }
                    }
                </div>

                <div class="pl-chat-quick">
                    <div class="pl-qr-head">
                        <span>Mensajes pregrabados</span>
                        <div class="pl-qr-tabs">
                            @foreach (var cat in QrCategories)
                            {
                                <button class="pl-qr-tab @(cat.Key == _qrCategory ? "active" : "")" @onclick="() => _qrCategory = cat.Key">@cat.Label</button>
                            }
                            <button class="pl-qr-tab" style="border:1px solid var(--border);" @onclick="OpenTemplateManager" title="Crear/editar pregrabados">+ Gestionar</button>
                        </div>
                    </div>
                    <div class="pl-qr-list">
                        @foreach (var tpl in CurrentTemplates())
                        {
                            var filled = FillTemplate(tpl.Body);
                            var shown = string.IsNullOrWhiteSpace(tpl.Name) ? filled : tpl.Name;
                            var label = tpl.MediaType == MessageMediaType.None ? shown : $"{MediaIcon(tpl.MediaType)} {(string.IsNullOrWhiteSpace(shown) ? tpl.MediaType.ToString() : shown)}";
                            <button class="pl-quick-chip" title="@filled" @onclick="() => UseTemplateAsync(tpl)">@label</button>
                        }
                        @if (CurrentTemplates().Count == 0)
                        {
                            <span class="text-muted" style="font-size:11px;">Sin pregrabados en esta categoria. Usa "+ Gestionar".</span>
                        }
                    </div>
                </div>
                <div class="cv-composer">
                    @if (_chatError is not null)
                    {
                        <div class="text-danger small" style="margin-bottom:6px;">@_chatError</div>
                    }
                    <div class="cv-composer-box">
                        @{ var slashItems = SlashItems(); }
                        @if (slashItems.Count > 0)
                        {
                            <div class="slash-pop">
                                <div class="slash-pop-head"><span>Pregrabados</span><em>Enter para insertar</em></div>
                                @for (var i = 0; i < slashItems.Count; i++)
                                {
                                    var t = slashItems[i];
                                    var sel = i == _slashSel;
                                    var nm = string.IsNullOrWhiteSpace(t.Name) ? Trunc(FillTemplate(t.Body), 24) : t.Name!;
                                    var prev = Trunc(FillTemplate(t.Body), 70);
                                    var meta = CategoryLabel(t.Category) + (t.MediaType != MessageMediaType.None ? " - " + MediaIcon(t.MediaType) : "");
                                    <button type="button" class="slash-item @(sel ? "sel" : "")" @onclick="() => PickSlashAsync(t)">
                                        <span class="slash-name">/@nm</span>
                                        <span class="slash-cat">@meta</span>
                                        <span class="slash-prev">@prev</span>
                                    </button>
                                }
                            </div>
                        }
                        <div class="pl-attach">
                            <button class="pl-attach-btn" title="Adjuntar" @onclick="() => _attachOpen = !_attachOpen" disabled="@_sending">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                            </button>
                            @if (_attachOpen)
                            {
                                <div class="pl-attach-menu">
                                    <label class="pl-attach-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21"/></svg>
                                        Imagen
                                        <InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Image))" accept="image/*" style="display:none;" />
                                    </label>
                                    <label class="pl-attach-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8Z"/><rect x="2" y="6" width="14" height="12" rx="2"/></svg>
                                        Video
                                        <InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Video))" accept="video/*" style="display:none;" />
                                    </label>
                                    <label class="pl-attach-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
                                        Audio
                                        <InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Audio))" accept="audio/*" style="display:none;" />
                                    </label>
                                    <label class="pl-attach-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/></svg>
                                        Documento
                                        <InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Document))" accept="*/*" style="display:none;" />
                                    </label>
                                    <button class="pl-attach-item" @onclick="OpenLocation">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                                        Ubicacion
                                    </button>
                                </div>
                            }
                        </div>
                        <textarea rows="1" placeholder="Escribe un mensaje..." @bind="_draft" @bind:event="oninput" @onkeydown="ChatKeyDown" disabled="@_sending"></textarea>
                        <button class="cv-send" @onclick="SendAsync" disabled="@(_sending || string.IsNullOrWhiteSpace(_draft))" title="Enviar">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                        </button>
                    </div>
                </div>
            }
        </div>

        @* ===== Columna 3: copiloto IA / contexto ===== *@
        <div class="cv-side-col">
            @if (_active is null)
            {
                <div class="cv-side-empty">Aqui veras el contexto del cliente y las sugerencias del copiloto.</div>
            }
            else
            {
                @if (_activeLead is not null)
                {
                    <div class="cv-context">
                        <div class="cv-ctx-title">Lead vinculado</div>
                        <div class="cv-ctx-name">@_activeLead.ContactName</div>
                        <div class="cv-ctx-rows">
                            @if (!string.IsNullOrWhiteSpace(_activeLead.Destination))
                            {
                                <div><span>Destino</span><strong>@_activeLead.Destination</strong></div>
                            }
                            @if (_activeLead.EstimatedValue is decimal v)
                            {
                                <div><span>Valor</span><strong>@Money(v, _activeLead.Currency)</strong></div>
                            }
                            <div><span>Estado</span><strong>@StatusText(_activeLead.Status)</strong></div>
                        </div>
                        <a class="btn btn-outline-secondary btn-sm" href="pipeline" style="margin-top:10px;width:100%;">Abrir en Pipeline</a>
                    </div>
                }
                else
                {
                    <div class="cv-context">
                        <div class="cv-ctx-title">Sin lead vinculado</div>
                        <div class="text-muted" style="font-size:12px;">Esta conversacion aun no esta asociada a un lead del embudo.</div>
                    </div>
                }

                <div class="cv-copilot">
                    <div class="cv-copilot-head">
                        <span class="cv-bot"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg></span>
                        <span class="cv-copilot-lbl">Copiloto IA</span>
                        <span class="cv-soon">Proximamente</span>
                    </div>
                    <div class="cv-copilot-note">
                        Cuando configures un agente en <a href="agentes">Agentes IA</a>, aqui apareceran sugerencias de respuesta y un resumen automatico de la conversacion.
                    </div>
                </div>
            }
        </div>
    </div>
}

@* ===== Modal: gestor de mensajes pregrabados ===== *@
@if (_tplManagerOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:620px;">
            <div class="modal-head">
                <h3>Mensajes pregrabados</h3>
                <button class="modal-close" @onclick="() => _tplManagerOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Categoria</label>
                    <input class="form-control" list="cv-tpl-cats" @bind="_tplFormCategory" placeholder="Elige una o escribe una nueva" autocomplete="off" />
                    <datalist id="cv-tpl-cats">
                        @foreach (var cat in QrCategories)
                        {
                            <option value="@cat.Key">@cat.Label</option>
                        }
                    </datalist>
                    <div class="text-muted" style="font-size:11px;margin-top:3px;">Escribe un nombre nuevo para crear otra categoria.</div>
                </div>
                <div class="field">
                    <label class="form-label">Nombre (opcional)</label>
                    <input class="form-control" @bind="_tplFormName" placeholder="Etiqueta corta, ej. Saludo inicial" autocomplete="off" maxlength="120" />
                    <div class="text-muted" style="font-size:11px;margin-top:3px;">Si lo defines, se muestra en el chip y en el comando "/".</div>
                </div>
                <div class="field">
                    <label class="form-label">Mensaje</label>
                    <textarea class="form-control" rows="2" @bind="_tplFormBody" placeholder="Usa {asesor} y {destino} para personalizar"></textarea>
                </div>
                <div class="field">
                    <label class="form-label">Adjunto (opcional)</label>
                    @if (_tplFormMediaUrl is not null)
                    {
                        <div style="display:flex;align-items:center;gap:8px;">
                            <span class="pl-chip">@MediaIcon(_tplFormMediaType) @_tplFormMediaType</span>
                            <button class="btn btn-outline-danger" style="padding:2px 8px;" @onclick="ClearTemplateMedia">Quitar</button>
                        </div>
                    }
                    else
                    {
                        <InputFile OnChange="OnTemplateMediaAsync" accept="image/*,video/*,audio/*" class="form-control" style="max-width:280px;" />
                    }
                </div>
                @if (_tplFormError is not null)
                {
                    <div class="text-danger small">@_tplFormError</div>
                }
                <div style="display:flex;gap:8px;margin:4px 0 14px;">
                    <button class="btn btn-primary" @onclick="SaveTemplateAsync" disabled="@_tplBusy">@(_tplEditId is null ? "+ Agregar" : "Guardar cambios")</button>
                    @if (_tplEditId is not null)
                    {
                        <button class="btn btn-outline-secondary" @onclick="ResetTemplateForm">Cancelar edicion</button>
                    }
                </div>

                <hr style="border-color:var(--border);" />
                @foreach (var cat in QrCategories)
                {
                    var items = _templates.Where(t => t.Category == cat.Key).OrderBy(t => t.SortOrder).ToList();
                    <div class="pl-stagegroup-title" style="margin-top:10px;">@cat.Label (@items.Count)</div>
                    @foreach (var t in items)
                    {
                        <div class="cfg-row">
                            <div class="grow">
                                @if (!string.IsNullOrWhiteSpace(t.Name))
                                {
                                    <div style="font-size:12.5px;font-weight:600;">@t.Name</div>
                                }
                                <div style="font-size:13px;color:@(string.IsNullOrWhiteSpace(t.Name) ? "inherit" : "var(--muted-foreground)");">
                                    @if (t.MediaType != MessageMediaType.None) { <span>@MediaIcon(t.MediaType) </span> }
                                    @(string.IsNullOrWhiteSpace(t.Body) ? "(solo adjunto)" : t.Body)
                                </div>
                            </div>
                            <button class="btn btn-outline-secondary" style="padding:2px 8px;" @onclick="() => EditTemplate(t)">Editar</button>
                            <button class="btn btn-outline-danger" style="padding:2px 8px;" @onclick="() => DeleteTemplateAsync(t.Id)" disabled="@_tplBusy">Eliminar</button>
                        </div>
                    }
                }
            </div>
            <div class="modal-foot">
