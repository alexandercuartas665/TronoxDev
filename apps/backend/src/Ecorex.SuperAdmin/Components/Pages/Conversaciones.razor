    private void EditTemplate(MessageTemplateDto t)
    {
        _tplEditId = t.Id;
        _tplFormCategory = t.Category;
        _tplFormName = t.Name;
        _tplFormBody = t.Body;
        _tplFormMediaType = t.MediaType;
        _tplFormMediaUrl = t.MediaUrl;
        _tplFormMediaMime = t.MediaMimeType;
