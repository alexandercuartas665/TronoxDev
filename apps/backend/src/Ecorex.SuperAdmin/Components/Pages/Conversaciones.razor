    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) { return "?"; }
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1
            ? parts[0][..1].ToUpperInvariant()
            : (parts[0][..1] + parts[^1][..1]).ToUpperInvariant();
    }

    private static string TimeLabel(DateTimeOffset? at)
    {
        if (at is not DateTimeOffset dt) { return ""; }
        var local = dt.LocalDateTime;
        var today = DateTime.Now.Date;
        if (local.Date == today) { return local.ToString("HH:mm"); }
        if (local.Date == today.AddDays(-1)) { return "Ayer"; }
        return local.ToString("dd/MM");
    }

    private static string MaskPhone(string? phone)
    {
        if (string.IsNullOrWhiteSpace(phone)) { return ""; }
        var digits = new string(phone.Where(char.IsDigit).ToArray());
        if (digits.Length <= 4) { return "+" + digits; }
        return $"+{digits[..^4]} ··· {digits[^4..]}";
    }

    private static string MapsLink(string? coords) => $"https://www.google.com/maps?q={coords}";
    private static string Money(decimal v, string? currency) => $"$ {v:N0}{(string.IsNullOrWhiteSpace(currency) ? "" : " " + currency)}";
    private static string StatusText(LeadStatus status) => status switch
    {
        LeadStatus.Won => "Ganado",
        LeadStatus.Lost => "Perdido",
        _ => "Abierto"
    };

