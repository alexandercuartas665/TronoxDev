    private void ResetTemplateForm()
    {
        _tplEditId = null;
        _tplFormName = null;
        _tplFormBody = null;
        _tplFormMediaType = MessageMediaType.None;
        _tplFormMediaUrl = null;
        _tplFormMediaMime = null;
        _tplFormError = null;
    }

    private void ClearTemplateMedia()
    {
        _tplFormMediaType = MessageMediaType.None;
        _tplFormMediaUrl = null;
        _tplFormMediaMime = null;
    }

    private async Task OnTemplateMediaAsync(InputFileChangeEventArgs e)
    {
        _tplFormError = null;
        var mime = e.File.ContentType ?? "";
        var type = mime.StartsWith("image") ? MessageMediaType.Image
            : mime.StartsWith("video") ? MessageMediaType.Video
            : mime.StartsWith("audio") ? MessageMediaType.Audio
            : MessageMediaType.Document;
        var saved = await SaveChatFileAsync(e.File, type);
        if (saved is null) { _tplFormError = "Archivo invalido o supera 16 MB."; return; }
        _tplFormMediaType = type;
        _tplFormMediaUrl = saved.Value.Url;
        _tplFormMediaMime = saved.Value.Mime;
    }

    private async Task SaveTemplateAsync()
    {
        _tplFormError = null;
        if (string.IsNullOrWhiteSpace(_tplFormBody) && _tplFormMediaUrl is null)
        {
            _tplFormError = "Escribe un mensaje o adjunta un archivo.";
            return;
        }
        _tplBusy = true;
        try
        {
            var actor = await ActorAsync();
            if (_tplEditId is null)
            {
                await TemplatesSvc.CreateAsync(new CreateMessageTemplateRequest(_tplFormCategory, _tplFormBody ?? "", _tplFormMediaType, _tplFormMediaUrl, _tplFormMediaMime, _tplFormName), actor);
            }
            else
            {
                await TemplatesSvc.UpdateAsync(_tplEditId.Value, new UpdateMessageTemplateRequest(_tplFormCategory, _tplFormBody ?? "", _tplFormMediaType, _tplFormMediaUrl, _tplFormMediaMime, _tplFormName), actor);
            }
            _templates = (await TemplatesSvc.ListAsync()).ToList();
            ResetTemplateForm();
        }
        finally { _tplBusy = false; }
    }

    private async Task DeleteTemplateAsync(Guid id)
    {
        _tplBusy = true;
        try
        {
            var actor = await ActorAsync();
            await TemplatesSvc.DeleteAsync(id, actor);
            _templates = (await TemplatesSvc.ListAsync()).ToList();
            if (_tplEditId == id) { ResetTemplateForm(); }
        }
        finally { _tplBusy = false; }
    }

    private async Task<(string Url, string Base64, string Mime, string Name)?> SaveChatFileAsync(IBrowserFile file, MessageMediaType type)
    {
        const long max = 16L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { return null; }
        using var ms = new MemoryStream();
        await file.OpenReadStream(max).CopyToAsync(ms);
        var bytes = ms.ToArray();
        var ext = System.IO.Path.GetExtension(file.Name);
        if (string.IsNullOrWhiteSpace(ext))
        {
            ext = type switch
            {
                MessageMediaType.Image => ".jpg",
                MessageMediaType.Video => ".mp4",
                MessageMediaType.Audio => ".ogg",
                _ => ".bin"
            };
        }
        var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", "chat");
        System.IO.Directory.CreateDirectory(dir);
        var name = $"chat-{Guid.NewGuid():N}{ext}";
        await System.IO.File.WriteAllBytesAsync(System.IO.Path.Combine(dir, name), bytes);
        var mime = string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType;
        return ($"/uploads/chat/{name}", Convert.ToBase64String(bytes), mime, file.Name);
    }

    private async Task<string?> ReadLocalBase64Async(string localUrl)
    {
        var rel = localUrl.TrimStart('/').Replace('/', System.IO.Path.DirectorySeparatorChar);
        var path = System.IO.Path.Combine(Env.WebRootPath, rel);
        if (!System.IO.File.Exists(path)) { return null; }
        return Convert.ToBase64String(await System.IO.File.ReadAllBytesAsync(path));
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

