@page "/bitacora-agente"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@using Ecorex.Domain.Enums
@inject IAiAgentLineService AgentLinesSvc
@inject IJSRuntime JS

<PageTitle>Bitacora del agente - ECOREX.tareas</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
            </div>
            <span>Comunicacion e IA</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Bitacora del <span>agente</span></h1>
        <p class="page-sub" style="margin-bottom:0;">Revisa como atendio el agente cada conversacion: mensaje recibido, prompts enviados a la IA, herramientas usadas y respuesta.</p>
    </div>
    <div style="display:flex;gap:8px;align-self:flex-start;flex-wrap:wrap;">
        <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@(_loading || _busy)">Actualizar</button>
        <button class="btn btn-outline-danger" @onclick="ClearAllAsync" disabled="@(_loading || _busy || _convs.Count == 0)"
                title="Borra TODA la bitacora de la empresa y el cache de datos capturados por los agentes (deja al agente en cero). No toca mensajes del chat ni leads.">
            @(_busy ? "Borrando..." : "Limpiar historial")
        </button>
    </div>
</div>

@if (_flash is not null)
{
    <div class="cv-warn" style="background:#ecfdf5;border-color:#a7f3d0;color:#065f46;display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
        <span>@_flash</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _flash = null">Cerrar</button>
    </div>
}

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div style="display:grid;grid-template-columns:minmax(300px,400px) 1fr;gap:22px;align-items:start;">
        <div class="card" style="padding:14px;">
            @if (_convs.Count == 0)
            {
                <p class="text-muted" style="padding:8px 2px;">Aun no hay atenciones registradas. Cuando un agente atienda una linea, apareceran aqui.</p>
            }
            else
            {
                <div style="display:flex;flex-direction:column;gap:4px;max-height:68vh;overflow-y:auto;">
                    @foreach (var c in _convs)
                    {
                        <div style="display:flex;align-items:center;gap:10px;padding:9px;border-radius:10px;cursor:pointer;@(_selectedId == c.ConversationId ? "background:var(--primary-soft);" : "")" @onclick="() => SelectAsync(c.ConversationId)">
                            <span style="width:38px;height:38px;border-radius:50%;flex-shrink:0;display:grid;place-items:center;color:#fff;font-weight:800;font-size:12px;background:var(--gradient-violet);">@Initials(c.ContactName ?? c.ContactPhone)</span>
                            <div style="flex:1;min-width:0;">
                                <div style="font-weight:700;font-size:13px;">@(string.IsNullOrWhiteSpace(c.ContactName) ? c.ContactPhone : c.ContactName)</div>
                                <div class="text-muted" style="font-size:11px;">@c.ContactPhone @(c.LineLabel is null ? "" : $"- linea {c.LineLabel}")</div>
                            </div>
                            <div style="text-align:right;">
                                <span class="badge bg-secondary">@c.Events</span>
                                <div class="text-muted" style="font-size:10.5px;">@(c.LastActivityAt?.ToLocalTime().ToString("dd MMM HH:mm") ?? "")</div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="card" style="padding:22px;">
            @if (_selectedId is not null)
            {
                <div style="display:flex;justify-content:flex-end;margin-bottom:12px;">
                    <button class="btn btn-sm btn-outline-danger" @onclick="ResetConversationAsync" disabled="@_busy"
                            title="Borra logs + cache + mensajes del chat de esta conversacion. El agente arranca de cero en el siguiente mensaje. No toca el lead.">
                        @(_busy ? "Reiniciando..." : "Reiniciar conversacion")
                    </button>
                </div>
            }
            @if (_selectedId is null)
            {
                <p class="text-muted" style="padding:24px 0;text-align:center;">Selecciona una conversacion para ver su bitacora de atencion.</p>
            }
            else if (_log.Count == 0)
            {
                <p class="text-muted">Sin eventos en esta conversacion.</p>
            }
            else
            {
                <div style="display:flex;flex-direction:column;gap:12px;">
                    @foreach (var e in _log)
                    {
                        <div style="border-left:3px solid @KindColor(e.Kind);padding:6px 0 6px 14px;">
                            <div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;align-items:center;">
                                <strong style="font-size:13.5px;"><span class="badge @KindBadge(e.Kind)" style="margin-right:6px;">@KindLabel(e.Kind)</span>@e.Title</strong>
                                <span class="text-muted" style="font-size:11.5px;">@e.OccurredAt.ToLocalTime().ToString("dd-MM-yyyy HH:mm:ss")</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(e.Content))
                            {
                                <textarea class="form-control" rows="@Rows(e.Content!)" readonly style="margin-top:6px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:11px;line-height:1.45;white-space:pre;">@e.Content</textarea>
                            }
                            @if (!string.IsNullOrWhiteSpace(e.Response))
                            {
                                <div class="text-muted" style="font-size:11px;margin-top:4px;">Resultado / respuesta:</div>
                                <textarea class="form-control" rows="@Rows(e.Response!)" readonly style="font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:11px;line-height:1.45;white-space:pre;">@e.Response</textarea>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _busy;
    private string? _flash;
    private List<AgentConversationDto> _convs = new();
    private Guid? _selectedId;
    private List<AgentRunLogEntryDto> _log = new();

    private async Task ClearAllAsync()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Vaciar TODA la bitacora del agente y el cache de datos capturados? Es irreversible. No borra mensajes del chat ni leads.")) { return; }
        _busy = true; _flash = null;
        try
        {
            var (logs, cache) = await AgentLinesSvc.ClearAllLogsAsync();
            _selectedId = null; _log = new();
            await ReloadAsync();
            _flash = $"Bitacora vaciada: {logs} evento(s) y {cache} dato(s) de cache eliminados. El agente arranca de cero.";
        }
        finally { _busy = false; }
    }

    private async Task ResetConversationAsync()
    {
        if (_selectedId is not Guid id) { return; }
        if (!await JS.InvokeAsync<bool>("confirm", "Reiniciar esta conversacion? Borra sus logs, su cache y los mensajes del chat. El agente arranca de cero en el siguiente mensaje. No toca el lead.")) { return; }
        _busy = true; _flash = null;
        try
        {
            var (logs, cache, messages) = await AgentLinesSvc.ResetConversationMemoryAsync(id);
            _selectedId = null; _log = new();
            await ReloadAsync();
            _flash = $"Conversacion reiniciada: {logs} log(s), {cache} dato(s) de cache y {messages} mensaje(s) eliminados.";
        }
        finally { _busy = false; }
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        _loading = false;
    }

    private async Task ReloadAsync()
    {
        _convs = (await AgentLinesSvc.ListAttendedConversationsAsync()).ToList();
        if (_selectedId is Guid id && _convs.All(c => c.ConversationId != id)) { _selectedId = null; _log = new(); }
    }

    private async Task SelectAsync(Guid id)
    {
        _selectedId = id;
        _log = (await AgentLinesSvc.GetConversationLogAsync(id)).ToList();
    }

    private static int Rows(string s)
    {
        var lines = s.Count(c => c == '\n') + 1;
        return Math.Clamp(lines, 2, 16);
    }

    private static string KindLabel(AiAgentRunLogKind k) => k switch
    {
        AiAgentRunLogKind.Inbound => "Recibido",
        AiAgentRunLogKind.Prompt => "Prompt IA",
        AiAgentRunLogKind.Tool => "Herramienta",
        AiAgentRunLogKind.Reply => "Respuesta",
        AiAgentRunLogKind.Error => "Error",
        _ => "Info"
    };

    private static string KindBadge(AiAgentRunLogKind k) => k switch
    {
        AiAgentRunLogKind.Inbound => "bg-secondary",
        AiAgentRunLogKind.Prompt => "bg-info",
        AiAgentRunLogKind.Tool => "bg-primary",
        AiAgentRunLogKind.Reply => "bg-success",
        AiAgentRunLogKind.Error => "bg-danger",
        _ => "bg-secondary"
    };

    private static string KindColor(AiAgentRunLogKind k) => k switch
    {
        AiAgentRunLogKind.Reply => "var(--success)",
        AiAgentRunLogKind.Tool => "var(--primary)",
        AiAgentRunLogKind.Error => "var(--destructive)",
        _ => "var(--border)"
    };

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) { return "?"; }
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1 ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant() : $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
    }
}
