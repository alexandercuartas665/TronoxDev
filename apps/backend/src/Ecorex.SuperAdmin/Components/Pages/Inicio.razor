@page "/inicio"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode InteractiveServer
@using System.Globalization
@using Ecorex.Application.Common
@using Ecorex.Application.Tenancy
@using Ecorex.SuperAdmin.Components.Shared.Tasks
@using Microsoft.EntityFrameworkCore
@inject IServiceScopeFactory ScopeFactory
@using Microsoft.Extensions.DependencyInjection

@* Dashboard /inicio del workspace, fiel al fuente del prototipo (ECOREX.dc.html):
   fecha + saludo 32/800 + resumen, boton negro con icono "+", 4 KPI cards (icono
   en tile t-violet/t-green/t-blue/t-rose, valor 34/800, label 13) y paneles
   "Mis tareas de hoy" (1.65fr) + "Alertas del sistema" (1fr). Datos reales.
   Se prerenderiza (KPIs en el HTML inicial) y el circuito habilita el wizard. *@

<PageTitle>Inicio - ECOREX.tareas</PageTitle>

<div class="dash">
    <div class="dash-head">
        <div>
            <div class="dash-today">@TodayLabel</div>
            <h1 class="dash-title">@_greeting@(_firstName is null ? "" : $", {_firstName}")</h1>
            <p class="dash-sub">
                Tienes <b>@_activeTasks @(_activeTasks == 1 ? "tarea" : "tareas")</b> y
                <b>@_alerts @(_alerts == 1 ? "alerta" : "alertas")</b> pendientes en @(_tenantName ?? "tu workspace").
            </p>
        </div>
        <button class="dash-new" @onclick="OpenWizardAsync">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
            Nueva actividad
        </button>
    </div>

    <div class="dash-kpis">
        <div class="dash-kpi">
            <div class="dash-kpi-top">
                <div class="dash-kpi-ico tv">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m9 12 2 2 4-4"/></svg>
                </div>
                @if (_tasksCreatedToday > 0)
                {
                    <span class="dash-kpi-delta tg" title="Tareas creadas hoy">+@_tasksCreatedToday</span>
                }
            </div>
            <div class="dash-kpi-value">@_activeTasks</div>
            <div class="dash-kpi-label">Tareas activas</div>
        </div>
        <div class="dash-kpi">
            <div class="dash-kpi-top">
                <div class="dash-kpi-ico tg">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
                </div>
                @if (_projectsCreatedThisMonth > 0)
                {
                    <span class="dash-kpi-delta tg" title="Proyectos creados este mes">+@_projectsCreatedThisMonth</span>
                }
            </div>
            <div class="dash-kpi-value">@_projectsInProgress</div>
            <div class="dash-kpi-label">Proyectos en curso</div>
        </div>
        <div class="dash-kpi">
            <div class="dash-kpi-top">
                <div class="dash-kpi-ico tb">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="8" x="3" y="3" rx="2"/><path d="M7 11v4a2 2 0 0 0 2 2h4"/><rect width="8" height="8" x="13" y="13" rx="2"/></svg>
                </div>
                @if (_stuckFlows > 0)
                {
                    <span class="dash-kpi-delta ta" title="Instancias de flujo atascadas">@_stuckFlows en pausa</span>
                }
            </div>
            <div class="dash-kpi-value">@_runningFlows</div>
            <div class="dash-kpi-label">Flujos ejecutandose</div>
        </div>
        <div class="dash-kpi">
            <div class="dash-kpi-top">
                <div class="dash-kpi-ico tr">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                </div>
                @if (_alerts > 0)
                {
                    <span class="dash-kpi-delta tr">urgente</span>
                }
            </div>
            <div class="dash-kpi-value">@_alerts</div>
            <div class="dash-kpi-label">Alertas</div>
        </div>
    </div>

    <div class="dash-panels">
        <div class="dash-card">
            <div class="dash-card-head">
                <div class="dash-card-title">Mis tareas de hoy</div>
                <a class="dash-card-link" href="/actividades">Ver tablero &rarr;</a>
            </div>
            <div>
                @if (_myToday.Count == 0)
                {
                    <div class="dash-empty">No tienes tareas con vencimiento para hoy. Buen trabajo.</div>
                }
                else
                {
                    @foreach (var t in _myToday)
                    {
                        <a class="dash-task" href="/actividades" title="@t.Title">
                            <span class="dash-task-dot @PrioTone(t.Priority)"></span>
                            <div class="dash-task-main">
                                <div class="dash-task-title">@t.Title</div>
                                <div class="dash-task-sub">@(t.ActivityTypeName ?? t.Number)</div>
                            </div>
                            <span class="dash-prio @PrioTone(t.Priority)">@TaskUi.PriorityLabel(t.Priority)</span>
                            <span class="dash-task-due @(IsOverdue(t) ? "late" : "")">@DueLabel(t)</span>
                        </a>
                    }
                }
            </div>
        </div>

        <div class="dash-card">
            <div class="dash-card-head">
                <div class="dash-card-title">Alertas del sistema</div>
                @if (_alerts > 0)
                {
                    <span class="dash-chip tr">@_alerts @(_alerts == 1 ? "nueva" : "nuevas")</span>
                }
            </div>
            <div>
                @if (_overdue.Count == 0)
                {
                    <div class="dash-empty">Sin alertas: no hay tareas vencidas.</div>
                }
                else
                {
                    @foreach (var t in _overdue)
                    {
                        <div class="dash-alert">
                            <div class="dash-alert-ico">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                            </div>
                            <div style="min-width:0;">
                                <div class="dash-alert-title">@t.Title</div>
                                <div class="dash-alert-meta">Vencida @(t.DueDate is { } d ? "el " + d.LocalDateTime.ToString("d MMM", Es) : "") @(string.IsNullOrEmpty(t.Number) ? "" : "\u00b7 " + t.Number)</div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    @* ===== Seccion Modulos (prototipo): headers de categoria con punto de color
           y cards con tile de icono, descripcion corta y pie "Ir al modulo" + codigo
           legacy. Solo areas que existen hoy en ECOREX. ===== *@
    <div class="dash-mods-head">
        <h2>Modulos</h2>
        <span>Accede a cualquier area del sistema</span>
    </div>

    <div class="dash-modsec">
        <div class="dash-modsec-head">
            <span class="dash-modsec-dot tv"></span>
            <div class="dash-modsec-name">OPERACIONES</div>
            <span class="dash-modsec-desc">Ejecucion de actividades, proyectos y servicios</span>
        </div>
        <div class="dash-mod-grid">
            <a class="dash-mod" href="/proyectos">
                <div class="dash-mod-top">
                    <div class="dash-mod-ico tv">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z"/></svg>
                    </div>
                    <div class="dash-mod-title">Proyectos</div>
                </div>
                <p class="dash-mod-desc">Agrupa actividades, ideas y recursos para gestionar tu proyecto de forma organizada.</p>
                <div class="dash-mod-foot">
                    <span class="dash-mod-go">Ir al modulo
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                    </span>
                    <span class="dash-mod-code">000042</span>
                </div>
            </a>
            <a class="dash-mod" href="/actividades">
                <div class="dash-mod-top">
                    <div class="dash-mod-ico tv">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="4"/><path d="m8 12 3 3 5-6"/></svg>
                    </div>
                    <div class="dash-mod-title">Administrar actividades</div>
                </div>
                <p class="dash-mod-desc">Controla ciclos de flujo de trabajo y eleva cada necesidad de tu empresa.</p>
                <div class="dash-mod-foot">
                    <span class="dash-mod-go">Ir al modulo
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                    </span>
                    <span class="dash-mod-code">000636</span>
                </div>
            </a>
            <a class="dash-mod" href="/tableros">
                <div class="dash-mod-top">
                    <div class="dash-mod-ico tv">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/></svg>
                    </div>
                    <div class="dash-mod-title">Gestor de tareas</div>
                </div>
                <p class="dash-mod-desc">Tableros kanban con columnas, etiquetas y checklists para organizar el trabajo del equipo.</p>
                <div class="dash-mod-foot">
                    <span class="dash-mod-go">Ir al modulo
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                    </span>
                </div>
            </a>
        </div>
    </div>

    <div class="dash-modsec">
        <div class="dash-modsec-head">
            <span class="dash-modsec-dot tb"></span>
            <div class="dash-modsec-name">AUTOMATIZACION</div>
            <span class="dash-modsec-desc">Flujos, formularios e inteligencia</span>
        </div>
        <div class="dash-mod-grid">
            <a class="dash-mod" href="/flujos">
                <div class="dash-mod-top">
                    <div class="dash-mod-ico tb">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="6" height="6" rx="1.4"/><rect x="16" y="15" width="6" height="6" rx="1.4"/><path d="M5 9v3a4 4 0 0 0 4 4h7"/></svg>
                    </div>
                    <div class="dash-mod-title">Flujos del proceso</div>
                </div>
                <p class="dash-mod-desc">Disena y ejecuta flujos BPMN 2.0 con asignacion de usuarios y reglas.</p>
                <div class="dash-mod-foot">
                    <span class="dash-mod-go">Ir al modulo
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                    </span>
                    <span class="dash-mod-code">000291</span>
                </div>
            </a>
            <a class="dash-mod" href="/formularios">
                <div class="dash-mod-top">
                    <div class="dash-mod-ico tb">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2.5"/><path d="M9 8h6M9 12h6M9 16h3"/></svg>
                    </div>
                    <div class="dash-mod-title">Formularios</div>
                </div>
                <p class="dash-mod-desc">Construye formularios dinamicos con 19 tipos de control sobre el motor EAV.</p>
                <div class="dash-mod-foot">
                    <span class="dash-mod-go">Ir al modulo
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                    </span>
                    <span class="dash-mod-code">000131</span>
                </div>
            </a>
            <a class="dash-mod" href="/reglas">
                <div class="dash-mod-top">
                    <div class="dash-mod-ico tb">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/></svg>
                    </div>
                    <div class="dash-mod-title">Reglas</div>
                </div>
                <p class="dash-mod-desc">Motor de reglas de negocio: valida, calcula y automatiza sobre formularios y flujos.</p>
                <div class="dash-mod-foot">
                    <span class="dash-mod-go">Ir al modulo
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                    </span>
                    <span class="dash-mod-code">000802</span>
                </div>
            </a>
        </div>
    </div>
</div>

<TaskWizard @ref="_wizard" OnCreated="OnTaskCreatedAsync" />

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private static readonly CultureInfo Es = new("es-CO");

    private static readonly TaskItemStatus[] ActiveStatuses =
    [
        TaskItemStatus.Pending,
        TaskItemStatus.Active,
        TaskItemStatus.InProgress
    ];

    private TaskWizard? _wizard;

    private string _greeting = "Hola";
    private string? _firstName;
    private string? _tenantName;

    private int _activeTasks;
    private int _projectsInProgress;
    private int _runningFlows;
    private int _alerts;
    // Badges de los KPI (prototipo: "+3", "+1", "2 en pausa"); ocultos cuando valen 0.
    private int _tasksCreatedToday;
    private int _projectsCreatedThisMonth;
    private int _stuckFlows;
    private List<TaskItemSummaryDto> _myToday = [];
    private List<TaskItemSummaryDto> _overdue = [];

    private static string TodayLabel
    {
        get
        {
            var s = DateTime.Now.ToString("dddd d 'de' MMMM, yyyy", Es);
            return char.ToUpper(s[0], Es) + s[1..];
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var hour = DateTime.Now.Hour;
        _greeting = hour < 12 ? "Buenos dias" : hour < 18 ? "Buenas tardes" : "Buenas noches";

        Guid? platformUserId = null;
        Guid? tenantId = null;
        if (AuthState is not null)
        {
            var state = await AuthState;
            _firstName = state.User.Identity?.Name?.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
            if (Guid.TryParse(state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var uid)) { platformUserId = uid; }
            if (Guid.TryParse(state.User.FindFirst("tenant_id")?.Value, out var tid)) { tenantId = tid; }
        }

        // Scope propio para NO compartir el DbContext del request con NavMenu/MainLayout
        // durante el prerender ("second operation started on this context"). El tenant se
        // fija explicitamente: en el circuito interactivo (SignalR) no hay HttpContext y
        // sin esto el filtro global queda fail-closed y los KPIs muestran cero.
        using var ambient = tenantId is Guid ambientTenant
            ? Ecorex.SuperAdmin.Auth.AmbientTenantContext.Begin(ambientTenant, platformUserId)
            : null;
        await using var scope = ScopeFactory.CreateAsyncScope();
        var tenants = scope.ServiceProvider.GetRequiredService<ITenantAdminService>();
        var tasksSvc = scope.ServiceProvider.GetRequiredService<ITaskItemService>();
        var projectsSvc = scope.ServiceProvider.GetRequiredService<IProjectService>();
        var tenantUsersSvc = scope.ServiceProvider.GetRequiredService<ITenantUserService>();
        var db = scope.ServiceProvider.GetRequiredService<IApplicationDbContext>();

        if (tenantId is Guid tenId)
        {
            _tenantName = (await tenants.GetAsync(tenId))?.Name;
        }

        // Npgsql solo acepta DateTimeOffset con offset 0 en "timestamp with time zone".
        var now = DateTimeOffset.UtcNow;

        // KPI 1: tareas en estados activos (solo cuenta: PageSize 1 y se usa TotalCount).
        _activeTasks = (await tasksSvc.ListAsync(new TaskItemListFilter(Statuses: ActiveStatuses, PageSize: 1))).TotalCount;

        // KPI 2: proyectos en curso (no archivados, no cerrados ni cancelados).
        var projects = await projectsSvc.ListAsync();
        _projectsInProgress = projects.Count(p => p.Status is ProjectStatus.Planning or ProjectStatus.Active or ProjectStatus.InExecution);

        // KPI 3: instancias de flujo Running (el query filter de EF aisla el tenant activo).
        _runningFlows = await db.WorkflowInstances.CountAsync(i => i.Status == WorkflowInstanceStatus.Running);

        // Badges de los KPI (deltas del prototipo, calculados con datos reales; 0 => oculto).
        var todayStart = new DateTimeOffset(DateTime.Today).ToUniversalTime();
        var monthStart = new DateTimeOffset(new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1)).ToUniversalTime();
        _tasksCreatedToday = await db.TaskItems.CountAsync(t => t.CreatedAt >= todayStart);
        _projectsCreatedThisMonth = await db.Projects.CountAsync(p => p.CreatedAt >= monthStart);
        _stuckFlows = await db.WorkflowInstances.CountAsync(i => i.Status == WorkflowInstanceStatus.Stuck);

        // KPI 4 + panel de alertas: tareas vencidas (DueDate <= ahora) en estado activo.
        var overdue = await tasksSvc.ListAsync(new TaskItemListFilter(Statuses: ActiveStatuses, DueTo: now, PageSize: 10));
        _alerts = overdue.TotalCount;
        _overdue = overdue.Items.OrderBy(t => t.DueDate).Take(4).ToList();

        // Mis tareas de hoy: asignadas a mi (TenantUser del PlatformUser actual) con
        // vencimiento hoy o ya vencidas; max 5 ordenadas por fecha de entrega.
        if (platformUserId is Guid pid)
        {
            var me = (await tenantUsersSvc.ListAsync()).FirstOrDefault(u => u.PlatformUserId == pid);
            if (me is not null)
            {
                var endOfToday = new DateTimeOffset(DateTime.Today.AddDays(1).AddTicks(-1)).ToUniversalTime();
                var mine = await tasksSvc.ListAsync(new TaskItemListFilter(
                    Statuses: ActiveStatuses, AssigneeTenantUserId: me.Id, DueTo: endOfToday, PageSize: 50));
                _myToday = mine.Items.OrderBy(t => t.DueDate).Take(5).ToList();
            }
        }
    }

    private async Task OpenWizardAsync()
    {
        if (_wizard is not null) { await _wizard.OpenAsync(); }
    }

    private async Task OnTaskCreatedAsync(TaskItemDetailDto _)
    {
        // Refresca KPIs y paneles tras crear una actividad desde el wizard.
        await OnInitializedAsync();
        StateHasChanged();
    }

    /// <summary>Tono del prototipo por prioridad: Alta rose / Media amber / Baja green.</summary>
    private static string PrioTone(TaskPriority p) => p switch
    {
        TaskPriority.High => "tr",
        TaskPriority.Medium => "ta",
        _ => "tg"
    };

    private static bool IsOverdue(TaskItemSummaryDto t) => t.DueDate is { } d && d.LocalDateTime.Date < DateTime.Today;

    private static string DueLabel(TaskItemSummaryDto t)
    {
        if (t.DueDate is not { } d) { return ""; }
        var date = d.LocalDateTime.Date;
        if (date < DateTime.Today) { return "Vencida"; }
        if (date == DateTime.Today) { return "Hoy"; }
        return date.ToString("dd MMM", Es);
    }
}
