@page "/formularios/{Id:guid}/disenar"
@attribute [Authorize(Policy = "Formularios.Disenar")]
@* Policy por modulo (paso 1: mismo requisito que TenantMember, nombre estable). TODO: derivar del Module Registry. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Text.Json
@using Ecorex.Application.Forms
@using Ecorex.Application.Forms.Calc
@using Ecorex.Application.Forms.Lookups
@using Ecorex.Application.MenuConfig
@using Ecorex.Application.Rules
@using Ecorex.Domain.Enums
@using Ecorex.SuperAdmin.Components.Shared.Forms
@inject IFormDefinitionService FormsSvc
@inject IFormTokenService TokensSvc
@inject IRuleDocumentService RulesSvc
@inject IFormLookupService LookupSvc
@inject IMenuConfigService MenuSvc
@inject NavigationManager Nav

@* ============================================================
   CONSTRUCTOR DE FORMULARIOS del prototipo (ECOREX.dc.html,
   formBuilderOpen): modal grande de 3 columnas (276px paleta +
   estructura / lienzo con presets de dispositivo / 320px
   propiedades con tabs Diseno-Datos-Reglas). Fiel al pixel del
   fuente (ADR-0021). PERSISTE-POR-CAMBIO: cada mutacion llama al
   servicio real y recarga (el boton Guardar confirma/refresca).
   ============================================================ *@

<PageTitle>Constructor de formularios - ECOREX.tareas</PageTitle>

@if (_loading)
{
    <p style="padding:30px;"><em>Cargando constructor...</em></p>
}
else if (_def is null)
{
    <div style="padding:40px 24px;text-align:center;">
        <h3>Formulario no encontrado</h3>
        <button class="fb-btn-ghost" style="margin-top:14px;" @onclick="@(() => Nav.NavigateTo("/formularios"))">Volver a formularios</button>
    </div>
}
else
{
    <div class="fb-scrim">
        <div class="fb-shell">
            @* ===== Header ===== *@
            <div class="fb-header">
                <button class="fb-back" title="Volver" @onclick="@(() => Nav.NavigateTo("/formularios"))">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 6-6 6 6 6"/></svg>
                </button>
                <span class="fb-code">FORX-@_def.Code</span>
                @if (_editingTitle)
                {
                    <input class="fb-title-input" value="@_titleDraft" @oninput="@(e => _titleDraft = e.Value?.ToString() ?? "")"
                           @onblur="SaveTitleAsync" @onkeydown="@(async e => { if (e.Key == "Enter") { await SaveTitleAsync(); } })" />
                }
                else
                {
                    <div class="fb-title" title="Clic para renombrar" @onclick="@(() => { _titleDraft = _def.Title; _editingTitle = true; })">@_def.Title</div>
                }
                <span class="fb-status" style="background:@StatusSoft();color:@StatusColor()">@StatusLabel()</span>
                <div class="fb-header-actions">
                    <button class="fb-btn-ghost" @onclick="OpenFormProps">Propiedades</button>
                    <button class="fb-btn-ghost" @onclick="OpenPreview">Vista previa</button>
                    @if (_def.Status == FormStatus.Active)
                    {
                        <button class="fb-btn-ghost" @onclick="DeactivateAsync" disabled="@_busy">Desactivar</button>
                        <button class="fb-btn-ghost" @onclick="OpenTokenModal" disabled="@_busy">Publicar por URL</button>
                    }
                    else
                    {
                        <button class="fb-btn-ghost" @onclick="ActivateAsync" disabled="@_busy">Activar</button>
                    }
                    <button class="fb-btn-primary" @onclick="SaveFlashAsync" disabled="@_busy">@(_savedFlash ? "Guardado" : "Guardar")</button>
                    <button class="fb-btn-ghost" @onclick="@(() => Nav.NavigateTo("/formularios"))">Cerrar</button>
                </div>
            </div>

            @if (_pageError is not null)
            {
                <div class="fb-error">
                    <span>@_pageError</span>
                    <button class="fb-error-x" @onclick="@(() => _pageError = null)">&times;</button>
                </div>
            }

            <div class="fb-body">
                @* ===== IZQUIERDA: paleta + estructura ===== *@
                <aside class="fb-left">
                    <div class="fb-left-scroll">
                        <div class="fb-group-name">1&nbsp;&nbsp;ELEMENTOS</div>
                        <div class="fb-group-hint">Arrastra al lienzo para construir tu formulario</div>
                        <div class="fb-pal-card" draggable="true"
                             @onclick="@(() => AddPaletteAsync(PaletteKey.Contenedor))"
                             @ondragstart="@(() => _dragPalette = PaletteKey.Contenedor)">
                            <span class="fb-pal-ic" style="background:var(--t-violet-bg);color:var(--t-violet)">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                            </span>
                            <span class="fb-pal-tx"><span class="fb-pal-name">Contenedor</span><span class="fb-pal-desc">Filas, columnas o secciones</span></span>
                            <span class="fb-pal-grip">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="6" r="1"/><circle cx="15" cy="6" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="9" cy="18" r="1"/><circle cx="15" cy="18" r="1"/></svg>
                            </span>
                        </div>
                        <div class="fb-pal-card" draggable="true"
                             @onclick="@(() => AddPaletteAsync(PaletteKey.Input))"
                             @ondragstart="@(() => _dragPalette = PaletteKey.Input)">
                            <span class="fb-pal-ic" style="background:var(--t-blue-bg);color:var(--t-blue)">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="10" rx="2"/><path d="M7 12h2"/></svg>
                            </span>
                            <span class="fb-pal-tx"><span class="fb-pal-name">Input</span><span class="fb-pal-desc">Texto, fecha, lista, numero...</span></span>
                            <span class="fb-pal-grip">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="6" r="1"/><circle cx="15" cy="6" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="9" cy="18" r="1"/><circle cx="15" cy="18" r="1"/></svg>
                            </span>
                        </div>

                        <div class="fb-group-name" style="margin-top:8px;">2&nbsp;&nbsp;DOCUMENTO</div>
                        <div class="fb-group-hint">Construye cartas, contratos o instructivos</div>
                        <div class="fb-pal-card" draggable="true"
                             @onclick="@(() => AddPaletteAsync(PaletteKey.Parrafo))"
                             @ondragstart="@(() => _dragPalette = PaletteKey.Parrafo)">
                            <span class="fb-pal-ic" style="background:var(--t-amber-bg);color:var(--t-amber)">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
                            </span>
                            <span class="fb-pal-tx"><span class="fb-pal-name">Texto</span><span class="fb-pal-desc">Parrafos, encabezados, listas</span></span>
                            <span class="fb-pal-grip">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="6" r="1"/><circle cx="15" cy="6" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="9" cy="18" r="1"/><circle cx="15" cy="18" r="1"/></svg>
                            </span>
                        </div>
                        <div class="fb-pal-card" draggable="true"
                             @onclick="@(() => AddPaletteAsync(PaletteKey.Divisor))"
                             @ondragstart="@(() => _dragPalette = PaletteKey.Divisor)">
                            <span class="fb-pal-ic" style="background:var(--t-amber-bg);color:var(--t-amber)">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
                            </span>
                            <span class="fb-pal-tx"><span class="fb-pal-name">Divisor</span><span class="fb-pal-desc">Linea horizontal separadora</span></span>
                            <span class="fb-pal-grip">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="6" r="1"/><circle cx="15" cy="6" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="9" cy="18" r="1"/><circle cx="15" cy="18" r="1"/></svg>
                            </span>
                        </div>
                        <div class="fb-pal-card" draggable="true"
                             @onclick="@(() => AddPaletteAsync(PaletteKey.Espacio))"
                             @ondragstart="@(() => _dragPalette = PaletteKey.Espacio)">
                            <span class="fb-pal-ic" style="background:var(--t-amber-bg);color:var(--t-amber)">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 7 12 3l4 4M8 17l4 4 4-4M3 12h18"/></svg>
                            </span>
                            <span class="fb-pal-tx"><span class="fb-pal-name">Espacio</span><span class="fb-pal-desc">Espaciado vertical configurable</span></span>
                            <span class="fb-pal-grip">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="6" r="1"/><circle cx="15" cy="6" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="9" cy="18" r="1"/><circle cx="15" cy="18" r="1"/></svg>
                            </span>
                        </div>

                        <div class="fb-group-name fb-struct-head" style="margin:8px 0 3px;">3&nbsp;&nbsp;ESTRUCTURA <span class="fb-struct-count">@TotalNodes()</span></div>
                        <div class="fb-tree">
                            <div class="fb-tree-root" @onclick="@(() => Select(null))">
                                <span class="fb-tree-root-ic">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                                </span>
                                <span class="fb-tree-root-name">Formulario</span>
                                <span class="fb-tree-badge">@TotalNodes()</span>
                            </div>
                            @foreach (var row in TreeRows())
                            {
                                var node = row.Node;
                                <div class="fb-tree-row @(IsSelected(node) ? "sel" : "") @(node.Hidden ? "dim" : "")"
                                     style="padding-left:@(6 + row.Depth * 15)px"
                                     @onclick="@(() => Select(node))">
                                    @if (row.HasKids)
                                    {
                                        <span class="fb-tree-chev" @onclick="@(() => ToggleCollapse(node.Id))" @onclick:stopPropagation="true">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="transition:transform .16s;transform:rotate(@(_collapsed.Contains(node.Id) ? 0 : 90)deg)"><path d="m9 6 6 6-6 6"/></svg>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="fb-tree-spc"></span>
                                    }
                                    <span class="fb-tree-ic" style="color:@node.Reg.Color">@((MarkupString)IconSvg(node.Reg.Icon, 14))</span>
                                    <span class="fb-tree-name">@node.Label</span>
                                    <span class="fb-tree-badge">@row.Badge</span>
                                    <button class="fb-tree-tgl @(node.Locked ? "lock-on" : "")" title="Fijo / bloqueado"
                                            @onclick="@(() => ToggleLockAsync(node))" @onclick:stopPropagation="true">
                                        @((MarkupString)(node.Locked
                                            ? IconSvg("<rect x=\"4\" y=\"11\" width=\"16\" height=\"10\" rx=\"2\"/><path d=\"M8 11V7a4 4 0 0 1 8 0v4\"/>", 12)
                                            : IconSvg("<rect x=\"4\" y=\"11\" width=\"16\" height=\"10\" rx=\"2\"/><path d=\"M8 11V7a4 4 0 0 1 7-1\"/>", 12)))
                                    </button>
                                    <button class="fb-tree-tgl @(node.Hidden ? "eye-off" : "")" title="Visible / oculto"
                                            @onclick="@(() => ToggleHideAsync(node))" @onclick:stopPropagation="true">
                                        @((MarkupString)(node.Hidden
                                            ? IconSvg("<path d=\"M9.9 4.24A9.1 9.1 0 0 1 12 4c7 0 10 8 10 8a13 13 0 0 1-1.67 2.68M6.6 6.6A13 13 0 0 0 2 12s3 8 10 8a9 9 0 0 0 5.4-1.6M1 1l22 22\"/>", 12)
                                            : IconSvg("<path d=\"M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/>", 12)))
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </aside>

                @* ===== CENTRO: toolbar device + lienzo ===== *@
                <div class="fb-center">
                    <div class="fb-devicebar">
                        <div class="fb-devicetabs">
                            <button class="fb-devicetab @(_device == "navegador" ? "on" : "")" @onclick="@(() => _device = "navegador")">
                                @((MarkupString)IconSvg("<rect x=\"3\" y=\"4\" width=\"18\" height=\"14\" rx=\"2\"/><path d=\"M8 20h8M12 18v2\"/>", 15)) Navegador
                            </button>
                            <button class="fb-devicetab @(_device == "tableta" ? "on" : "")" @onclick="@(() => _device = "tableta")">
                                @((MarkupString)IconSvg("<rect x=\"3\" y=\"4\" width=\"18\" height=\"14\" rx=\"2\"/><path d=\"M8 20h8M12 18v2\"/>", 15)) Tableta
                            </button>
                            <button class="fb-devicetab @(_device == "movil" ? "on" : "")" @onclick="@(() => _device = "movil")">
                                @((MarkupString)IconSvg("<rect x=\"3\" y=\"4\" width=\"18\" height=\"14\" rx=\"2\"/><path d=\"M8 20h8M12 18v2\"/>", 15)) Movil
                            </button>
                        </div>
                        <span class="fb-devicelabel">A4 - 820x1180</span>
                    </div>
                    <div class="fb-canvas" @ondragover:preventDefault @ondrop="@(() => DropOnAsync(null, null))" @ondrop:preventDefault>
                        <div class="fb-sheet" style="width:@CanvasWidth()">
                            <div class="fb-sheet-grid" @onclick="@(() => Select(null))">
                                @foreach (var node in NodesOf(null))
                                {
                                    @RenderNode(node, inRow: true)
                                }
                                @if (NodesOf(null).Count == 0)
                                {
                                    <div class="fb-empty-root">Lienzo vacio - arrastra o toca un elemento de la paleta</div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                @* ===== DERECHA: propiedades ===== *@
                <aside class="fb-right">
                    <div class="fb-props-head">
                        <div class="fb-group-name" style="margin-bottom:9px;">4&nbsp;&nbsp;PROPIEDADES</div>
                        <div class="fb-props-id">
                            <span class="fb-props-ic" style="background:@(Sel?.Reg.Soft ?? "var(--surface-3)");color:@(Sel?.Reg.Color ?? "var(--ink-3)")">
                                @((MarkupString)IconSvg(Sel?.Reg.Icon ?? RegOf(FormControlType.Text).Icon, 18))
                            </span>
                            <div class="fb-props-tx">
                                <div class="fb-props-name">@(Sel?.Label ?? "Formulario")</div>
                                <div class="fb-props-tipo">@(Sel?.Reg.Tipo ?? "-")</div>
                            </div>
                        </div>
                    </div>
                    <div class="fb-props-tabs">
                        <button class="fb-props-tab @(_propTab == "diseno" ? "on" : "")" @onclick="@(() => _propTab = "diseno")">
                            @((MarkupString)IconSvg("<path d=\"M12 20h9M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z\"/>", 13)) Diseno
                        </button>
                        <button class="fb-props-tab @(_propTab == "datos" ? "on" : "")" @onclick="@(() => _propTab = "datos")">
                            @((MarkupString)IconSvg("<path d=\"m12 2 9 5v10l-9 5-9-5V7l9-5Z\"/><path d=\"m3 7 9 5 9-5M12 12v10\"/>", 13)) Datos
                        </button>
                        <button class="fb-props-tab @(_propTab == "reglas" ? "on" : "")" @onclick="@(() => _propTab = "reglas")">
                            @((MarkupString)IconSvg("<path d=\"M13 2 4 14h7l-1 8 9-12h-7l1-8Z\"/>", 13)) Reglas
                        </button>
                    </div>
                    <div class="fb-props-body">
                        @if (Sel is null)
                        {
                            <div class="fb-hint-box">
                                <div class="fb-group-name" style="margin-bottom:8px;">SUGERENCIA</div>
                                <p class="fb-hint-text">Selecciona un contenedor o un input en el lienzo o en el arbol para editar sus propiedades.</p>
                            </div>
                        }
                        else
                        {
                            @if (_propTab == "diseno")
                            {
                                @RenderDisenoTab(Sel)
                            }
                            else if (_propTab == "datos")
                            {
                                @RenderDatosTab(Sel)
                            }
                            else
                            {
                                @RenderReglasTab(Sel)
                            }
                            <button class="fb-del-btn" @onclick="@(() => DeleteNodeAsync(Sel))" disabled="@_busy">
                                @((MarkupString)IconSvg("<path d=\"M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6\"/>", 14))
                                Eliminar elemento
                            </button>
                        }
                    </div>
                </aside>
            </div>
        </div>
    </div>
}

@* ===== Modal vista previa (renderer real) ===== *@
@if (_showPreview && _def is not null)
{
    <div class="modal-overlay" style="z-index:70;" @onclick="@(() => _showPreview = false)">
        <div class="modal-dialog" style="max-width:820px;" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>Vista previa - @_def.Title</h3>
                <button class="modal-close" @onclick="@(() => _showPreview = false)">&times;</button>
            </div>
            <div class="modal-body">
                @* Fill real cuando el formulario esta activo (llenado end-to-end desde el
                   constructor, ADR-0021); Design (solo lectura) mientras es borrador. *@
                <DynamicFormRenderer DefinitionId="@_def.Id"
                                     Mode="@(_def.Status == FormStatus.Active ? FormRenderMode.Fill : FormRenderMode.Design)"
                                     Reference="@($"PREVIEW-{_def.Code}")" />
            </div>
        </div>
    </div>
}

@* ===== Modal publicar por URL (token) - misma estructura estable que la ola 2 (E2E) ===== *@
@if (_showTokenModal && _def is not null)
{
    <div class="modal-overlay" style="z-index:70;" @onclick="CloseTokenModal">
        <div class="modal-dialog" style="max-width:560px;" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>Publicar por URL</h3>
                <button class="modal-close" @onclick="CloseTokenModal">&times;</button>
            </div>
            <div class="modal-body">
                @if (_emittedUrl is null)
                {
                    <div class="field">
                        <label class="form-label">Referencia (opcional)</label>
                        <input class="form-control" @bind="_tReference" maxlength="100" placeholder="T00042" />
                    </div>
                    <div class="field-row">
                        <div class="field">
                            <label class="form-label">Expira en (horas)</label>
                            <input type="number" class="form-control" @bind="_tHours" min="1" max="8760" />
                        </div>
                        <div class="field" style="display:flex;flex-direction:column;justify-content:flex-end;gap:6px;">
                            <label class="pl-toggle"><input type="checkbox" @bind="_tSingleUse" /> Un solo uso</label>
                            <label class="pl-toggle"><input type="checkbox" @bind="_tAllowAnonymous" /> Permitir anonimo</label>
                        </div>
                    </div>
                    @if (_modalError is not null)
                    {
                        <div class="tk-field-error">@_modalError</div>
                    }
                }
                else
                {
                    <p style="font-size:13px;margin-bottom:8px;">
                        Comparte esta URL. <strong>Se muestra una sola vez</strong>: solo se guarda el hash del token.
                    </p>
                    <div class="fd-token-url">@_emittedUrl</div>
                    <p style="font-size:12px;color:var(--ink-3);margin-top:8px;">
                        Expira: @_emittedExpiresAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                    </p>
                }

                @if (_tokens.Count > 0)
                {
                    <div style="margin-top:16px;">
                        <label class="form-label">Tokens emitidos</label>
                        @foreach (var t in _tokens)
                        {
                            <div class="fd-token-row">
                                <span class="fd-token-state @TokenStateClass(t)">@TokenStateLabel(t)</span>
                                <span style="flex:1;">@(t.Reference ?? "(sin referencia)") - expira @t.ExpiresAt.ToLocalTime().ToString("dd MMM HH:mm")@(t.SingleUse ? " - un solo uso" : "")</span>
                                @if (t.RevokedAt is null)
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="@(() => RevokeTokenAsync(t.Id))" disabled="@_busy">Revocar</button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="CloseTokenModal" disabled="@_busy">Cerrar</button>
                @if (_emittedUrl is null)
                {
                    <button class="btn btn-primary" @onclick="EmitTokenAsync" disabled="@_busy">Emitir URL</button>
                }
            </div>
        </div>
    </div>
}

@* ===== Propiedades del formulario (ola F3): transaccionalidad + identidad ===== *@
@if (_showFormProps && _def is not null)
{
    <div class="modal-overlay" style="z-index:70;" @onclick="@(() => _showFormProps = false)">
        <div class="modal-dialog" style="max-width:520px;" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>Propiedades del formulario</h3>
                <button class="modal-close" @onclick="@(() => _showFormProps = false)">&times;</button>
            </div>
            <div class="modal-body">
                <label class="pl-toggle"><input type="checkbox" @bind="_txIsTransactional" /> Es transaccional (cada envio confirmado es un registro)</label>
                @if (_txIsTransactional)
                {
                    <div class="field" style="margin-top:14px;">
                        <label class="form-label">Identidad del registro</label>
                        <select class="form-control" @bind="_txMode">
                            <option value="@nameof(FormIdentityMode.None)">Ninguna</option>
                            <option value="@nameof(FormIdentityMode.Sequence)">Consecutivo del sistema</option>
                            <option value="@nameof(FormIdentityMode.NaturalKey)">Por dato (clave natural)</option>
                        </select>
                    </div>
                    @if (_txMode == nameof(FormIdentityMode.NaturalKey))
                    {
                        <div class="field">
                            <label class="form-label">Campo clave (unico por tenant)</label>
                            <select class="form-control" @bind="_txField">
                                <option value="">Selecciona...</option>
                                @foreach (var q in _def.Questions.Where(x => x.SourceKind == FormSourceKind.Options && string.IsNullOrWhiteSpace(x.CalcExpression)))
                                {
                                    <option value="@q.FieldCode">@q.Label (@q.FieldCode)</option>
                                }
                            </select>
                        </div>
                    }
                    @if (_txMode == nameof(FormIdentityMode.Sequence))
                    {
                        <p style="font-size:12px;color:var(--ink-3);margin-top:8px;">
                            El numero se genera con el prefijo del codigo del formulario (ej. @_def.Code-000001).
                        </p>
                    }
                }

                <hr style="margin:16px 0;border:none;border-top:1px solid var(--line);" />
                <label class="pl-toggle"><input type="checkbox" @bind="_isModule" @bind:after="OnModuleToggledAsync" /> Es un modulo del sistema (menu propio + bandeja en /m/@_def.Code)</label>
                @if (_isModule)
                {
                    <div class="field-row" style="margin-top:12px;">
                        <div class="field">
                            <label class="form-label">Menu (vista)</label>
                            <select class="form-control" value="@(_moduleViewId?.ToString() ?? "")"
                                    @onchange="@(e => OnModuleViewChangedAsync(Guid.TryParse(e.Value?.ToString(), out var v) ? v : (Guid?)null))">
                                <option value="">Selecciona...</option>
                                @foreach (var view in _menuViews)
                                {
                                    <option value="@view.Id" selected="@(view.Id == _moduleViewId)">@view.Name@(view.IsDefault ? " (por defecto)" : "")</option>
                                }
                            </select>
                        </div>
                        <div class="field">
                            <label class="form-label">Grupo del menu (donde aparece)</label>
                            <select class="form-control" @bind="_moduleParentId">
                                <option value="">Raiz del menu</option>
                                @foreach (var g in _menuGroups)
                                {
                                    <option value="@g.Id">@g.Label</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="field">
                        <label class="form-label">Nombre en el menu</label>
                        <input class="form-control" @bind="_moduleLabel" maxlength="80" placeholder="@_def.Title" />
                        <p style="font-size:12px;color:var(--ink-3);margin-top:4px;">Como se muestra en el menu. Si lo dejas vacio, usa el titulo del formulario.</p>
                    </div>
                    <div class="field">
                        <label class="form-label">Icono</label>
                        <MenuIconPicker @bind-Value="_moduleIcon" />
                    </div>
                    <div class="field">
                        <label class="form-label">Columnas de la bandeja</label>
                        <div class="fb-chkgrid">
                            @foreach (var q in _def.Questions.Where(x => !FormFieldValidator.IsNonInput(x.ControlType)))
                            {
                                <label class="pl-toggle"><input type="checkbox" checked="@_moduleColumns.Contains(q.FieldCode)"
                                    @onchange="@(e => ToggleSet(_moduleColumns, q.FieldCode, (bool)e.Value!))" /> @q.Label</label>
                            }
                        </div>
                    </div>
                    <div class="field">
                        <label class="form-label">Campos de filtro</label>
                        <div class="fb-chkgrid">
                            @foreach (var q in _def.Questions.Where(x => !FormFieldValidator.IsNonInput(x.ControlType)))
                            {
                                <label class="pl-toggle"><input type="checkbox" checked="@_moduleFilters.Contains(q.FieldCode)"
                                    @onchange="@(e => ToggleSet(_moduleFilters, q.FieldCode, (bool)e.Value!))" /> @q.Label</label>
                            }
                        </div>
                    </div>
                    @if (_def.IsModule)
                    {
                        <p style="font-size:12px;color:var(--t-green);margin-top:4px;">Ya publicado como modulo. Ruta: /m/@_def.Code</p>
                    }
                }
                @if (_modalError is not null)
                {
                    <div class="tk-field-error">@_modalError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="@(() => _showFormProps = false)" disabled="@_busy">Cerrar</button>
                <button class="btn btn-primary" @onclick="SaveFormPropsAsync" disabled="@_busy">Guardar</button>
            </div>
        </div>
    </div>
}

