            var result = await RulesSvc.UnlinkQuestionAsync(linkId);
            if (!result.IsOk) { _pageError = result.Error; return; }
            _rulesLoadedFor = null;
            await EnsureRulesLoadedAsync(n);
        }
        finally
        {
            _busy = false;
        }
    }

