    private static Reg RegOf(FormControlType t) => ControlReg.GetValueOrDefault(t, ControlReg[FormControlType.Text]);
    private static Reg RegOf(FormContainerType t) => ContainerReg.GetValueOrDefault(t, ContainerReg[FormContainerType.Section]);

    /// <summary>Icono del registro: path simple ("M...") o markup svg interno ("&lt;rect.../&gt;").</summary>
    private static string IconSvg(string icon, int size)
    {
        var body = icon.StartsWith('<') ? icon : $"<path d=\"{icon}\"/>";
        return $"<svg width=\"{size}\" height=\"{size}\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.9\" stroke-linecap=\"round\" stroke-linejoin=\"round\">{body}</svg>";
    }

    // ---- Nodo unificado (contenedor o pregunta) ----

    private sealed class Node
    {
        public required Guid Id { get; init; }
        public required bool IsQuestion { get; init; }
        public FormQuestionDto? Q { get; init; }
        public FormContainerDto? C { get; init; }
        public required Reg Reg { get; init; }
        public string Label => IsQuestion ? Q!.Label : C!.Name;
        public int Width => IsQuestion ? Q!.Width : C!.Width;
        public bool Locked => IsQuestion ? Q!.IsLocked : C!.IsLocked;
        public bool Hidden => IsQuestion ? Q!.IsHidden : C!.IsHidden;
        public bool IsContainer => !IsQuestion;
        public bool IsDoc => IsQuestion && Reg.Cat == "doc";
    }

    private Node ToNode(FormQuestionDto q) => new() { Id = q.Id, IsQuestion = true, Q = q, Reg = RegOf(q.ControlType) };
    private Node ToNode(FormContainerDto c) => new() { Id = c.Id, IsQuestion = false, C = c, Reg = RegOf(c.ContainerType) };

    /// <summary>Hijos de un contenedor (o de la raiz con null): preguntas primero, luego sub-contenedores.</summary>
    private List<Node> NodesOf(Guid? containerId)
    {
        var nodes = new List<Node>();
        nodes.AddRange(_def!.Questions.Where(q => q.ContainerId == containerId).OrderBy(q => q.SortOrder).Select(ToNode));
        nodes.AddRange(_def!.Containers.Where(c => c.ParentId == containerId).OrderBy(c => c.SortOrder).Select(ToNode));
        return nodes;
    }

    private int TotalNodes() => _def is null ? 0 : _def.Questions.Count + _def.Containers.Count;

    private Node? Sel => _selId is Guid id
        ? (_selIsQuestion
            ? _def!.Questions.Where(q => q.Id == id).Select(ToNode).FirstOrDefault()
            : _def!.Containers.Where(c => c.Id == id).Select(ToNode).FirstOrDefault())
        : null;

    private bool IsSelected(Node n) => _selId == n.Id;

    private void Select(Node? n)
    {
        _selId = n?.Id;
        _selIsQuestion = n?.IsQuestion ?? false;
        _rulePickerOpen = false;
    }

    private sealed record TreeRow(Node Node, int Depth, bool HasKids, string Badge);

    private List<TreeRow> TreeRows()
    {
        var rows = new List<TreeRow>();
        void Walk(Guid? parentId, int depth)
        {
            foreach (var node in NodesOf(parentId))
            {
                var kids = node.IsContainer ? NodesOf(node.Id) : new List<Node>();
                var badge = node.IsContainer ? kids.Count.ToString() : $"{node.Width}/12";
                rows.Add(new TreeRow(node, depth, node.IsContainer && kids.Count > 0, badge));
                if (node.IsContainer && !_collapsed.Contains(node.Id))
                {
                    Walk(node.Id, depth + 1);
                }
            }
        }
        Walk(null, 0);
        return rows;
    }

    private void ToggleCollapse(Guid id)
    {
        if (!_collapsed.Remove(id))
        {
            _collapsed.Add(id);
        }
    }

    private string CanvasWidth() => _device switch
    {
        "tableta" => "620px",
        "movil" => "380px",
        _ => "820px"
    };

    // ---- Ciclo de vida ----

    private IReadOnlyList<FormDefinitionListItemDto> _allDefs = [];

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        // Definiciones para el selector de formulario hijo (Subform, ola F5).
        _allDefs = await FormsSvc.ListAsync();
        _loading = false;
    }

    private async Task ReloadAsync()
    {
        _def = await FormsSvc.GetAsync(Id);
    }

    private async Task SaveFlashAsync()
    {
        // Persistencia por cambio (ADR-0021): Guardar confirma recargando el estado real.
        await ReloadAsync();
        _savedFlash = true;
        StateHasChanged();
        await Task.Delay(1400);
        _savedFlash = false;
    }

    private string StatusLabel() => _def!.IsArchived ? "Archivado" : _def.Status switch
    {
        FormStatus.Active => "Publicado",
        FormStatus.Draft => "Borrador",
        _ => "Inactivo"
    };

    private string StatusColor() => !_def!.IsArchived && _def.Status == FormStatus.Active
        ? "var(--t-green)"
        : !_def.IsArchived && _def.Status == FormStatus.Draft ? "var(--t-amber)" : "var(--ink-3)";

    private string StatusSoft() => !_def!.IsArchived && _def.Status == FormStatus.Active
        ? "var(--t-green-bg)"
        : !_def.IsArchived && _def.Status == FormStatus.Draft ? "var(--t-amber-bg)" : "var(--surface-3)";

    private async Task SaveTitleAsync()
    {
        _editingTitle = false;
        var title = _titleDraft.Trim();
        if (title.Length == 0 || title == _def!.Title)
        {
            return;
        }
        var result = await FormsSvc.UpdateHeaderAsync(Id, new UpdateFormDefinitionRequest(title, _def.Description, _def.Version));
        if (!result.IsOk)
        {
            _pageError = result.Error;
            return;
        }
        _def = result.Value;
    }

    // ---- Agregar elementos (paleta) ----

    private async Task AddPaletteAsync(PaletteKey key)
    {
        // Como el prototipo (fbAddTo): dentro del contenedor seleccionado, si no a la raiz.
        var target = Sel is { IsContainer: true } ? Sel.Id : (Guid?)null;
        await AddElementAsync(key, target);
    }

    private async Task AddElementAsync(PaletteKey key, Guid? containerId)
    {
        _pageError = null;
        _busy = true;
        try
        {
            if (key == PaletteKey.Contenedor)
            {
                var result = await FormsSvc.AddContainerAsync(Id, new SaveFormContainerRequest(
                    "Fila", FormContainerType.Row, containerId));
                if (!result.IsOk) { _pageError = result.Error; return; }
                await ReloadAsync();
                _selId = result.Value!.Id;
                _selIsQuestion = false;
            }
            else
            {
                var (type, label) = key switch
                {
                    PaletteKey.Parrafo => (FormControlType.Paragraph, "Texto"),
                    PaletteKey.Divisor => (FormControlType.Divider, "Divisor"),
                    PaletteKey.Espacio => (FormControlType.Spacer, "Espacio"),
                    _ => (FormControlType.Text, "Texto corto")
                };
                var result = await AddQuestionOfTypeAsync(type, label, containerId);
                if (result is null) { return; }
                await ReloadAsync();
                _selId = result.Id;
                _selIsQuestion = true;
            }
            _propTab = "diseno";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task<FormQuestionDto?> AddQuestionOfTypeAsync(FormControlType type, string label, Guid? containerId)
    {
        var request = new SaveFormQuestionRequest(
            containerId, NewFieldCode(type), label, type,
            OptionsJson: DefaultOptions(type),
            DefaultValue: type switch
            {
                FormControlType.Paragraph => "Texto del documento...",
                FormControlType.Spacer => "24",
                _ => null
            });
        var result = await FormsSvc.AddQuestionAsync(Id, request);
        if (!result.IsOk)
        {
            _pageError = result.Error;
            return null;
        }
        return result.Value;
    }

    private static string NewFieldCode(FormControlType type)
        => $"{type.ToString().ToLowerInvariant()}_{Guid.NewGuid().ToString("N")[..5]}";

    private static string? DefaultOptions(FormControlType type) => type switch
    {
        FormControlType.Select or FormControlType.Radio or FormControlType.MultiCheck =>
            """[{"id":"opcion_1","label":"Opcion 1"},{"id":"opcion_2","label":"Opcion 2"}]""",
        FormControlType.GridDetail =>
            """[{"id":"columna_1","label":"Columna 1"},{"id":"columna_2","label":"Columna 2"}]""",
        _ => null
    };

    // ---- Drag and drop ----

    private async Task DropOnAsync(Guid? containerId, Node? before)
    {
        if (_dragPalette is PaletteKey key)
        {
            _dragPalette = null;
            await AddElementAsync(key, containerId);
            return;
        }
        if (_dragNodeId is not Guid dragId)
        {
            return;
        }
        _dragNodeId = null;
        if (dragId == containerId || before?.Id == dragId)
        {
            return;
        }
        _busy = true;
        try
        {
            if (_dragNodeIsQuestion)
            {
                var siblings = _def!.Questions.Where(q => q.ContainerId == containerId && q.Id != dragId)
                    .OrderBy(q => q.SortOrder).ToList();
                var index = before is { IsQuestion: true }
                    ? Math.Max(siblings.FindIndex(q => q.Id == before.Id), 0)
                    : siblings.Count;
                var result = await FormsSvc.MoveQuestionToAsync(dragId, containerId, index);
                if (!result.IsOk) { _pageError = result.Error; }
            }
            else
            {
                var siblings = _def!.Containers.Where(c => c.ParentId == containerId && c.Id != dragId)
                    .OrderBy(c => c.SortOrder).ToList();
                var index = before is { IsQuestion: false }
                    ? Math.Max(siblings.FindIndex(c => c.Id == before.Id), 0)
                    : siblings.Count;
                var result = await FormsSvc.MoveContainerToAsync(dragId, containerId, index);
                if (!result.IsOk) { _pageError = result.Error; }
            }
            await ReloadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

