            <button title="Bajar" disabled="@node.Locked" @onclick="@(() => MoveNodeAsync(node, false))">
                @((MarkupString)IconSvg("m6 9 6 6 6-6", 15))
            </button>
            <button title="Duplicar" @onclick="@(() => DuplicateNodeAsync(node))">
                @((MarkupString)IconSvg("<rect x=\"9\" y=\"9\" width=\"11\" height=\"11\" rx=\"2\"/><path d=\"M5 15V5a2 2 0 0 1 2-2h8\"/>", 15))
