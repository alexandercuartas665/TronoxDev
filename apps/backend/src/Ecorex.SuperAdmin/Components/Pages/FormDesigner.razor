                <div class="fb-field">
                    <label>Presentacion</label>
                    <select class="fb-select" value="@q.Presentation"
                            @onchange="@(e => PatchQuestionAsync(q, r => r with { Presentation = ParsePresentation(e.Value?.ToString()) }))">
                        <option value="@nameof(FormFieldPresentation.Autocomplete)">Autocompletar</option>
                        <option value="@nameof(FormFieldPresentation.Dropdown)">Lista</option>
                        <option value="@nameof(FormFieldPresentation.Modal)">Buscador</option>
                    </select>
                </div>

                <div class="fb-field">
                    <label>Mostrar (etiqueta)</label>
                    <select class="fb-select" value="@(q.DisplayField ?? "")"
                            @onchange="@(e => PatchQuestionAsync(q, r => r with { DisplayField = e.Value?.ToString() }))">
