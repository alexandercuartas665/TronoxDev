    /// <summary>Editor del mapa de autollenado: filas campoFuente -> campoFormulario (se copia al elegir).</summary>
    private RenderFragment RenderAutofillMap(FormQuestionDto q, IReadOnlyList<FormLookupFieldMeta> fields) => __builder =>
    {
        var map = ParseAutofillMap(q.AutofillMapJson).ToList();
        var targets = _def!.Questions
            .Where(x => x.Id != q.Id && x.SourceKind == FormSourceKind.Options)
            .Select(x => x.FieldCode).ToList();

        <div class="fb-autofill">
            @foreach (var pair in map)
            {
                var src = pair.Key;
                <div class="fb-autofill-row">
                    <select class="fb-select" value="@src"
                            @onchange="@(e => SetAutofillAsync(q, src, e.Value?.ToString(), pair.Value))">
                        @foreach (var f in fields)
                        {
                            <option value="@f.Key" selected="@(f.Key == src)">@f.Label</option>
                        }
                    </select>
                    <span class="fb-autofill-arrow">&rarr;</span>
                    <select class="fb-select" value="@pair.Value"
                            @onchange="@(e => SetAutofillAsync(q, src, src, e.Value?.ToString()))">
                        <option value="">Campo destino...</option>
                        @foreach (var t in targets)
                        {
                            <option value="@t" selected="@(t == pair.Value)">@t</option>
                        }
                    </select>
                    <button type="button" class="fb-autofill-x" title="Quitar" @onclick="@(() => RemoveAutofillAsync(q, src))">&times;</button>
                </div>
            }
            @if (fields.Count > 0)
            {
                <button type="button" class="fb-autofill-add" @onclick="@(() => AddAutofillAsync(q, fields))">+ Agregar mapeo</button>
            }
        </div>
    };

    // Metadata de lookup cacheada para los selectores del designer (por origen|fuente).
    private readonly Dictionary<string, IReadOnlyList<FormLookupFieldMeta>> _lookupFields = new(StringComparer.Ordinal);
    private readonly Dictionary<FormSourceKind, IReadOnlyList<FormLookupSourceOption>> _lookupSources = new();
    private readonly HashSet<string> _lookupMetaLoading = new(StringComparer.Ordinal);

    private static string MetaKey(FormQuestionDto q) => $"{q.SourceKind}|{q.SourceRef}";

    private IReadOnlyList<FormLookupFieldMeta> LookupFieldsFor(FormQuestionDto q)
        => _lookupFields.GetValueOrDefault(MetaKey(q)) ?? Array.Empty<FormLookupFieldMeta>();

    /// <summary>Carga (una vez) las fuentes y campos de la fuente del campo, para los selectores.</summary>
    private async Task EnsureLookupMetaAsync(FormQuestionDto q)
    {
        if (q.SourceKind == FormSourceKind.Options) { return; }
        var key = MetaKey(q);
        if (_lookupFields.ContainsKey(key) || !_lookupMetaLoading.Add(key)) { return; }
        try
        {
            if (!_lookupSources.ContainsKey(q.SourceKind))
            {
                _lookupSources[q.SourceKind] = await LookupSvc.ListSourcesAsync(q.SourceKind);
            }
            _lookupFields[key] = await LookupSvc.DescribeFieldsAsync(q.SourceKind, q.SourceRef);
        }
        catch (Exception)
        {
            _lookupFields[key] = Array.Empty<FormLookupFieldMeta>();
        }
        finally
        {
            _lookupMetaLoading.Remove(key);
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task ChangeSourceKindAsync(FormQuestionDto q, string? kindStr)
    {
        var kind = Enum.TryParse<FormSourceKind>(kindStr, out var k) ? k : FormSourceKind.Options;
        await PatchQuestionAsync(q, r => r with
        {
            SourceKind = kind,
            // El valor guardado es siempre el id de la fila/entidad; SourceRef solo aplica al contenedor.
            ValueField = kind == FormSourceKind.Options ? null : "id",
            SourceRef = kind == FormSourceKind.DataContainer ? r.SourceRef : null,
        });
    }

    private static FormFieldPresentation ParsePresentation(string? s)
        => Enum.TryParse<FormFieldPresentation>(s, out var p) ? p : FormFieldPresentation.Autocomplete;

    private static IReadOnlyDictionary<string, string> ParseAutofillMap(string? json)
    {
        var map = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(json)) { return map; }
        try
        {
            using var doc = JsonDocument.Parse(json);
            if (doc.RootElement.ValueKind != JsonValueKind.Object) { return map; }
            foreach (var p in doc.RootElement.EnumerateObject())
            {
                var target = p.Value.ValueKind == JsonValueKind.String ? p.Value.GetString() : null;
                map[p.Name] = target ?? "";
            }
        }
        catch (JsonException) { /* mapa invalido: se ignora */ }
        return map;
    }

    private async Task AddAutofillAsync(FormQuestionDto q, IReadOnlyList<FormLookupFieldMeta> fields)
    {
        var map = new Dictionary<string, string>(ParseAutofillMap(q.AutofillMapJson), StringComparer.OrdinalIgnoreCase);
        var candidate = fields.Select(f => f.Key).FirstOrDefault(k => !map.ContainsKey(k));
        if (candidate is null) { return; }
        map[candidate] = "";
        await PatchAutofillAsync(q, map);
    }

    private async Task SetAutofillAsync(FormQuestionDto q, string oldSource, string? newSource, string? target)
    {
        var map = new Dictionary<string, string>(ParseAutofillMap(q.AutofillMapJson), StringComparer.OrdinalIgnoreCase);
        map.Remove(oldSource);
        if (!string.IsNullOrWhiteSpace(newSource)) { map[newSource] = target ?? ""; }
        await PatchAutofillAsync(q, map);
    }

    private async Task RemoveAutofillAsync(FormQuestionDto q, string source)
    {
        var map = new Dictionary<string, string>(ParseAutofillMap(q.AutofillMapJson), StringComparer.OrdinalIgnoreCase);
        map.Remove(source);
        await PatchAutofillAsync(q, map);
    }

    private Task PatchAutofillAsync(FormQuestionDto q, Dictionary<string, string> map)
    {
        var json = map.Count == 0 ? null : JsonSerializer.Serialize(map);
        return PatchQuestionAsync(q, r => r with { AutofillMapJson = json });
    }

    private RenderFragment RenderReglasTab(Node node) => __builder =>
    {
        <p class="fb-rules-desc">Procesos de ejecucion ligados a este objeto (motor CONTROL_REGLAS).</p>
        @if (!node.IsQuestion)
        {
            <div class="fb-rules-empty">Sin reglas asignadas</div>
            <p class="fb-rules-desc" style="margin-top:10px;">Las reglas se vinculan a campos de captura (selecciona un input).</p>
            return;
        }
        _ = EnsureRulesLoadedAsync(node);
        @if (_questionRules.Count > 0)
        {
            @foreach (var link in _questionRules)
            {
                <div class="fb-rule-row">
                    <span class="fb-rule-dot"></span>
                    <div class="fb-rule-tx">
                        <div class="fb-rule-verb">@link.VerbName</div>
                        <div class="fb-rule-trigger">Al cambiar - @link.DocumentCode @link.RuleName</div>
                    </div>
                    <span class="fb-rule-x" @onclick="@(() => UnlinkRuleAsync(node, link.Id))">&times;</span>
                </div>
            }
        }
        else
        {
            <div class="fb-rules-empty">Sin reglas asignadas</div>
        }
        @if (_rulePickerOpen)
        {
            <div class="fb-rule-picker">
                <div class="fb-field">
                    <label>Documento de reglas</label>
                    <select class="fb-select" value="@(_pickDocId?.ToString() ?? "")"
                            @onchange="@(e => PickDocAsync(Guid.TryParse(e.Value?.ToString(), out var id) ? id : null))">
                        <option value="">Selecciona...</option>
                        @foreach (var doc in _ruleDocs)
                        {
                            <option value="@doc.Id">@doc.DocumentCode - @doc.Name</option>
                        }
                    </select>
                </div>
                <div class="fb-field">
                    <label>Regla</label>
                    <select class="fb-select" value="@(_pickRuleId?.ToString() ?? "")"
                            @onchange="@(e => _pickRuleId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null)">
                        <option value="">Selecciona...</option>
                        @foreach (var rule in _ruleOptions)
                        {
                            <option value="@rule.Id">@rule.VerbName - @rule.Name</option>
                        }
                    </select>
                </div>
                <div style="display:flex;gap:8px;">
                    <button class="fb-btn-ghost" style="flex:1;" @onclick="@(() => _rulePickerOpen = false)">Cancelar</button>
                    <button class="fb-btn-primary" style="flex:1;" disabled="@(_pickRuleId is null || _busy)" @onclick="@(() => LinkRuleAsync(node))">Vincular</button>
                </div>
            </div>
        }
        else
        {
            <button class="fb-rule-add" @onclick="OpenRulePickerAsync">+ Vincular regla existente</button>
        }

        @* D4: autoria inline de una condicion "si campo = valor -> mostrar/ocultar/requerir otro".
           Arma el verbo BLOQUEAR_CAMPO_XCONDICION sin salir del constructor; el runtime ya la aplica. *@
        @if (_condOpen)
        {
            var captureFields = _def?.Questions
                .Where(x => x.Id != node.Q!.Id && FormFieldValidator.IsCapture(x.ControlType))
                .ToList() ?? new();
            <div class="fb-rule-picker fb-cond">
                <div class="fb-cond-line">
                    <span>Si el campo</span>
                    <select class="fb-select" value="@_condSource" @onchange="@(e => _condSource = e.Value?.ToString() ?? "")">
                        <option value="">(este campo)</option>
                        @foreach (var f in captureFields)
                        {
                            <option value="@f.FieldCode">@f.Label</option>
                        }
                    </select>
                    <select class="fb-select" value="@_condOp" @onchange="@(e => _condOp = e.Value?.ToString() ?? "equals")">
                        <option value="equals">es igual a</option>
                        <option value="notEquals">es distinto de</option>
                        <option value="empty">esta vacio</option>
                        <option value="notEmpty">tiene valor</option>
                    </select>
                    @if (_condOp is "equals" or "notEquals")
                    {
                        <input class="fb-input" placeholder="valor" value="@_condValue"
                               @onchange="@(e => _condValue = e.Value?.ToString() ?? "")" />
                    }
                </div>
                <div class="fb-cond-line">
                    <span>entonces</span>
                    <select class="fb-select" value="@_condEffect" @onchange="@(e => _condEffect = e.Value?.ToString() ?? "show")">
                        <option value="show">mostrar</option>
                        <option value="hide">ocultar</option>
                        <option value="require">hacer obligatorio</option>
                        <option value="optional">hacer opcional</option>
                    </select>
                    <span>el campo</span>
                    <select class="fb-select" value="@_condTarget" @onchange="@(e => _condTarget = e.Value?.ToString() ?? "")">
                        <option value="">Selecciona...</option>
                        @foreach (var f in captureFields)
                        {
                            <option value="@f.FieldCode">@f.Label</option>
                        }
                    </select>
                </div>
                @if (_condError is not null)
                {
                    <div class="fb-cond-err">@_condError</div>
                }
                <div style="display:flex;gap:8px;">
                    <button class="fb-btn-ghost" style="flex:1;" @onclick="@(() => _condOpen = false)">Cancelar</button>
                    <button class="fb-btn-primary" style="flex:1;" disabled="@_busy" @onclick="@(() => SaveConditionAsync(node))">Crear regla</button>
                </div>
            </div>
        }
        else
        {
            <button class="fb-rule-add" @onclick="@(() => { _condOpen = true; _condError = null; })" style="margin-top:6px;">+ Condicion (mostrar/ocultar segun otro campo)</button>
        }
    };

    private RenderFragment RenderToggleRow(string label, string desc, bool on, Func<Task> toggle) => __builder =>
    {
        <div class="fb-toggle-row" @onclick="@(() => toggle())">
            <div>
                <div class="fb-toggle-label">@label</div>
                <div class="fb-toggle-desc">@desc</div>
            </div>
            <div class="fb-toggle @(on ? "on" : "")"><span></span></div>
        </div>
    };

    private RenderFragment RenderChipList(List<string> items, string accent,
        Func<int, string?, Task> setAt, Func<int, Task> removeAt, Func<Task> add) => __builder =>
    {
        <div class="fb-chips">
            @for (var i = 0; i < items.Count; i++)
            {
                var index = i;
                <div class="fb-chip">
                    <span class="fb-chip-dot" style="background:@accent"></span>
                    <input value="@items[index]" @onchange="@(e => setAt(index, e.Value?.ToString()))" />
                    <span class="fb-chip-x" @onclick="@(() => removeAt(index))">&times;</span>
                </div>
            }
            <button class="fb-chip-add" @onclick="@(() => add())">+ Agregar</button>
        </div>
    };

    // ---- Helpers de edicion ----

    private async Task RenameAsync(Node node, string label)
    {
        label = label.Trim();
        if (label.Length == 0)
        {
            return;
        }
        if (node.IsQuestion) { await PatchQuestionAsync(node.Q!, r => r with { Label = label }); }
        else { await PatchContainerAsync(node.C!, r => r with { Name = label }); }
    }

    private async Task ChangeTypeAsync(FormQuestionDto q, string value)
    {
        var type = Enum.Parse<FormControlType>(value);
        await PatchQuestionAsync(q, r => r with
        {
            ControlType = type,
            OptionsJson = FormFieldValidator.ParseOptions(q.OptionsJson).Count > 0 ? q.OptionsJson : DefaultOptions(type)
        });
    }

    private static List<string> TabsOf(FormContainerDto c)
    {
        if (string.IsNullOrWhiteSpace(c.TabsJson))
        {
            return new List<string> { "Pestana 1", "Pestana 2" };
        }
        try
        {
            return JsonSerializer.Deserialize<List<string>>(c.TabsJson) ?? new List<string>();
        }
        catch (JsonException)
        {
            return new List<string>();
        }
    }

    private async Task PatchTabsAsync(FormContainerDto c, int index, string? value)
    {
        var tabs = TabsOf(c);
        if (index < 0)
        {
            tabs.Add(value ?? $"Pestana {tabs.Count + 1}");
        }
        else if (value is null)
        {
            if (index < tabs.Count) { tabs.RemoveAt(index); }
        }
        else if (index < tabs.Count)
        {
            tabs[index] = value;
        }
        await PatchContainerAsync(c, r => r with { TabsJson = JsonSerializer.Serialize(tabs) });
    }

    private static List<string> OptionLabels(FormQuestionDto q)
        => FormFieldValidator.ParseOptions(q.OptionsJson).Select(o => o.Label).ToList();

    private async Task PatchOptionAsync(FormQuestionDto q, int index, string? value)
    {
        var options = FormFieldValidator.ParseOptions(q.OptionsJson).ToList();
        if (index < 0)
        {
            var n = options.Count + 1;
            options.Add(new FormOption($"opcion_{n}_{Guid.NewGuid().ToString("N")[..4]}", value ?? $"Opcion {n}"));
        }
        else if (value is null)
        {
            if (index < options.Count) { options.RemoveAt(index); }
        }
        else if (index < options.Count)
        {
            options[index] = options[index] with { Label = value };
        }
        var json = JsonSerializer.Serialize(options, new JsonSerializerOptions(JsonSerializerDefaults.Web));
        await PatchQuestionAsync(q, r => r with { OptionsJson = json });
    }

    // ---- Editor de columnas del GridDetail (D3): una columna puede ser texto o lista, y requerida ----

    private static List<FormGridColumn> GridColumns(FormQuestionDto q)
        => FormGridCalculator.ParseColumns(q.OptionsJson).ToList();

    /// <summary>
    /// Serializa las columnas al formato exacto que lee <see cref="FormGridCalculator.ParseColumns"/>
    /// ({id,label,type,required,options,calc,agg,rollup}). NO se serializa el record directo porque
    /// el parser espera "type" (no "kind") y omite lo que este en su valor por defecto para no ensuciar
    /// las columnas viejas [{id,label}].
    /// </summary>
    private async Task SaveGridColumnsAsync(FormQuestionDto q, IReadOnlyList<FormGridColumn> cols)
    {
        var shaped = cols.Select(c =>
        {
            var o = new Dictionary<string, object?> { ["id"] = c.Id, ["label"] = c.Label };
            if (c.IsSelect)
            {
                o["type"] = "select";
                o["options"] = (c.Options ?? new List<FormOption>()).Select(x => new { id = x.Id, label = x.Label }).ToList();
            }
            if (c.Required) { o["required"] = true; }
            if (!string.IsNullOrWhiteSpace(c.Calc)) { o["calc"] = c.Calc; }
            if (c.Agg != FormAggregate.None) { o["agg"] = c.Agg.ToString(); }
            if (!string.IsNullOrWhiteSpace(c.Rollup)) { o["rollup"] = c.Rollup; }
            return o;
        }).ToList();
        var json = JsonSerializer.Serialize(shaped, new JsonSerializerOptions(JsonSerializerDefaults.Web));
        await PatchQuestionAsync(q, r => r with { OptionsJson = json });
    }

    private Task AddGridColumnAsync(FormQuestionDto q)
    {
        var cols = GridColumns(q);
        var n = cols.Count + 1;
        cols.Add(new FormGridColumn($"col_{n}_{Guid.NewGuid().ToString("N")[..4]}", $"Columna {n}", null, FormAggregate.None, null));
        return SaveGridColumnsAsync(q, cols);
    }

    private Task RemoveGridColumnAsync(FormQuestionDto q, int index)
    {
        var cols = GridColumns(q);
        if (index >= 0 && index < cols.Count) { cols.RemoveAt(index); }
        return SaveGridColumnsAsync(q, cols);
    }

    private Task PatchGridColumnAsync(FormQuestionDto q, int index, Func<FormGridColumn, FormGridColumn> patch)
    {
        var cols = GridColumns(q);
        if (index < 0 || index >= cols.Count) { return Task.CompletedTask; }
        cols[index] = patch(cols[index]);
        return SaveGridColumnsAsync(q, cols);
    }

    private Task SetGridColumnKindAsync(FormQuestionDto q, int index, string kind)
        => PatchGridColumnAsync(q, index, c => c with
        {
            Kind = kind,
            // Al pasar a lista sin opciones aun, se siembra una para que el editor no quede vacio.
            Options = kind == "select" ? (c.Options is { Count: > 0 } ? c.Options : new List<FormOption> { new("op_1", "Opcion 1") }) : c.Options
        });

    /// <summary>Edita/agrega/quita una opcion de una columna Select.</summary>
    private Task PatchGridColumnOptionAsync(FormQuestionDto q, int colIndex, int optIndex, string? value)
        => PatchGridColumnAsync(q, colIndex, c =>
        {
            var opts = (c.Options ?? new List<FormOption>()).ToList();
            if (optIndex < 0)
            {
                var n = opts.Count + 1;
                opts.Add(new FormOption($"op_{n}_{Guid.NewGuid().ToString("N")[..4]}", value ?? $"Opcion {n}"));
            }
            else if (value is null)
            {
                if (optIndex < opts.Count) { opts.RemoveAt(optIndex); }
            }
            else if (optIndex < opts.Count)
            {
                opts[optIndex] = opts[optIndex] with { Label = value };
            }
            return c with { Options = opts };
        });
}
