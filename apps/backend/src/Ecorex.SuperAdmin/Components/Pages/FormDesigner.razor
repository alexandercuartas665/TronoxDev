    private RenderFragment RenderNode(Node node, bool inRow) => __builder =>
    {
        var span = inRow ? Math.Clamp(node.Width, 1, 12) : 12;
        @if (node.Hidden)
        {
            <div class="fb-node-hidden" style="grid-column:span @span" draggable="true"
                 @onclick="@(() => Select(node))" @onclick:stopPropagation="true"
                 @ondragstart="@(() => OnNodeDragStart(node))" @ondragstart:stopPropagation="true"
                 @ondragover:preventDefault @ondragover:stopPropagation
                 @ondrop="@(() => DropOnAsync(ParentOf(node), node))" @ondrop:preventDefault @ondrop:stopPropagation="true">
                @((MarkupString)IconSvg("<path d=\"M9.9 4.24A9.1 9.1 0 0 1 12 4c7 0 10 8 10 8a13 13 0 0 1-1.67 2.68M6.6 6.6A13 13 0 0 0 2 12s3 8 10 8a9 9 0 0 0 5.4-1.6M1 1l22 22\"/>", 14))
                <span>@node.Label - oculto</span>
            </div>
            return;
        }
        @if (node.IsContainer)
        {
            var c = node.C!;
            var kids = NodesOf(c.Id);
            var isRow = c.ContainerType == FormContainerType.Row;
            <div class="fb-node-container @(IsSelected(node) ? "sel" : "")" style="grid-column:span @span" draggable="true"
                 @onclick="@(() => Select(node))" @onclick:stopPropagation="true"
                 @ondragstart="@(() => OnNodeDragStart(node))" @ondragstart:stopPropagation="true"
                 @ondragover:preventDefault @ondragover:stopPropagation
                 @ondrop="@(() => DropOnAsync(c.Id, null))" @ondrop:preventDefault @ondrop:stopPropagation="true">
                @if (IsSelected(node))
                {
                    @RenderNodeActions(node)
                }
                <div class="fb-node-label" style="color:@node.Reg.Color;background:@node.Reg.Soft">
                    @((MarkupString)IconSvg(node.Reg.Icon, 11)) @c.Name
                </div>
                <div class="@(isRow ? "fb-kids-row" : "fb-kids-col")">
                    @foreach (var kid in kids)
                    {
                        @RenderNode(kid, inRow: isRow)
                    }
                    @if (kids.Count == 0)
                    {
                        <div class="fb-node-empty" style="@(isRow ? "grid-column:span 12" : "")">Contenedor vacio - arrastra o toca un elemento</div>
                    }
                </div>
            </div>
            return;
        }
        @if (node.IsDoc)
        {
            var q = node.Q!;
            @if (q.ControlType == FormControlType.Divider)
            {
                <div class="fb-node-divider @(IsSelected(node) ? "sel" : "")" style="grid-column:span @span" draggable="true"
                     @onclick="@(() => Select(node))" @onclick:stopPropagation="true"
                     @ondragstart="@(() => OnNodeDragStart(node))" @ondragstart:stopPropagation="true"
                     @ondragover:preventDefault @ondragover:stopPropagation
                     @ondrop="@(() => DropOnAsync(ParentOf(node), node))" @ondrop:preventDefault @ondrop:stopPropagation="true">
                    @if (IsSelected(node))
                    {
                        @RenderNodeActions(node)
                    }
                    <div class="fb-divider-line"></div>
                </div>
            }
            else if (q.ControlType == FormControlType.Spacer)
            {
                <div class="fb-node-spacer @(IsSelected(node) ? "sel" : "")"
                     style="grid-column:span @span;height:@(int.TryParse(q.DefaultValue, out var h) && h > 0 ? h : 24)px" draggable="true"
                     @onclick="@(() => Select(node))" @onclick:stopPropagation="true"
                     @ondragstart="@(() => OnNodeDragStart(node))" @ondragstart:stopPropagation="true"
                     @ondragover:preventDefault @ondragover:stopPropagation
                     @ondrop="@(() => DropOnAsync(ParentOf(node), node))" @ondrop:preventDefault @ondrop:stopPropagation="true">
                    @if (IsSelected(node))
                    {
                        @RenderNodeActions(node)
                    }
                </div>
            }
            else
            {
                <div class="fb-node-paragraph @(IsSelected(node) ? "sel" : "")" style="grid-column:span @span" draggable="true"
                     @onclick="@(() => Select(node))" @onclick:stopPropagation="true"
                     @ondragstart="@(() => OnNodeDragStart(node))" @ondragstart:stopPropagation="true"
                     @ondragover:preventDefault @ondragover:stopPropagation
                     @ondrop="@(() => DropOnAsync(ParentOf(node), node))" @ondrop:preventDefault @ondrop:stopPropagation="true">
                    @if (IsSelected(node))
                    {
                        @RenderNodeActions(node)
                    }
                    @(string.IsNullOrWhiteSpace(node.Q!.DefaultValue) ? "Texto del documento..." : node.Q.DefaultValue)
                </div>
            }
            return;
        }
        @* Control de captura *@
        <div class="fb-node-control @(IsSelected(node) ? "sel" : "")" style="grid-column:span @span" draggable="true"
             @onclick="@(() => Select(node))" @onclick:stopPropagation="true"
             @ondragstart="@(() => OnNodeDragStart(node))" @ondragstart:stopPropagation="true"
             @ondragover:preventDefault @ondragover:stopPropagation
             @ondrop="@(() => DropOnAsync(ParentOf(node), node))" @ondrop:preventDefault @ondrop:stopPropagation="true">
            @if (IsSelected(node))
            {
                @RenderNodeActions(node)
            }
            <div class="fb-ctrl-head">
                <span class="fb-ctrl-ic" style="color:@node.Reg.Color">@((MarkupString)IconSvg(node.Reg.Icon, 14))</span>
                <span class="fb-ctrl-label">
                    @node.Q!.Label@if (node.Q.Required)
                    {
                        <span class="fb-ctrl-req"> *</span>
                    }
                </span>
                <span class="fb-ctrl-badge">@(node.Width)/12</span>
            </div>
            @RenderCtrlPreview(node.Q!)
        </div>
    };

    private Guid? ParentOf(Node node) => node.IsQuestion ? node.Q!.ContainerId : node.C!.ParentId;

    private RenderFragment RenderNodeActions(Node node) => __builder =>
    {
        <div class="fb-node-actions" @onclick:stopPropagation="true">
            <button title="Subir" disabled="@node.Locked" @onclick="@(() => MoveNodeAsync(node, true))">
