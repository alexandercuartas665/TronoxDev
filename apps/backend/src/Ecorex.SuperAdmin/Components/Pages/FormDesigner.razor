    private async Task DuplicateNodeAsync(Node n)
    {
        _pageError = null;
        _busy = true;
        try
        {
            if (n.IsQuestion)
            {
                var q = n.Q!;
                var result = await FormsSvc.AddQuestionAsync(Id, ToRequest(q) with { FieldCode = NewFieldCode(q.ControlType) });
                if (!result.IsOk) { _pageError = result.Error; return; }
                await FormsSvc.MoveQuestionToAsync(result.Value!.Id, q.ContainerId, q.SortOrder + 1);
                await ReloadAsync();
                _selId = result.Value.Id;
                _selIsQuestion = true;
            }
            else
            {
                var copyId = await DuplicateContainerRecursiveAsync(n.C!, n.C!.ParentId);
                if (copyId is Guid cid)
                {
                    await FormsSvc.MoveContainerToAsync(cid, n.C.ParentId, n.C.SortOrder + 1);
                    await ReloadAsync();
                    _selId = cid;
                    _selIsQuestion = false;
                }
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task<Guid?> DuplicateContainerRecursiveAsync(FormContainerDto source, Guid? parentId)
    {
        var created = await FormsSvc.AddContainerAsync(Id, ToRequest(source) with { ParentId = parentId });
        if (!created.IsOk) { _pageError = created.Error; return null; }
        foreach (var q in _def!.Questions.Where(q => q.ContainerId == source.Id).OrderBy(q => q.SortOrder))
        {
            await FormsSvc.AddQuestionAsync(Id, ToRequest(q) with
            {
                ContainerId = created.Value!.Id,
                FieldCode = NewFieldCode(q.ControlType)
            });
        }
        foreach (var child in _def.Containers.Where(c => c.ParentId == source.Id).OrderBy(c => c.SortOrder))
        {
            await DuplicateContainerRecursiveAsync(child, created.Value!.Id);
        }
        return created.Value!.Id;
    }

