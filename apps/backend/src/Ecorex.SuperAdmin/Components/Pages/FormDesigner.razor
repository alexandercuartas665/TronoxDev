    private async Task SaveConditionAsync(Node n)
    {
        _condError = null;
        if (!n.IsQuestion || _def is null) { return; }
        if (string.IsNullOrWhiteSpace(_condTarget)) { _condError = "Elige el campo objetivo."; return; }
        // Origen vacio = el propio campo disparador (el mas comun: "si ESTE campo = X").
        var source = string.IsNullOrWhiteSpace(_condSource) ? n.Q!.FieldCode : _condSource;
        if (string.Equals(source, _condTarget, StringComparison.OrdinalIgnoreCase))
        {
            _condError = "El campo evaluado y el objetivo no pueden ser el mismo.";
            return;
        }

        _busy = true;
        try
        {
            // La regla se dispara cuando cambia el CAMPO EVALUADO (source), no el nodo seleccionado en
            // el arbol: hay que vincularla a la pregunta de ese campo.
            var trigger = _def.Questions.FirstOrDefault(q => q.FieldCode == source) ?? n.Q!;
            var res = await RulesSvc.CreateFieldConditionRuleAsync(new CreateFieldConditionRequest(
                _def.Id, trigger.Id, source, _condOp,
                _condOp is "equals" or "notEquals" ? _condValue : null,
                _condTarget, _condEffect));
            if (!res.IsOk) { _condError = res.Error ?? "No se pudo crear la regla."; return; }
            _condOpen = false;
            _condSource = ""; _condValue = ""; _condTarget = ""; _condOp = "equals"; _condEffect = "show";
            _rulesLoadedFor = null;
            await EnsureRulesLoadedAsync(n);
        }
        finally { _busy = false; }
    }

