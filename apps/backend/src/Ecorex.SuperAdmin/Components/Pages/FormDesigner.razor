    private static readonly string[] TenantRoles = { "Owner", "Admin", "Supervisor", "Advisor" };

    private static Dictionary<string, List<string>> ParseFieldVis(string? json)
    {
        var map = new Dictionary<string, List<string>>(StringComparer.Ordinal) { ["hide"] = new(), ["readonly"] = new() };
        if (string.IsNullOrWhiteSpace(json)) { return map; }
        try
        {
            using var doc = JsonDocument.Parse(json);
            foreach (var key in new[] { "hide", "readonly" })
            {
                if (doc.RootElement.TryGetProperty(key, out var arr) && arr.ValueKind == JsonValueKind.Array)
                {
                    map[key] = arr.EnumerateArray().Select(e => e.GetString() ?? "").Where(s => s.Length > 0).ToList();
                }
            }
        }
        catch (JsonException) { }
        return map;
    }

    private static bool FieldVisHas(FormQuestionDto q, string key, string role)
        => ParseFieldVis(q.FieldVisibilityJson)[key].Contains(role, StringComparer.OrdinalIgnoreCase);

    private Task ToggleFieldVisAsync(FormQuestionDto q, string key, string role, bool on)
    {
        var map = ParseFieldVis(q.FieldVisibilityJson);
        map[key].RemoveAll(r => string.Equals(r, role, StringComparison.OrdinalIgnoreCase));
        if (on) { map[key].Add(role); }
        var isEmpty = map["hide"].Count == 0 && map["readonly"].Count == 0;
        var json = isEmpty ? null : JsonSerializer.Serialize(map);
        return PatchQuestionAsync(q, r => r with { FieldVisibilityJson = json });
    }

    private static IReadOnlyList<string> ParseCodeList(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) { return Array.Empty<string>(); }
        try { return System.Text.Json.JsonSerializer.Deserialize<List<string>>(json) ?? new(); }
        catch (System.Text.Json.JsonException) { return Array.Empty<string>(); }
    }

    private async void OpenFormProps()
    {
        _modalError = null;
        _txIsTransactional = _def!.IsTransactional;
        _txMode = _def.IdentityMode.ToString();
        _txField = _def.IdentitySourceFieldCode;
        _isModule = _def.IsModule;
        _moduleIcon = _def.ModuleIcon;
        _moduleLabel = _def.Title;
        _moduleParentId = null;
        _moduleColumns.Clear(); _moduleFilters.Clear();
        foreach (var c in ParseCodeList(_def.ListColumnsJson)) { _moduleColumns.Add(c); }
        foreach (var f in ParseCodeList(_def.FilterFieldsJson)) { _moduleFilters.Add(f); }
        _showFormProps = true;
        // Vistas de menu para elegir DONDE colgar el modulo (ola F4).
        _menuViews = await MenuSvc.ListViewsAsync();
        _moduleViewId = _menuViews.FirstOrDefault(v => v.IsDefault)?.Id ?? _menuViews.FirstOrDefault()?.Id;
        if (_isModule && _moduleViewId is Guid vid) { await LoadMenuGroupsAsync(vid); }
        StateHasChanged();
    }

    private async Task OnModuleToggledAsync()
    {
        if (_isModule && _menuGroups.Count == 0 && _moduleViewId is Guid vid)
        {
            await LoadMenuGroupsAsync(vid);
        }
    }

    private async Task OnModuleViewChangedAsync(Guid? viewId)
    {
        _moduleViewId = viewId;
        _moduleParentId = null;
        if (viewId is Guid vid) { await LoadMenuGroupsAsync(vid); } else { _menuGroups.Clear(); }
    }

    /// <summary>Aplana el arbol de la vista a grupos (Section/Subgroup) para el selector de ubicacion.</summary>
    private async Task LoadMenuGroupsAsync(Guid viewId)
    {
        _menuGroups.Clear();
        var tree = await MenuSvc.GetViewTreeAsync(viewId);
        if (!tree.IsOk || tree.Value is null) { return; }
        void Walk(IReadOnlyList<MenuEditorNodeDto> nodes, int depth)
        {
            foreach (var n in nodes)
            {
                if (n.Kind is MenuNodeKind.Section or MenuNodeKind.Subgroup)
                {
                    _menuGroups.Add((n.Id, new string(' ', depth * 3) + n.Name));
                }
                if (n.Children.Count > 0) { Walk(n.Children, depth + 1); }
            }
        }
        Walk(tree.Value.Roots, 0);
    }

    private async Task SaveFormPropsAsync()
    {
        _modalError = null;
        var mode = Enum.TryParse<FormIdentityMode>(_txMode, out var m) ? m : FormIdentityMode.None;
        if (_txIsTransactional && mode == FormIdentityMode.NaturalKey && string.IsNullOrWhiteSpace(_txField))
        {
            _modalError = "Elige el campo clave para la identidad por dato.";
            return;
        }
        if (_isModule && !_def!.IsModule && _moduleViewId is null)
        {
            _modalError = "Elige la vista de menu donde publicar el modulo.";
            return;
        }
        _busy = true;
        try
        {
            var tx = await FormsSvc.SetTransactionalAsync(_def!.Id,
                new SetFormTransactionalRequest(_txIsTransactional, mode, _txField));
            if (!tx.IsOk) { _modalError = tx.Error; return; }
            _def = tx.Value;

            // Modulo: promover/retirar con el grupo elegido (ola F4).
            Guid? parent = Guid.TryParse(_moduleParentId, out var pid) ? pid : null;
            var mod = await FormsSvc.SetModuleAsync(_def!.Id,
                new SetFormModuleRequest(_isModule, _moduleViewId, parent, _moduleIcon,
                    _moduleColumns.ToList(), _moduleFilters.ToList(), _moduleLabel));
            if (!mod.IsOk) { _modalError = mod.Error; return; }
            _def = mod.Value;

            _showFormProps = false;
        }
        finally
        {
            _busy = false;
        }
    }

