    /// <summary>Cierra todos los popovers del sidebar del modal de tarjeta.</summary>
    private void CloseAllPopovers()
    {
        _showMembersPop = _showTagsPop = _showDatePop = _showColorPop = _showMovePop = false;
    }

    /// <summary>Abre el popover indicado y cierra los demas (mutuamente excluyentes).</summary>
    private void TogglePopover(string name)
    {
        var wasOpen = name switch
        {
            "members" => _showMembersPop,
            "tags" => _showTagsPop,
            "date" => _showDatePop,
            "color" => _showColorPop,
            "move" => _showMovePop,
            _ => false,
        };
        CloseAllPopovers();
        if (wasOpen) return; // si ya estaba abierto, queda cerrado
        switch (name)
        {
            case "members": _showMembersPop = true; break;
            case "tags": _showTagsPop = true; break;
            case "date": _showDatePop = true; break;
            case "color": _showColorPop = true; break;
            case "move": _showMovePop = true; break;
        }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private async Task<string> ActorNameAsync()
    {
        if (AuthState is null) { return "Usuario"; }
        var st = await AuthState;
        return st.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Usuario";
    }

    private async Task<string> ActorInitialsAsync()
    {
        var name = await ActorNameAsync();
        return InitialsOf(name);
    }
