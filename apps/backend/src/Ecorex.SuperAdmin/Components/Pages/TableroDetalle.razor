@* ===== Modal Historial ===== *@
@if (_showHistorial)
{
    <div class="modal-overlay" @onclick="@(() => _showHistorial = false)">
        <div class="modal-dialog" style="max-width:680px;" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>Tareas archivadas</h3>
                <button class="modal-close" @onclick="@(() => _showHistorial = false)">&times;</button>
            </div>
            <div class="modal-body">
                @if (_archivedCards.Count == 0)
                {
                    <p style="color:var(--muted-foreground);font-style:italic;">No hay tareas archivadas en este tablero.</p>
                }
                else
                {
                    <div style="display:flex;flex-direction:column;gap:8px;max-height:480px;overflow-y:auto;">
                        @foreach (var card in _archivedCards)
                        {
                            var col = _columns.FirstOrDefault(c => c.Id == card.ColumnId);
                            <div style="display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid var(--border);border-radius:8px;">
                                <div style="flex:1;">
                                    <div style="font-weight:600;font-size:13.5px;">@card.Title</div>
                                    <div style="font-size:11.5px;color:var(--muted-foreground);">@(col?.Name ?? "(sin columna)")</div>
                                </div>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => RestoreCardAsync(card.Id))" disabled="@_busy">Restaurar</button>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="@(() => _showHistorial = false)">Cerrar</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid BoardId { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private TaskBoardDto? _board;
    private List<TaskBoardColumnDto> _columns = new();
    private List<TaskCardSummaryDto> _cards = new();
    private List<TaskCardSummaryDto> _archivedCards = new();
    private List<TaskCardTagDto> _boardTags = new();
    private List<TenantUserDto> _tenantUsers = new();
    private HashSet<Guid> _doneColumnIds = new();

    private Guid? _dragCardId;
    private Guid? _dragOverColumnId;

    // Modal "Nueva tarea"
    private bool _showNewCardModal;
    private Guid _newCardColumnId;
    private string _newCardTitle = "";
    private string _newCardDescription = "";
    private DateTime? _newCardDueDate;
    private string? _newCardColor;

    // Paleta predefinida para colores del titulo de la tarjeta.
    private static readonly string[] _colorPalette = new[]
    {
        "#ef4444", "#f97316", "#f59e0b", "#22c55e", "#10b981",
        "#06b6d4", "#3b82f6", "#6366f1", "#8b5cf6", "#a855f7",
        "#ec4899", "#475569"
    };
    private string _customColor = "#7c4dff";
    private bool _showColorPop;

    private TaskCardDetailDto? _cardDetail;
    private bool _editingTitle;
    private bool _editingDesc;
    private string _editTitle = "";
    private string _editDescription = "";
    private string _newChecklistText = "";
    private string _newComment = "";
    private bool _showChecklistAdd;

    // Popovers
    private bool _showMembersPop;
    private bool _showTagsPop;
    private bool _showDatePop;
    private bool _showMovePop;
    private DateTime? _dueDate;

    // Catalogo etiquetas en modal config
    private string _newTagName = "";
    private string _newTagColor = "#7c4dff";
    private string _newColumnName = "";

    // UI state
    private string _view = "kanban";
    private string _search = "";
    private string _sort = "manual";
    private bool _showConfig;
    private bool _showHistorial;
    private string _actorInitials = "??";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        var boards = await BoardsSvc.ListBoardsAsync(includeArchived: true);
        _board = boards.FirstOrDefault(b => b.Id == BoardId);
        if (_board is null) { return; }
        _columns = (await BoardsSvc.ListColumnsAsync(BoardId)).OrderBy(c => c.SortOrder).ToList();
        _doneColumnIds = _columns.Where(c => c.IsDone).Select(c => c.Id).ToHashSet();
        _cards = (await CardsSvc.ListByBoardAsync(BoardId, includeArchived: false)).ToList();
        var allCards = (await CardsSvc.ListByBoardAsync(BoardId, includeArchived: true)).ToList();
        _archivedCards = allCards.Where(c => c.IsArchived).ToList();
        _boardTags = (await BoardsSvc.ListBoardTagsAsync(BoardId)).ToList();
        _tenantUsers = (await TenantUsersSvc.ListAsync()).ToList();
        _actorInitials = await ActorInitialsAsync();
    }

    private int _totalCount => _cards.Count;
    private int _doneCount => _cards.Count(c => _doneColumnIds.Contains(c.ColumnId));
    private int _inProgressCount => _cards.Count(c => !_doneColumnIds.Contains(c.ColumnId) && _columns.FirstOrDefault()?.Id != c.ColumnId);
    private int _completionRate => _totalCount == 0 ? 0 : (int)Math.Round((double)_doneCount / _totalCount * 100);

    private IEnumerable<TaskCardSummaryDto> FilteredCardsForColumn(Guid columnId)
    {
        var q = _cards.Where(c => c.ColumnId == columnId);
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(c => (c.Title?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                          || c.Members.Any(m => m.DisplayName.Contains(s, StringComparison.OrdinalIgnoreCase) || m.Initials.Contains(s, StringComparison.OrdinalIgnoreCase)));
        }
        q = _sort switch
        {
            "due" => q.OrderBy(c => c.DueAt ?? DateTimeOffset.MaxValue),
            "title" => q.OrderBy(c => c.Title),
            _ => q.OrderBy(c => c.SortOrder),
        };
        return q;
    }

    private IEnumerable<TaskCardSummaryDto> AllFilteredCards()
    {
        var q = _cards.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(c => (c.Title?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                          || c.Members.Any(m => m.DisplayName.Contains(s, StringComparison.OrdinalIgnoreCase)));
        }
        q = _sort switch
        {
            "due" => q.OrderBy(c => c.DueAt ?? DateTimeOffset.MaxValue),
            "title" => q.OrderBy(c => c.Title),
            _ => q.OrderBy(c => _columns.FindIndex(co => co.Id == c.ColumnId)).ThenBy(c => c.SortOrder),
        };
        return q;
    }

    private string StatusClass(TaskBoardColumnDto? c)
    {
        if (c is null) return "todo";
        if (c.IsDone) return "done";
        var idx = _columns.FindIndex(x => x.Id == c.Id);
        return idx switch
        {
            1 => "progress",
            2 => "review",
            _ => "todo",
        };
    }

    private static string FormatDue(DateTimeOffset due, bool isLate)
    {
        if (isLate) return "Atrasado";
        var local = due.ToLocalTime().Date;
        var today = DateTimeOffset.Now.Date;
        if (local == today) return "Hoy";
        if (local == today.AddDays(1)) return "Manana";
        if (local == today.AddDays(-1)) return "Ayer";
        return local.ToString("dd MMM");
    }

    private static string FormatRelative(DateTimeOffset when)
    {
        var diff = DateTimeOffset.UtcNow - when;
        if (diff.TotalMinutes < 1) return "ahora mismo";
        if (diff.TotalMinutes < 60) return $"hace {(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24) return $"hace {(int)diff.TotalHours} h";
        if (diff.TotalDays < 7) return $"hace {(int)diff.TotalDays} d";
        return when.ToLocalTime().ToString("dd MMM");
    }

    private static string InitialsOf(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "??";
        var trimmed = name.Trim();
        var atIdx = trimmed.IndexOf('@');
        if (atIdx > 0) trimmed = trimmed[..atIdx];
        var parts = trimmed.Split(new[] { ' ', '.', '-', '_' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return trimmed.Length >= 2 ? trimmed[..2].ToUpperInvariant() : trimmed.ToUpperInvariant();
        if (parts.Length == 1) return parts[0].Length >= 2 ? parts[0][..2].ToUpperInvariant() : parts[0].ToUpperInvariant();
        return (parts[0][0].ToString() + parts[1][0]).ToUpperInvariant();
    }

    private async Task OnDropAsync(Guid targetColumnId)
    {
        _dragOverColumnId = null;
        if (_dragCardId is null) { return; }
        var card = _cards.FirstOrDefault(c => c.Id == _dragCardId.Value);
        var dragged = _dragCardId.Value;
        _dragCardId = null;
        if (card is null || card.ColumnId == targetColumnId) { return; }

        var actor = await ActorAsync();
        var actorName = await ActorNameAsync();
        var newOrder = _cards.Count(c => c.ColumnId == targetColumnId);
        var ok = await CardsSvc.MoveAsync(dragged, new MoveTaskCardRequest(targetColumnId, newOrder), actor, actorName);
        if (ok) { await LoadAsync(); }
    }

