@page "/tableros/{boardId:guid}"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@using Ecorex.Domain.Enums
@inject ITaskBoardService BoardsSvc
@inject ITaskCardService CardsSvc
@inject ITenantUserService TenantUsersSvc
@inject NavigationManager Nav

<PageTitle>@(_board?.Name ?? "Tablero") - ECOREX.tareas</PageTitle>

@if (_loading)
{
    <p><em>Cargando tablero...</em></p>
}
else if (_board is null)
{
    <div class="card" style="padding:32px;max-width:680px;">
        <p>No se encontro el tablero. <a href="/tableros">Volver a tableros</a>.</p>
    </div>
}
else
{
    <div class="module-head">
        <div>
            <div class="module-eyebrow">
                <div class="module-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
                </div>
                <span>Gestion de Proyectos</span>
            </div>
            <h1 class="page-title" style="margin-top:12px;">@_board.Name <span>Agil</span></h1>
            <p class="page-sub" style="margin-bottom:0;">@(string.IsNullOrWhiteSpace(_board.Description) ? "Embudo Kanban con etapas configurables para mover tareas hasta su cierre." : _board.Description)</p>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
            <button class="btn btn-outline-secondary" @onclick="@(() => Nav.NavigateTo("/tableros"))">&larr; Tableros</button>
            <button class="btn btn-outline-secondary" @onclick="OpenConfig">Configurar tablero</button>
            <button class="btn btn-outline-secondary" @onclick="OpenHistorial">Historial</button>
            <button class="btn btn-primary" @onclick="@(() => OpenNewCardModal(_columns.FirstOrDefault()?.Id ?? Guid.Empty))" disabled="@(_columns.Count == 0)">+ Nueva tarea</button>
        </div>
    </div>

    @* ===== 3 KPI cards ===== *@
    <div class="kpi-grid" style="margin-bottom:24px;grid-template-columns:repeat(3,minmax(0,1fr));max-width:1280px;">
        <div class="kpi-card">
            <div class="kpi-top">
                <div class="kpi-icon tone-primary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v6h6"/></svg>
                </div>
            </div>
            <div class="kpi-label">Total tareas</div>
            <div class="kpi-value">@_totalCount</div>
            <div class="kpi-hint">Activas en el tablero</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-top">
                <div class="kpi-icon tone-success">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/></svg>
                </div>
            </div>
            <div class="kpi-label">Tasa de finalizacion</div>
            <div class="kpi-value">@_completionRate%</div>
            <div class="kpi-hint">@_doneCount completadas de @_totalCount</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-top">
                <div class="kpi-icon tone-gold">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
            </div>
            <div class="kpi-label">En progreso</div>
            <div class="kpi-value">@_inProgressCount</div>
            <div class="kpi-hint">Tareas en desarrollo</div>
        </div>
    </div>

    @* ===== Toolbar (search + sort + view + filter) ===== *@
    <div class="tb-toolbar">
        <div class="tb-toolbar-search">
            <svg class="tb-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input type="text" placeholder="Buscar tarea o responsable..." @bind="_search" @bind:event="oninput" />
        </div>
        <div class="tb-toolbar-right">
            <div class="tb-sort">
                <span>Ordenar:</span>
                <select @bind="_sort">
                    <option value="manual">Manual</option>
                    <option value="due">Fecha</option>
                    <option value="title">Titulo</option>
                </select>
            </div>
            <div class="tb-view">
                <button class="@(_view == "kanban" ? "active" : "")" @onclick="@(() => _view = "kanban")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
                    Kanban
                </button>
                <button class="@(_view == "list" ? "active" : "")" @onclick="@(() => _view = "list")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/><line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/></svg>
                    Lista
                </button>
            </div>
        </div>
    </div>

    @if (_view == "kanban")
    {
        <div class="tb-board">
            @foreach (var col in _columns)
            {
                <div class="tb-col @(_dragOverColumnId == col.Id ? "tb-col-drag" : "")"
                     ondragover="event.preventDefault()"
                     @ondragenter="@(() => _dragOverColumnId = col.Id)"
                     @ondragleave="@(() => { if (_dragOverColumnId == col.Id) _dragOverColumnId = null; })"
                     @ondrop="@(() => OnDropAsync(col.Id))">
                    <div class="tb-col-head">
                        <span class="tb-col-name">@col.Name</span>
                        <span class="tb-col-count">@FilteredCardsForColumn(col.Id).Count()</span>
                    </div>
                    <div class="tb-col-body">
                        @{
                            var colCards = FilteredCardsForColumn(col.Id).ToList();
                        }
                        @if (colCards.Count == 0)
                        {
                            <div class="tb-col-empty">Sin tareas en esta etapa</div>
                        }
                        @foreach (var card in colCards)
                        {
                            <div class="tb-card-item @(_dragCardId == card.Id ? "dragging" : "")"
                                 draggable="true"
                                 @ondragstart="@(() => _dragCardId = card.Id)"
                                 @ondragend="@(() => _dragCardId = null)"
                                 @onclick="@(() => OpenCardAsync(card.Id))">
                                @if (card.Tags.Count > 0)
                                {
                                    <div class="tb-card-tags">
                                        @foreach (var t in card.Tags)
                                        {
                                            <span class="tb-tag" style="@(string.IsNullOrWhiteSpace(t.Color) ? "" : $"background:{t.Color};color:#fff;")">@t.Name</span>
                                        }
                                    </div>
                                }
                                <div class="tb-card-title" style="@(string.IsNullOrEmpty(card.Color) ? "" : $"color:{card.Color};border-left:3px solid {card.Color};padding-left:8px;")">@card.Title</div>
                                @if (!string.IsNullOrWhiteSpace(card.Description) || card.ChecklistTotal > 0 || card.CommentsCount > 0 || card.AttachmentsCount > 0)
                                {
                                    <div class="tb-card-meta">
                                        @if (!string.IsNullOrWhiteSpace(card.Description))
                                        {
                                            <span class="tb-card-meta-item" title="Tiene descripcion">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" x2="3" y1="6" y2="6"/><line x1="21" x2="3" y1="12" y2="12"/><line x1="15" x2="3" y1="18" y2="18"/></svg>
                                            </span>
                                        }
                                        @if (card.ChecklistTotal > 0)
                                        {
                                            <span class="tb-card-meta-item" title="Checklist">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                                                <span>@card.ChecklistDone/@card.ChecklistTotal</span>
                                            </span>
                                        }
                                        @if (card.CommentsCount > 0)
                                        {
                                            <span class="tb-card-meta-item" title="Comentarios">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                                <span>@card.CommentsCount</span>
                                            </span>
                                        }
                                        @if (card.AttachmentsCount > 0)
                                        {
                                            <span class="tb-card-meta-item" title="Adjuntos">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 17.93 8.8l-8.59 8.57a2 2 0 1 1-2.83-2.83l8.49-8.48"/></svg>
                                                <span>@card.AttachmentsCount</span>
                                            </span>
                                        }
                                    </div>
                                }
                                <div class="tb-card-foot">
                                    <div class="tb-members">
                                        @if (card.Members.Count == 0)
                                        {
                                            <div class="tb-avatar empty" title="Sin asignar">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                            </div>
                                        }
                                        else
                                        {
                                            @foreach (var m in card.Members)
                                            {
                                                <div class="tb-avatar" title="@m.DisplayName">@m.Initials</div>
                                            }
                                        }
                                    </div>
                                    @if (card.DueAt is not null)
                                    {
                                        var isLate = card.DueAt < DateTimeOffset.UtcNow && !_doneColumnIds.Contains(card.ColumnId);
                                        <span class="tb-due @(isLate ? "late" : "")">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                            @FormatDue(card.DueAt.Value, isLate)
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <div class="tb-col-foot">
                        <button class="tb-col-add" @onclick="@(() => OpenNewCardModal(col.Id))" disabled="@_busy">
                            <span class="tb-col-add-plus">+</span> Agregar tarea
                        </button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        @* ===== Vista Lista ===== *@
        <div class="tb-list">
            @{
                var listCards = AllFilteredCards().ToList();
            }
            @if (listCards.Count == 0)
            {
                <div class="tb-list-empty">No hay tareas que coincidan con la busqueda.</div>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th style="width:36%;">Tarea</th>
                            <th>Etiquetas</th>
                            <th>Columna</th>
                            <th>Asignados</th>
                            <th>Vence</th>
                            <th style="text-align:right;">Checklist</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var card in listCards)
                        {
                            var col = _columns.FirstOrDefault(c => c.Id == card.ColumnId);
                            var isLate = card.DueAt is not null && card.DueAt < DateTimeOffset.UtcNow && !_doneColumnIds.Contains(card.ColumnId);
                            <tr @onclick="@(() => OpenCardAsync(card.Id))">
                                <td><strong>@card.Title</strong></td>
                                <td>
                                    @foreach (var t in card.Tags)
                                    {
                                        <span class="tb-tag" style="@(string.IsNullOrWhiteSpace(t.Color) ? "" : $"background:{t.Color};color:#fff;") margin-right:4px;">@t.Name</span>
                                    }
                                </td>
                                <td>
                                    <span class="tb-status @StatusClass(col)">@(col?.Name ?? "-")</span>
                                </td>
                                <td>
                                    <div class="tb-members">
                                        @foreach (var m in card.Members)
                                        {
                                            <div class="tb-avatar" title="@m.DisplayName">@m.Initials</div>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (card.DueAt is not null)
                                    {
                                        <span class="tb-due @(isLate ? "late" : "")">@FormatDue(card.DueAt.Value, isLate)</span>
                                    }
                                </td>
                                <td style="text-align:right;color:var(--muted-foreground);font-size:12.5px;">
                                    @if (card.ChecklistTotal > 0)
                                    {
                                        <text>@card.ChecklistDone / @card.ChecklistTotal</text>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
}

@* ===== Modal: detalle de tarjeta ===== *@
@if (_cardDetail is not null)
{
    var detail = _cardDetail;
    var col = _columns.FirstOrDefault(c => c.Id == detail.Card.ColumnId);
    <div class="modal-overlay" @onclick="CloseCard">
        <div class="tb-modal" @onclick:stopPropagation="true">
            <div class="tb-modal-head">
                <svg class="tb-modal-head-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
                <div class="tb-modal-head-content">
                    @if (_editingTitle)
                    {
                        <input class="form-control" @bind="_editTitle" @bind:event="oninput" style="font-size:1.4rem;font-weight:700;" />
                        <div style="margin-top:8px;display:flex;gap:8px;">
                            <button class="btn btn-sm btn-primary" @onclick="SaveTitleAsync" disabled="@_busy">Guardar</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => { _editingTitle = false; _editTitle = detail.Card.Title; })">Cancelar</button>
                        </div>
                    }
                    else
                    {
                        <h2 class="tb-modal-title" @onclick="@(() => { _editingTitle = true; _editTitle = detail.Card.Title; })" style="cursor:text;@(string.IsNullOrEmpty(detail.Card.Color) ? "" : $"color:{detail.Card.Color};")">@detail.Card.Title</h2>
                        <p class="tb-modal-subtitle">en la lista <strong>@(col?.Name ?? "(sin columna)")</strong></p>
                    }
                </div>
                <button class="tb-modal-close" @onclick="CloseCard" aria-label="Cerrar">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>

            <div class="tb-modal-body">
                <div class="tb-modal-main">
                    @* Members + Tags inline row *@
                    @if (detail.Card.Members.Count > 0 || detail.Card.Tags.Count > 0)
                    {
                        <div class="tb-modal-inline-row">
                            @if (detail.Card.Members.Count > 0)
                            {
                                <div>
                                    <h4 class="tb-modal-mini-h4">Miembros</h4>
                                    <div style="display:flex;gap:4px;align-items:center;">
                                        @foreach (var m in detail.Card.Members)
                                        {
                                            <div class="tb-avatar lg" title="@m.DisplayName" @onclick="@(() => UnassignMemberAsync(m.TenantUserId))" style="cursor:pointer;">@m.Initials</div>
                                        }
                                        <button class="tb-modal-add-btn" @onclick="@(() => _showMembersPop = !_showMembersPop)" title="Agregar miembro">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                                        </button>
                                    </div>
                                </div>
                            }
                            @if (detail.Card.Tags.Count > 0)
                            {
                                <div>
                                    <h4 class="tb-modal-mini-h4">Etiquetas</h4>
                                    <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:center;">
                                        @foreach (var t in detail.Card.Tags)
                                        {
                                            <span class="tb-modal-tag" style="@(string.IsNullOrWhiteSpace(t.Color) ? "" : $"background:{t.Color};color:#fff;")" @onclick="@(() => DetachTagAsync(t.Id))" title="Quitar etiqueta">@t.Name</span>
                                        }
                                        <button class="tb-modal-add-btn sq" @onclick="@(() => _showTagsPop = !_showTagsPop)" title="Agregar etiqueta">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @* Descripcion *@
                    <div class="tb-modal-section">
                        <svg class="tb-modal-section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" x2="3" y1="6" y2="6"/><line x1="21" x2="3" y1="12" y2="12"/><line x1="15" x2="3" y1="18" y2="18"/></svg>
                        <div class="tb-modal-section-body">
                            <div class="tb-modal-section-head">
                                <h3 class="tb-modal-section-title">Descripcion</h3>
                                @if (!string.IsNullOrWhiteSpace(detail.Card.Description) && !_editingDesc)
                                {
                                    <button class="tb-modal-section-action" @onclick="@(() => { _editingDesc = true; _editDescription = detail.Card.Description ?? ""; })">Editar</button>
                                }
                            </div>
                            @if (_editingDesc)
                            {
                                <div class="tb-desc-edit">
                                    <textarea @bind="_editDescription" @bind:event="oninput" placeholder="Que detalles importantes debe saber el equipo?"></textarea>
                                    <div class="tb-desc-edit-actions">
                                        <button class="btn btn-sm btn-primary" @onclick="SaveDescriptionAsync" disabled="@_busy">Guardar</button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => { _editingDesc = false; _editDescription = detail.Card.Description ?? ""; })">Cancelar</button>
                                    </div>
                                </div>
                            }
                            else if (string.IsNullOrWhiteSpace(detail.Card.Description))
                            {
                                <div class="tb-desc-empty" @onclick="@(() => { _editingDesc = true; _editDescription = ""; })">
                                    Agrega una descripcion mas detallada...
                                </div>
                            }
                            else
                            {
                                <div class="tb-desc-text" @onclick="@(() => { _editingDesc = true; _editDescription = detail.Card.Description ?? ""; })">@detail.Card.Description</div>
                            }
                        </div>
                    </div>

                    @* Checklist *@
                    @if (detail.Checklist.Count > 0 || _showChecklistAdd)
                    {
                        var totalChecks = detail.Checklist.Count;
                        var doneChecks = detail.Checklist.Count(i => i.IsCompleted);
                        var pct = totalChecks == 0 ? 0 : (int)Math.Round((double)doneChecks / totalChecks * 100);
                        <div class="tb-modal-section">
                            <svg class="tb-modal-section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                            <div class="tb-modal-section-body">
                                <div class="tb-modal-section-head">
                                    <h3 class="tb-modal-section-title">Checklist</h3>
                                </div>
                                @if (totalChecks > 0)
                                {
                                    <div class="tb-check-progress">
                                        <span class="tb-check-progress-label">@pct%</span>
                                        <div class="tb-check-bar">
                                            <div class="tb-check-bar-fill" style="width:@(pct)%"></div>
                                        </div>
                                    </div>
                                }
                                <div class="tb-check-list">
                                    @foreach (var item in detail.Checklist)
                                    {
                                        <div class="tb-check-item">
                                            <input type="checkbox" checked="@item.IsCompleted" @onchange="@(e => ToggleChecklistItemAsync(item.Id, (bool)e.Value!, item.Text))" />
                                            <span class="tb-check-item-text @(item.IsCompleted ? "done" : "")">@item.Text</span>
                                            <button class="tb-check-item-del" @onclick="@(() => DeleteChecklistItemAsync(item.Id))" title="Eliminar">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                                            </button>
                                        </div>
                                    }
                                </div>
                                <div class="tb-check-add">
                                    <input @bind="_newChecklistText" @bind:event="oninput" placeholder="Agregar elemento al checklist..." />
                                    <button class="btn btn-sm btn-primary" @onclick="AddChecklistAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_newChecklistText))">Agregar</button>
                                </div>
                            </div>
                        </div>
                    }

                    @* Actividad *@
                    <div class="tb-modal-section">
                        <svg class="tb-modal-section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                        <div class="tb-modal-section-body">
                            <div class="tb-modal-section-head">
                                <h3 class="tb-modal-section-title">Actividad</h3>
                            </div>
                            <div class="tb-act-input">
                                <div class="tb-avatar lg">@_actorInitials</div>
                                <div class="tb-act-input-box">
                                    <textarea @bind="_newComment" @bind:event="oninput" placeholder="Escribe un comentario..."></textarea>
                                    <div class="tb-act-input-foot">
                                        <span></span>
                                        <button class="btn btn-sm btn-primary" @onclick="AddCommentAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_newComment))">Guardar</button>
                                    </div>
                                </div>
                            </div>
                            <div class="tb-act-list">
                                @if (detail.Activity.Count == 0)
                                {
