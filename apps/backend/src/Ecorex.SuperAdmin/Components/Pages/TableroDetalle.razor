@* ===== Modal Configurar tablero ===== *@
@if (_showConfig)
{
    <div class="modal-overlay" @onclick="@(() => _showConfig = false)">
        <div class="modal-dialog" style="max-width:720px;" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>Configurar tablero</h3>
                <button class="modal-close" @onclick="@(() => _showConfig = false)">&times;</button>
            </div>
            <div class="modal-body">
                <h4 style="font-size:13px;font-weight:700;margin:0 0 10px;">Columnas</h4>
                <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:18px;">
                    @foreach (var c in _columns)
                    {
                        <div class="tb-config-row">
                            <span class="tb-color-dot" style="background:@(string.IsNullOrWhiteSpace(c.Color) ? "#7c4dff" : c.Color);"></span>
                            <input type="text" value="@c.Name" @onchange="@(e => RenameColumnAsync(c.Id, e.Value?.ToString() ?? c.Name, c.IsDone))" />
                            <label style="display:flex;align-items:center;gap:4px;font-size:12px;color:var(--muted-foreground);">
                                <input type="checkbox" checked="@c.IsDone" @onchange="@(e => RenameColumnAsync(c.Id, c.Name, (bool)e.Value!))" />
                                Completado
                            </label>
                            <button class="btn btn-sm btn-outline-danger" @onclick="@(() => DeleteColumnAsync(c.Id))">&times;</button>
                        </div>
                    }
                </div>
                <div style="display:flex;gap:6px;margin-bottom:24px;">
                    <input class="form-control form-control-sm" @bind="_newColumnName" @bind:event="oninput" placeholder="Nueva columna" />
                    <button class="btn btn-sm btn-primary" @onclick="AddColumnAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_newColumnName))">+ Agregar</button>
                </div>

                <h4 style="font-size:13px;font-weight:700;margin:0 0 10px;">Catalogo de etiquetas</h4>
                <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:14px;">
                    @foreach (var t in _boardTags)
                    {
                        <div class="tb-config-row">
                            <span class="tb-color-dot" style="background:@(string.IsNullOrWhiteSpace(t.Color) ? "#94a3b8" : t.Color);"></span>
                            <input type="text" value="@t.Name" @onchange="@(e => RenameTagAsync(t.Id, e.Value?.ToString() ?? t.Name, t.Color))" />
                            <input type="text" value="@(t.Color ?? "")" @onchange="@(e => RenameTagAsync(t.Id, t.Name, e.Value?.ToString()))" style="max-width:90px;" placeholder="#color" />
                            <button class="btn btn-sm btn-outline-danger" @onclick="@(() => DeleteTagAsync(t.Id))">&times;</button>
                        </div>
                    }
                </div>
                <div style="display:flex;gap:6px;">
                    <input class="form-control form-control-sm" @bind="_newTagName" @bind:event="oninput" placeholder="Nueva etiqueta" />
                    <input class="form-control form-control-sm" @bind="_newTagColor" @bind:event="oninput" placeholder="#7c4dff" style="max-width:110px;" />
                    <button class="btn btn-sm btn-primary" @onclick="CreateTagAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_newTagName))">+ Agregar</button>
                </div>
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="@(() => _showConfig = false)">Cerrar</button>
            </div>
        </div>
    </div>
}

@* ===== Modal Nueva tarea ===== *@
@if (_showNewCardModal)
{
