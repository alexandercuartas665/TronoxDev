@page "/proyectos/{ProjectId:guid}"
@attribute [Authorize(Policy = "Proyectos.Ver")]
@* Policy por modulo (paso 1: mismo requisito que TenantMember, nombre estable). TODO: derivar del Module Registry. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@using Ecorex.Domain.Enums
@using Ecorex.SuperAdmin.Components.Shared.Tasks
@inject IProjectService ProjectsSvc
@inject ITenantUserService TenantUsersSvc
@inject NavigationManager Nav

<PageTitle>@(_project?.Name ?? "Proyecto") - ECOREX.tareas</PageTitle>

@if (_loading)
{
    <p><em>Cargando proyecto...</em></p>
}
else if (_project is null)
{
    <div class="card" style="padding:32px;max-width:680px;">
        <p>No se encontro el proyecto. <a href="/proyectos">Volver a proyectos</a>.</p>
    </div>
}
else
{
    <nav class="ecorex-breadcrumb" aria-label="Ruta de navegacion">
        <a href="/inicio">Workspace</a>
        <span class="sep">/</span>
        <a href="/proyectos">Proyectos</a>
        <span class="sep">/</span>
        <span class="cur">@_project.Code</span>
    </nav>

    <div class="module-head">
        <div>
            <div class="module-eyebrow">
                <div class="module-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
                </div>
                <span>Proyecto @_project.Code</span>
            </div>
            <h1 class="page-title" style="margin-top:12px;">@_project.Name</h1>
            <p class="page-sub" style="margin-bottom:0;">@(string.IsNullOrWhiteSpace(_project.Description) ? "Tablero de actividades del proyecto." : _project.Description)</p>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
            <button class="btn btn-outline-secondary" @onclick="@(() => Nav.NavigateTo("/proyectos"))">&larr; Proyectos</button>
            <button class="btn btn-primary" @onclick="@(() => _kanban is null ? Task.CompletedTask : _kanban.OpenNewTaskAsync())">+ Tarea</button>
        </div>
    </div>

    @* ===== Cabecera: estado, owner, fechas, miembros ===== *@
    <div class="tk-project-head card">
        <div class="tk-project-head-row">
            <div class="tk-project-field">
                <span class="wlbl">Estado</span>
                <select class="form-control form-control-sm" value="@_project.Status" @onchange="@(e => ChangeStatusAsync(Enum.Parse<ProjectStatus>(e.Value!.ToString()!)))">
                    @foreach (var s in Enum.GetValues<ProjectStatus>())
                    {
                        <option value="@s">@TaskUi.ProjectStatusLabel(s)</option>
                    }
                </select>
            </div>
            <div class="tk-project-field">
                <span class="wlbl">Owner</span>
                <span class="tk-assignee"><span class="tb-avatar">@TaskUi.InitialsOf(UserEmail(_project.OwnerTenantUserId))</span> @UserEmail(_project.OwnerTenantUserId)</span>
            </div>
            <div class="tk-project-field">
                <span class="wlbl">Fechas</span>
                <span class="wval">@(_project.StartDate?.ToString("dd MMM yyyy") ?? "?") - @(_project.EndDate?.ToString("dd MMM yyyy") ?? "abierto")</span>
            </div>
            <div class="tk-project-field">
                <span class="wlbl">Tareas</span>
                <span class="wval">@_project.TaskCount</span>
            </div>
            <div class="tk-project-field" style="flex:1;">
                <span class="wlbl">Miembros</span>
                <div style="display:flex;align-items:center;gap:4px;">
                    <div class="tb-members">
                        @foreach (var m in _members)
                        {
                            <div class="tb-avatar lg" title="@($"{m.Email}{(m.IsOwner ? " (owner)" : m.CanEdit ? " (edita)" : " (lectura)")}")">@TaskUi.InitialsOf(m.Email)</div>
                        }
                    </div>
                    <button class="tb-modal-add-btn sq" title="Gestionar miembros" @onclick="@(() => _showMembers = !_showMembers)">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                    </button>
                </div>
            </div>
        </div>
        @if (_statusError is not null)
        {
            <div class="tk-field-error" style="padding:0 18px 12px;">@_statusError</div>
        }

        @* Panel de miembros (agregar / quitar / CanEdit) *@
        @if (_showMembers)
        {
            <div class="tk-members-panel">
                <div class="tk-members-list">
                    @foreach (var m in _members)
                    {
                        <div class="tk-member-row">
                            <span class="tb-avatar">@TaskUi.InitialsOf(m.Email)</span>
                            <span class="tk-member-mail">@m.Email</span>
                            @if (m.IsOwner)
                            {
                                <span class="tk-status st-active">Owner</span>
                            }
                            else
                            {
                                <label class="pl-toggle" title="Puede editar el proyecto y sus tareas">
                                    <input type="checkbox" checked="@m.CanEdit" @onchange="@(e => SetCanEditAsync(m.TenantUserId, (bool)e.Value!))" />
                                    Puede editar
                                </label>
                                <button class="btn btn-sm btn-outline-danger" @onclick="@(() => RemoveMemberAsync(m.TenantUserId))" disabled="@_busy">Quitar</button>
                            }
                        </div>
                    }
                </div>
                <div class="tk-member-add">
                    <select class="form-control form-control-sm" @bind="_newMemberId">
                        <option value="">Agregar usuario...</option>
                        @foreach (var u in _users.Where(u => _members.All(m => m.TenantUserId != u.Id)))
                        {
                            <option value="@u.Id">@u.Email</option>
                        }
                    </select>
                    <label class="pl-toggle"><input type="checkbox" @bind="_newMemberCanEdit" /> Puede editar</label>
                    <button class="btn btn-sm btn-primary" @onclick="AddMemberAsync" disabled="@(_busy || string.IsNullOrEmpty(_newMemberId))">Agregar</button>
                </div>
                @if (_memberError is not null)
                {
                    <div class="tk-field-error">@_memberError</div>
                }
            </div>
        }
    </div>

    @* ===== Hitos del proyecto (Proyectos P1) ===== *@
    <div class="card" style="padding:18px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
            <h2 style="font-size:15px;font-weight:700;margin:0;flex:1;">Hitos del proyecto</h2>
            <span class="wlbl">@_milestones.Count(m => m.IsCompleted)/@_milestones.Count completados</span>
        </div>

        @if (_milestones.Count == 0)
        {
            <p class="page-sub" style="margin:0 0 12px;">Aun no hay hitos. Agrega el primero abajo.</p>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px;">
                @foreach (var m in _milestones)
                {
                    <div class="tk-member-row" style="gap:10px;">
                        <input type="checkbox" checked="@m.IsCompleted" title="Marcar completado"
                               @onchange="@(e => SetMilestoneCompletedAsync(m.Id, (bool)e.Value!))" disabled="@_busy" />
                        <span style="flex:1;@(m.IsCompleted ? "text-decoration:line-through;color:var(--ink-3);" : "")">@m.Name</span>
                        <span class="wlbl">@(m.DueDate?.ToString("dd MMM yyyy") ?? "sin fecha")</span>
                        <span class="tk-status st-active" title="Actividades enlazadas">@m.TaskCount act.</span>
                        <button class="btn btn-sm btn-outline-danger" @onclick="@(() => RemoveMilestoneAsync(m.Id))" disabled="@_busy">Quitar</button>
                    </div>
                }
            </div>
        }

        <div class="tk-member-add">
            <input class="form-control form-control-sm" style="flex:1;" placeholder="Nombre del hito" @bind="_newMilestoneName" />
            <input class="form-control form-control-sm" type="date" style="max-width:170px;" @bind="_newMilestoneDue" />
            <button class="btn btn-sm btn-primary" @onclick="AddMilestoneAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_newMilestoneName))">Agregar hito</button>
        </div>
        @if (_milestoneError is not null)
        {
            <div class="tk-field-error">@_milestoneError</div>
        }
    </div>

    @* ===== Timeline de hitos (P2): reusa los hitos ordenados por fecha ===== *@
    @if (_milestones.Count > 0)
    {
        <div class="card" style="padding:18px;margin-bottom:16px;">
            <h2 style="font-size:15px;font-weight:700;margin:0 0 14px;">Linea de tiempo</h2>
            <div style="display:flex;gap:0;overflow-x:auto;padding:4px 0 8px;">
                @foreach (var m in _milestones.OrderBy(x => x.DueDate ?? DateOnly.MaxValue).ThenBy(x => x.SortOrder))
                {
                    <div style="flex:1 0 130px;min-width:130px;text-align:center;position:relative;padding:0 6px;">
                        <div style="height:2px;background:var(--line);position:absolute;top:9px;left:0;right:0;"></div>
                        <div style="width:14px;height:14px;border-radius:50%;margin:2px auto;position:relative;z-index:1;
                                    background:@(m.IsCompleted ? "var(--brand, #6d3bff)" : "var(--surface)");border:2px solid var(--brand, #6d3bff);"></div>
                        <div style="font-size:12px;font-weight:600;color:var(--ink);margin-top:6px;">@m.Name</div>
                        <div style="font-size:11px;color:var(--ink-3);">@(m.DueDate?.ToString("dd MMM yyyy") ?? "sin fecha")</div>
                    </div>
                }
            </div>
        </div>
    }

    @* ===== Presupuesto y costos (P2) ===== *@
    <div class="card" style="padding:18px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
            <h2 style="font-size:15px;font-weight:700;margin:0;flex:1;">Presupuesto y costos</h2>
            <span class="wlbl">Presupuestado @BudgetTotalPlanned.ToString("N0") &middot; Real @BudgetTotalActual.ToString("N0")</span>
        </div>
        @if (_budget.Count > 0)
        {
            <div style="overflow-x:auto;">
                <table style="width:100%;border-collapse:collapse;font-size:13px;">
                    <thead>
                        <tr style="text-align:left;color:var(--ink-3);border-bottom:1px solid var(--line);">
                            <th style="padding:6px 8px;">Rubro</th><th style="padding:6px 8px;">Categoria</th>
                            <th style="padding:6px 8px;text-align:right;">Presupuestado</th><th style="padding:6px 8px;text-align:right;">Real</th>
                            <th style="padding:6px 8px;text-align:right;">Diferencia</th><th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in _budget)
                        {
                            <tr style="border-bottom:1px solid var(--line);">
                                <td style="padding:6px 8px;">@b.Name</td>
                                <td style="padding:6px 8px;color:var(--ink-2);">@(b.Category ?? "-")</td>
                                <td style="padding:6px 8px;text-align:right;">@b.PlannedAmount.ToString("N0")</td>
                                <td style="padding:6px 8px;text-align:right;">@b.ActualAmount.ToString("N0")</td>
                                <td style="padding:6px 8px;text-align:right;color:@((b.ActualAmount - b.PlannedAmount) > 0 ? "var(--danger)" : "var(--ink-2)");">@((b.ActualAmount - b.PlannedAmount).ToString("N0"))</td>
                                <td style="padding:6px 8px;text-align:right;"><button class="btn btn-sm btn-outline-danger" @onclick="@(() => RemoveBudgetAsync(b.Id))" disabled="@_busy">Quitar</button></td>
                            </tr>
                        }
                        <tr style="font-weight:700;">
                            <td style="padding:6px 8px;" colspan="2">Total</td>
                            <td style="padding:6px 8px;text-align:right;">@BudgetTotalPlanned.ToString("N0")</td>
                            <td style="padding:6px 8px;text-align:right;">@BudgetTotalActual.ToString("N0")</td>
                            <td style="padding:6px 8px;text-align:right;">@((BudgetTotalActual - BudgetTotalPlanned).ToString("N0"))</td><td></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }
        else { <p class="page-sub" style="margin:0 0 12px;">Aun no hay rubros. Agrega el primero abajo.</p> }
        <div class="tk-member-add" style="flex-wrap:wrap;">
            <input class="form-control form-control-sm" style="flex:2;min-width:160px;" placeholder="Rubro" @bind="_newBudgetName" />
            <input class="form-control form-control-sm" style="flex:1;min-width:110px;" placeholder="Categoria" @bind="_newBudgetCategory" />
            <input class="form-control form-control-sm" style="max-width:130px;" type="number" placeholder="Presupuestado" @bind="_newBudgetPlanned" />
            <input class="form-control form-control-sm" style="max-width:110px;" type="number" placeholder="Real" @bind="_newBudgetActual" />
            <button class="btn btn-sm btn-primary" @onclick="AddBudgetAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_newBudgetName))">Agregar</button>
        </div>
        @if (_budgetError is not null) { <div class="tk-field-error">@_budgetError</div> }
    </div>

    @* ===== Analisis DOFA (P2) ===== *@
    <div class="card" style="padding:18px;margin-bottom:16px;">
        <h2 style="font-size:15px;font-weight:700;margin:0 0 12px;">Analisis DOFA</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            @foreach (var q in new[] { DofaQuadrant.Fortaleza, DofaQuadrant.Oportunidad, DofaQuadrant.Debilidad, DofaQuadrant.Amenaza })
            {
                <div style="border:1px solid var(--line);border-radius:12px;padding:12px;">
                    <div style="font-weight:700;font-size:13px;margin-bottom:8px;color:@DofaColor(q);">@DofaLabel(q)</div>
                    @foreach (var d in _dofa.Where(x => x.Quadrant == q))
                    {
                        <div class="tk-member-row" style="gap:8px;padding:5px 0;">
                            <span style="flex:1;font-size:13px;">@d.Text</span>
                            <button class="btn btn-sm btn-link p-0 text-danger" @onclick="@(() => RemoveDofaAsync(d.Id))" disabled="@_busy">&times;</button>
                        </div>
                    }
                    <div style="display:flex;gap:6px;margin-top:6px;">
                        <input class="form-control form-control-sm" placeholder="Agregar..." value="@_dofaInputs[q]" @onchange="@(e => _dofaInputs[q] = e.Value?.ToString() ?? "")" @onkeydown="@(e => OnDofaKey(e, q))" />
                    </div>
                </div>
            }
        </div>
        @if (_dofaError is not null) { <div class="tk-field-error">@_dofaError</div> }
    </div>

    @* ===== Kanban del proyecto (componente reutilizado con filtro fijo) ===== *@
    <TaskKanban @ref="_kanban" ProjectId="@ProjectId" />
}

@code {
    [Parameter] public Guid ProjectId { get; set; }

    private bool _loading = true;
    private bool _busy;
    private ProjectDto? _project;
    private List<ProjectMemberDto> _members = new();
    private List<TenantUserDto> _users = new();
    private TaskKanban? _kanban;

    private bool _showMembers;
    private string _newMemberId = "";
    private bool _newMemberCanEdit;
    private string? _memberError;
    private string? _statusError;

    // Proyectos P1: hitos
    private List<ProjectMilestoneDto> _milestones = new();
    private string _newMilestoneName = "";
    private DateOnly? _newMilestoneDue;
    private string? _milestoneError;

    // Proyectos P2: presupuesto/costos
    private List<ProjectBudgetItemDto> _budget = new();
    private string _newBudgetName = "";
    private string? _newBudgetCategory;
    private decimal _newBudgetPlanned;
    private decimal _newBudgetActual;
    private string? _budgetError;
    private decimal BudgetTotalPlanned => _budget.Sum(b => b.PlannedAmount);
    private decimal BudgetTotalActual => _budget.Sum(b => b.ActualAmount);

    // Proyectos P2: DOFA
    private List<ProjectDofaDto> _dofa = new();
    private readonly Dictionary<DofaQuadrant, string> _dofaInputs = new()
    {
        [DofaQuadrant.Fortaleza] = "", [DofaQuadrant.Oportunidad] = "",
        [DofaQuadrant.Debilidad] = "", [DofaQuadrant.Amenaza] = ""
    };
    private string? _dofaError;

    private static string DofaLabel(DofaQuadrant q) => q switch
    {
        DofaQuadrant.Fortaleza => "Fortalezas", DofaQuadrant.Oportunidad => "Oportunidades",
        DofaQuadrant.Debilidad => "Debilidades", _ => "Amenazas"
    };
    private static string DofaColor(DofaQuadrant q) => q switch
    {
        DofaQuadrant.Fortaleza => "var(--t-green, #14a078)", DofaQuadrant.Oportunidad => "var(--t-blue, #3b82f6)",
        DofaQuadrant.Debilidad => "var(--t-amber, #f59e0b)", _ => "var(--danger, #e11d48)"
    };

    protected override async Task OnInitializedAsync()
    {
        _users = (await TenantUsersSvc.ListAsync()).ToList();
        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        _project = await ProjectsSvc.GetAsync(ProjectId);
        _members = _project is null ? new List<ProjectMemberDto>() : (await ProjectsSvc.ListMembersAsync(ProjectId)).ToList();
        _milestones = _project is null ? new List<ProjectMilestoneDto>() : (await ProjectsSvc.ListMilestonesAsync(ProjectId)).ToList();
        _budget = _project is null ? new List<ProjectBudgetItemDto>() : (await ProjectsSvc.ListBudgetItemsAsync(ProjectId)).ToList();
        _dofa = _project is null ? new List<ProjectDofaDto>() : (await ProjectsSvc.ListDofaAsync(ProjectId)).ToList();
    }

    // ---- P2: presupuesto ----
    private async Task AddBudgetAsync()
    {
        if (string.IsNullOrWhiteSpace(_newBudgetName)) { return; }
        _busy = true; _budgetError = null;
        try
        {
            var r = await ProjectsSvc.AddBudgetItemAsync(ProjectId,
                new CreateBudgetItemRequest(_newBudgetName.Trim(), _newBudgetPlanned, _newBudgetActual, _newBudgetCategory));
            if (!r.IsOk) { _budgetError = r.Error; return; }
            _newBudgetName = ""; _newBudgetCategory = null; _newBudgetPlanned = 0; _newBudgetActual = 0;
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    private async Task RemoveBudgetAsync(Guid itemId)
    {
        _busy = true; _budgetError = null;
        try { var r = await ProjectsSvc.RemoveBudgetItemAsync(itemId); if (!r.IsOk) { _budgetError = r.Error; } await LoadAsync(); }
        finally { _busy = false; }
    }

    // ---- P2: DOFA ----
    private async Task OnDofaKey(KeyboardEventArgs e, DofaQuadrant q)
    {
        if (e.Key != "Enter") { return; }
        var text = (_dofaInputs[q] ?? "").Trim();
        if (text.Length == 0) { return; }
        _busy = true; _dofaError = null;
        try
        {
            var r = await ProjectsSvc.AddDofaAsync(ProjectId, new CreateDofaRequest(q, text));
            if (!r.IsOk) { _dofaError = r.Error; return; }
            _dofaInputs[q] = "";
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    private async Task RemoveDofaAsync(Guid dofaId)
    {
        _busy = true; _dofaError = null;
        try { var r = await ProjectsSvc.RemoveDofaAsync(dofaId); if (!r.IsOk) { _dofaError = r.Error; } await LoadAsync(); }
        finally { _busy = false; }
    }

    private async Task AddMilestoneAsync()
    {
        if (string.IsNullOrWhiteSpace(_newMilestoneName)) { return; }
        _busy = true;
        _milestoneError = null;
        try
        {
            var result = await ProjectsSvc.AddMilestoneAsync(ProjectId, new CreateMilestoneRequest(_newMilestoneName.Trim(), _newMilestoneDue));
            if (!result.IsOk) { _milestoneError = result.Error; return; }
            _newMilestoneName = "";
            _newMilestoneDue = null;
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    private async Task SetMilestoneCompletedAsync(Guid milestoneId, bool completed)
    {
        _busy = true;
        _milestoneError = null;
        try
        {
            var result = await ProjectsSvc.SetMilestoneCompletedAsync(milestoneId, completed);
            if (!result.IsOk) { _milestoneError = result.Error; }
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    private async Task RemoveMilestoneAsync(Guid milestoneId)
    {
        _busy = true;
        _milestoneError = null;
        try
        {
            var result = await ProjectsSvc.RemoveMilestoneAsync(milestoneId);
            if (!result.IsOk) { _milestoneError = result.Error; }
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    private string UserEmail(Guid tenantUserId)
        => _users.FirstOrDefault(u => u.Id == tenantUserId)?.Email ?? "?";

    private async Task ChangeStatusAsync(ProjectStatus status)
    {
        if (_project is null || _project.Status == status) { return; }
        _busy = true;
        _statusError = null;
        try
        {
            var result = await ProjectsSvc.UpdateAsync(ProjectId, new UpdateProjectRequest(
                _project.Name, _project.Description, status,
                _project.StartDate, _project.EndDate, _project.OwnerTenantUserId, _project.Version));
            if (!result.IsOk)
            {
                _statusError = result.Status == TaskCoreStatus.Conflict
                    ? "Otro usuario modifico el proyecto. Se recargo con los datos mas recientes."
                    : result.Error;
            }
            await LoadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task AddMemberAsync()
    {
        if (!Guid.TryParse(_newMemberId, out var userId)) { return; }
        _busy = true;
        _memberError = null;
        try
        {
            var result = await ProjectsSvc.AddMemberAsync(ProjectId, userId, _newMemberCanEdit);
            if (!result.IsOk) { _memberError = result.Error; return; }
            _newMemberId = "";
            _newMemberCanEdit = false;
            await LoadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SetCanEditAsync(Guid tenantUserId, bool canEdit)
    {
        _busy = true;
        _memberError = null;
        try
        {
            var result = await ProjectsSvc.SetMemberCanEditAsync(ProjectId, tenantUserId, canEdit);
            if (!result.IsOk) { _memberError = result.Error; }
            await LoadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RemoveMemberAsync(Guid tenantUserId)
    {
        _busy = true;
        _memberError = null;
        try
        {
            var result = await ProjectsSvc.RemoveMemberAsync(ProjectId, tenantUserId);
            if (!result.IsOk) { _memberError = result.Error; }
            await LoadAsync();
        }
        finally
        {
            _busy = false;
        }
    }
}
