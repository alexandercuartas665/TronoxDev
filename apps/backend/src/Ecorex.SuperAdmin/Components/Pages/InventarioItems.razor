    private string? CfgEditingKey() => _cfgFields.FirstOrDefault(f => f.Id == _cfgEditId)?.FieldKey;

    /// <summary>
    /// Mueve el campo a otro tipo de item. El servicio se niega si el destino ya tiene esa clave o si
    /// alguna formula del tipo origen la usa; el motivo se muestra tal cual.
    /// </summary>
    private Task MoveCfgFieldToTypeAsync(ItemFieldDto f, string? targetTypeId) => GuardAsync(async () =>
    {
        if (!Guid.TryParse(targetTypeId, out var target)) { return; }
        _cfgError = null;
        _busy = true;
        try
        {
            _cfgError = await FieldSvc.MoveFieldToTypeAsync(f.Id, target);
