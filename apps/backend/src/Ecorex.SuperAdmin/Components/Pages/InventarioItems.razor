    /// <summary>
    /// Sube una o varias imagenes del item. Sirve tanto al clic como al arrastrar y soltar: el
    /// InputFile que cubre la zona de arrastre recibe los dos gestos y dispara este mismo OnChange.
    /// </summary>
    private async Task OnImageFilesSelectedAsync(InputFileChangeEventArgs e)
    {
        if (_editingId is not Guid id) { return; }
        _dragOver = false;
        _editorError = null;
        _uploading = true;
        _busy = true;
        var errores = new List<string>();
        await _dbGate.WaitAsync();
        try
        {
            // Tope de 10 por tanda: InputFile lanza si se piden mas de los permitidos por llamada.
            foreach (var file in e.GetMultipleFiles(10))
            {
                var url = await StoreImageAsync(file, errores);
                if (url is null) { continue; }

                var result = await ItemSvc.AddImageAsync(id, url, RecortarNombre(file.Name));
                if (!result.IsOk) { errores.Add(result.Error ?? $"No se pudo registrar {file.Name}."); }
            }
            await RefreshImagesAsync(id);
        }
        catch (InvalidOperationException)
        {
            errores.Add("Solo se pueden subir 10 imagenes a la vez.");
        }
        finally
        {
            _dbGate.Release();
            _busy = false;
            _uploading = false;
            _editorError = errores.Count > 0 ? string.Join(" ", errores) : null;
        }
    }

    /// <summary>
    /// Valida y guarda el archivo en wwwroot/uploads/items/{tenant} devolviendo la ruta publica.
    /// Se sigue el patron ya usado en Marca.razor y Pipeline.razor (archivo en wwwroot + URL en BD),
    /// asi la columna Url del ItemImage no cambia y los items con URL externa antigua siguen validos.
    /// La carpeta por tenant + nombre con Guid hacen imposible que un tenant pise el archivo de otro.
    ///
    /// Orden de las comprobaciones (de la mas barata a la mas cara):
    ///  1. tenant activo -> sin el no hay carpeta que aisle y el archivo caeria en un sitio comun;
    ///  2. extension contra lista blanca de ImageUploadGuard (sin .svg: XML con script = XSS);
    ///  3. tamano, para no leer a memoria algo enorme;
    ///  4. BYTES MAGICOS del contenido ya leido. Solo esta ultima es infalsificable renombrando:
    ///     extension y ContentType los pone el navegador, o sea el atacante.
    /// </summary>
    private async Task<string?> StoreImageAsync(IBrowserFile file, List<string> errores)
    {
        // Sin tenant no se puede aislar por carpeta: se rechaza en vez de escribir en cualquier lado.
        if (TenantCtx.TenantId is not Guid tenantId)
        {
            errores.Add("No hay tenant activo: vuelve a entrar antes de subir imagenes.");
            return null;
        }

        // La extension devuelta es la CONSTANTE de la lista blanca, no el texto del cliente: por eso
        // concatenarla a la ruta no puede introducir separadores ni ".." (path traversal).
        var ext = ImageUploadGuard.ResolveExtension(file.Name);
        if (ext is null)
        {
            errores.Add($"{file.Name}: formato no permitido. Solo se aceptan {ImageUploadGuard.FormatosTexto}.");
            return null;
        }
        if (file.Size <= 0)
        {
            errores.Add($"{file.Name}: el archivo esta vacio.");
            return null;
        }
        if (file.Size > MaxImageBytes)
        {
            errores.Add($"{file.Name}: supera el limite de {MaxImageBytes / (1024 * 1024)} MB.");
            return null;
        }

        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(MaxImageBytes).CopyToAsync(ms);
            var bytes = ms.ToArray();

            // Se valida el CONTENIDO antes de escribir nada en disco.
            if (!ImageUploadGuard.MatchesSignature(bytes, ext))
            {
                errores.Add($"{file.Name}: el contenido no es una imagen {ext.TrimStart('.').ToUpperInvariant()} valida.");
                return null;
            }

            var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", "items", tenantId.ToString("N"));
            System.IO.Directory.CreateDirectory(dir);
            var stored = ImageUploadGuard.BuildStoredFileName("item", ext);
            await System.IO.File.WriteAllBytesAsync(System.IO.Path.Combine(dir, stored), bytes);
            return $"/uploads/items/{tenantId:N}/{stored}";
        }
        catch
        {
            errores.Add($"{file.Name}: no se pudo subir.");
            return null;
        }
    }

    /// <summary>
    /// Nombre original recortado para guardarlo como referencia. La columna FileName admite 255;
    /// el nombre lo elige el cliente y sin recorte una subida con nombre larguisimo tumbaria el
    /// guardado. Este valor es SOLO informativo: no interviene en la ruta del archivo.
    /// </summary>
    private static string RecortarNombre(string? name)
    {
        var n = (name ?? string.Empty).Trim();
        return n.Length > MaxFileNameChars ? n[..MaxFileNameChars] : n;
    }

