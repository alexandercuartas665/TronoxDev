    private async Task RefreshImagesAsync(Guid itemId)
    {
        var detail = await ItemSvc.GetDetailAsync(itemId);
        _images = detail?.Images ?? [];
    }

    private static string FormatPrice(decimal? price)
        => price is decimal p ? p.ToString("N2", CultureInfo.InvariantCulture) : "-";

    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) { return "?"; }
        return parts.Length == 1
            ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant()
            : string.Concat(char.ToUpperInvariant(parts[0][0]), char.ToUpperInvariant(parts[1][0]));
    }

    /// <summary>Fila editable de "Datos tienda" (par etiqueta/valor) en el formulario.</summary>
    private sealed class FormDato
    {
        public string Etiqueta { get; set; } = "";
        public string? Valor { get; set; }
    }
