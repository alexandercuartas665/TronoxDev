                if (Guid.TryParse(_cfgType, out var typeId)) { _cfgFields = await FieldSvc.ListByTypeAsync(typeId); }
                await LoadTypeFieldsAsync();
            }
        }
        finally { _busy = false; }
    });

    private async Task InsertFormulaKeyAsync(string key)
    {
        _cfgFormula = string.IsNullOrWhiteSpace(_cfgFormula) ? $"{{{key}}}" : $"{_cfgFormula} {{{key}}}";
        if (Guid.TryParse(_cfgType, out var typeId))
        {
            _cfgFormulaError = await FieldSvc.ValidateFormulaAsync(_cfgFormula, typeId, _cfgEditId, CfgEditingKey());
        }
    }

    /// <summary>
    /// Rehace los calculados del item abierto. Es aritmetica en memoria sobre unas pocas claves: no
    /// toca la base. Se llama al escribir cualquier campo (cualquiera puede alimentar una formula) y
    /// al cargar el item.
    /// </summary>
    private void RecalcCalculated()
    {
        var calculated = _typeFields
            .Where(f => f.FieldType == TerceroFieldType.Calculated && !string.IsNullOrWhiteSpace(f.Formula))
            .Select(f => new CalculatedField(f.FieldKey, f.Formula!))
            .ToList();

        _calculated = calculated.Count == 0
            ? new(StringComparer.Ordinal)
            : FormulaCalculator.EvaluateAll(calculated, _fieldValues).ToDictionary(x => x.Key, x => x.Value, StringComparer.Ordinal);
    }

    private Task SaveCfgFieldAsync() => GuardAsync(async () =>
    {
        _cfgError = null;
        if (!Guid.TryParse(_cfgType, out var typeId)) { _cfgError = "Elige un tipo."; return; }
        if (string.IsNullOrWhiteSpace(_cfgLabel)) { _cfgError = "La etiqueta es obligatoria."; return; }
        _busy = true;
        try
        {
            var formula = _cfgFieldType == TerceroFieldType.Calculated ? _cfgFormula.Trim() : null;
            if (_cfgFieldType == TerceroFieldType.Calculated)
            {
                _cfgFormulaError = await FieldSvc.ValidateFormulaAsync(formula, typeId, _cfgEditId, CfgEditingKey());
                if (_cfgFormulaError is not null) { return; }
            }

            if (_cfgEditId is Guid editId)
            {
                var upd = new UpdateItemFieldRequest(_cfgLabel, _cfgFieldType, _cfgColumn, _cfgOptions, _cfgDescription,
                    _cfgRequired, formula, _cfgShowInFilter);
                var r = await FieldSvc.UpdateFieldAsync(editId, upd);
                if (r is null) { _cfgError = "No se pudo guardar el campo."; return; }
            }
            else
            {
                var req = new CreateItemFieldRequest(typeId, _cfgLabel, _cfgFieldType, _cfgColumn, _cfgOptions, null,
                    _cfgDescription, _cfgRequired, formula, _cfgShowInFilter);
                var r = await FieldSvc.CreateFieldAsync(req);
                if (r is null) { _cfgError = "No se pudo crear el campo."; return; }
            }
            ResetCfgForm();
            _cfgFields = await FieldSvc.ListByTypeAsync(typeId);
            // La barra de filtros vive de _allFieldDefs: si no se refresca, marcar "filtrable" no
            // aparece hasta recargar la pagina.
            _allFieldDefs = await FieldSvc.ListAllAsync();
            // Si el item abierto es de este tipo, refresca sus campos en vivo.
            if (_showEditor && _fType == _cfgType) { _typeFields = _cfgFields; }
        }
        finally { _busy = false; }
    });

