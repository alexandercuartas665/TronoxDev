    private ItemQuery BuildQuery() => new(
        Guid.TryParse(_fltWarehouse, out var w) ? w : null,
        Guid.TryParse(_fltBrand, out var b) ? b : null,
        Guid.TryParse(_fltGroup, out var g) ? g : null,
        Guid.TryParse(_fltType, out var t) ? t : null,
        _search,
        _includeInactive,
        _currentPage,
        20,
        _fieldFilters.Count > 0 ? new Dictionary<string, string>(_fieldFilters, StringComparer.Ordinal) : null);

    // ---- Filtros por campo configurable (ADR-0029) ----

    /// <summary>Filtros activos: FieldKey -> valor exigido.</summary>
    private readonly Dictionary<string, string> _fieldFilters = new(StringComparer.Ordinal);

    /// <summary>Definiciones de TODOS los tipos: la barra de filtros necesita las marcadas.</summary>
    private IReadOnlyList<ItemFieldDto> _allFieldDefs = [];

    /// <summary>
    /// Campos filtrables. Si hay un tipo elegido en la barra, solo los suyos: los de otro tipo no
    /// aplicarian a ningun item de la lista.
    /// </summary>
    private List<ItemFieldDto> FilterableFields()
    {
        var fields = _allFieldDefs.Where(f => f.ShowInFilter);
        if (Guid.TryParse(_fltType, out var typeId)) { fields = fields.Where(f => f.ItemTypeId == typeId); }
        return fields.OrderBy(f => f.SortOrder).ToList();
    }

    /// <summary>Valores que existen en la pagina actual. Ofrecer opciones vacias solo estorba.</summary>
    private List<string> FilterOptions(string fieldKey)
        => (_page?.Items ?? [])
            .Select(r => r.Filtrables is not null && r.Filtrables.TryGetValue(fieldKey, out var v) ? v : null)
            .Where(v => !string.IsNullOrWhiteSpace(v))
            .Select(v => v!)
            .Concat(_fieldFilters.TryGetValue(fieldKey, out var actual) ? new[] { actual } : [])
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(v => v, StringComparer.CurrentCulture)
            .ToList();

    private async Task SetFieldFilterAsync(string fieldKey, string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) { _fieldFilters.Remove(fieldKey); }
        else { _fieldFilters[fieldKey] = value; }
        await ApplyFiltersAsync();
    }

    private async Task ReloadAsync()
    {
        _page = await ItemSvc.ListAsync(BuildQuery());
    }

    private async Task ApplyFiltersAsync()
    {
        _currentPage = 1;
        await ReloadAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        if (page < 1 || page > TotalPages) { return; }
        _currentPage = page;
        await ReloadAsync();
    }

