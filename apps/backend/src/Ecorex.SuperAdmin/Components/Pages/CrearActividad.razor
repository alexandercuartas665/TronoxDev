@page "/crear-actividad"
@attribute [Authorize(Policy = "Tareas.Ver")]
@* Item "Crear una actividad" (legacy 000038) del menu del prototipo: pagina liviana que
   abre directamente el asistente TaskWizard existente. Al crear o cerrar el asistente se
   redirige a /actividades (Administrar actividades); el cierre lo detecta el vigia JS
   window.ecorexWatchWizard (MainLayout) porque TaskWizard no expone callback de cierre.
   prerender:false como en Actividades para no duplicar OnInitialized y permitir interop JS. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.SuperAdmin.Components.Shared.Tasks
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Crear una actividad - ECOREX.tareas</PageTitle>

<nav class="ecorex-breadcrumb" aria-label="Ruta de navegacion">
    <a href="/inicio">Workspace</a>
    <span class="sep">/</span>
    <span>Mis Procesos</span>
    <span class="sep">/</span>
    <span class="cur">Crear una actividad</span>
</nav>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="4"/><path d="M12 8v8M8 12h8"/></svg>
            </div>
            <span>Mis Procesos</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Crear una <span>actividad</span></h1>
        <p class="page-sub" style="margin-bottom:0;">Asistente de nueva actividad (legacy 000038). Al terminar se abre el gestor de actividades.</p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <button class="btn btn-primary" @onclick="OpenWizardAsync">+ Nueva actividad</button>
        <a class="btn btn-outline-secondary" href="actividades">Ir a administrar actividades</a>
    </div>
</div>

<TaskWizard @ref="_wizard" OnCreated="OnCreatedAsync" />

@code {
    private TaskWizard? _wizard;
    private bool _navigated;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _wizard is null) { return; }
        await OpenWizardAsync();
    }

    private async Task OpenWizardAsync()
    {
        if (_wizard is null) { return; }
        // Ola 4: al llegar desde el menu "Mis Procesos" (crear-actividad?sub=<subcategoriaId>)
        // el wizard abre con la categoria/subcategoria fijadas (no las vuelve a pedir).
        Guid? presetSub = null;
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("sub", out var subVal) && Guid.TryParse(subVal, out var sid)) { presetSub = sid; }
        await _wizard.OpenAsync(presetSubcategoriaId: presetSub);
        // Vigia JS: al desaparecer el overlay del wizard redirige a /actividades.
        try { await Js.InvokeVoidAsync("ecorexWatchWizard"); }
        catch { /* interop no disponible: quedan los botones de la pagina como respaldo */ }
    }

    private Task OnCreatedAsync(Ecorex.Application.Tenancy.TaskItemDetailDto _)
    {
        if (!_navigated)
        {
            _navigated = true;
            Navigation.NavigateTo("actividades");
        }
        return Task.CompletedTask;
    }
}
