    private void OpenDocumentsModal()
    {
        _documentsHint = null;
        _docFormOpen = false;
        _documentError = null;
        _showDocuments = true;
    }

    private void CloseDocumentsModal()
    {
        _showDocuments = false;
        _documentsHint = null;
    }

    private void OpenDocumentForm(RuleDocumentDto? document)
    {
        _editingDocument = document;
        _documentError = null;
        _dCode = document?.DocumentCode ?? "";
        _dName = document?.Name ?? "";
        _dCategory = document?.Category ?? "";
        _dDescription = document?.Description ?? "";
        _dStatus = document?.Status ?? RuleStatus.Active;
        _docFormOpen = true;
    }

    private async Task SaveDocumentAsync()
    {
        _documentError = null;
        _busy = true;
        try
        {
            var request = new SaveRuleDocumentRequest(_dCode.Trim(), _dName.Trim(), _dCategory.Trim(),
                string.IsNullOrWhiteSpace(_dDescription) ? null : _dDescription.Trim(), _dStatus);
            var result = _editingDocument is null
                ? await RulesSvc.CreateDocumentAsync(request)
                : await RulesSvc.UpdateDocumentAsync(_editingDocument.Id, request);
            if (!result.IsOk)
            {
                _documentError = result.Error;
                return;
            }
            _docFormOpen = false;
            await LoadDocumentsAsync();
            await LoadAllRulesAsync();
            await LoadStatsAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ToggleDocumentArchiveAsync()
    {
        if (_editingDocument is null) { return; }
        _busy = true;
        try
        {
            var result = await RulesSvc.SetDocumentArchivedAsync(_editingDocument.Id, !_editingDocument.IsArchived);
            if (!result.IsOk) { _documentError = result.Error; return; }
            _docFormOpen = false;
            await LoadDocumentsAsync();
            await LoadAllRulesAsync();
            await LoadStatsAsync();
        }
        finally
        {
            _busy = false;
        }
    }

