    // ---- Fragmentos y helpers de presentacion ----

    private RenderFragment HistoryItem(RuleExecutionLogDto log) => @<div class="rg-history-item @(log.Status == RuleExecutionStatus.Failed ? "err" : log.Status == RuleExecutionStatus.Skipped ? "skip" : "")">
        <span class="dot"></span>
        <div class="rg-history-body">
            <strong>@log.RuleNameSnapshot - @TriggerLabel(log.TriggerKind) - @StatusExecLabel(log.Status)</strong>
            <div class="when">@WhenLabel(log.CreatedAt) &middot; @log.DurationMs ms &middot; @(log.Status == RuleExecutionStatus.Success ? (log.ExecutedByName ?? "Sistema") : (log.ErrorMessage ?? log.ExecutedByName ?? "Sistema"))</div>
        </div>
    </div>;

    /// <summary>Barra lateral del item: color por verbo (rotando --t-*) y gris si Inactiva.</summary>
    private string VerbColorVar(RuleListItemDto rule)
    {
        if (rule.Status == RuleStatus.Inactive)
        {
            return "--ink-3";
        }
        string[] tones = ["--t-blue", "--t-green", "--t-violet", "--t-amber", "--t-rose"];
        var index = 0;
        for (var i = 0; i < _catalog.Count; i++)
        {
            if (string.Equals(_catalog[i].VerbName, rule.VerbName, StringComparison.OrdinalIgnoreCase))
            {
                index = i;
                break;
            }
        }
        return tones[index % tones.Length];
    }

    internal static string StatusLabel(RuleStatus status) => status switch
    {
        RuleStatus.Active => "Activa",
        RuleStatus.Development => "Desarrollo",
        RuleStatus.Inactive => "Inactiva",
        _ => status.ToString()
    };

    internal static string StatusBadgeClass(RuleStatus status) => status switch
    {
        RuleStatus.Active => "on",
        RuleStatus.Development => "warn",
        RuleStatus.Inactive => "off",
        _ => ""
    };

    internal static string StatusExecLabel(RuleExecutionStatus status) => status switch
    {
        RuleExecutionStatus.Success => "Exito",
        RuleExecutionStatus.Failed => "Fallo",
        RuleExecutionStatus.Skipped => "Omitida",
        _ => status.ToString()
    };

    internal static string TriggerLabel(RuleTriggerKind kind) => kind switch
    {
        RuleTriggerKind.Manual => "Manual",
        RuleTriggerKind.FormField => "Campo de formulario",
        RuleTriggerKind.WorkflowNode => "Nodo de flujo",
        _ => kind.ToString()
    };

    internal static string RateLabel(double? rate)
        => rate is double value ? $"{value * 100:0.#}%" : "-";

    /// <summary>"Hoy 14:32" / "Ayer 09:10" / "02/07 13:55" (hora local).</summary>
    internal static string WhenLabel(DateTimeOffset at)
    {
        var local = at.ToLocalTime();
        var today = DateTimeOffset.Now.Date;
        if (local.Date == today) { return $"Hoy {local:HH:mm}"; }
        if (local.Date == today.AddDays(-1)) { return $"Ayer {local:HH:mm}"; }
        return local.ToString("dd/MM HH:mm");
    }

    /// <summary>"hace 3 min" / "hace 2 h" / "hace 5 dias" (para el status strip).</summary>
    internal static string RelativeLabel(DateTimeOffset? at)
    {
        if (at is not DateTimeOffset value) { return "-"; }
        var elapsed = DateTimeOffset.UtcNow - value.ToUniversalTime();
        if (elapsed < TimeSpan.FromMinutes(1)) { return "hace un momento"; }
        if (elapsed < TimeSpan.FromHours(1)) { return $"hace {(int)elapsed.TotalMinutes} min"; }
        if (elapsed < TimeSpan.FromDays(1)) { return $"hace {(int)elapsed.TotalHours} h"; }
        return $"hace {(int)elapsed.TotalDays} dia(s)";
    }

    private static Guid? ParseGuid(object? value)
        => Guid.TryParse(value?.ToString(), out var id) ? id : null;
