    private async Task OnLinkFormDefinitionChangedAsync(ChangeEventArgs e)
    {
        _linkFormDefinitionId = ParseGuid(e.Value);
        _linkQuestionId = null;
        _questionOptions = _linkFormDefinitionId is Guid id
            ? await RulesSvc.ListFormQuestionOptionsAsync(id)
            : [];
    }

    private async Task OnLinkWorkflowChangedAsync(ChangeEventArgs e)
    {
        _linkWorkflowId = ParseGuid(e.Value);
        _linkNodeId = null;
        _nodeOptions = _linkWorkflowId is Guid id
            ? await RulesSvc.ListWorkflowNodeOptionsAsync(id)
            : [];
    }

    private async Task LinkQuestionAsync()
    {
        if (_selected is null || _linkQuestionId is not Guid questionId) { return; }
        _busy = true;
        try
        {
            var result = await RulesSvc.LinkToQuestionAsync(_selected.Id, questionId, _formLinks.Count);
            if (!result.IsOk) { _ruleError = result.Error; return; }
            _ruleError = null;
            _formLinks = (await RulesSvc.ListFormLinksAsync(_selected.Id)).ToList();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task UnlinkQuestionAsync(RuleFormLinkDto link)
    {
        _busy = true;
        try
        {
            var result = await RulesSvc.UnlinkQuestionAsync(link.Id);
            if (!result.IsOk) { _ruleError = result.Error; return; }
            if (_selected is not null)
            {
                _formLinks = (await RulesSvc.ListFormLinksAsync(_selected.Id)).ToList();
            }
        }
        finally
        {
            _busy = false;
        }
    }

