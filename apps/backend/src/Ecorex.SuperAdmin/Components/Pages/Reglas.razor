@page "/reglas"
@attribute [Authorize(Policy = "Reglas.Editar")]
@* Policy por modulo (paso 1: mismo requisito que TenantMember, nombre estable). TODO: derivar del Module Registry. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Text
@using System.Text.Json
@using System.Text.Json.Nodes
@using Ecorex.Application.Rules
@using Ecorex.Domain.Enums
@inject IRuleDocumentService RulesSvc
@inject IRulesEngine Engine

<PageTitle>Reglas - ECOREX.tareas</PageTitle>

<div class="rg-page">

    @* ===== Topbar del modulo (proto gen_reglas: breadcrumb + MOD + acciones) ===== *@
    <div class="rg-topbar">
        <nav class="rg-crumb" aria-label="Ruta de navegacion">
            <span>Home</span>
            <span class="sep">/</span>
            <span>General</span>
            <span class="sep">/</span>
            <span class="last">Reglas de negocio</span>
            <span class="rg-mod-code">MOD 000802</span>
        </nav>
        <div class="rg-top-actions">
            <button class="rg-btn" disabled title="Proximamente: no hay formato de importacion definido">Importar XML</button>
            <button class="rg-btn" title="Ejecutar prueba de la regla seleccionada" @onclick="RunSelectedTestAsync"
                    disabled="@(_selected is null || _isNew || _busy)">Probar</button>
            <button class="rg-btn" @onclick="OpenDocumentsModal">Documentos</button>
            <button class="rg-btn primary" @onclick="StartNewRule">+ Nueva regla</button>
        </div>
    </div>

    @* ===== KPIs reales (RuleExecutionLog / conteos, ventana 30d) ===== *@
    <div class="rg-kpis">
        <div class="rg-kpi">
            <div class="rg-kpi-ic tb"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/></svg></div>
            <div class="rg-kpi-tx"><div class="rg-kpi-v">@(_stats?.Documents ?? 0)</div><div class="rg-kpi-l">Documentos</div></div>
        </div>
        <div class="rg-kpi">
            <div class="rg-kpi-ic tv"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/></svg></div>
            <div class="rg-kpi-tx"><div class="rg-kpi-v">@(_stats?.Rules ?? 0)</div><div class="rg-kpi-l">Reglas</div></div>
        </div>
        <div class="rg-kpi">
            <div class="rg-kpi-ic ta"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
            <div class="rg-kpi-tx"><div class="rg-kpi-v">@(_stats?.Executions30d ?? 0)</div><div class="rg-kpi-l">Ejecuciones (30d)</div></div>
        </div>
        <div class="rg-kpi">
            <div class="rg-kpi-ic tg"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg></div>
            <div class="rg-kpi-tx"><div class="rg-kpi-v">@RateLabel(_stats?.SuccessRate30d)</div><div class="rg-kpi-l">Tasa de exito (30d)</div></div>
        </div>
    </div>

    @* ===== Layout 3 paneles permanente (proto: 320px / 1fr / 300px) ===== *@
    <div class="rg-layout">

        @* ---- Panel izquierdo: lista PLANA de reglas del tenant ---- *@
        <aside class="rg-panel rg-left">
            <div class="rg-panel-head">
                <div class="rg-panel-title">Reglas <span class="rg-count">@FilteredRules.Count</span></div>
                <button class="rg-btn sm" @onclick="@(() => _showFilter = !_showFilter)">Filtrar</button>
            </div>
            @if (_showFilter)
            {
                <div class="rg-filter-pop">
                    <div class="rg-filter-field">
                        <label>Documento</label>
                        <select value="@(_filterDocumentId?.ToString() ?? "")" @onchange="@(e => { _filterDocumentId = ParseGuid(e.Value); })">
                            <option value="">(todos)</option>
                            @foreach (var d in _documents)
                            {
                                <option value="@d.Id">@d.DocumentCode - @d.Name</option>
                            }
                        </select>
                    </div>
                    <div class="rg-filter-field">
                        <label>Categoria</label>
                        <select value="@_filterCategory" @onchange="@(e => _filterCategory = e.Value?.ToString() ?? "")">
                            <option value="">(todas)</option>
                            @foreach (var c in Categories)
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                    </div>
                    <div class="rg-filter-field">
                        <label>Estado</label>
                        <select value="@_filterStatus" @onchange="@(e => _filterStatus = e.Value?.ToString() ?? "")">
                            <option value="">(todos)</option>
                            <option value="@RuleStatus.Active">Activa</option>
                            <option value="@RuleStatus.Development">Desarrollo</option>
                            <option value="@RuleStatus.Inactive">Inactiva</option>
                        </select>
                    </div>
                    <div class="rg-filter-field">
                        <label>Modo</label>
                        <select value="@_filterMode" @onchange="@(e => _filterMode = e.Value?.ToString() ?? "")">
                            <option value="">(todos)</option>
                            <option value="ENSAMBLADO">Ensamblado</option>
                            <option value="EXECUTE">Execute (prohibido)</option>
                            <option value="MDATA">mDATA (no implementado)</option>
                        </select>
                    </div>
                    <label class="rg-filter-check">
                        <input type="checkbox" checked="@_includeArchived"
                               @onchange="@(async e => { _includeArchived = (bool)e.Value!; await LoadAllRulesAsync(); })" />
                        Ver documentos archivados
                    </label>
                    <button class="rg-btn sm" @onclick="ClearFilters">Limpiar filtros</button>
                </div>
            }
            <div class="rg-search">
                <input placeholder="Buscar por nombre, tabla, proceso..." value="@_search"
                       @oninput="@(e => _search = e.Value?.ToString() ?? "")" />
            </div>
            <div class="rg-panel-body">
                @if (FilteredRules.Count == 0)
                {
                    <div class="rg-empty-list">
                        @(_allRules.Count == 0
                            ? "Sin reglas todavia. Crea la primera con + Nueva regla."
                            : "Ninguna regla coincide con la busqueda o el filtro.")
                    </div>
                }
                @foreach (var r in FilteredRules)
                {
                    <div class="rule-item @(r.Id == _selectedId && !_isNew ? "active" : "")" @onclick="@(() => SelectRuleAsync(r.Id))">
                        <div class="rule-mode" style="background:var(@VerbColorVar(r))"></div>
                        <div class="rule-body">
                            <div class="rule-name">
                                <span class="rule-name-text">@r.Name</span>
                                <span class="rg-badge @StatusBadgeClass(r.Status)">@StatusLabel(r.Status)</span>
                            </div>
                            <div class="rule-meta">
                                <span class="mode-chip mode-ensamblado">Ensamblado</span>
                                <span class="dot"></span>
                                <span class="rule-cat">@r.DocumentCategory</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </aside>

        @* ---- Editor central ---- *@
        <section class="rg-editor">
            @if (_selected is null && !_isNew)
            {
                <div class="rg-editor-empty">
                    <h3>Selecciona una regla</h3>
                    <p>Elige una regla del panel izquierdo o crea una con <strong>+ Nueva regla</strong>.</p>
                </div>
            }
            else
            {
                <div class="rg-rule-head">
                    <div class="rg-rule-title-row">
                        <h1 class="rg-rule-title">
                            @(_isNew ? "Nueva regla" : _selected!.Name)
                            <span class="rg-badge @StatusBadgeClass(_rStatus)">@StatusLabel(_rStatus)</span>
                        </h1>
                        <div class="rg-rule-desc">@(string.IsNullOrWhiteSpace(_rDescription) ? "Sin descripcion." : _rDescription)</div>
                    </div>
                    <div class="rg-top-actions">
                        @if (!_isNew)
                        {
                            <button class="rg-btn sm" @onclick="DuplicateRuleAsync" disabled="@_busy">Duplicar</button>
                            @if (_confirmDelete)
                            {
                                <span class="rg-confirm">
                                    Eliminar? (con historial se inactiva)
                                    <button class="rg-btn sm danger" @onclick="ConfirmDeleteAsync" disabled="@_busy">Si, eliminar</button>
                                    <button class="rg-btn sm" @onclick="@(() => _confirmDelete = false)">No</button>
                                </span>
                            }
                            else
                            {
                                <button class="rg-btn sm danger" @onclick="@(() => _confirmDelete = true)" disabled="@_busy">Eliminar</button>
                            }
                        }
                        <button class="rg-btn sm primary" @onclick="SaveRuleAsync" disabled="@_busy">@(_isNew ? "Crear regla" : "Guardar")</button>
                    </div>
                </div>

                <div class="rg-tabs">
                    <button class="rg-tab @(_editorTab == 0 ? "active" : "")" @onclick="@(() => _editorTab = 0)">Configuracion</button>
                    <button class="rg-tab @(_editorTab == 1 ? "active" : "")" disabled="@_isNew" @onclick="@(() => _editorTab = 1)">
                        Historial <span class="count">@_history.Count</span>
                    </button>
                    <button class="rg-tab @(_editorTab == 2 ? "active" : "")" disabled="@_isNew" @onclick="@(() => _editorTab = 2)">
                        Consumidores <span class="count">@(_formLinks.Count + _nodeLinks.Count)</span>
                    </button>
                </div>

                <div class="rg-editor-body">
                    @if (_editorTab == 0)
                    {
                        <div class="rg-warn-banner">
                            <strong>Aviso:</strong>&nbsp;los modos <code>mDATA</code> y <code>Execute</code> no estan implementados en el motor (ADR-0016: SQL directo prohibido). Solo <code>Ensamblado</code> se ejecuta.
                        </div>

                        @if (_ruleError is not null)
                        {
                            <div class="rg-error">@_ruleError</div>
                        }

                        <div class="rg-meta"><label>Nombre</label><input maxlength="100" value="@_rName" @onchange="@(e => _rName = e.Value?.ToString() ?? "")" /></div>
                        <div class="rg-meta"><label>Descripcion</label><input maxlength="400" value="@_rDescription" @onchange="@(e => _rDescription = e.Value?.ToString() ?? "")" /></div>
                        <div class="rg-meta">
                            <label>Modo ejecucion</label>
                            <select>
                                <option selected>Ensamblado (llama verbo .NET tipado)</option>
                                <option disabled>Execute (SQL directo - prohibido por ADR-0016)</option>
                                <option disabled>mDATA (solo consulta - no implementado)</option>
                            </select>
                        </div>
                        <div class="rg-meta">
                            <label>Documento</label>
                            <select value="@_rDocumentId" @onchange="@(e => _rDocumentId = ParseGuid(e.Value) ?? _rDocumentId)">
                                @foreach (var d in _documents)
                                {
                                    <option value="@d.Id">@d.DocumentCode - @d.Name (@d.Category)</option>
                                }
                            </select>
                        </div>
                        <div class="rg-meta"><label>Prioridad</label><input class="rg-priority" type="number" value="@_rSortOrder" @onchange="@(e => _rSortOrder = int.TryParse(e.Value?.ToString(), out var n) ? n : _rSortOrder)" /></div>
                        <div class="rg-meta">
                            <label>Verbo</label>
                            <select value="@_rVerbName" @onchange="OnVerbChanged">
                                <option value="">-- Selecciona un verbo del catalogo tipado --</option>
                                @foreach (var v in _catalog)
                                {
                                    <option value="@v.VerbName">@v.VerbName - @v.DisplayName</option>
                                }
                            </select>
                        </div>
                        <div class="rg-meta">
                            <label>Estado</label>
                            <select @bind="_rStatus">
                                <option value="@RuleStatus.Active">Activa</option>
                                <option value="@RuleStatus.Development">Desarrollo</option>
                                <option value="@RuleStatus.Inactive">Inactiva</option>
                            </select>
                        </div>

                        <div class="rg-section-title">
                            <span>PARAM_XML</span>
                            <div class="rg-inline-actions">
                                <button class="rg-btn sm" @onclick="FormatXml">Formatear</button>
                                <button class="rg-btn sm" @onclick="ValidateXml">Validar</button>
                            </div>
                        </div>
                        @if (_xmlMessage is not null)
                        {
                            <div class="@(_xmlOk ? "rg-ok" : "rg-error")">@_xmlMessage</div>
                        }
                        <div class="rg-xml-row">
                            <div class="rg-code">
                                <pre class="rg-code-hl" aria-hidden="true">@((MarkupString)HighlightXml(_paramXml))</pre>
                                <textarea class="rg-code-input" spellcheck="false" value="@_paramXml"
                                          @oninput="@(e => _paramXml = e.Value?.ToString() ?? "")"></textarea>
                            </div>
                            <div class="rg-render">
                                <div class="rg-render-title">Vista renderizada</div>
                                @if (SelectedDescriptor is RuleVerbDescriptor descriptor)
                                {
                                    <p class="rg-render-desc">@descriptor.Description</p>
                                    @foreach (var p in descriptor.Params)
                                    {
                                        <div class="rg-param-field">
                                            <label>@p.Label @(p.Required ? "*" : "") <span class="rg-param-name">(@p.Name)</span></label>
                                            @switch (p.Type)
                                            {
                                                case RuleParamType.Boolean:
                                                    <label class="rg-param-toggle">
                                                        <input type="checkbox" checked="@(GetParamValue(p.Name) == "true")"
                                                               @onchange="@(e => SetParamValue(p.Name, (bool)e.Value! ? "true" : ""))" />
                                                        Si
                                                    </label>
                                                    break;
                                                case RuleParamType.Number:
                                                    <input type="number" value="@GetParamValue(p.Name)"
                                                           @onchange="@(e => SetParamValue(p.Name, e.Value?.ToString()))" />
                                                    break;
                                                case RuleParamType.Json:
                                                    <textarea rows="3" value="@GetParamValue(p.Name)"
                                                              @onchange="@(e => SetParamValue(p.Name, e.Value?.ToString()))"></textarea>
                                                    break;
                                                default:
                                                    <input value="@GetParamValue(p.Name)"
                                                           @onchange="@(e => SetParamValue(p.Name, e.Value?.ToString()))" />
                                                    break;
                                            }
                                            @if (!string.IsNullOrWhiteSpace(p.Description))
                                            {
                                                <div class="rg-param-help">@p.Description</div>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <p class="rg-render-desc">Selecciona un verbo para configurar sus parametros.</p>
                                }
                                <button class="rg-btn primary rg-run" @onclick="RunSelectedTestAsync" disabled="@(_isNew || _busy)">Ejecutar regla</button>
                                @if (_testResult is not null)
                                {
                                    <div class="rg-test-result @(_testResult.Status == RuleExecutionStatus.Success ? "ok" : "err")">
                                        <strong>@StatusExecLabel(_testResult.Status)</strong>
                                        - @(_testResult.Message ?? _testResult.ErrorMessage ?? "(sin mensaje)")
                                        <br />
                                        <small>@_testResult.RecordsAffected registro(s) - @_testResult.DurationMs ms - @_testResult.Actions.Count accion(es) de UI. La ejecucion quedo en el historial.</small>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="rg-section-title">
                            <span>Historial reciente</span>
                            <button class="rg-btn sm" disabled="@_isNew" @onclick="@(() => _editorTab = 1)">Ver todo</button>
                        </div>
                        <div class="rg-history-card">
                            @if (_history.Count == 0)
                            {
                                <div class="rg-empty-dashed">Sin ejecuciones registradas (el historial expira a los 90 dias).</div>
                            }
                            @foreach (var log in _history.Take(4))
                            {
                                @HistoryItem(log)
                            }
                        </div>
                    }
                    else if (_editorTab == 1)
                    {
                        @* ---- Tab Historial: lista completa del RuleExecutionLog de la regla ---- *@
                        <div class="rg-history-card">
                            @if (_history.Count == 0)
                            {
                                <div class="rg-empty-dashed">Sin ejecuciones registradas (el historial expira a los 90 dias).</div>
                            }
                            @foreach (var log in _history.Take(_historyShown))
                            {
                                @HistoryItem(log)
                            }
                        </div>
                        @if (_history.Count > _historyShown)
                        {
                            <button class="rg-btn sm rg-more" @onclick="@(() => _historyShown += HistoryPageSize)">
                                Mostrar @Math.Min(HistoryPageSize, _history.Count - _historyShown) mas (@_history.Count en total)
                            </button>
                        }
                    }
                    else
                    {
                        @* ---- Tab Consumidores: vinculos reales (formularios / flujos) ---- *@
                        @if (_ruleError is not null)
                        {
                            <div class="rg-error">@_ruleError</div>
                        }
                        @if (_formLinks.Count == 0 && _nodeLinks.Count == 0)
                        {
                            <div class="rg-empty-dashed">Sin consumidores: la regla solo corre con "Ejecutar regla" (prueba manual).</div>
                        }
                        @foreach (var link in _formLinks)
                        {
                            <div class="rg-consumer">
                                <span class="rg-badge info">Formulario</span>
                                <div class="rg-consumer-tx">
                                    <strong>@link.FormTitle</strong>
                                    <span class="rg-consumer-meta">@link.FormCode / campo <span class="mono">@link.FieldCode</span> (@link.QuestionLabel) - orden @link.SortOrder</span>
                                </div>
                                <button class="rg-btn sm danger" @onclick="@(() => UnlinkQuestionAsync(link))" disabled="@_busy">Quitar</button>
                            </div>
                        }
                        @foreach (var link in _nodeLinks)
                        {
                            <div class="rg-consumer">
                                <span class="rg-badge violet">Flujo</span>
                                <div class="rg-consumer-tx">
                                    <strong>@link.WorkflowName</strong>
                                    <span class="rg-consumer-meta">@link.ProcessCode / nodo @(link.NodeName ?? link.BpmnElementId) - orden @link.SortOrder @(link.IsAutonomous ? "(autonoma)" : "")</span>
                                </div>
                                <button class="rg-btn sm danger" @onclick="@(() => UnlinkNodeAsync(link))" disabled="@_busy">Quitar</button>
                            </div>
                        }

                        <div class="rg-section-title"><span>Agregar vinculo</span></div>
                        <div class="rg-link-row">
                            <select value="@(_linkFormDefinitionId?.ToString() ?? "")" @onchange="OnLinkFormDefinitionChangedAsync">
                                <option value="">-- Formulario --</option>
                                @foreach (var o in _formDefinitionOptions)
                                {
                                    <option value="@o.Id">@o.Label</option>
                                }
                            </select>
                            <select value="@(_linkQuestionId?.ToString() ?? "")" disabled="@(_linkFormDefinitionId is null)"
                                    @onchange="@(e => _linkQuestionId = ParseGuid(e.Value))">
                                <option value="">-- Pregunta --</option>
                                @foreach (var o in _questionOptions)
                                {
                                    <option value="@o.Id">@o.Label</option>
                                }
                            </select>
                            <button class="rg-btn sm" @onclick="LinkQuestionAsync" disabled="@(_busy || _linkQuestionId is null)">Vincular</button>
                        </div>
                        <div class="rg-link-row">
                            <select value="@(_linkWorkflowId?.ToString() ?? "")" @onchange="OnLinkWorkflowChangedAsync">
                                <option value="">-- Definicion de flujo --</option>
                                @foreach (var o in _workflowOptions)
                                {
                                    <option value="@o.Id">@o.Label</option>
                                }
                            </select>
                            <select value="@(_linkNodeId?.ToString() ?? "")" disabled="@(_linkWorkflowId is null)"
                                    @onchange="@(e => _linkNodeId = ParseGuid(e.Value))">
                                <option value="">-- Nodo (Task) --</option>
                                @foreach (var o in _nodeOptions)
                                {
                                    <option value="@o.Id">@o.Label</option>
                                }
                            </select>
                            <label class="rg-param-toggle" title="Autonoma: se ejecuta sola al activar el nodo">
                                <input type="checkbox" @bind="_linkAutonomous" /> Auto
                            </label>
                            <button class="rg-btn sm" @onclick="LinkNodeAsync" disabled="@(_busy || _linkNodeId is null)">Vincular</button>
                        </div>
                    }
                </div>

                <div class="rg-status-strip">
                    <span class="dot"></span>
                    <span>@StatusStripLabel</span>
                    @if (_statusMessage is not null)
                    {
                        <span class="rg-status-msg">@_statusMessage</span>
                    }
                </div>
            }
        </section>

        @* ---- Panel derecho: Propiedades ---- *@
        <aside class="rg-panel rg-right">
            <div class="rg-panel-head">
                <div class="rg-panel-title">Propiedades</div>
            </div>
            @if (_selected is null || _isNew)
            {
                <div class="rg-empty-list">Sin regla seleccionada.</div>
            }
            else
            {
                <div class="rg-props">
                    <div class="rg-prop"><label>ID Regla</label><div class="value mono">@RuleCode</div></div>
                    <div class="rg-prop"><label>Documento</label><div class="value">@(SelectedDocument?.DocumentCode ?? "-") - @(SelectedDocument?.Name ?? "")</div></div>
                    <div class="rg-prop"><label>Verbo</label><div class="value mono">@_selected.VerbName</div></div>
                    <div class="rg-divider"></div>
                    <div class="rg-prop"><label>Ejecuciones (30d)</label><div class="value big">@(_metrics?.Executions30d ?? 0)</div></div>
                    <div class="rg-prop">
                        <label>Tasa exito</label>
                        <div class="value">
                            @if (_metrics?.SuccessRate30d is double rate)
                            {
                                <span class="rg-badge @(rate >= 0.9 ? "on" : rate >= 0.5 ? "warn" : "off")">@RateLabel(rate)</span>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </div>
                    </div>
                    <div class="rg-prop"><label>Tiempo promedio</label><div class="value">@(_metrics?.AvgDurationMs30d is int ms ? $"{ms} ms" : "-")</div></div>
                    <div class="rg-divider"></div>
                    <div class="rg-prop">
                        <label>Consumidores</label>
                        <div class="value rg-consumer-summary">
                            @if (_formLinks.Count == 0 && _nodeLinks.Count == 0)
                            {
                                <span>Sin consumidores</span>
                            }
                            @if (_formLinks.Count > 0)
                            {
                                <div><span class="rg-badge info">Formulario</span> @_formLinks.Count vinculo(s)</div>
                            }
                            @if (_nodeLinks.Count > 0)
                            {
                                <div><span class="rg-badge violet">Flujo</span> @_nodeLinks.Count vinculo(s)</div>
                            }
                        </div>
                    </div>
                    <div class="rg-divider"></div>
                    <div class="rg-prop"><label>Creada</label><div class="value">@(_audit?.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy") ?? "-") &middot; @(_audit?.CreatedByName ?? "sistema")</div></div>
                    <div class="rg-prop"><label>Ultima modificacion</label><div class="value">@(LastModified?.ToLocalTime().ToString("dd/MM/yyyy") ?? "-") &middot; @RelativeLabel(LastModified)</div></div>
                </div>
            }
        </aside>
    </div>
</div>

@* ===== Modal Documentos (CRUD existente: crear / renombrar / archivar) ===== *@
@if (_showDocuments)
{
    <div class="modal-overlay" @onclick="CloseDocumentsModal">
        <div class="modal-dialog rg-docs-modal" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>@(_editingDocument is null && _docFormOpen ? "Nuevo documento de reglas" : _docFormOpen ? $"Editar {_editingDocument!.DocumentCode}" : "Documentos de reglas")</h3>
                <button class="modal-close" @onclick="CloseDocumentsModal">&times;</button>
            </div>
            <div class="modal-body">
                @if (_documentsHint is not null)
                {
                    <div class="rg-warn-banner" style="margin-bottom:12px;">@_documentsHint</div>
                }
                @if (!_docFormOpen)
                {
                    @if (_documents.Count == 0)
                    {
                        <p><em>Sin documentos de reglas todavia.</em></p>
                    }
                    @foreach (var d in _documents)
                    {
                        <div class="rg-doc-row">
                            <div class="rg-doc-tx">
                                <span class="mono">@d.DocumentCode</span>
                                <strong>@d.Name</strong>
                                <span class="rg-doc-meta">@d.Category - @d.RuleCount regla@(d.RuleCount == 1 ? "" : "s") @(d.IsArchived ? "- ARCHIVADO" : "")</span>
                            </div>
                            <button class="rg-btn sm" @onclick="@(() => OpenDocumentForm(d))">Editar</button>
                        </div>
                    }
                }
                else
                {
                    <div class="field">
                        <label class="form-label">Codigo *</label>
                        <input class="form-control" @bind="_dCode" maxlength="25" placeholder="RUL-001" />
                    </div>
                    <div class="field">
                        <label class="form-label">Nombre *</label>
                        <input class="form-control" @bind="_dName" maxlength="100" placeholder="Nombre del documento" />
                    </div>
                    <div class="field">
                        <label class="form-label">Categoria *</label>
                        <input class="form-control" @bind="_dCategory" maxlength="100" placeholder="FORMULARIOS / PROCESOS / IA" />
                    </div>
                    <div class="field">
                        <label class="form-label">Descripcion</label>
                        <textarea class="form-control" rows="2" @bind="_dDescription"></textarea>
                    </div>
                    <div class="field">
                        <label class="form-label">Estado</label>
                        <select class="form-control" @bind="_dStatus">
                            <option value="@RuleStatus.Active">Activo</option>
                            <option value="@RuleStatus.Development">Desarrollo</option>
                            <option value="@RuleStatus.Inactive">Inactivo</option>
                        </select>
                    </div>
                    @if (_documentError is not null)
                    {
                        <div class="rg-error">@_documentError</div>
                    }
                }
            </div>
            <div class="modal-foot">
                @if (!_docFormOpen)
                {
                    <span style="flex:1;"></span>
                    <button class="rg-btn" @onclick="CloseDocumentsModal">Cerrar</button>
                    <button class="rg-btn primary" @onclick="@(() => OpenDocumentForm(null))">+ Nuevo documento</button>
                }
                else
                {
                    @if (_editingDocument is not null)
                    {
                        <button class="rg-btn danger" @onclick="ToggleDocumentArchiveAsync" disabled="@_busy">
                            @(_editingDocument.IsArchived ? "Restaurar" : "Archivar")
                        </button>
                    }
                    <span style="flex:1;"></span>
                    <button class="rg-btn" @onclick="@(() => _docFormOpen = false)" disabled="@_busy">Volver</button>
                    <button class="rg-btn primary" @onclick="SaveDocumentAsync" disabled="@_busy">@(_editingDocument is null ? "Crear documento" : "Guardar")</button>
                }
            </div>
        </div>
    </div>
}

@* ===== Mini modal: elegir documento para la nueva regla ===== *@
@if (_showPickDocument)
{
    <div class="modal-overlay" @onclick="@(() => _showPickDocument = false)">
        <div class="modal-dialog rg-pick-modal" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>Documento de la nueva regla</h3>
                <button class="modal-close" @onclick="@(() => _showPickDocument = false)">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Documento *</label>
                    <select class="form-control" value="@_pickDocumentId" @onchange="@(e => _pickDocumentId = ParseGuid(e.Value) ?? _pickDocumentId)">
                        @foreach (var d in _documents)
                        {
                            <option value="@d.Id">@d.DocumentCode - @d.Name (@d.Category)</option>
                        }
                    </select>
                </div>
            </div>
            <div class="modal-foot">
                <span style="flex:1;"></span>
                <button class="rg-btn" @onclick="@(() => _showPickDocument = false)">Cancelar</button>
                <button class="rg-btn primary" @onclick="@(() => { _showPickDocument = false; BeginNewRule(_pickDocumentId); })">Continuar</button>
            </div>
        </div>
    </div>
}

@code {
    private const int HistoryPageSize = 25;

    private bool _busy;
    private bool _includeArchived;
    private string _search = "";
    private bool _showFilter;
    private Guid? _filterDocumentId;
    private string _filterCategory = "";
    private string _filterStatus = "";
    private string _filterMode = "";

    private RuleTenantStatsDto? _stats;
    private List<RuleListItemDto> _allRules = new();
    private List<RuleDocumentDto> _documents = new();
    private IReadOnlyList<RuleVerbDescriptor> _catalog = [];

    // Seleccion / editor
    private Guid _selectedId;
    private RuleDto? _selected;
    private bool _isNew;
    private int _editorTab;
    private string _rName = "";
    private string _rDescription = "";
    private string _rVerbName = "";
    private int _rSortOrder;
    private Guid _rDocumentId;
    private RuleStatus _rStatus = RuleStatus.Active;
    private string? _ruleError;
    private string? _statusMessage;
    private bool _confirmDelete;
    private readonly Dictionary<string, string> _paramValues = new(StringComparer.Ordinal);

    // PARAM_XML
    private string _paramXml = "";
    private bool _xmlOk;
    private string? _xmlMessage;

    // Metricas / auditoria / historial
    private RuleMetricsDto? _metrics;
    private RuleAuditDto? _audit;
    private List<RuleExecutionLogDto> _history = new();
    private int _historyShown = HistoryPageSize;
    private RuleExecutionOutcome? _testResult;

    // Vinculos
    private List<RuleFormLinkDto> _formLinks = new();
    private List<RuleNodeLinkDto> _nodeLinks = new();
    private IReadOnlyList<RuleOption> _formDefinitionOptions = [];
    private IReadOnlyList<RuleOption> _questionOptions = [];
    private IReadOnlyList<RuleOption> _workflowOptions = [];
    private IReadOnlyList<RuleOption> _nodeOptions = [];
    private Guid? _linkFormDefinitionId;
    private Guid? _linkQuestionId;
    private Guid? _linkWorkflowId;
    private Guid? _linkNodeId;
    private bool _linkAutonomous = true;

    // Modal documentos
    private bool _showDocuments;
    private bool _docFormOpen;
    private string? _documentsHint;
    private RuleDocumentDto? _editingDocument;
    private string _dCode = "";
    private string _dName = "";
    private string _dCategory = "";
    private string _dDescription = "";
    private RuleStatus _dStatus = RuleStatus.Active;
    private string? _documentError;

    // Mini modal de documento para regla nueva
    private bool _showPickDocument;
    private Guid _pickDocumentId;

    private RuleVerbDescriptor? SelectedDescriptor
        => _catalog.FirstOrDefault(v => string.Equals(v.VerbName, _rVerbName, StringComparison.OrdinalIgnoreCase));

    private RuleDocumentDto? SelectedDocument
        => _documents.FirstOrDefault(d => d.Id == (_selected?.DocumentId ?? _rDocumentId));

    /// <summary>ID legible de la regla: DocumentCode + primeros 8 del Guid (proto: CR-000047).</summary>
    private string RuleCode
        => _selected is null ? "-" : $"{SelectedDocument?.DocumentCode ?? "RUL"}-{_selected.Id.ToString("N")[..8].ToUpperInvariant()}";

    private DateTimeOffset? LastModified => _audit?.UpdatedAt ?? _audit?.CreatedAt;

    private string StatusStripLabel
    {
        get
        {
            if (_isNew) { return "Regla sin guardar."; }
            var who = _audit?.UpdatedByName ?? _audit?.CreatedByName ?? "sistema";
            return $"Guardado {RelativeLabel(LastModified)} - ultima edicion {who}";
        }
    }

    private IReadOnlyList<string> Categories
        => _allRules.Select(r => r.DocumentCategory).Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(c => c, StringComparer.OrdinalIgnoreCase).ToList();

    private List<RuleListItemDto> FilteredRules
    {
        get
        {
            IEnumerable<RuleListItemDto> query = _allRules;
            if (_filterDocumentId is Guid documentId)
            {
                query = query.Where(r => r.DocumentId == documentId);
            }
            if (_filterCategory.Length > 0)
            {
                query = query.Where(r => string.Equals(r.DocumentCategory, _filterCategory, StringComparison.OrdinalIgnoreCase));
            }
            if (_filterStatus.Length > 0 && Enum.TryParse<RuleStatus>(_filterStatus, out var status))
            {
                query = query.Where(r => r.Status == status);
            }
            if (_filterMode.Length > 0 && _filterMode != "ENSAMBLADO")
            {
                // Todas las reglas reales son Ensamblado (Execute/mDATA no existen, ADR-0016).
                query = [];
            }
            if (!string.IsNullOrWhiteSpace(_search))
            {
                var term = _search.Trim();
                query = query.Where(r =>
                    r.Name.Contains(term, StringComparison.OrdinalIgnoreCase)
                    || (r.Description?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false)
                    || r.VerbName.Contains(term, StringComparison.OrdinalIgnoreCase)
                    || r.DocumentCode.Contains(term, StringComparison.OrdinalIgnoreCase)
                    || r.DocumentName.Contains(term, StringComparison.OrdinalIgnoreCase)
                    || r.DocumentCategory.Contains(term, StringComparison.OrdinalIgnoreCase));
            }
            return query.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _catalog = Engine.GetVerbCatalog();
        await LoadDocumentsAsync();
        await LoadAllRulesAsync();
        await LoadStatsAsync();
        var first = _allRules.FirstOrDefault();
        if (first is not null)
        {
            await SelectRuleAsync(first.Id);
        }
    }

    // ---- Cargas ----

    private async Task LoadDocumentsAsync()
        => _documents = (await RulesSvc.ListDocumentsAsync(includeArchived: true)).ToList();

    private async Task LoadAllRulesAsync()
        => _allRules = (await RulesSvc.ListAllRulesAsync(_includeArchived)).ToList();

    private async Task LoadStatsAsync()
        => _stats = await RulesSvc.GetTenantStatsAsync();

    private async Task SelectRuleAsync(Guid ruleId)
    {
        var rule = await RulesSvc.GetRuleAsync(ruleId);
        if (rule is null)
        {
            return;
        }
        _isNew = false;
        _selectedId = ruleId;
        _selected = rule;
        _editorTab = 0;
        _confirmDelete = false;
        _ruleError = null;
        _statusMessage = null;
        _testResult = null;
        _xmlMessage = null;
        _historyShown = HistoryPageSize;

        _rName = rule.Name;
        _rDescription = rule.Description ?? "";
        _rVerbName = rule.VerbName;
        _rSortOrder = rule.SortOrder;
        _rDocumentId = rule.DocumentId;
        _rStatus = rule.Status;
        _paramValues.Clear();
        LoadParamValuesFromJson(rule.ParamsJson);
        RegenerateXmlFromForm();

        await ReloadRuleContextAsync(ruleId);
    }

    /// <summary>Recarga historial, metricas, auditoria y vinculos de la regla seleccionada.</summary>
    private async Task ReloadRuleContextAsync(Guid ruleId)
    {
        _history = (await RulesSvc.ListExecutionLogsAsync(ruleId: ruleId, take: 500)).ToList();
        _metrics = await RulesSvc.GetRuleMetricsAsync(ruleId);
        _audit = await RulesSvc.GetRuleAuditAsync(ruleId);
        _formLinks = (await RulesSvc.ListFormLinksAsync(ruleId)).ToList();
        _nodeLinks = (await RulesSvc.ListNodeLinksAsync(ruleId)).ToList();
        _formDefinitionOptions = await RulesSvc.ListFormDefinitionOptionsAsync();
        _workflowOptions = await RulesSvc.ListWorkflowDefinitionOptionsAsync();
        _linkFormDefinitionId = null;
        _linkQuestionId = null;
        _linkWorkflowId = null;
        _linkNodeId = null;
        _questionOptions = [];
        _nodeOptions = [];
    }

    // ---- Nueva regla ----

    private void StartNewRule()
    {
        if (_documents.Count(d => !d.IsArchived) == 0)
        {
            _documentsHint = "Crea primero un documento de reglas: la regla nueva vive dentro de un documento.";
            _showDocuments = true;
            _docFormOpen = _documents.Count == 0;
            return;
        }
        if (_selected is not null)
        {
            BeginNewRule(_selected.DocumentId);
            return;
        }
        _pickDocumentId = _documents.First(d => !d.IsArchived).Id;
        _showPickDocument = true;
    }

    private void BeginNewRule(Guid documentId)
    {
        _isNew = true;
        _selected = null;
        _selectedId = Guid.Empty;
        _editorTab = 0;
        _confirmDelete = false;
        _ruleError = null;
        _statusMessage = null;
        _testResult = null;
        _xmlMessage = null;
        _rName = "";
        _rDescription = "";
        _rVerbName = "";
        _rSortOrder = _allRules.Where(r => r.DocumentId == documentId)
            .Select(r => r.SortOrder).DefaultIfEmpty(-1).Max() + 1;
        _rDocumentId = documentId;
        _rStatus = RuleStatus.Active;
        _paramValues.Clear();
        _history = new List<RuleExecutionLogDto>();
        _metrics = null;
        _audit = null;
        _formLinks = new List<RuleFormLinkDto>();
        _nodeLinks = new List<RuleNodeLinkDto>();
        RegenerateXmlFromForm();
    }

    // ---- Guardar / duplicar / eliminar ----

    private async Task SaveRuleAsync()
    {
        _ruleError = null;
        _statusMessage = null;
        if (string.IsNullOrWhiteSpace(_rName) || string.IsNullOrWhiteSpace(_rVerbName))
        {
            _ruleError = "Nombre y verbo son obligatorios.";
            return;
        }
        var paramsJson = BuildParamsJson(out var paramsError);
        if (paramsError is not null)
        {
            _ruleError = paramsError;
            return;
        }
        _busy = true;
        try
        {
            var request = new SaveRuleRequest(_rName.Trim(), _rVerbName,
                string.IsNullOrWhiteSpace(_rDescription) ? null : _rDescription.Trim(),
                _rSortOrder, paramsJson, _rStatus,
                DocumentId: _isNew ? null : _rDocumentId);
            var result = _isNew
                ? await RulesSvc.CreateRuleAsync(_rDocumentId, request)
                : await RulesSvc.UpdateRuleAsync(_selectedId, request);
            if (!result.IsOk)
            {
                _ruleError = result.Error;
                return;
            }
            _selected = result.Value;
            _selectedId = result.Value!.Id;
            _isNew = false;
            await LoadAllRulesAsync();
            await LoadStatsAsync();
            await ReloadRuleContextAsync(_selectedId);
            RegenerateXmlFromForm();
            _statusMessage = "Cambios guardados.";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DuplicateRuleAsync()
    {
        if (_selected is null) { return; }
        _busy = true;
        try
        {
            var result = await RulesSvc.DuplicateRuleAsync(_selected.Id);
            if (!result.IsOk)
            {
                _ruleError = result.Error;
                return;
            }
            await LoadAllRulesAsync();
            await LoadStatsAsync();
            _busy = false;
            await SelectRuleAsync(result.Value!.Id);
            _statusMessage = "Regla duplicada (nace en Desarrollo, sin vinculos).";
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>
    /// Eliminar con la regla de negocio vigente (ADR-0016): si la regla tiene historial
    /// (append-only) NO se borra, se INACTIVA y se avisa claro.
    /// </summary>
    private async Task ConfirmDeleteAsync()
    {
        if (_selected is null) { return; }
        _confirmDelete = false;
        _busy = true;
        try
        {
            var result = await RulesSvc.DeleteRuleAsync(_selected.Id);
            if (result.IsOk)
            {
                _statusMessage = $"Regla '{_selected.Name}' eliminada.";
            }
            else if (result.Status == RuleServiceStatus.Invalid)
            {
                var deactivate = await RulesSvc.UpdateRuleAsync(_selected.Id, new SaveRuleRequest(
                    _selected.Name, _selected.VerbName, _selected.Description,
                    _selected.SortOrder, _selected.ParamsJson, RuleStatus.Inactive));
                if (!deactivate.IsOk)
                {
                    _ruleError = deactivate.Error;
                    return;
                }
                _statusMessage = "La regla tiene historial de ejecuciones (append-only): se marco INACTIVA en vez de borrarse.";
                await LoadAllRulesAsync();
                await LoadStatsAsync();
                _busy = false;
                await SelectRuleAsync(_selected.Id);
                _statusMessage = "La regla tiene historial de ejecuciones (append-only): se marco INACTIVA en vez de borrarse.";
                return;
            }
            else
            {
                _ruleError = result.Error;
                return;
            }

            _selected = null;
            _selectedId = Guid.Empty;
            await LoadAllRulesAsync();
            await LoadStatsAsync();
            var first = _allRules.FirstOrDefault();
            if (first is not null)
            {
                var message = _statusMessage;
                _busy = false;
                await SelectRuleAsync(first.Id);
                _statusMessage = message;
            }
        }
        finally
        {
            _busy = false;
        }
    }

    // ---- Prueba manual (Probar / Ejecutar regla) ----

    private async Task RunSelectedTestAsync()
    {
        if (_selected is null || _isNew) { return; }
        _busy = true;
        try
        {
            // Guarda primero (la prueba corre sobre lo persistido) y ejecuta con el
            // usuario actual: la ejecucion SIEMPRE queda en el historial.
            _busy = false;
            await SaveRuleAsync();
            _busy = true;
            if (_ruleError is not null)
            {
                return;
            }
            var tenantUserId = await RulesSvc.GetCurrentTenantUserIdAsync();
            var result = await Engine.ExecuteRuleAsync(_selected!.Id, RuleInvocation.Manual(tenantUserId));
            _testResult = result.Value ?? new RuleExecutionOutcome(_selected.Id, _selected.Name,
                _selected.VerbName, RuleExecutionStatus.Failed, result.Error, 0, 0, [], false, result.Error);
            await ReloadRuleContextAsync(_selected.Id);
            await LoadStatsAsync();
            _statusMessage = $"Prueba ejecutada: {StatusExecLabel(_testResult.Status)} ({_testResult.DurationMs} ms).";
        }
        finally
        {
            _busy = false;
        }
    }

    // ---- PARAM_XML (representacion editable del ParamsJson tipado, ADR-0023) ----

    private void RegenerateXmlFromForm()
    {
        if (SelectedDescriptor is not RuleVerbDescriptor descriptor)
        {
            _paramXml = "<!-- Selecciona un verbo del catalogo para generar el contrato PARAM_XML -->";
            return;
        }
        var paramsJson = BuildParamsJson(out _);
        _paramXml = RuleParamXml.Generate(descriptor, paramsJson);
    }

    private void FormatXml()
    {
        var result = RuleParamXml.Format(_paramXml);
        if (result.IsOk)
        {
            _paramXml = result.Value!;
            _xmlOk = true;
            _xmlMessage = "XML formateado.";
        }
        else
        {
            _xmlOk = false;
            _xmlMessage = result.Error;
        }
    }

    private void ValidateXml()
    {
        if (SelectedDescriptor is not RuleVerbDescriptor descriptor)
        {
            _xmlOk = false;
            _xmlMessage = "Selecciona un verbo antes de validar.";
            return;
        }
        var result = RuleParamXml.Parse(_paramXml, descriptor);
        if (!result.IsOk)
        {
            _xmlOk = false;
            _xmlMessage = result.Error;
            return;
        }
        // XML valido: pasa a ser la fuente de los parametros (vista renderizada incluida).
        _paramValues.Clear();
        LoadParamValuesFromJson(result.Value);
        _xmlOk = true;
        _xmlMessage = "XML valido: parametros aplicados a la vista renderizada. Guarda para persistir.";
    }

    private void OnVerbChanged(ChangeEventArgs e)
    {
        _rVerbName = e.Value?.ToString() ?? "";
        _paramValues.Clear();
        _xmlMessage = null;
        RegenerateXmlFromForm();
    }

    private string GetParamValue(string name) => _paramValues.GetValueOrDefault(name) ?? "";

    private void SetParamValue(string name, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            _paramValues.Remove(name);
        }
        else
        {
            _paramValues[name] = value;
        }
        // La vista renderizada es autoritativa al editarla: el XML se regenera.
        RegenerateXmlFromForm();
    }

    /// <summary>Carga el ParamsJson existente al editor por-parametro del descriptor.</summary>
    private void LoadParamValuesFromJson(string? paramsJson)
    {
        if (string.IsNullOrWhiteSpace(paramsJson))
        {
            return;
        }
        try
        {
            using var doc = JsonDocument.Parse(paramsJson);
            if (doc.RootElement.ValueKind != JsonValueKind.Object)
            {
                return;
            }
            foreach (var property in doc.RootElement.EnumerateObject())
            {
                _paramValues[property.Name] = property.Value.ValueKind == JsonValueKind.String
                    ? property.Value.GetString() ?? ""
                    : property.Value.GetRawText();
            }
        }
        catch (JsonException)
        {
            // ParamsJson corrupto: el editor arranca vacio y el guardado lo reescribe.
        }
    }

    /// <summary>Construye el ParamsJson tipado a partir de los inputs del descriptor.</summary>
    private string? BuildParamsJson(out string? error)
    {
        error = null;
        var descriptor = SelectedDescriptor;
        if (descriptor is null || _paramValues.Count == 0)
        {
            return _paramValues.Count == 0 ? null : "{}";
        }
        var result = new JsonObject();
        foreach (var (name, raw) in _paramValues)
        {
            var paramDescriptor = descriptor.Params.FirstOrDefault(p => p.Name == name);
            switch (paramDescriptor?.Type)
            {
                case RuleParamType.Boolean:
                    result[name] = string.Equals(raw, "true", StringComparison.OrdinalIgnoreCase);
                    break;
                case RuleParamType.Number:
                    if (!decimal.TryParse(raw, System.Globalization.CultureInfo.InvariantCulture, out var number))
                    {
                        error = $"El parametro '{name}' debe ser numerico.";
                        return null;
                    }
                    result[name] = number;
                    break;
                case RuleParamType.Json:
                    try
                    {
                        result[name] = JsonNode.Parse(raw);
                    }
                    catch (JsonException)
                    {
                        error = $"El parametro '{name}' no es JSON valido.";
                        return null;
                    }
                    break;
                default:
                    result[name] = raw;
                    break;
            }
        }
        return result.ToJsonString();
    }

    // ---- Coloreado de sintaxis del editor XML (tags azul, atributos rosa, strings verde) ----

    /// <summary>
    /// Resalta el XML para la capa &lt;pre&gt; detras del textarea transparente. Escapa TODO
    /// el texto y envuelve tokens en spans (t=tag, a=atributo, s=string, c=comentario).
    /// </summary>
    internal static string HighlightXml(string xml)
    {
        var sb = new StringBuilder(xml.Length + 128);
        var i = 0;
        while (i < xml.Length)
        {
            if (xml[i] == '<' && i + 3 < xml.Length && xml.AsSpan(i).StartsWith("<!--"))
            {
                var end = xml.IndexOf("-->", i, StringComparison.Ordinal);
                end = end < 0 ? xml.Length : end + 3;
                sb.Append("<span class=\"c\">").Append(Escape(xml[i..end])).Append("</span>");
                i = end;
            }
            else if (xml[i] == '<')
            {
                var end = FindTagEnd(xml, i);
                AppendTag(sb, xml[i..end]);
                i = end;
            }
            else
            {
                var next = xml.IndexOf('<', i);
                next = next < 0 ? xml.Length : next;
                sb.Append(Escape(xml[i..next]));
                i = next;
            }
        }
        sb.Append('\n'); // linea fantasma: mantiene la altura del pre = la del textarea
        return sb.ToString();
    }

    /// <summary>Fin del tag respetando comillas (un '&gt;' dentro de un atributo no cierra).</summary>
    private static int FindTagEnd(string xml, int start)
    {
        var inQuote = '\0';
        for (var i = start; i < xml.Length; i++)
        {
            var c = xml[i];
            if (inQuote != '\0')
            {
                if (c == inQuote) { inQuote = '\0'; }
            }
            else if (c is '"' or '\'')
            {
                inQuote = c;
            }
            else if (c == '>')
            {
                return i + 1;
            }
        }
        return xml.Length;
    }

    /// <summary>Resalta el interior de un tag: nombre (t), atributos (a) y valores (s).</summary>
    private static void AppendTag(StringBuilder sb, string tag)
    {
        var i = 0;
        // "<" o "</" + nombre del elemento.
        var nameEnd = i;
        while (nameEnd < tag.Length && tag[nameEnd] is not (' ' or '\t' or '\n' or '\r'))
        {
            nameEnd++;
        }
        sb.Append("<span class=\"t\">").Append(Escape(tag[i..nameEnd])).Append("</span>");
        i = nameEnd;

        while (i < tag.Length)
        {
            var c = tag[i];
            if (c is '"' or '\'')
            {
                var end = tag.IndexOf(c, i + 1);
                end = end < 0 ? tag.Length : end + 1;
                sb.Append("<span class=\"s\">").Append(Escape(tag[i..end])).Append("</span>");
                i = end;
            }
            else if (char.IsLetter(c) || c == '_')
            {
                var end = i;
                while (end < tag.Length && (char.IsLetterOrDigit(tag[end]) || tag[end] is '_' or '-' or ':' or '.'))
                {
                    end++;
                }
                sb.Append("<span class=\"a\">").Append(Escape(tag[i..end])).Append("</span>");
                i = end;
            }
            else if (c is '>' or '/')
            {
                var end = tag.Length;
                sb.Append("<span class=\"t\">").Append(Escape(tag[i..end])).Append("</span>");
                i = end;
            }
            else
            {
                sb.Append(Escape(tag[i].ToString()));
                i++;
            }
        }
    }

    private static string Escape(string text)
        => text.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");

