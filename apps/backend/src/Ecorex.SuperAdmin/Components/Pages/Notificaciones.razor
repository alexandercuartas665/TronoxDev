@page "/notificaciones"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Notifications
@using Ecorex.Domain.Enums
@using System.Security.Claims
@inject INotificationService Notifications
@inject NavigationManager Nav

@* Ola 7 (entrega real de notificaciones): bandeja in-app del usuario. Respaldada por la tabla
   Notification (entrega por destinatario, leido/no leido). La campana del topbar enlaza aqui. *@

<PageTitle>Notificaciones - ECOREX.tareas</PageTitle>

<div style="max-width:820px;margin:0 auto;padding:24px 20px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:18px">
        <h1 style="font-size:20px;font-weight:700;color:var(--ink);margin:0;flex:1">Notificaciones</h1>
        @if (_items is { Count: > 0 } && _items.Any(n => !n.IsRead))
        {
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="MarkAllReadAsync" disabled="@_busy">
                Marcar todas como leidas
            </button>
        }
    </div>

    @if (_items is null)
    {
        <div style="color:var(--ink-3);font-size:14px">Cargando...</div>
    }
    else if (_items.Count == 0)
    {
        <div style="padding:48px 24px;text-align:center;color:var(--ink-3);font-size:14px;
                    border:1px dashed var(--line);border-radius:12px">
            No tienes notificaciones.
        </div>
    }
    else
    {
        <div style="display:flex;flex-direction:column;gap:8px">
            @foreach (var n in _items)
            {
                <div style="display:flex;gap:12px;padding:14px 16px;border:1px solid var(--line);border-radius:12px;
                            background:@(n.IsRead ? "var(--surface)" : "var(--surface-2, var(--surface))");
                            @(n.IsRead ? "" : "box-shadow: inset 3px 0 0 var(--brand, #6d3bff);")">
                    <div style="flex-shrink:0;margin-top:2px;color:var(--ink-2)">
                        @KindIcon(n.Kind)
                    </div>
                    <div style="flex:1;min-width:0">
                        <div style="font-weight:@(n.IsRead ? "500" : "700");color:var(--ink);font-size:14px">@n.Title</div>
                        <div style="color:var(--ink-2);font-size:13px;margin-top:2px">@n.Body</div>
                        <div style="color:var(--ink-3);font-size:11px;margin-top:6px">
                            @n.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            @if (!string.IsNullOrWhiteSpace(n.ActorName)) { <span> &middot; @n.ActorName</span> }
                        </div>
                    </div>
                    <div style="display:flex;flex-direction:column;gap:6px;align-items:flex-end">
                        @if (!n.IsRead)
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => MarkReadAsync(n.Id)" disabled="@_busy">
                                Marcar leida
                            </button>
                        }
                        @if (!string.IsNullOrWhiteSpace(n.LinkRoute))
                        {
                            <button type="button" class="btn btn-sm btn-link p-0" @onclick="() => OpenAsync(n)">Abrir</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private IReadOnlyList<NotificationDto>? _items;
    private Guid _platformUserId;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            Guid.TryParse(state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out _platformUserId);
        }
        await ReloadAsync();
    }

    private async Task ReloadAsync()
        => _items = await Notifications.ListForPlatformUserAsync(_platformUserId, take: 50);

    private async Task MarkReadAsync(Guid id)
    {
        _busy = true;
        try { await Notifications.MarkReadAsync(id); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task MarkAllReadAsync()
    {
        _busy = true;
        try { await Notifications.MarkAllReadForPlatformUserAsync(_platformUserId); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task OpenAsync(NotificationDto n)
    {
        if (!n.IsRead) { await Notifications.MarkReadAsync(n.Id); }
        Nav.NavigateTo("/" + n.LinkRoute!.TrimStart('/'));
    }

    private static RenderFragment KindIcon(NotificationKind kind) => builder =>
    {
        // Icono simple por tipo (SVG inline, sin dependencias).
        var path = kind switch
        {
            NotificationKind.TaskAssigned => "M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11",
            NotificationKind.ConceptNotice => "M2 3h6l2 3h12v13a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1Z",
            _ => "M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"
        };
        builder.AddMarkupContent(0,
            $"<svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"{path}\"/></svg>");
    };
}
