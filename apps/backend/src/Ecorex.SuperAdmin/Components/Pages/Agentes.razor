    }

    // ===== Eliminar agente (doble confirmacion) =====
    private void OpenDeleteAgent(AiAgentDto a)
    {
        _deleteAgent = a;
        _deleteStep = 1;
        _delResourcesCount = a.ResourceCount;
        _delPromptsCount = 0;
        _delCacheFieldsCount = 0;
        _delConfirmName = "";
        _delError = null;
    }

    private void CloseDeleteAgent()
    {
        _deleteAgent = null;
        _deleteStep = 1;
        _delConfirmName = "";
        _delError = null;
    }

    private async Task GoToDeleteStep2()
    {
        if (_deleteAgent is null) { return; }
        // Cargamos las cuentas exactas justo antes del paso 2 para que el usuario vea que se borrara.
        try
        {
            var detail = await AgentsSvc.GetAsync(_deleteAgent.Id);
            if (detail is not null)
            {
                _delResourcesCount = detail.Resources.Count;
                _delPromptsCount = detail.Prompts.Count;
            }
            _delCacheFieldsCount = (await CacheSvc.ListFieldsAsync(_deleteAgent.Id)).Count;
        }
        catch { /* si fallan las cuentas seguimos con los valores por defecto */ }
        _deleteStep = 2;
    }

    private async Task ConfirmDeleteAgentAsync()
    {
        if (_deleteAgent is null) { return; }
        if (!string.Equals(_delConfirmName, _deleteAgent.Name, StringComparison.Ordinal))
        {
            _delError = "El nombre no coincide.";
            return;
        }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var ok = await AgentsSvc.DeleteAsync(_deleteAgent.Id, actor);
            if (!ok) { _delError = "No se pudo eliminar el agente."; return; }
            CloseDeleteAgent();
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _delError = ex.Message;
        }
        finally { _busy = false; }
    }

    private async Task DeleteResourceAsync(Guid id)
    {
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            await AgentsSvc.DeleteResourceAsync(id, actor);
            _resources.RemoveAll(x => x.Id == id);
        }
        finally { _busy = false; }
    }

