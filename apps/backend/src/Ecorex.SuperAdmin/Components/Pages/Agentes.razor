    }

    private async Task SavePromptAsync()
    {
        _promptError = null;
        if (_editId is null) { return; }
        if (string.IsNullOrWhiteSpace(_pName) || string.IsNullOrWhiteSpace(_pBody)) { _promptError = "Nombre y prompt son obligatorios."; return; }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            if (_promptEditId is null)
            {
                var created = await AgentsSvc.AddPromptAsync(new CreateAgentPromptRequest(_editId.Value, _pName, _pRule, _pBody), actor);
                if (created is not null) { _prompts.Add(created); }
            }
            else
            {
                var updated = await AgentsSvc.UpdatePromptAsync(_promptEditId.Value, new UpdateAgentPromptRequest(_pName, _pRule, _pBody), actor);
                if (updated is not null)
                {
                    var idx = _prompts.FindIndex(x => x.Id == updated.Id);
                    if (idx >= 0) { _prompts[idx] = updated; }
                }
            }
            _promptModalOpen = false;
        }
        finally { _busy = false; }
    }

    private async Task DeletePromptAsync(Guid id)
    {
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            await AgentsSvc.DeletePromptAsync(id, actor);
            _prompts.RemoveAll(p => p.Id == id);
        }
        finally { _busy = false; }
    }

