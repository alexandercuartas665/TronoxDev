    private async Task OpenEditAsync(Guid id)
    {
        var detail = await AgentsSvc.GetAsync(id);
        if (detail is null) { return; }
        _editId = id;
        _editorError = null;
        _fName = detail.Agent.Name;
        _fRole = detail.Agent.Role;
        _fProvider = detail.Agent.Provider;
        _fModel = detail.Agent.Model;
        _fPrompt = detail.Agent.SystemPrompt;
        _fActive = detail.Agent.IsActive;
        _disabledTools.Clear();
        foreach (var t in detail.Agent.DisabledTools ?? Array.Empty<string>()) { _disabledTools.Add(t); }
        _resources = detail.Resources.ToList();
        _prompts = detail.Prompts.ToList();
        await ReloadCacheAsync(id);
        await ReloadVersionsAsync(id);
        _agentLines = (await AgentLinesSvc.ListLinesForAgentAsync(id)).ToList();
        _cacheOpen = false;
        _resourcesOpen = false;
        _linesOpen = false;
        _versionsOpen = false;
        _versionPendingRestore = null;
        _perceivedModalOpen = false;
        ResetTest();
        _editorOpen = true;
    }

    // ===== Duplicar agente y versiones de prompts =====
    private async Task DuplicateAgentAsync(AiAgentDto a)
    {
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var copy = await AgentsSvc.DuplicateAsync(a.Id, actor);
            await ReloadAsync();
            if (copy is not null)
            {
                await OpenEditAsync(copy.Id);
            }
        }
        finally { _busy = false; }
    }

