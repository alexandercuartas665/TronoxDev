    private void AskRestoreVersion(AiAgentPromptVersionDto v) => _versionPendingRestore = v;

    private async Task ConfirmRestoreVersionAsync()
    {
        if (_versionPendingRestore is null || _editId is null) { return; }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var detail = await AgentsSvc.RestorePromptVersionAsync(_editId.Value, _versionPendingRestore.Index, actor);
            _versionPendingRestore = null;
            if (detail is not null)
            {
                _fPrompt = detail.Agent.SystemPrompt;
                _prompts = detail.Prompts.ToList();
                await ReloadVersionsAsync(_editId.Value);
                await ReloadAsync();
