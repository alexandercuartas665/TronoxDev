        _resEmojiOpen = false;
        _resModalOpen = true;
    }

    private async Task OnResourceModalFileAsync(InputFileChangeEventArgs e)
    {
        _resError = null;
        // WhatsApp solo muestra imagenes JPEG o PNG. SVG/GIF/WebP fallan al enviarse por Evolution/Baileys,
        // y el adjunto se cae en silencio en la conversacion. Lo bloqueamos aqui con un mensaje claro.
        if (_rType == AgentResourceType.Image)
        {
            var ext = System.IO.Path.GetExtension(e.File.Name).ToLowerInvariant();
            if (ext is not (".jpg" or ".jpeg" or ".png"))
            {
                _resError = $"WhatsApp no admite imagenes {(string.IsNullOrEmpty(ext) ? "sin extension" : ext)} como foto. Sube un JPEG o PNG.";
                return;
            }
        }
        var saved = await SaveAgentFileAsync(e.File);
        if (saved is null) { _resError = "No se pudo subir el archivo."; return; }
        _rFileUrl = saved.Value.Url;
        _rFileName = saved.Value.Name;
    }

    private async Task SaveResourceAsync()
    {
        _resError = null;
        if (_editId is null) { return; }
        if (string.IsNullOrWhiteSpace(_rName)) { _resError = "El nombre es obligatorio."; return; }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            if (_resEditId is null)
            {
                var created = await AgentsSvc.AddResourceAsync(new CreateAgentResourceRequest(_editId.Value, _rName, _rType, _rDetail, _rFileUrl, _rFileName), actor);
                if (created is not null) { _resources.Add(created); }
            }
            else
            {
                var updated = await AgentsSvc.UpdateResourceAsync(_resEditId.Value, new UpdateAgentResourceRequest(_rName, _rType, _rDetail, _rFileUrl, _rFileName), actor);
                if (updated is not null)
                {
                    var idx = _resources.FindIndex(x => x.Id == updated.Id);
                    if (idx >= 0) { _resources[idx] = updated; }
                }
            }
            _resModalOpen = false;
        }
        finally { _busy = false; }
    }

