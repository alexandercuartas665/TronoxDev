    private bool AllSticky() => _cacheFields.Count > 0 && _cacheFields.All(f => !f.IsUpdatable);

    private async Task BulkToggleStickyAsync()
    {
        if (_editId is null || _cacheFields.Count == 0) { return; }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var target = !AllSticky();   // si NO todos son sticky -> los pone sticky (IsUpdatable=false); si todos son sticky, los pone actualizables.
            await CacheSvc.BulkSetFieldsUpdatableAsync(_editId.Value, !target, actor);
            await ReloadCacheAsync(_editId.Value);
        }
        finally { _busy = false; }
    }

