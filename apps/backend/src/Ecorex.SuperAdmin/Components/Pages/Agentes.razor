        <button type="button" class="rt-btn" title="Negrita (*texto*)" @onclick="() => Bold(targetId)"><b>B</b></button>
        <button type="button" class="rt-btn" title="Cursiva (_texto_)" @onclick="() => Italic(targetId)"><i>i</i></button>
        <button type="button" class="rt-btn" title="Tachado (~texto~)" @onclick="() => Strike(targetId)"><s>S</s></button>
        <button type="button" class="rt-btn" title="Monoespaciado" @onclick="() => Mono(targetId)">&lt;/&gt;</button>
        <button type="button" class="rt-btn" title="Vineta" @onclick="() => Bullet(targetId)">&bull;</button>
