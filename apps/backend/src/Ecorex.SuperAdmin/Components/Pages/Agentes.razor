    private static string? AcceptFor(AgentResourceType t) => t switch
    {
        AgentResourceType.Image => "image/png,image/jpeg",
        AgentResourceType.Video => "video/mp4,video/3gpp",
        AgentResourceType.Audio => "audio/ogg,audio/mpeg,audio/mp4",
        AgentResourceType.Pdf => "application/pdf",
        _ => null
    };

    private async Task<(string Url, string Name)?> SaveAgentFileAsync(IBrowserFile file)
    {
        const long max = 25L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { return null; }
        using var ms = new MemoryStream();
        await file.OpenReadStream(max).CopyToAsync(ms);
        var ext = System.IO.Path.GetExtension(file.Name);
        var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", "agents");
        System.IO.Directory.CreateDirectory(dir);
        var name = $"agent-{Guid.NewGuid():N}{ext}";
        await System.IO.File.WriteAllBytesAsync(System.IO.Path.Combine(dir, name), ms.ToArray());
        return ($"/uploads/agents/{name}", file.Name);
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

