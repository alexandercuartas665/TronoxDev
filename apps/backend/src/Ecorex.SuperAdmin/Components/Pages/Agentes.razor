@page "/agentes"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@using Ecorex.Application.Admin
@using Ecorex.Domain.Enums
@inject IAiAgentService AgentsSvc
@inject IEnumerable<IAgentToolset> Toolsets
@inject IAiAgentCacheService CacheSvc
@inject IAiServerConfigService AiServersSvc
@inject IAiInferenceService InferenceSvc
@inject IAiUsageService UsageSvc
@inject IWhatsAppLineService LinesSvc
@inject IAiAgentLineService AgentLinesSvc
@inject IWhatsAppConnectorService Connector
@inject IWebHostEnvironment Env
@inject IJSRuntime JS

<PageTitle>Agentes IA - ECOREX.tareas</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
            </div>
            <span>Infraestructura & IA</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Agentes <span>IA</span></h1>
        <p class="page-sub" style="margin-bottom:0;">Configura cada agente: elige el servicio de IA disponible, define su comportamiento, agrega recursos y ponlo en produccion o apagalo.</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenNew">+ Nuevo agente</button>
</div>

@if (!_loading && _usage is not null)
{
    <div class="kpi-grid" style="margin-bottom:22px;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));max-width:760px;">
        <div class="kpi-card">
            <div class="kpi-label">Consumo de tokens</div>
            <div class="kpi-value">@Tokens(_usage.TotalTokens)</div>
            <div class="kpi-hint">@_usage.InputTokens entrada · @_usage.OutputTokens salida</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Llamadas de IA</div>
            <div class="kpi-value">@_usage.TotalCalls</div>
            <div class="kpi-hint">en todos los agentes</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Costo estimado</div>
            <div class="kpi-value">$@_usage.EstimatedCostUsd.ToString("0.####")</div>
            <div class="kpi-hint">USD (tarifa aproximada)</div>
        </div>
        @if (_quota is { HasLimit: true })
        {
            <div class="kpi-card">
                <div class="kpi-label">Cupo mensual del plan</div>
                <div class="kpi-value">@Tokens(_quota.MonthlyUsedTokens) / @Tokens(_quota.MonthlyLimitTokens)</div>
                <div class="ag-quota-bar"><div class="ag-quota-fill @(_quota.Exceeded ? "over" : "")" style="width:@(_quota.UsedPct)%;"></div></div>
                <div class="kpi-hint">@Tokens(_quota.Remaining) tokens disponibles este mes</div>
            </div>
        }
    </div>
    @if (_quota is { Exceeded: true })
    {
        <div class="cv-warn" style="border-color:var(--destructive);color:var(--destructive);max-width:760px;margin-bottom:18px;">
            Alcanzaste el limite de tokens de IA de tu plan este mes (@Tokens(_quota.MonthlyLimitTokens)).
            @(_quota.Hard ? "Los agentes no podran responder hasta el proximo ciclo o hasta que actualices tu plan." : "Puedes seguir usando los agentes, pero estas por encima del cupo de tu plan.")
        </div>
    }
}

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else if (_agents.Count == 0)
{
    <div class="card" style="padding:28px;max-width:680px;text-align:center;color:var(--muted-foreground);">
        Aun no hay agentes. Crea el primero con "+ Nuevo agente".
    </div>
}
else
{
    <div class="ag-grid">
        @foreach (var a in _agents)
        {
            <div class="ag-card">
                <div class="ag-card-top">
                    <span class="ag-provider @ProviderClass(a.Provider)">@ProviderLabel(a.Provider)</span>
                    <span class="badge @(a.IsActive ? "bg-success" : "bg-secondary")">@(a.IsActive ? "En produccion" : "Apagado")</span>
                    <button class="ag-card-del" title="Duplicar agente (copia toda la config menos la linea de atencion)" @onclick="() => DuplicateAgentAsync(a)" disabled="@_busy" style="margin-left:auto;">
                        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                    </button>
                    <button class="ag-card-del" title="Eliminar agente" @onclick="() => OpenDeleteAgent(a)" disabled="@_busy">&times;</button>
                </div>
                <div class="ag-name">@a.Name</div>
                @if (!string.IsNullOrWhiteSpace(a.Role))
                {
                    <div class="ag-role">@a.Role</div>
                }
                <div class="ag-prompt">@(string.IsNullOrWhiteSpace(a.SystemPrompt) ? "Sin prompt configurado" : Trim(a.SystemPrompt, 110))</div>
                <div class="ag-foot">
                    <span class="ag-res">@a.ResourceCount recurso@(a.ResourceCount == 1 ? "" : "s") · @Tokens(AgentTokens(a.Id)) tokens</span>
                    <div style="display:flex;gap:6px;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenEditAsync(a.Id)" disabled="@_busy">Configurar</button>
                        <label class="ag-switch" title="@(a.IsActive ? "Apagar" : "Poner en produccion")">
                            <input type="checkbox" checked="@a.IsActive" @onchange="@(e => ToggleActiveAsync(a, (bool)e.Value!))" disabled="@_busy" />
                            <span class="ag-slider"></span>
                        </label>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* ===== Modal: configurar agente ===== *@
@if (_editorOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:@(_editId is null ? "640px" : "min(1480px, 95vw)");">
            <div class="modal-head">
                <h3>@(_editId is null ? "Nuevo agente" : "Configurar agente")</h3>
                <button class="modal-close" @onclick="CloseEditor">&times;</button>
            </div>
            <div class="modal-body">
              <div class="ag-editor-cols">
               @* ===== Columna izquierda: historial de versiones (red de seguridad) ===== *@
               @if (_editId is not null)
               {
                   <div class="ag-editor-versions">
                       <div class="pl-stagegroup-title" style="margin:0 0 8px;">Historial de versiones</div>
                       <div class="text-muted" style="font-size:11px;line-height:1.5;margin-bottom:10px;">Cada "Guardar cambios" guarda una copia del prompt base + enrutados (ultimas @MaxVersionsShown). Pulsa una version anterior para restaurarla.</div>
                       @if (_versionsLoading)
                       {
                           <div class="text-muted small">Cargando...</div>
                       }
                       else if (_versions.Count == 0)
                       {
                           <div class="text-muted" style="font-size:11.5px;line-height:1.5;">Aun no hay versiones guardadas. Se crea una cada vez que pulsas <strong>"Guardar cambios"</strong>.</div>
                       }
                       else
                       {
                           <div style="display:flex;flex-direction:column;gap:5px;">
                               @foreach (var v in _versions)
                               {
                                   <button type="button" @onclick="() => AskRestoreVersion(v)" disabled="@(_busy || v.Index == 0)"
                                           title="@(v.Index == 0 ? "Es la version actual" : "Restaurar esta version")"
                                           style="display:flex;align-items:center;gap:8px;width:100%;text-align:left;border:1px solid var(--border);background:@(v.Index == 0 ? "rgba(108,76,241,.06)" : "transparent");border-radius:7px;padding:7px 9px;cursor:@(v.Index == 0 ? "default" : "pointer");font-size:12px;">
                                       <span style="width:7px;height:7px;border-radius:50%;background:@(v.Index == 0 ? "var(--primary,#6c4cf1)" : "var(--border)");flex:0 0 auto;"></span>
                                       <span style="white-space:nowrap;">@v.SavedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                       @if (v.Index == 0)
                                       {
                                           <span style="margin-left:auto;font-size:10px;color:var(--primary,#6c4cf1);">actual</span>
                                       }
                                       else
                                       {
                                           <span style="margin-left:auto;font-size:10px;color:var(--muted-foreground);">Restaurar</span>
                                       }
                                   </button>
                               }
                           </div>
                       }
                   </div>
               }
               <div class="ag-editor-left">
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Nombre *</label>
                        <input class="form-control" @bind="_fName" autocomplete="off" />
                    </div>
                    <div class="field">
                        <label class="form-label">Rol / funcion</label>
                        <input class="form-control" @bind="_fRole" placeholder="Copiloto, clasificador, seguimiento..." autocomplete="off" />
                    </div>
                </div>
                @if (_providerOptions.Count == 0)
                {
                    <div class="text-danger small" style="margin:4px 0 10px;">
                        No hay servicios de IA disponibles. Pide al administrador de la plataforma que habilite un proveedor en "Servidores de IA".
                    </div>
                }
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Servicio de IA *</label>
                        <select class="form-control" @bind="_fProvider" disabled="@(_providerOptions.Count == 0)">
                            @foreach (var opt in EditorProviderOptions())
                            {
                                <option value="@opt.Provider">@opt.DisplayName</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label class="form-label">Modelo</label>
                        <input class="form-control" value="@EffectiveModel(_fProvider)" disabled />
                        <div class="text-muted" style="font-size:11px;margin-top:4px;">Lo define el administrador de la plataforma.</div>
                    </div>
                </div>
                @if (_editId is not null)
                {
                    <div class="field">
                        <label class="form-label">Prompt base (comportamiento principal)</label>
                        @RichToolbar("basePrompt", () => _baseEmojiOpen, v => _baseEmojiOpen = v)
                        <textarea id="basePrompt" class="form-control" rows="4" @bind="_fPrompt" @bind:event="oninput" placeholder="Instrucciones generales que definen el comportamiento del agente..."></textarea>
                    </div>
                }
                @if (_editorError is not null)
                {
                    <div class="text-danger small">@_editorError</div>
                }
                <div style="display:flex;gap:8px;align-items:center;margin:4px 0 8px;">
                    <button class="btn btn-primary" @onclick="SaveAgentAsync" disabled="@(_busy || (_editId is null && _providerOptions.Count == 0))">@(_editId is null ? "Crear agente" : "Guardar cambios")</button>
                    @if (_editId is not null)
                    {
                        <label class="ag-switch">
                            <input type="checkbox" checked="@_fActive" @onchange="@(e => ToggleActiveInEditorAsync((bool)e.Value!))" disabled="@_busy" />
                            <span class="ag-slider"></span>
                        </label>
                        <span class="small text-muted">@(_fActive ? "En produccion" : "Apagado")</span>
                    }
                </div>

                @if (_editId is not null)
                {
                    @* ===== Prompts enrutados ===== *@
                    <hr style="border-color:var(--border);margin:14px 0;" />
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
                        <div class="pl-stagegroup-title">Prompts enrutados</div>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenPrompt(null)" disabled="@_busy">+ Agregar prompt</button>
                    </div>
                    <div class="text-muted" style="font-size:12px;margin-bottom:10px;">El enrutador evalua el mensaje del cliente y aplica el prompt cuya regla coincide (ej. "cuando pregunte por Panama") antes del comportamiento base.</div>
                    @if (_prompts.Count == 0)
                    {
                        <div class="text-muted small">Sin prompts enrutados. El agente usara solo el prompt base.</div>
                    }
                    else
                    {
                        <div class="ag-list">
                            @foreach (var p in _prompts)
                            {
                                <div class="ag-item">
                                    <div class="ag-item-main">
                                        <div class="ag-item-name">@p.Name</div>
                                        <div class="ag-item-sub">@(string.IsNullOrWhiteSpace(p.Rule) ? "Sin regla" : p.Rule)</div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenPrompt(p)" disabled="@_busy">Editar</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePromptAsync(p.Id)" disabled="@_busy">&times;</button>
                                </div>
                            }
                        </div>
                    }

                    @* ===== Datos cache (objetivos del agente) - acordeon ===== *@
                    <hr style="border-color:var(--border);margin:14px 0;" />
                    <div class="ag-accordion">
                        <div class="ag-accordion-head" role="button" tabindex="0" @onclick="() => _cacheOpen = !_cacheOpen">
                            <span class="ag-accordion-chev @(_cacheOpen ? "open" : "")">&#9656;</span>
                            <span class="pl-stagegroup-title" style="margin:0;">Datos cache (objetivo)</span>
                            <span class="ag-accordion-count">@_cacheFields.Count</span>
                            <span class="ag-accordion-spacer"></span>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick:stopPropagation="true" @onclick="() => OpenCacheField(null)" disabled="@_busy">+ Agregar dato</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick:stopPropagation="true" @onclick="BulkToggleStickyAsync" disabled="@(_busy || _cacheFields.Count == 0)" title="Marca todos los campos como sticky (no se actualizan tras captura) o, si ya estan todos sticky, los pone actualizables.">@(AllSticky() ? "Marcar todos actualizables" : "Marcar todos sticky")</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick:stopPropagation="true" @onclick="OpenPerceivedModal" disabled="@_busy">Ver datos percibidos</button>
                        </div>
                        @if (_cacheOpen)
                        {
                            <div class="ag-accordion-body">
                                <div class="text-muted" style="font-size:12px;margin-bottom:10px;">Define que datos debe ir capturando el agente durante la conversacion (ej. "pais", "nombre", "destino"). Cuando un telefono se enlace al sistema se creara una sesion de cache por conversacion; aqui usamos el agente como sesion de prueba.</div>
                                @if (_cacheFields.Count == 0)
                                {
                                    <div class="text-muted small">Sin datos definidos. Agrega el primero para que el agente empiece a capturarlos.</div>
                                }
                                else
                                {
                                    <div class="ag-list ag-list-scroll">
                                        @foreach (var f in _cacheFields)
                                        {
                                            <div class="ag-item">
                                                <span class="ag-rtype">DATO</span>
                                                <div class="ag-item-main">
                                                    <div class="ag-item-name">
                                                        @f.Label <span class="text-muted" style="font-size:11px;">(@f.FieldKey)</span>
                                                        @if (!f.IsUpdatable)
                                                        {
                                                            <span class="ag-pill-sticky" title="Una vez capturado, este dato queda fijo y no se actualiza.">sticky</span>
                                                        }
                                                    </div>
                                                    <div class="ag-item-sub">@(string.IsNullOrWhiteSpace(f.Description) ? "Sin descripcion" : Trim(f.Description!, 90))</div>
                                                </div>
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenCacheField(f)" disabled="@_busy">Editar</button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCacheFieldAsync(f.Id)" disabled="@_busy">&times;</button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @* ===== Recursos del agente - acordeon ===== *@
                    <hr style="border-color:var(--border);margin:14px 0;" />
                    <div class="ag-accordion">
                        <div class="ag-accordion-head" role="button" tabindex="0" @onclick="() => _resourcesOpen = !_resourcesOpen">
                            <span class="ag-accordion-chev @(_resourcesOpen ? "open" : "")">&#9656;</span>
                            <span class="pl-stagegroup-title" style="margin:0;">Recursos del agente</span>
                            <span class="ag-accordion-count">@_resources.Count</span>
                            <span class="ag-accordion-spacer"></span>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick:stopPropagation="true" @onclick="() => OpenResource(null)" disabled="@_busy">+ Agregar recurso</button>
                        </div>
                        @if (_resourcesOpen)
                        {
                            <div class="ag-accordion-body">
                                <div class="text-muted" style="font-size:12px;margin-bottom:10px;">Archivos y datos que el agente puede usar para responder a los clientes.</div>
                                @if (_resources.Count == 0)
                                {
                                    <div class="text-muted small">Sin recursos. Agrega imagenes, videos, audios, PDF, ubicaciones o textos.</div>
                                }
                                else
                                {
                                    <div class="ag-list ag-list-scroll">
                                        @foreach (var r in _resources)
                                        {
                                            <div class="ag-item">
                                                <span class="ag-rtype">@ResourceLabel(r.ResourceType)</span>
                                                <div class="ag-item-main">
                                                    <div class="ag-item-name">@r.Name</div>
                                                    <div class="ag-item-sub">@(string.IsNullOrWhiteSpace(r.Detail) ? (r.FileName ?? "Sin detalle") : Trim(r.Detail!, 70))</div>
                                                </div>
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenResource(r)" disabled="@_busy">Editar</button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteResourceAsync(r.Id)" disabled="@_busy">&times;</button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @* ===== Lineas de WhatsApp que atiende el agente - acordeon ===== *@
                    <hr style="border-color:var(--border);margin:14px 0;" />
                    <div class="ag-accordion">
                        <div class="ag-accordion-head" role="button" tabindex="0" @onclick="() => _linesOpen = !_linesOpen">
                            <span class="ag-accordion-chev @(_linesOpen ? "open" : "")">&#9656;</span>
                            <span class="pl-stagegroup-title" style="margin:0;">Lineas de WhatsApp</span>
                            <span class="ag-accordion-count">@_agentLines.Count(l => l.Connected)</span>
                        </div>
                        @if (_linesOpen)
                        {
                            <div class="ag-accordion-body">
                                <div class="text-muted" style="font-size:12px;margin-bottom:10px;">Conecta el agente a una linea para que atienda automaticamente los mensajes que lleguen ahi. Cada cliente se atiende por separado (linea + numero). Con "Auto-confirmar" el agente reserva y cancela por si mismo; apagado, solo deja la solicitud para que un asesor la confirme.</div>
                                @if (_agentLines.Count == 0)
                                {
                                    <div class="text-muted small">No hay lineas de WhatsApp. Crea una en "Lineas WhatsApp".</div>
                                }
                                else
                                {
                                    <div class="ag-list">
                                        @foreach (var l in _agentLines)
                                        {
                                            <div class="ag-item">
                                                <div class="ag-item-main">
                                                    <div class="ag-item-name">@(string.IsNullOrWhiteSpace(l.PhoneNumber) ? l.InstanceName : l.PhoneNumber) <span class="badge @LineBadge(l.LineStatus)">@l.LineStatus</span></div>
                                                    <div class="ag-item-sub">
                                                        @if (l.OtherAgentName is not null)
                                                        {
                                                            <span class="text-warning">La atiende el agente "@l.OtherAgentName". Conectar aqui la reasignara a este agente.</span>
                                                        }
                                                        else if (l.Connected)
                                                        {
                                                            <span>Atendida por este agente &middot; @(l.AutoConfirm ? "Autonomo (reserva/cancela)" : "Modo sugerencia (deja al asesor)")</span>
                                                        }
                                                        else
                                                        {
                                                            <span>Sin atender por este agente.</span>
                                                        }
                                                    </div>
                                                </div>
                                                @if (l.Connected)
                                                {
                                                    <label class="ag-switch" title="Auto-confirmar (autonomo)" style="margin-right:6px;">
                                                        <input type="checkbox" checked="@l.AutoConfirm" @onchange="@(e => ToggleAutoConfirmAsync(l.LineId, (bool)e.Value!))" disabled="@_busy" />
                                                        <span class="ag-slider"></span>
                                                    </label>
                                                    <span class="small text-muted" style="margin-right:8px;">Auto</span>
                                                }
                                                <button class="btn btn-sm @(l.Connected ? "btn-outline-danger" : "btn-outline-secondary")" @onclick="() => ToggleConnectedAsync(l.LineId, !l.Connected)" disabled="@_busy">
                                                    @(l.Connected ? "Desconectar" : "Conectar")
                                                </button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @* ===== Herramientas (MCP) que el agente puede usar - acordeon ===== *@
                    <hr style="border-color:var(--border);margin:14px 0;" />
                    <div class="ag-accordion">
                        <div class="ag-accordion-head" role="button" tabindex="0" @onclick="() => _toolsOpen = !_toolsOpen">
                            <span class="ag-accordion-chev @(_toolsOpen ? "open" : "")">&#9656;</span>
                            <span class="pl-stagegroup-title" style="margin:0;">Herramientas (MCP)</span>
                            <span class="ag-accordion-count">@EnabledToolCount()/@TotalToolCount()</span>
                        </div>
                        @if (_toolsOpen)
                        {
                            <div class="ag-accordion-body">
                                <div class="text-muted" style="font-size:12px;margin-bottom:10px;">Activa o desactiva las herramientas que este agente puede invocar al conversar. Los cambios se guardan con "Guardar cambios".</div>
                                @foreach (var ts in Toolsets)
                                {
                                    <div style="font-weight:700;font-size:11.5px;text-transform:uppercase;letter-spacing:.04em;margin:10px 0 2px;color:var(--muted-foreground);">@ts.GroupLabel</div>
                                    @foreach (var spec in ts.GetSpecs())
                                    {
                                        var enabled = !_disabledTools.Contains(spec.Name);
                                        <div style="display:flex;align-items:flex-start;gap:10px;padding:7px 2px;border-bottom:1px solid var(--border);">
                                            <label class="ag-switch" style="margin-top:2px;flex:none;">
                                                <input type="checkbox" checked="@enabled" @onchange="@(e => ToggleTool(spec.Name, (bool)e.Value!))" disabled="@_busy" />
                                                <span class="ag-slider"></span>
                                            </label>
                                            <div style="min-width:0;">
                                                <div style="font-weight:600;font-size:13px;">@Humanize(spec.Name)</div>
                                                <div class="text-muted" style="font-size:11.5px;">@Trim(spec.Description ?? "", 130)</div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>

                }
               </div>@* /ag-editor-left *@

               @if (_editId is not null)
               {
                <div class="ag-editor-right">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
                        <div class="pl-stagegroup-title">Probar agente</div>
                        @if (_testMsgs.Count > 0)
                        {
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => { _testMsgs.Clear(); _testError = null; }" disabled="@_testBusy">Limpiar</button>
                        }
                    </div>
                    <div class="text-muted" style="font-size:11.5px;margin-bottom:10px;">Conversa como si fueras el cliente. Usa el prompt y los recursos de la izquierda (aunque no los hayas guardado).</div>

                    @if (_phoneLines.Count > 0)
                    {
                        <div class="ag-phone">
                            <label class="ag-phone-toggle">
                                <input type="checkbox" checked="@_phoneSend" @onchange="e => _phoneSend = (bool)e.Value!" />
                                <span>Enviar respuestas a un telefono</span>
                            </label>
                            @if (_phoneSend)
                            {
                                <div class="ag-phone-row">
                                    @if (_phoneLines.Count > 1)
                                    {
                                        <select class="form-control form-control-sm" @bind="_phoneLineId">
                                            @foreach (var ln in _phoneLines)
                                            {
                                                <option value="@ln.Id">@(string.IsNullOrWhiteSpace(ln.PhoneNumber) ? ln.InstanceName : ln.PhoneNumber)</option>
                                            }
                                        </select>
                                    }
                                    <input class="form-control form-control-sm" @bind="_phoneNumber" placeholder="Numero con codigo pais (ej. 573001234567)" autocomplete="off" />
                                </div>
                                @if (_phoneInfo is not null)
                                {
                                    <div class="text-muted" style="font-size:11px;margin-top:4px;">@_phoneInfo</div>
                                }
                            }
                        </div>
                    }

                    <div class="ag-test">
                        <div class="ag-test-body">
                            @if (_testMsgs.Count == 0)
                            {
                                <div class="ag-test-empty">Escribe un mensaje para probar la respuesta del agente.</div>
                            }
                            else
                            {
                                @foreach (var t in _testMsgs)
                                {
                                    <div class="ag-bubble @(t.Role == "model" ? "bot" : "me")">
                                        @if (!string.IsNullOrWhiteSpace(t.Text)) { <div>@t.Text</div> }
                                        @if (t.Attachments is { Count: > 0 })
                                        {
                                            @foreach (var a in t.Attachments)
                                            {
                                                <div class="ag-attach">
                                                    @switch (a.ResourceType)
                                                    {
                                                        case AgentResourceType.Text:
                                                            <div class="ag-attach-text">@a.Detail</div>
                                                            break;
                                                        case AgentResourceType.Image:
                                                            <img src="@a.FileUrl" alt="@a.Name" />
                                                            @if (!string.IsNullOrWhiteSpace(a.Detail)) { <div class="ag-attach-cap">@a.Detail</div> }
                                                            break;
                                                        case AgentResourceType.Video:
                                                            <video src="@a.FileUrl" controls></video>
                                                            @if (!string.IsNullOrWhiteSpace(a.Detail)) { <div class="ag-attach-cap">@a.Detail</div> }
                                                            break;
                                                        case AgentResourceType.Audio:
                                                            <audio src="@a.FileUrl" controls></audio>
                                                            break;
                                                        case AgentResourceType.Location:
                                                            <a href="@MapsLink(a.Detail)" target="_blank">📍 @a.Name</a>
                                                            break;
                                                        default:
                                                            <a href="@a.FileUrl" target="_blank" download>📎 @(a.FileName ?? a.Name)</a>
                                                            @if (!string.IsNullOrWhiteSpace(a.Detail)) { <div class="ag-attach-cap">@a.Detail</div> }
                                                            break;
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            }
                            @if (_testBusy)
                            {
                                <div class="ag-bubble bot ag-typing">Escribiendo...</div>
                            }
                        </div>
                        @if (_testError is not null)
                        {
                            <div class="text-danger small" style="padding:0 4px 6px;">@_testError</div>
                        }
                        @if (_testImageBase64 is not null)
                        {
                            <div style="display:flex;align-items:center;gap:8px;padding:4px;margin-bottom:4px;font-size:11.5px;color:var(--muted-foreground);">
                                <span>Imagen adjunta: @_testImageName</span>
                                <button type="button" class="btn btn-sm btn-outline-secondary" style="padding:0 7px;" @onclick="() => { _testImageBase64 = null; _testImageName = null; }">Quitar</button>
                            </div>
                        }
                        <div class="ag-test-input">
                            <label class="btn btn-sm btn-outline-secondary" title="Adjuntar foto (caja de arena)" style="cursor:pointer;padding:6px 9px;">
                                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21"/></svg>
                                <InputFile OnChange="OnTestImageAsync" accept="image/*" style="display:none;" />
                            </label>
                            <input class="form-control" placeholder="Mensaje del cliente..." @bind="_testInput" @bind:event="oninput" @onkeydown="TestKeyDown" disabled="@_testBusy" />
                            <button class="btn btn-primary btn-sm" @onclick="SendTestAsync" disabled="@(_testBusy || (string.IsNullOrWhiteSpace(_testInput) && _testImageBase64 is null))">Enviar</button>
                        </div>
                    </div>

                    @* Acordeon de depuracion: log cronologico de los prompts enviados a la IA (mas reciente arriba). *@
                    <div class="ag-accordion" style="margin-top:10px;">
                        <div class="ag-accordion-head" role="button" tabindex="0" @onclick="() => _debugPromptOpen = !_debugPromptOpen">
                            <span class="ag-accordion-chev @(_debugPromptOpen ? "open" : "")">&#9656;</span>
                            <span class="pl-stagegroup-title" style="margin:0;">Prompts enviados a la IA</span>
                            @if (_debugLog.Count > 0)
                            {
                                <span class="ag-accordion-count" title="Llamadas registradas">@_debugLog.Count</span>
                            }
                            <span class="ag-accordion-spacer"></span>
                            @if (_debugLog.Count > 0)
                            {
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick:stopPropagation="true" @onclick="ClearDebugLog">Limpiar</button>
                            }
                        </div>
                        @if (_debugPromptOpen)
                        {
                            <div class="ag-accordion-body">
                                @if (_debugLog.Count == 0)
                                {
                                    <div class="text-muted small">Envia un mensaje al agente para ver aqui los prompts (principal del agente + extractor de cache) que se enviaron a la IA, con su fecha y hora.</div>
                                }
                                else
                                {
                                    <div style="display:flex;flex-direction:column;gap:10px;max-height:520px;overflow-y:auto;padding-right:4px;">
                                        @for (int i = _debugLog.Count - 1; i >= 0; i--)
                                        {
                                            var entry = _debugLog[i];
                                            <div class="ag-prompt-entry">
                                                <div class="ag-prompt-entry-head">
                                                    <span class="ag-prompt-entry-time">fecha hora: @entry.SentAt.ToLocalTime().ToString("dd-MM-yyyy HH:mm:ss")</span>
                                                    <span class="ag-prompt-entry-title">@entry.Title</span>
                                                </div>
                                                <div class="ag-prompt-entry-label">Prompt enviado</div>
                                                <textarea class="form-control" rows="10" readonly style="font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:11px;line-height:1.45;white-space:pre;">@entry.Content</textarea>
                                                @if (entry.Response is not null)
                                                {
                                                    <div class="ag-prompt-entry-label" style="margin-top:8px;">Respuesta del LLM</div>
                                                    <textarea class="form-control" rows="4" readonly style="font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:11px;line-height:1.45;white-space:pre;">@entry.Response</textarea>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>@* /ag-editor-right *@
               }
              </div>@* /ag-editor-cols *@
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="CloseEditor">Cerrar</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: prompt enrutado ===== *@
@if (_promptModalOpen)
{
    <div class="modal-overlay" style="z-index:1200;">
        <div class="modal-dialog" style="max-width:1040px;">
            <div class="modal-head">
                <h3>@(_promptEditId is null ? "Nuevo prompt" : "Editar prompt")</h3>
                <button class="modal-close" @onclick="() => _promptModalOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div style="display:flex;gap:16px;align-items:stretch;">
                    @* Panel lateral: versiones guardadas de ESTE prompt (solo al editar uno existente). *@
                    @if (_promptEditId is not null)
                    {
                        <div style="flex:0 0 215px;border-right:1px solid var(--border);padding-right:14px;max-height:430px;overflow:auto;">
                            <div class="pl-stagegroup-title" style="margin:0 0 8px;">Versiones</div>
                            @if (_promptVersionsLoading)
                            {
                                <div class="text-muted small">Cargando...</div>
                            }
                            else if (_promptVersions.Count == 0)
                            {
                                <div class="text-muted" style="font-size:11.5px;line-height:1.5;">Sin versiones guardadas de este prompt todavia. Se crean cada vez que pulsas <strong>"Guardar cambios"</strong> del agente.</div>
                            }
                            else
                            {
                                <div style="display:flex;flex-direction:column;gap:5px;">
                                    @foreach (var ev in _promptVersions)
                                    {
                                        <button type="button" @onclick="() => LoadPromptVersion(ev)"
                                                style="display:flex;align-items:center;gap:8px;width:100%;text-align:left;border:1px solid @(_promptVersionActive == ev.Index ? "var(--primary,#6c4cf1)" : "var(--border)");background:@(_promptVersionActive == ev.Index ? "rgba(108,76,241,.08)" : "transparent");border-radius:7px;padding:7px 9px;cursor:pointer;font-size:12px;">
                                            <span style="width:7px;height:7px;border-radius:50%;background:@(ev.Index == 0 ? "var(--primary,#6c4cf1)" : "var(--border)");flex:0 0 auto;"></span>
                                            <span style="white-space:nowrap;">@ev.SavedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                            @if (ev.Index == 0)
                                            {
                                                <span style="margin-left:auto;font-size:10px;color:var(--primary,#6c4cf1);">actual</span>
                                            }
                                        </button>
                                    }
                                </div>
                                <div class="text-muted" style="font-size:11px;margin-top:10px;line-height:1.5;">Haz click en una fecha para cargar ese texto en el editor. Se aplica al pulsar <strong>Guardar</strong>.</div>
                            }
                        </div>
                    }
                    <div style="flex:1;min-width:0;">
                        <div class="field">
                            <label class="form-label">Nombre *</label>
                            <input class="form-control" @bind="_pName" placeholder="Ej. Cotizacion Panama" autocomplete="off" />
                        </div>
                        <div class="field">
                            <label class="form-label">Regla (cuando usarlo)</label>
                            <input class="form-control" @bind="_pRule" placeholder="Ej. cuando el cliente pregunte por el destino Panama" autocomplete="off" />
                        </div>
                        <div class="field">
                            <label class="form-label">Prompt *</label>
                            @RichToolbar("promptBody", () => _promptEmojiOpen, v => _promptEmojiOpen = v)
                            <textarea id="promptBody" class="form-control" rows="9" @bind="_pBody" @bind:event="oninput" placeholder="Instrucciones que el agente debe seguir cuando aplica esta regla..."></textarea>
                        </div>
                        @if (_promptError is not null)
                        {
                            <div class="text-danger small">@_promptError</div>
                        }
                    </div>
                </div>
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _promptModalOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="SavePromptAsync" disabled="@_busy">@(_promptEditId is null ? "Agregar" : "Guardar")</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: dato cache ===== *@
@if (_cacheModalOpen)
{
    <div class="modal-overlay" style="z-index:1200;">
        <div class="modal-dialog" style="max-width:560px;">
            <div class="modal-head">
                <h3>@(_cacheEditId is null ? "Nuevo dato cache" : "Editar dato cache")</h3>
                <button class="modal-close" @onclick="() => _cacheModalOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Nombre del dato *</label>
                    <input class="form-control" @bind="_cName" placeholder="Ej. Pais, Nombre, Destino" autocomplete="off" />
                </div>
                <div class="field">
                    <label class="form-label">De que trata el dato</label>
                    <textarea class="form-control" rows="3" @bind="_cDescription" placeholder="Pista para el motor: que dato debe extraer del mensaje del cliente"></textarea>
                </div>
                <div class="field">
                    <label class="form-label" style="display:flex;align-items:center;gap:10px;">
                        <label class="ag-switch" style="margin:0;">
                            <input type="checkbox" checked="@_cIsUpdatable" @onchange="e => _cIsUpdatable = (bool)e.Value!" />
                            <span class="ag-slider"></span>
                        </label>
                        Actualizable durante la conversacion
                    </label>
                    <div class="text-muted" style="font-size:11.5px;margin-top:4px;">
                        @if (_cIsUpdatable)
                        {
                            <span>El agente puede sobrescribir el valor si el cliente cambia de opinion (ej. cambio de destino, de fecha).</span>
                        }
                        else
                        {
                            <span>Una vez capturado, el valor queda fijo y el motor no lo sobrescribe (ideal para tipo_cliente, idContacto, etc).</span>
                        }
                    </div>
                </div>
                @if (_cacheError is not null)
                {
                    <div class="text-danger small">@_cacheError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _cacheModalOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveCacheFieldAsync" disabled="@_busy">@(_cacheEditId is null ? "Agregar" : "Guardar")</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: datos percibidos (sesion de prueba) ===== *@
@if (_perceivedModalOpen)
{
    <div class="modal-overlay" style="z-index:1200;">
        <div class="modal-dialog" style="max-width:720px;">
            <div class="modal-head">
                <h3>Datos percibidos (sesion de prueba)</h3>
                <button class="modal-close" @onclick="() => _perceivedModalOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="text-muted" style="font-size:12px;margin-bottom:10px;">Lo que el motor de inferencia ha logrado extraer hasta ahora. Para esta sesion de prueba la clave es el id del agente; en un chat real sera el id de la conversacion.</div>
                @if (_cacheValues.Count == 0)
                {
                    <div class="text-muted small">Aun no hay campos definidos. Agrega primero un dato cache.</div>
                }
                else
                {
                    <div class="ag-list ag-list-scroll">
                        @foreach (var v in _cacheValues)
                        {
                            <div class="ag-item">
                                <div class="ag-item-main">
                                    <div class="ag-item-name">@v.Label</div>
                                    <div class="ag-item-sub">
                                        @if (string.IsNullOrWhiteSpace(v.Value))
                                        {
                                            <em class="text-muted">Sin capturar todavia</em>
                                        }
                                        else
                                        {
                                            @v.Value
                                        }
                                        @if (!string.IsNullOrWhiteSpace(v.Source) || v.UpdatedAt is not null)
                                        {
                                            <span class="text-muted" style="font-size:11px;margin-left:6px;">
                                                @(string.IsNullOrWhiteSpace(v.Source) ? "" : $"({v.Source}) ")@(v.UpdatedAt?.ToLocalTime().ToString("dd MMM HH:mm") ?? "")
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-danger" @onclick="ClearCacheValuesAsync" disabled="@(_busy || _cacheValues.All(v => string.IsNullOrWhiteSpace(v.Value)))">Vaciar datos percibidos</button>
                <button class="btn btn-outline-secondary" @onclick="() => _perceivedModalOpen = false">Cerrar</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: recurso ===== *@
@if (_resModalOpen)
{
    <div class="modal-overlay" style="z-index:1200;">
        <div class="modal-dialog" style="max-width:1040px;">
            <div class="modal-head">
                <h3>@(_resEditId is null ? "Nuevo recurso" : "Editar recurso")</h3>
                <button class="modal-close" @onclick="() => _resModalOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Nombre *</label>
                        <input class="form-control" @bind="_rName" placeholder="Ej. Brochure Cartagena" autocomplete="off" />
                    </div>
                    <div class="field">
                        <label class="form-label">Tipo</label>
                        <select class="form-control" @bind="_rType">
                            <option value="@AgentResourceType.Text">Texto</option>
                            <option value="@AgentResourceType.Image">Imagen</option>
                            <option value="@AgentResourceType.Video">Video</option>
                            <option value="@AgentResourceType.Audio">Audio</option>
                            <option value="@AgentResourceType.Pdf">PDF</option>
                            <option value="@AgentResourceType.Location">Ubicacion</option>
                        </select>
                    </div>
                </div>
                <div class="field">
                    <label class="form-label">Detalle</label>
                    @RichToolbar("resourceDetail", () => _resEmojiOpen, v => _resEmojiOpen = v)
                    <textarea id="resourceDetail" class="form-control" rows="6" @bind="_rDetail" @bind:event="oninput" placeholder="@DetailHint(_rType)"></textarea>
                </div>
                @if (_rType is not (AgentResourceType.Text or AgentResourceType.Location))
                {
                    <div class="field">
                        <label class="form-label">Archivo</label>
                        @if (!string.IsNullOrWhiteSpace(_rFileUrl))
                        {
                            <div class="ag-file" style="margin-bottom:6px;">
                                <a href="@_rFileUrl" target="_blank">@(_rFileName ?? "ver archivo")</a>
                            </div>
                        }
                        <InputFile OnChange="OnResourceModalFileAsync" accept="@AcceptFor(_rType)" />
                        @if (_rType == AgentResourceType.Image)
                        {
                            <div class="text-muted small" style="margin-top:4px;">WhatsApp solo admite JPEG o PNG como imagen (no SVG).</div>
                        }
                    </div>
                }
                @if (_resError is not null)
                {
                    <div class="text-danger small">@_resError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _resModalOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveResourceAsync" disabled="@_busy">@(_resEditId is null ? "Agregar" : "Guardar")</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: eliminar agente (doble confirmacion) ===== *@
@if (_deleteAgent is not null)
{
    <div class="modal-overlay" style="z-index:1300;">
        <div class="modal-dialog" style="max-width:560px;">
            <div class="modal-head">
                <h3>@(_deleteStep == 1 ? "Eliminar agente" : "Confirmacion final")</h3>
                <button class="modal-close" @onclick="CloseDeleteAgent">&times;</button>
            </div>
            <div class="modal-body">
                @if (_deleteStep == 1)
                {
                    <div style="font-size:14px;margin-bottom:12px;">
                        Vas a eliminar el agente <strong>@_deleteAgent.Name</strong>. Esta accion no se puede deshacer.
                    </div>
                    <div class="text-muted" style="font-size:12.5px;">
                        Si continuas, en el siguiente paso te mostraremos exactamente que se borrara y te pediremos una confirmacion final.
                    </div>
                }
                else
                {
                    <div style="font-size:13.5px;margin-bottom:10px;">
                        Esto eliminara <strong>permanentemente</strong>:
                    </div>
                    <ul style="font-size:13px;line-height:1.7;margin-bottom:14px;">
                        <li>El agente <strong>@_deleteAgent.Name</strong> y su prompt base.</li>
                        <li><strong>@_delResourcesCount</strong> recurso@(_delResourcesCount == 1 ? "" : "s") (saludos, fichas, PDFs, etc).</li>
                        <li><strong>@_delPromptsCount</strong> prompt@(_delPromptsCount == 1 ? "" : "s") enrutado@(_delPromptsCount == 1 ? "" : "s").</li>
                        <li><strong>@_delCacheFieldsCount</strong> campo@(_delCacheFieldsCount == 1 ? "" : "s") de cache y sus valores capturados.</li>
                    </ul>
                    <div class="field">
                        <label class="form-label" style="font-size:12.5px;">Para confirmar, escribe el nombre exacto del agente:</label>
                        <input class="form-control" placeholder="@_deleteAgent.Name" @bind="_delConfirmName" @bind:event="oninput" autocomplete="off" />
                    </div>
                    @if (_delError is not null)
                    {
                        <div class="text-danger small" style="margin-top:6px;">@_delError</div>
                    }
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="CloseDeleteAgent" disabled="@_busy">Cancelar</button>
                @if (_deleteStep == 1)
                {
                    <button class="btn btn-outline-danger" @onclick="GoToDeleteStep2">Continuar</button>
                }
                else
                {
                    <button class="btn btn-danger" @onclick="ConfirmDeleteAgentAsync" disabled="@(_busy || !string.Equals(_delConfirmName, _deleteAgent.Name, StringComparison.Ordinal))">Eliminar definitivamente</button>
                }
            </div>
        </div>
    </div>
}

@* ===== Modal: confirmar restauracion de version ===== *@
@if (_versionPendingRestore is not null)
{
    <div class="modal-overlay" style="z-index:1300;">
        <div class="modal-dialog" style="max-width:520px;">
            <div class="modal-head">
                <h3>Restaurar version @(_versionPendingRestore.Index + 1)</h3>
                <button class="modal-close" @onclick="() => _versionPendingRestore = null">&times;</button>
            </div>
            <div class="modal-body">
                <div style="font-size:14px;margin-bottom:12px;">
                    Vas a restaurar la instantanea del <strong>@_versionPendingRestore.SavedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>.
                </div>
                <div class="text-muted" style="font-size:12.5px;line-height:1.6;">
                    Se reemplazaran el prompt base y los prompts enrutados actuales por los de esa version.
                    El estado actual se guarda como una nueva version antes de restaurar, asi que puedes deshacerlo.
                </div>
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _versionPendingRestore = null" disabled="@_busy">Cancelar</button>
                <button class="btn btn-primary" @onclick="ConfirmRestoreVersionAsync" disabled="@_busy">Restaurar esta version</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private List<AiAgentDto> _agents = new();
    private List<AiProviderOptionDto> _providerOptions = new();
    private AiUsageSummaryDto? _usage;
    private AiQuotaDto? _quota;

    private bool _editorOpen;
    private Guid? _editId;
    private string? _editorError;
    private string _fName = "";
    private string? _fRole;
    private AiProvider _fProvider = AiProvider.Claude;
    private string? _fModel;
    private string _fPrompt = "";

    // Herramientas (MCP) deshabilitadas para el agente en edicion. Vacio = todas habilitadas.
    private bool _toolsOpen;
    private readonly HashSet<string> _disabledTools = new(StringComparer.OrdinalIgnoreCase);
    private bool _fActive;
    private List<AiAgentResourceDto> _resources = new();
    private List<AiAgentPromptDto> _prompts = new();

