    private void OpenCacheField(AiAgentCacheFieldDto? f)
    {
        _cacheError = null;
        _cacheEditId = f?.Id;
        _cName = f?.Label ?? "";
        _cDescription = f?.Description;
        _cIsUpdatable = f?.IsUpdatable ?? true;
        _cacheModalOpen = true;
    }

    private async Task SaveCacheFieldAsync()
    {
        _cacheError = null;
        if (_editId is null) { return; }
        if (string.IsNullOrWhiteSpace(_cName)) { _cacheError = "El nombre es obligatorio."; return; }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            if (_cacheEditId is null)
            {
                var created = await CacheSvc.CreateFieldAsync(new CreateAgentCacheFieldRequest(_editId.Value, _cName, _cDescription, _cIsUpdatable), actor);
                if (created is null) { _cacheError = "No se pudo crear el dato."; return; }
            }
            else
            {
                var updated = await CacheSvc.UpdateFieldAsync(_cacheEditId.Value, new UpdateAgentCacheFieldRequest(_cName, _cDescription, _cIsUpdatable), actor);
                if (updated is null) { _cacheError = "No se pudo actualizar el dato."; return; }
            }
            await ReloadCacheAsync(_editId.Value);
            _cacheModalOpen = false;
        }
        finally { _busy = false; }
    }

