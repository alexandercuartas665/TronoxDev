    private Task Bold(string id) => Fmt(id, "*", "*");
    private Task Italic(string id) => Fmt(id, "_", "_");
    private Task Strike(string id) => Fmt(id, "~", "~");
    private Task Mono(string id) => Fmt(id, "```", "```");
    private Task Bullet(string id) => JS.InvokeVoidAsync("ecorexAgentEditor.insert", id, "\n- ").AsTask();
    private async Task Fmt(string id, string before, string after) => await JS.InvokeVoidAsync("ecorexAgentEditor.wrap", id, before, after);
    private async Task Emoji(string id, string e) => await JS.InvokeVoidAsync("ecorexAgentEditor.insert", id, e);

    private async Task TestKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) { await SendTestAsync(); }
    }

    private async Task OnTestImageAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        const long max = 10L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { _testError = "La imagen no es valida o supera 10MB."; return; }
        using var ms = new MemoryStream();
        await file.OpenReadStream(max).CopyToAsync(ms);
        _testImageBase64 = Convert.ToBase64String(ms.ToArray());
        _testImageMime = string.IsNullOrWhiteSpace(file.ContentType) ? "image/jpeg" : file.ContentType;
        _testImageName = file.Name;
    }

    private async Task SendTestAsync()
    {
        if (_editId is null || (string.IsNullOrWhiteSpace(_testInput) && _testImageBase64 is null)) { return; }
        _testError = null;
        var hadImage = _testImageBase64 is not null;
        _testMsgs.Add(new TestMsg("user", string.IsNullOrWhiteSpace(_testInput) ? (hadImage ? "(foto enviada)" : "") : _testInput!.Trim()));
        _testInput = null;
        _testBusy = true;
        // La imagen adjunta se manda en ESTE turno y luego se limpia.
        var img = _testImageBase64; var imgMime = _testImageMime;
        _testImageBase64 = null; _testImageName = null;
        try
        {
            // Pasamos tambien los adjuntos de cada turno; el extractor de cache los usa para construir
            // una transcripcion legible (sino veria texto vacio cuando el agente solo respondio con un recurso).
            var turns = _testMsgs.Select(m => new AiChatTurn(m.Role, m.Text, m.Attachments)).ToList();
            var result = await InferenceSvc.TestChatAsync(_editId.Value, turns, _fPrompt, await ActorAsync(), img, imgMime);
            // Acumulamos las entradas del log de prompts (principal + extractor) en orden cronologico.
            if (result.DebugPrompts is not null) { _debugLog.AddRange(result.DebugPrompts); }
            if (result.Ok && (!string.IsNullOrWhiteSpace(result.Text) || result.Attachments is { Count: > 0 }))
            {
                _testMsgs.Add(new TestMsg("model", result.Text ?? "", result.Attachments));
                _usage = await UsageSvc.GetSummaryAsync();
                _quota = await UsageSvc.GetQuotaAsync();
                if (_phoneSend) { await SendToPhoneAsync(result.Text, result.Attachments); }
            }
            else
            {
                _testError = result.Error ?? "El agente no devolvio respuesta.";
            }
        }
        finally { _testBusy = false; }
    }

    private void ClearDebugLog() => _debugLog.Clear();

    // Reenvia la respuesta del agente (texto + adjuntos) a un telefono real por una linea conectada.
    private async Task SendToPhoneAsync(string? text, IReadOnlyList<AiChatAttachment>? attachments)
    {
        _phoneInfo = null;
        if (_phoneLineId == Guid.Empty || string.IsNullOrWhiteSpace(_phoneNumber)) { _phoneInfo = "Elige una linea y un numero."; return; }
        var phone = new string(_phoneNumber.Where(char.IsDigit).ToArray());
        var actor = await ActorAsync();
        try
        {
            if (!string.IsNullOrWhiteSpace(text))
            {
                await Connector.SendTestAsync(_phoneLineId, phone, text!, actor);
            }
            if (attachments is { Count: > 0 })
            {
                foreach (var a in attachments)
                {
                    if (a.ResourceType == AgentResourceType.Text)
                    {
                        if (!string.IsNullOrWhiteSpace(a.Detail)) { await Connector.SendTestAsync(_phoneLineId, phone, a.Detail!, actor); }
                    }
                    else if (a.ResourceType == AgentResourceType.Location)
                    {
                        var parts = (a.Detail ?? "").Split(',');
                        if (parts.Length == 2 && double.TryParse(parts[0], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lat)
                            && double.TryParse(parts[1], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lng))
                        {
                            await Connector.SendLocationAsync(_phoneLineId, phone, lat, lng, a.Name, actor);
                        }
                    }
                    else
                    {
                        var b64 = await ReadLocalBase64Async(a.FileUrl);
                        if (b64 is not null)
                        {
                            var mt = a.ResourceType switch
                            {
                                AgentResourceType.Image => MessageMediaType.Image,
                                AgentResourceType.Video => MessageMediaType.Video,
                                AgentResourceType.Audio => MessageMediaType.Audio,
                                _ => MessageMediaType.Document
                            };
                            await Connector.SendMediaAsync(_phoneLineId, phone, mt, b64, null, a.FileName, a.Detail, actor);
                        }
                    }
                }
            }
            _phoneInfo = $"Enviado a {phone}.";
        }
        catch (Exception ex) { _phoneInfo = "No se pudo enviar al telefono: " + ex.Message; }
    }

    private async Task<string?> ReadLocalBase64Async(string? localUrl)
    {
        if (string.IsNullOrWhiteSpace(localUrl)) { return null; }
        var rel = localUrl.TrimStart('/').Replace('/', System.IO.Path.DirectorySeparatorChar);
        var path = System.IO.Path.Combine(Env.WebRootPath, rel);
        if (!System.IO.File.Exists(path)) { return null; }
        return Convert.ToBase64String(await System.IO.File.ReadAllBytesAsync(path));
    }

    private void CloseEditor() => _editorOpen = false;

    // ===== Herramientas (MCP) =====
    private void ToggleTool(string name, bool enabled)
    {
        if (enabled) { _disabledTools.Remove(name); }
        else { _disabledTools.Add(name); }
    }
    private int TotalToolCount() => Toolsets.Sum(t => t.GetSpecs().Count);
    private int EnabledToolCount() => Toolsets.Sum(t => t.GetSpecs().Count(s => !_disabledTools.Contains(s.Name)));
    private static string Humanize(string toolName) =>
        string.IsNullOrEmpty(toolName) ? toolName : char.ToUpperInvariant(toolName[0]) + toolName[1..].Replace('_', ' ');

    private async Task SaveAgentAsync()
    {
        _editorError = null;
        if (string.IsNullOrWhiteSpace(_fName)) { _editorError = "El nombre es obligatorio."; return; }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var model = EffectiveModel(_fProvider);
            if (_editId is null)
            {
                var created = await AgentsSvc.CreateAsync(new CreateAiAgentRequest(_fName, _fRole, _fProvider, model, _fPrompt, _disabledTools.ToList()), actor);
                if (created is null) { _editorError = "No se pudo crear el agente."; return; }
                _editId = created.Id;
                await ReloadCacheAsync(_editId.Value);
            }
            else
            {
                await AgentsSvc.UpdateAsync(_editId.Value, new UpdateAiAgentRequest(_fName, _fRole, _fProvider, model, _fPrompt, _disabledTools.ToList()), actor);
                await ReloadVersionsAsync(_editId.Value);
            }
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

