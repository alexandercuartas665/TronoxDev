@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@inject Ecorex.Application.Admin.IPlatformBrandingService BrandingSvc
@inject Ecorex.Application.Admin.IGoogleAuthConfigService GoogleCfg

<PageTitle>Ingresar - @_brand.PlatformName</PageTitle>

<AuthShell PlatformName="@_brand.PlatformName"
           LogoUrl="@_brand.LoginLogoUrl"
           Headline="@(_brand.LoginHeadline ?? "Organiza tu operacion")"
           Subtext="@(_brand.LoginSubtext ?? "Tareas, proyectos, flujos y formularios configurables sin codigo, en un solo lugar.")"
           ShowBoardMock="true"
           ShellClass="@(StartSignup ? "is-signup" : null)">

    <!-- INICIAR SESION -->
    <section class="auth-pane auth-pane-login">
        <div class="auth-head">
            <h1>Iniciar sesion</h1>
            <p>Bienvenido de nuevo. Ingresa a tu panel.</p>
        </div>

        @if (Error == 1)
        {
            <div class="auth-alert auth-alert-error">Credenciales invalidas o cuenta sin acceso.</div>
        }
        @if (Reset == 1)
        {
            <div class="auth-alert auth-alert-ok">Tu contrasena se actualizo. Ya puedes iniciar sesion.</div>
        }
        @if (!string.IsNullOrWhiteSpace(GError))
        {
            <div class="auth-alert auth-alert-error">@GError</div>
        }

        @if (_googleEnabled)
        {
            <div class="auth-providers">
                <a class="auth-provider" href="/connect/google">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="16" height="16">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
                    </svg>
                    <span>Continuar con Google</span>
                </a>
            </div>
            <div class="auth-divider"><span>o con tu correo</span></div>
        }

        <form method="post" action="/auth/login" class="auth-form">
            <div class="auth-field">
                <label for="login-email">Correo electronico</label>
                <input id="login-email" name="email" type="email" required placeholder="tu.correo@ejemplo.com" />
            </div>
            <div class="auth-field">
                <div class="auth-label-row">
                    <label for="login-password">Contrasena</label>
                    <a class="auth-forgot" href="/recuperar">Olvidaste tu contrasena?</a>
                </div>
                <div class="auth-input-icon">
                    <input id="login-password" name="password" type="password" required placeholder="Tu contrasena" />
                    <button type="button" class="auth-eye" onclick="ecorexAuth.toggle('login-password', this)">MOSTRAR</button>
                </div>
            </div>
            <label class="auth-remember" for="login-remember">
                <input id="login-remember" name="remember" type="checkbox" value="true" checked />
                <span>Recordar mi sesion en este equipo</span>
            </label>
            <button class="auth-submit" type="submit">
                <span>Ingresar</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </button>
        </form>

        <p class="auth-switch">
            No tienes una cuenta?
            <button type="button" onclick="ecorexAuth.show('signup')">Crea una aqui</button>
        </p>
    </section>

    <!-- CREAR CUENTA (autogestion) -->
    <section class="auth-pane auth-pane-signup">
        <div class="auth-head">
            <h1>Crear una cuenta</h1>
            <p>Registra tu empresa y organiza tu operacion en minutos.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(RegError))
        {
            <div class="auth-alert auth-alert-error">@RegError</div>
        }

        <form method="post" action="/auth/register" class="auth-form">
            <div class="auth-field">
                <label for="reg-agency">Nombre de tu empresa</label>
                <input id="reg-agency" name="agencyName" type="text" required placeholder="Ej. Sky System" />
            </div>
            <div class="auth-field">
                <label for="reg-name">Tu nombre</label>
                <input id="reg-name" name="displayName" type="text" placeholder="Ej. Alexander Cuartas" />
            </div>
            <div class="auth-field">
                <label for="reg-email">Correo electronico</label>
                <input id="reg-email" name="email" type="email" required placeholder="tu.correo@ejemplo.com" />
            </div>
            <div class="auth-field">
                <label for="reg-password">Contrasena</label>
                <div class="auth-input-icon">
                    <input id="reg-password" name="password" type="password" required minlength="8" placeholder="Minimo 8 caracteres" />
                    <button type="button" class="auth-eye" onclick="ecorexAuth.toggle('reg-password', this)">MOSTRAR</button>
                </div>
            </div>
            <p class="auth-legal">
                Al registrarte aceptas los Terminos del Servicio y la Politica de Privacidad de @_brand.PlatformName.
            </p>
            <button class="auth-submit" type="submit">
                <span>Registrar cuenta</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </button>
        </form>

        @if (_googleEnabled)
        {
            <div class="auth-divider"><span>o registrate con</span></div>
            <div class="auth-providers">
                <button type="button" class="auth-provider" onclick="ecorexAuth.googleSignup()">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="16" height="16">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
                    </svg>
                    <span>Continuar con Google</span>
                </button>
            </div>
            <p class="auth-hint" id="reg-google-hint" hidden>Escribe primero el nombre de tu empresa para continuar con Google.</p>
        }

        <p class="auth-switch">
            Ya tienes una cuenta?
            <button type="button" onclick="ecorexAuth.show('login')">Iniciar sesion</button>
        </p>
    </section>

</AuthShell>

<script>
    window.ecorexAuth = {
        show: function (mode) {
            var shell = document.querySelector('.auth-shell');
            if (!shell) return;
            shell.classList.toggle('is-signup', mode === 'signup');
        },
        toggle: function (id, btn) {
            var input = document.getElementById(id);
            if (!input) return;
            var show = input.type === 'password';
            input.type = show ? 'text' : 'password';
            btn.textContent = show ? 'OCULTAR' : 'MOSTRAR';
        },
        googleSignup: function () {
            var input = document.getElementById('reg-agency');
            var hint = document.getElementById('reg-google-hint');
            var agency = input ? (input.value || '').trim() : '';
            if (!agency) {
                if (hint) hint.hidden = false;
                if (input) { input.classList.add('auth-input-error'); input.focus(); }
                return;
            }
            if (hint) hint.hidden = true;
            window.location = '/connect/google?mode=signup&agency=' + encodeURIComponent(agency);
        }
    };
</script>

@code {
    [SupplyParameterFromQuery] public int? Error { get; set; }
    [SupplyParameterFromQuery] public int? Reset { get; set; }
    [SupplyParameterFromQuery] public string? RegError { get; set; }
    [SupplyParameterFromQuery(Name = "gerror")] public string? GError { get; set; }
    [SupplyParameterFromQuery] public string? Mode { get; set; }

    private Ecorex.Application.Admin.PlatformBrandingDto _brand = Ecorex.Application.Admin.PlatformBrandingDto.Default;
    private bool _googleEnabled;

    private bool StartSignup => string.Equals(Mode, "signup", StringComparison.OrdinalIgnoreCase)
        || !string.IsNullOrWhiteSpace(RegError);

    protected override async Task OnInitializedAsync()
    {
        _brand = await BrandingSvc.GetAsync();
        _googleEnabled = (await GoogleCfg.GetAsync())?.IsEnabled == true;
    }
}
