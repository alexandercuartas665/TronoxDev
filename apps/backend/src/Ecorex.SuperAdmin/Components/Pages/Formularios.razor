@page "/formularios"
@attribute [Authorize(Policy = "Formularios.Disenar")]
@* Policy por modulo (paso 1: mismo requisito que TenantMember, nombre estable). TODO: derivar del Module Registry. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Globalization
@using Ecorex.Application.Forms
@using Ecorex.Domain.Enums
@inject IFormDefinitionService FormsSvc
@inject NavigationManager Nav

@* ============================================================
   INDICE DE FORMULARIOS del prototipo (ECOREX.dc.html, pantalla
   'forms'): rotulo de modulo, KPIs, busqueda, vista tarjetas /
   lista. Fiel al pixel del fuente (ADR-0021). Abrir una tarjeta
   navega al CONSTRUCTOR (/formularios/{id}/disenar).
   ============================================================ *@

<PageTitle>Formularios - ECOREX.tareas</PageTitle>

<div class="fx-page">
    <div class="fx-head">
        <div>
            <div class="fx-eyebrow">MODULO 000131 - AUTOMATIZACION</div>
            <h1 class="fx-title">Formularios</h1>
            <p class="fx-subtitle">Todos los formularios del motor EAV. Abre uno para editarlo en el constructor.</p>
        </div>
        <button class="fx-btn-new" @onclick="CreateAndOpenAsync" disabled="@_busy">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
            Nuevo formulario
        </button>
    </div>

    @if (_error is not null)
    {
        <div class="fx-error">@_error</div>
    }

    <div class="fx-kpis">
        <div class="fx-kpi">
            <div class="fx-kpi-ic" style="background:var(--t-violet-bg);color:var(--t-violet)">
                <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2.5"/><path d="M9 8h6M9 12h6M9 16h3"/></svg>
            </div>
            <div class="fx-kpi-tx"><div class="fx-kpi-v">@_definitions.Count</div><div class="fx-kpi-l">Formularios</div></div>
        </div>
        <div class="fx-kpi">
            <div class="fx-kpi-ic" style="background:var(--t-green-bg);color:var(--t-green)">
                <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="4"/><path d="m8 12 3 3 5-6"/></svg>
            </div>
            <div class="fx-kpi-tx"><div class="fx-kpi-v">@_definitions.Count(d => d.Status == FormStatus.Active && !d.IsArchived)</div><div class="fx-kpi-l">Publicados</div></div>
        </div>
        <div class="fx-kpi">
            <div class="fx-kpi-ic" style="background:var(--t-blue-bg);color:var(--t-blue)">
                <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4v16h16"/><rect x="7.5" y="11" width="3" height="6" rx="1"/><rect x="13.5" y="7" width="3" height="10" rx="1"/></svg>
            </div>
            <div class="fx-kpi-tx"><div class="fx-kpi-v">@N(_definitions.Sum(d => d.ResponseCount))</div><div class="fx-kpi-l">Respuestas</div></div>
        </div>
        <div class="fx-kpi">
            <div class="fx-kpi-ic" style="background:var(--t-amber-bg);color:var(--t-amber)">
                <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/></svg>
            </div>
            <div class="fx-kpi-tx"><div class="fx-kpi-v">@_definitions.Count(d => d.RuleCount > 0)</div><div class="fx-kpi-l">Con reglas</div></div>
        </div>
    </div>

    <div class="fx-toolbar">
        <div class="fx-search">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--ink-3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
            <input value="@_query" @oninput="@(e => _query = e.Value?.ToString() ?? "")" placeholder="Buscar formulario..." />
        </div>
        @* Activos / Archivados: el indice mostraba todo mezclado y lo archivado solo se distinguia
           por el badge, asi que archivar no despejaba nada. Ahora el principal son los activos y lo
           archivado se consulta aparte. El contador solo aparece si hay algo que ver. *@
        <div class="fx-viewtabs fx-statetabs">
            <button class="fx-viewtab @(!_showArchived ? "on" : "")" @onclick="@(() => _showArchived = false)">
                Activos
                <span class="fx-tabn">@ActiveCount</span>
            </button>
            <button class="fx-viewtab @(_showArchived ? "on" : "")" @onclick="@(() => _showArchived = true)"
                    disabled="@(ArchivedCount == 0 && !_showArchived)">
                Archivados
                @if (ArchivedCount > 0)
                {
                    <span class="fx-tabn">@ArchivedCount</span>
                }
            </button>
        </div>
        <div class="fx-viewtabs">
            <button class="fx-viewtab @(!_listView ? "on" : "")" @onclick="@(() => _listView = false)">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/></svg>
                Tarjetas
            </button>
            <button class="fx-viewtab @(_listView ? "on" : "")" @onclick="@(() => _listView = true)">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg>
                Lista
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <p class="fx-loading"><em>Cargando formularios...</em></p>
    }
    else if (!Filtered.Any())
    {
        <div class="fx-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2.5"/><path d="M9 8h6M9 12h6M9 16h3"/></svg>
            <p>
                @if (!string.IsNullOrWhiteSpace(_query))
                {
                    @($"Ningun formulario coincide con \"{_query.Trim()}\".")
                }
                else if (_showArchived)
                {
                    @("No hay formularios archivados.")
                }
                else
                {
                    @("Aun no hay formularios. Crea el primero.")
                }
            </p>
        </div>
    }
    else if (!_listView)
    {
        <div class="fx-cards">
            @foreach (var d in Filtered)
            {
                @* La tarjeta era un <button> y el de archivar va DENTRO: un boton no puede anidar
                   otro boton (HTML invalido, y el navegador desarma el marcado). Por eso la tarjeta
                   es un div con rol de boton, que conserva teclado (Enter/Espacio) y foco. *@
                <div class="fx-card" role="button" tabindex="0"
                     @onclick="@(() => OpenDesigner(d.Id))"
                     @onkeydown="@(e => OnCardKeyAsync(e, d.Id))">
                    <div class="fx-card-top">
                        <span class="fx-card-ic">
                            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2.5"/><path d="M9 8h6M9 12h6M9 16h3"/></svg>
                        </span>
                        <span class="fx-badge" style="background:@ToneSoft(d);color:@Tone(d)">@EstadoLabel(d)</span>
                        @* stopPropagation: sin esto el clic tambien abriria el disenador detras. *@
                        <button class="fx-card-del @(d.IsArchived ? "on" : "")"
                                title="@(d.IsArchived ? "Restaurar formulario" : "Archivar formulario")"
                                aria-label="@(d.IsArchived ? "Restaurar" : "Archivar") @d.Title"
                                disabled="@_busy" @onclick:stopPropagation="true"
                                @onclick="@(() => AskArchiveAsync(d))">
                            @if (d.IsArchived)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/></svg>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/><path d="M10 11v5M14 11v5"/></svg>
                            }
                        </button>
                    </div>
                    <div class="fx-card-name">@d.Title</div>
                    <div class="fx-card-meta">
                        <span class="fx-code">FORX-@d.Code</span>
                        <span class="fx-cat">@Category(d)</span>
                    </div>
                    <div class="fx-card-stats">
                        <div><div class="fx-stat-v">@d.QuestionCount</div><div class="fx-stat-l">campos</div></div>
                        <div><div class="fx-stat-v">@N(d.ResponseCount)</div><div class="fx-stat-l">respuestas</div></div>
                        <div><div class="fx-stat-v amber">@d.RuleCount</div><div class="fx-stat-l">reglas</div></div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="fx-list">
            <div class="fx-list-head">
                <div class="fx-list-th pad-l">FORMULARIO</div>
                <div class="fx-list-th">CATEGORIA</div>
                <div class="fx-list-th">CAMPOS</div>
                <div class="fx-list-th">RESPUESTAS</div>
                <div class="fx-list-th pad-l2">ESTADO</div>
            </div>
            @foreach (var d in Filtered)
            {
                <button class="fx-list-row" @onclick="@(() => OpenDesigner(d.Id))">
                    <div class="fx-list-name">
                        <div class="fx-list-title">@d.Title</div>
                        <div class="fx-code">FORX-@d.Code</div>
                    </div>
                    <div class="fx-list-cell">@Category(d)</div>
                    <div class="fx-list-cell">@d.QuestionCount</div>
                    <div class="fx-list-cell">@N(d.ResponseCount)</div>
                    <div class="fx-list-estado"><span class="fx-badge" style="background:@ToneSoft(d);color:@Tone(d)">@EstadoLabel(d)</span></div>
                </button>
            }
        </div>
    }
</div>

@if (_confirming is not null)
{
    <div class="fx-overlay" @onclick="CloseConfirm">
        <div class="fx-modal" @onclick:stopPropagation="true">
            <div class="fx-m-body">
                <div class="fx-m-title">Archivar formulario</div>
                <p class="fx-m-text">
                    <b>@_confirming.Title</b> se marcara como archivado y dejara de ofrecerse.
                    Su definicion y sus respuestas se conservan, y puedes restaurarlo desde esta
                    misma tarjeta.
                </p>
                @if (_confirming.ResponseCount > 0)
                {
                    @* Se nombra el formulario y su codigo: sin eso, el aviso queda junto a otras
                       tarjetas que muestran 0 respuestas y parece que el numero viene de otro
                       lado (llego a leerse como una fuga entre tenants, que no lo es). *@
                    <div class="fx-m-warn">
                        <b>@_confirming.Code &#183; @_confirming.Title</b> tiene
                        @N(_confirming.ResponseCount) respuesta(s) guardada(s). No se borran.
                    </div>
                }
                @if (_confirmError is not null)
                {
                    <div class="fx-m-err">@_confirmError</div>
                }
            </div>
            <div class="fx-m-foot">
                <button class="fx-mbtn" @onclick="CloseConfirm" disabled="@_busy">Cancelar</button>
                <button class="fx-mbtn fx-mbtn-go" @onclick="ConfirmArchiveAsync" disabled="@_busy">Archivar</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _busy;
    private bool _listView;

    /// <summary>Pestana activa: false = activos (lo normal), true = el archivo.</summary>
    private bool _showArchived;
    private string _query = "";
    private string? _error;
    private List<FormDefinitionListItemDto> _definitions = new();

    /// <summary>Formulario cuyo archivado se esta confirmando (null = sin dialogo abierto).</summary>
    private FormDefinitionListItemDto? _confirming;
    private string? _confirmError;

    private static readonly CultureInfo Es = CultureInfo.GetCultureInfo("es-CO");

    protected override async Task OnInitializedAsync()
    {
        // Igual que el prototipo: los archivados aparecen con badge "Archivado".
        _definitions = (await FormsSvc.ListAsync(includeArchived: true)).ToList();
        _loading = false;
    }

    private int ActiveCount => _definitions.Count(d => !d.IsArchived);
    private int ArchivedCount => _definitions.Count(d => d.IsArchived);

    /// <summary>
    /// La pestana manda: o activos o archivados, nunca mezclados. La busqueda se aplica dentro de
    /// la pestana elegida.
    /// </summary>
    private IEnumerable<FormDefinitionListItemDto> Filtered
    {
        get
        {
            var scope = _definitions.Where(d => d.IsArchived == _showArchived);
            if (string.IsNullOrWhiteSpace(_query)) { return scope; }
            var q = _query.Trim();
            return scope.Where(d =>
                d.Title.Contains(q, StringComparison.OrdinalIgnoreCase)
                || d.Code.Contains(q, StringComparison.OrdinalIgnoreCase));
        }
    }

    /// <summary>Separador de miles del prototipo (toLocaleString('es') -> "1.204").</summary>
    private static string N(int value) => value.ToString("N0", Es);

    /// <summary>La tarjeta es un div con rol de boton: el teclado tiene que abrirla igual.</summary>
    private Task OnCardKeyAsync(KeyboardEventArgs e, Guid id)
    {
        if (e.Key is "Enter" or " ") { OpenDesigner(id); }
        return Task.CompletedTask;
    }

    /// <summary>
    /// Restaurar es inocuo, asi que va directo. Archivar pide confirmacion: retira el formulario
    /// de circulacion y conviene ver antes cuantas respuestas tiene.
    /// </summary>
    private async Task AskArchiveAsync(FormDefinitionListItemDto d)
    {
        if (d.IsArchived) { await SetArchivedAsync(d, false); return; }
        _confirmError = null;
        _confirming = d;
    }

    private void CloseConfirm()
    {
        _confirming = null;
        _confirmError = null;
    }

    private async Task ConfirmArchiveAsync()
    {
        if (_confirming is null) { return; }
        if (await SetArchivedAsync(_confirming, true)) { CloseConfirm(); }
    }

    /// <summary>
    /// Devuelve false si el servicio lo rechazo (p.ej. el formulario esta en uso): el error se
    /// muestra DENTRO del dialogo, que es donde esta mirando el usuario.
    /// </summary>
    private async Task<bool> SetArchivedAsync(FormDefinitionListItemDto d, bool archived)
    {
        _busy = true;
        _error = null;
        try
        {
            var result = await FormsSvc.SetArchivedAsync(d.Id, archived);
            if (!result.IsOk)
            {
                var msg = result.Error ?? "No se pudo archivar el formulario.";
                if (_confirming is not null) { _confirmError = msg; } else { _error = msg; }
                return false;
            }
            _definitions = (await FormsSvc.ListAsync(includeArchived: true)).ToList();
            // Si se restauro el ultimo archivado, esta pestana quedo vacia: no dejar al usuario
            // mirando una lista sin nada y con el tab deshabilitado.
            if (_showArchived && ArchivedCount == 0) { _showArchived = false; }
            return true;
        }
        finally
        {
            _busy = false;
        }
    }

    // Estados del prototipo: Active=Publicado, Draft=Borrador, IsArchived=Archivado.
    // Inactive (retirado) usa el tono gris de Archivado con su propio rotulo.
    internal static string StatusLabel(FormStatus status) => status switch
    {
        FormStatus.Draft => "Borrador",
        FormStatus.Active => "Publicado",
        FormStatus.Inactive => "Inactivo",
        _ => status.ToString()
    };

    private static string EstadoLabel(FormDefinitionListItemDto d)
        => d.IsArchived ? "Archivado" : StatusLabel(d.Status);

    private static string Tone(FormDefinitionListItemDto d) => d.IsArchived
        ? "var(--ink-3)"
        : d.Status switch
        {
            FormStatus.Active => "var(--t-green)",
            FormStatus.Draft => "var(--t-amber)",
            _ => "var(--ink-3)"
        };

    private static string ToneSoft(FormDefinitionListItemDto d) => d.IsArchived
        ? "var(--surface-3)"
        : d.Status switch
        {
            FormStatus.Active => "var(--t-green-bg)",
            FormStatus.Draft => "var(--t-amber-bg)",
            _ => "var(--surface-3)"
        };

    /// <summary>
    /// El modelo no tiene campo Categoria (deuda ADR-0021): el badge muestra la categoria
    /// del modulo del prototipo como valor fijo.
    /// </summary>
    private static string Category(FormDefinitionListItemDto d) => "General";

    private void OpenDesigner(Guid id) => Nav.NavigateTo($"/formularios/{id}/disenar");

    /// <summary>"Nuevo formulario" del prototipo: crea (codigo FRM-### siguiente) y abre el constructor.</summary>
    private async Task CreateAndOpenAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            var next = 1;
            foreach (var d in _definitions)
            {
                var tail = d.Code.Split('-')[^1];
                if (int.TryParse(tail, out var n) && n >= next)
                {
                    next = n + 1;
                }
            }
            var result = await FormsSvc.CreateAsync(new CreateFormDefinitionRequest(
                $"FRM-{next:000}", "Formulario nuevo"));
            if (!result.IsOk || result.Value is null)
            {
                _error = result.Error ?? "No se pudo crear el formulario.";
                return;
            }
            Nav.NavigateTo($"/formularios/{result.Value.Id}/disenar");
        }
        finally
        {
            _busy = false;
        }
    }
}
