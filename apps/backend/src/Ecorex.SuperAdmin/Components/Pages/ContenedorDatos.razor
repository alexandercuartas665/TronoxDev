@page "/contenedor-datos"
@attribute [Authorize(Policy = "Perm:contenedor-datos:View")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Globalization
@using System.Security.Claims
@using Ecorex.Application.DataContainers
@using Ecorex.Application.MenuConfig
@using Ecorex.Application.Roles
@using Ecorex.Domain.Enums
@using Ecorex.SuperAdmin.Auth
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable
@inject IDataModelService ModelSvc
@inject IDataContainerService ContainerSvc
@inject IDataImportConfigService ConfigSvc
@inject IApiImportService ApiSvc
@inject IDataContainerModuleService ModuleSvc
@inject IMenuConfigService MenuSvc
@inject ICurrentPermissions Perms
@inject IJSRuntime JS
@* "Probar conexion" de un cliente remoto: el registro sabe que agentes estan conectados al hub. *@
@inject Ecorex.SuperAdmin.Agents.IAgentRegistry Agents
@* "Actualizar datos": ejecuta la programacion ahora y consulta su resultado. *@
@inject Ecorex.SuperAdmin.Agents.IProcessRunner Runner
@inject Ecorex.SuperAdmin.Agents.IAgentImportService Imports
@inject AuthenticationStateProvider AuthProvider

<PageTitle>Contenedor de datos - ECOREX.tareas</PageTitle>

<nav class="ecorex-breadcrumb" aria-label="Ruta de navegacion">
    <a href="/inicio">Workspace</a>
    <span class="sep">/</span>
    <span>Sistema</span>
    <span class="sep">/</span>
    <span class="cur">Contenedor de datos</span>
</nav>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/></svg>
            </div>
            <span>Sistema &#183; Datos personalizados</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Contenedor de datos</h1>
        <p class="page-sub" style="margin-bottom:0;">Un contenedor agrupa varias tablas relacionadas (modelo ER) y define como se alimentan: Excel, API REST o base de datos.</p>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
        @if (_canCreate)
        {
            <button class="btn btn-primary" @onclick="OpenCreate">+ Nuevo contenedor</button>
        }
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else if (_models.Count == 0)
{
    <div class="coming-soon" style="padding:40px 24px;">
        <h3>Sin contenedores</h3>
        <p>Aun no tienes contenedores. Crea el primero con "+ Nuevo contenedor".</p>
    </div>
}
else
{
    <div class="dc-grid">
        @foreach (var m in _models)
        {
            <div class="dc-card">
                <div class="dc-card-head">
                    <div class="dc-card-name">@m.Name</div>
                    <span class="dc-badge">@m.TableCount tablas</span>
                </div>
                <div class="dc-card-desc">@(string.IsNullOrWhiteSpace(m.Description) ? "(sin descripcion)" : Truncate(m.Description!, 140))</div>
                <div class="dc-card-meta">@m.TableCount tablas &#183; @m.RelationCount relaciones &#183; act. @m.UpdatedAt.LocalDateTime.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)</div>
                <div class="dc-card-actions">
                    <button class="btn btn-sm btn-primary" @onclick="() => OpenModelAsync(m.Id)">Abrir</button>
                    @if (_canDelete)
                    {
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteModelAsync(m.Id, m.Name)" disabled="@_busy">Eliminar</button>
                    }
                </div>
            </div>
        }
    </div>
}

@if (_pageError is not null)
{
    <div class="tk-field-error">@_pageError</div>
}

@* ===== Modal GRANDE del contenedor (2 columnas: lienzo ER | alimentacion) ===== *@
@if (_modalOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog dc-model-dialog" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>@(_mId is null ? "Nuevo contenedor" : _mName)</h3>
                <button class="modal-close" @onclick="CloseModal">&times;</button>
            </div>
            <div class="modal-body dc-model-body">
                @* ---- Cabecera del contenedor (nombre/descripcion) ---- *@
                <div class="dc-model-headform">
                    <div class="field" style="flex:1;min-width:220px;">
                        <label class="form-label">Nombre del contenedor</label>
                        <input class="form-control" @bind="_mName" maxlength="120" placeholder="Ej. Facturacion" />
                    </div>
                    <div class="field" style="flex:2;min-width:260px;">
                        <label class="form-label">Descripcion (opcional)</label>
                        <input class="form-control" @bind="_mDescription" maxlength="400" placeholder="Para que sirve este contenedor..." />
                    </div>
                    <div style="display:flex;align-items:flex-end;">
                        <button class="btn btn-primary" @onclick="SaveModelHeaderAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_mName))">
                            @(_busy ? "..." : (_mId is null ? "Crear contenedor" : "Guardar"))
                        </button>
                    </div>
                </div>
                @if (_headError is not null)
                {
                    <div class="tk-field-error">@_headError</div>
                }

                @if (_mId is null)
                {
                    <div class="coming-soon" style="padding:26px 20px;margin-top:14px;">
                        <p style="margin:0;">Guarda el contenedor para empezar a agregar tablas y configurar su alimentacion.</p>
                    </div>
                }
                else
                {
                    <div class="dc-model-grid">
                        @* ================= IZQUIERDA: LIENZO ER ================= *@
                        <div class="dc-model-left">
                            <div class="dc-left-head">
                                <div class="dc-cfg-title" style="margin:0;border:0;padding:0;">Modelo ER (@(_detail?.Tables.Count ?? 0) tablas)</div>
                                <div style="display:flex;gap:6px;">
                                    @if (_canEdit)
                                    {
                                        <button class="btn btn-sm btn-primary" @onclick="OpenNewTable">+ Tabla</button>
                                    }
                                </div>
                            </div>
                            <div class="dc-canvas">
                                @if (_detail is not null)
                                {
                                    @* Capa SVG con las lineas de relacion (debajo de las cajas). *@
                                    <svg class="dc-canvas-svg" width="3000" height="2000" xmlns="http://www.w3.org/2000/svg">
                                        @foreach (var rel in _detail.Relations)
                                        {
                                            @if (TryEdge(rel, out var x1, out var y1, out var x2, out var y2))
                                            {
                                                var stroke = rel.Kind == DataModelRelationKind.ManyToMany ? "#e08b2f" : "#7c5cff";
                                                var mx = (x1 + x2) / 2;
                                                var my = (y1 + y2) / 2;
                                                <line x1="@F(x1)" y1="@F(y1)" x2="@F(x2)" y2="@F(y2)" stroke="@stroke" stroke-width="2"
                                                      stroke-dasharray="@(rel.Kind == DataModelRelationKind.ManyToMany ? "6 4" : "0")" />
                                                <circle cx="@F(x2)" cy="@F(y2)" r="4" fill="@stroke" />
                                                @((MarkupString)$"<text x=\"{F(mx)}\" y=\"{F(my - 4)}\" fill=\"{stroke}\" font-size=\"11\" text-anchor=\"middle\">{System.Net.WebUtility.HtmlEncode(rel.Name ?? "")}</text>")
                                            }
                                        }
                                    </svg>

                                    @foreach (var t in _detail.Tables)
                                    {
                                        <div class="dc-table-node" data-table-id="@t.Id"
                                             style="left:@Px(GetX(t.Id))px; top:@Px(GetY(t.Id))px;">
                                            <div class="dc-node-head">
                                                <span class="dc-node-title" title="@t.Name">@t.Name</span>
                                                <span class="dc-node-tools">
                                                    <button class="dc-node-btn" title="Ver datos / importar Excel" @onclick="() => OpenData(t)">&#9636;</button>
                                                    @if (_canEdit)
                                                    {
                                                        <button class="dc-node-btn @(IsPublished(t.Id) ? "dc-node-btn-pub" : "")"
                                                                title="@(IsPublished(t.Id) ? "Publicada en el menu: configurar o quitar" : "Publicar esta tabla en el menu")"
                                                                @onclick="() => OpenPublishAsync(t)">&#9873;</button>
                                                        <button class="dc-node-btn" title="Editar tabla" @onclick="() => OpenEditTable(t)">&#9998;</button>
                                                    }
                                                    @if (_canDelete)
                                                    {
                                                        <button class="dc-node-btn dc-node-btn-del" title="Eliminar tabla" @onclick="() => DeleteTableAsync(t.Id, t.Name)">&times;</button>
                                                    }
                                                </span>
                                            </div>
                                            <div class="dc-node-fields">
                                                @if (t.Columns.Count == 0)
                                                {
                                                    <div class="dc-node-empty">sin campos</div>
                                                }
                                                else
                                                {
                                                    @foreach (var col in t.Columns.OrderBy(c => c.SortOrder))
                                                    {
                                                        <div class="dc-node-field">
                                                            <span class="dc-field-name">@col.Name</span>
                                                            <span class="dc-field-type">@TypeShort(col.Type)</span>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    }

                                    @if (_detail.Tables.Count == 0)
                                    {
                                        <div class="dc-canvas-hint">Sin tablas todavia. Usa "+ Tabla" para crear la primera.</div>
                                    }
                                }
                            </div>
                            <div class="dc-legend">
                                <span><i class="dc-lg dc-lg-ref"></i> Referencia (N:1)</span>
                                <span><i class="dc-lg dc-lg-many"></i> Relacion (N:N)</span>
                                <span class="text-muted">Arrastra el encabezado de una caja para moverla.</span>
                            </div>

                            @* ----- Relaciones (aristas del ER): entidad propia, ortogonal al tipo de dato ----- *@
                            <div class="dc-section-title" style="margin-top:14px;">Relaciones</div>
                            @if (_detail.Relations.Count == 0)
                            {
                                <div class="text-muted" style="font-size:12px;margin-bottom:8px;">Sin relaciones. Crea una uniendo dos tablas abajo.</div>
                            }
                            else
                            {
                                <div class="dc-rel-list">
                                    @foreach (var rel in _detail.Relations)
                                    {
                                        <div class="dc-rel-item">
                                            <span class="dc-rel-badge @(rel.Kind == DataModelRelationKind.ManyToMany ? "nn" : "n1")">@(rel.Kind == DataModelRelationKind.ManyToMany ? "N:N" : "N:1")</span>
                                            <span class="dc-rel-text">@TableName(rel.FromTableId) &rarr; @TableName(rel.ToTableId)@(string.IsNullOrWhiteSpace(rel.Name) ? "" : $" ({rel.Name})")</span>
                                            @if (_canDelete)
                                            {
                                                <button class="btn btn-sm btn-outline-danger" title="Eliminar relacion" @onclick="() => DeleteRelationAsync(rel.Id)" disabled="@_busy">&times;</button>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            @if (_canEdit && _detail.Tables.Count >= 2)
                            {
                                <div class="dc-rel-add">
                                    <select class="form-control" @bind="_relFrom">
                                        <option value="">Tabla origen</option>
                                        @foreach (var t in _detail.Tables) { <option value="@t.Id">@t.Name</option> }
                                    </select>
                                    <span class="text-muted">&rarr;</span>
                                    <select class="form-control" @bind="_relTo">
                                        <option value="">Tabla destino</option>
                                        @foreach (var t in _detail.Tables) { <option value="@t.Id">@t.Name</option> }
                                    </select>
                                    <select class="form-control" @bind="_relKind" style="max-width:120px;">
                                        <option value="@DataModelRelationKind.ManyToOne">N:1</option>
                                        <option value="@DataModelRelationKind.ManyToMany">N:N</option>
                                    </select>
                                    <input class="form-control" placeholder="Etiqueta (opcional)" @bind="_relName" style="max-width:150px;" />
                                    <button class="btn btn-sm btn-primary" @onclick="AddRelationAsync" disabled="@_busy">+ Relacion</button>
                                </div>
                            }
                            else if (_canEdit)
                            {
                                <div class="text-muted" style="font-size:12px;">Crea al menos <strong>2 tablas</strong> para poder relacionarlas.</div>
                            }
                            @if (_relError is not null) { <div class="tk-field-error" style="margin-top:6px;">@_relError</div> }
                        </div>

                        @* ================= DERECHA: ALIMENTACION ================= *@
                        <div class="dc-model-right">
                            <div class="dc-cfg-title">Alimentacion</div>

                            @* ----- Clientes remotos (primero: es la identidad del agente, lo que se
                                 configura antes que nada para que la colmena pueda conectarse) ----- *@
                            <DcAccordion Title="Clientes remotos" Open="@(_accOpen == Acc.Clientes)"
                                         OpenChanged="@(v => SetAcc(Acc.Clientes, v))"
                                         Badge="@(_clients.Count > 0 ? $"{_clients.Count}" : null)">
                                @RenderClientes
                            </DcAccordion>

                            @* ----- Conectores ----- *@
                            <DcAccordion Title="Conectores" Open="@(_accOpen == Acc.Conectores)"
                                         OpenChanged="@(v => SetAcc(Acc.Conectores, v))"
                                         Badge="@(_connectors.Count > 0 ? $"{_connectors.Count}" : null)">
                            <div class="dc-section-title" style="display:none;">Conectores</div>
                            @if (_connectors.Count > 0)
                            {
                                <ul class="dc-mini-list">
                                    @foreach (var c in _connectors)
                                    {
                                        <li>
                                            <div>
                                                <strong>@c.Name</strong> <span class="dc-badge">@ConnectorKindLabel(c.Kind)</span>
                                                @* A que TABLA alimenta: sin esto la ficha no decia a donde iban los datos. *@
                                                @if (c.ContainerName is not null)
                                                {
                                                    <span class="dc-badge dc-badge-target">&#8594; @c.ContainerName</span>
                                                }
                                                else
                                                {
                                                    <span class="dc-badge dc-badge-warn" title="Este conector no tiene tabla destino: hay que elegirla en cada importacion, y no puede refrescarse solo.">&#8594; sin tabla</span>
                                                }
                                                <div class="text-muted" style="font-size:11px;">
                                                    @ConnectorSummary(c)@(c.HasCredentials ? " · con credenciales" : "")@(c.IsActive ? "" : " · inactivo")
                                                </div>
                                            </div>
                                            <div style="display:flex;gap:4px;">
                                                @if (_canEdit && c.Kind == ConnectorKind.RestApi && c.IsActive)
                                                {
                                                    <button class="btn btn-sm btn-primary" @onclick="() => OpenApiImport(c)" disabled="@_busy" title="Traer datos del API a una tabla">Importar</button>
                                                }
                                                @if (_canEdit)
                                                {
                                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditConnector(c)" disabled="@_busy">Editar</button>
                                                }
                                                @if (_canDelete)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteConnectorAsync(c.Id)" disabled="@_busy">&times;</button>
                                                }
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                            @if (_canEdit)
                            {
                                <div class="dc-mini-form">
                                    <div class="dc-section-sub">@(_conEditId is null ? "Nuevo conector" : "Editar conector")</div>
                                    <input class="form-control" placeholder="Nombre" @bind="_conName" />
                                    <select class="form-control" @bind="_conKind">
                                        <option value="@ConnectorKind.Excel">Excel</option>
                                        <option value="@ConnectorKind.RestApi">API REST</option>
                                        <option value="@ConnectorKind.Database">Base de datos</option>
                                    </select>

                                    @* Tabla destino: sin esto el conector no sabe a donde alimenta, y
                                       no puede refrescarse solo (habria que preguntarlo cada vez). *@
                                    <select class="form-control" @bind="_conContainerId">
                                        <option value="">Tabla destino: (elegir al importar)</option>
                                        @foreach (var t in _detail!.Tables)
                                        {
                                            <option value="@t.Id">Alimenta: @t.Name</option>
                                        }
                                    </select>

                                    @if (_conKind == ConnectorKind.RestApi)
                                    {
                                        <input class="form-control" placeholder="Endpoint URL" @bind="_conEndpoint" />
                                        <div style="display:flex;gap:6px;">
                                            <input class="form-control" placeholder="Metodo (GET)" @bind="_conMethod" style="max-width:110px;" />
                                            <select class="form-control" @bind="_conAuth">
                                                <option value="@ConnectorAuthKind.None">Sin auth</option>
                                                <option value="@ConnectorAuthKind.ApiKey">API Key</option>
                                                <option value="@ConnectorAuthKind.Bearer">Bearer</option>
                                                <option value="@ConnectorAuthKind.Basic">Basic</option>
                                            </select>
                                        </div>
                                        <input class="form-control" type="password" placeholder="@(_conEditId is null ? "Credenciales" : "Credenciales (vacio = conservar)")" @bind="_conCreds" />
                                        <textarea class="form-control" rows="2" placeholder="Mapeo JSON (opcional)" @bind="_conMapping"></textarea>
                                    }
                                    else if (_conKind == ConnectorKind.Database)
                                    {
                                        <select class="form-control" @bind="_conEngine">
                                            <option value="">Motor...</option>
                                            @foreach (var e in Enum.GetValues<DbEngine>())
                                            {
                                                <option value="@e">@e</option>
                                            }
                                        </select>
                                        <div style="display:flex;gap:6px;">
                                            <input class="form-control" placeholder="Host" @bind="_conHost" />
                                            <input class="form-control" placeholder="Puerto" @bind="_conPort" style="max-width:100px;" />
                                        </div>
                                        <input class="form-control" placeholder="Base de datos" @bind="_conDatabase" />
                                        <input class="form-control" placeholder="Usuario" @bind="_conUser" />
                                        <input class="form-control" type="password" placeholder="@(_conEditId is null ? "Credenciales" : "Credenciales (vacio = conservar)")" @bind="_conCreds" />
                                        <textarea class="form-control" rows="3" placeholder="Consulta: SELECT que trae los datos" @bind="_conQuery"></textarea>
                                    }

                                    <label class="dc-req"><input type="checkbox" @bind="_conActive" /> Activo</label>
                                    @if (_conError is not null)
                                    {
                                        <div class="tk-field-error">@_conError</div>
                                    }
                                    <div style="display:flex;gap:6px;">
                                        <button class="btn btn-sm btn-primary" @onclick="SaveConnectorAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_conName))">@(_conEditId is null ? "+ Agregar" : "Guardar")</button>
                                        @if (_conEditId is not null)
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="ResetConnectorForm">Cancelar</button>
                                        }
                                    </div>
                                </div>
                            }

                            </DcAccordion>

                            @* ----- Destino ----- *@
                            <DcAccordion Title="Destino" Open="@(_accOpen == Acc.Destino)"
                                         OpenChanged="@(v => SetAcc(Acc.Destino, v))"
                                         Badge="@(_destKind == DestinationKind.System ? "Sistema" : "BD aliada")">
                            <div class="dc-mini-form">
                                <select class="form-control" @bind="_destKind">
                                    <option value="@DestinationKind.System">Sistema (tablas del contenedor)</option>
                                    <option value="@DestinationKind.AlliedDatabase">Base de datos aliada</option>
                                </select>
                                @if (_destKind == DestinationKind.AlliedDatabase)
                                {
                                    <select class="form-control" @bind="_destEngine">
                                        <option value="">Motor...</option>
                                        @foreach (var e in Enum.GetValues<DbEngine>())
                                        {
                                            <option value="@e">@e</option>
                                        }
                                    </select>
                                    <div style="display:flex;gap:6px;">
                                        <input class="form-control" placeholder="Host" @bind="_destHost" />
                                        <input class="form-control" placeholder="Puerto" @bind="_destPort" style="max-width:100px;" />
                                    </div>
                                    <input class="form-control" placeholder="Base de datos" @bind="_destDatabase" />
                                    <input class="form-control" placeholder="Usuario" @bind="_destUser" />
                                    <input class="form-control" type="password" placeholder="@(_destHasCreds ? "Credenciales (vacio = conservar)" : "Credenciales")" @bind="_destCreds" />
                                }
                                @if (_destError is not null)
                                {
                                    <div class="tk-field-error">@_destError</div>
                                }
                                @if (_canEdit)
                                {
                                    <button class="btn btn-sm btn-primary" @onclick="SaveDestinationAsync" disabled="@_busy">Guardar destino</button>
                                }
                            </div>
                            </DcAccordion>

                            @* Clientes remotos se pinta ARRIBA (ver RenderClientes en @@code). *@

                            @* ----- Procesos ----- *@
                            <DcAccordion Title="Procesos (horarios)" Open="@(_accOpen == Acc.Procesos)"
                                         OpenChanged="@(v => SetAcc(Acc.Procesos, v))"
                                         Badge="@(_processes.Count > 0 ? $"{_processes.Count}" : null)">
                            @if (_processes.Count > 0)
                            {
                                <ul class="dc-mini-list">
                                    @foreach (var p in _processes)
                                    {
                                        <li>
                                            <div>
                                                <strong>@p.Name</strong> <span class="dc-badge">@ScheduleLabel(p.ScheduleKind)</span>
                                                <div class="text-muted" style="font-size:11px;">
                                                    @(p.ConnectorName ?? "sin conector")@(p.ClientName is not null ? " · " + p.ClientName : "")
                                                    @(p.ScheduleKind == ImportScheduleKind.Interval && p.IntervalMinutes is int m ? $" · cada {m} min" : "")
                                                    @(p.ScheduleKind == ImportScheduleKind.Cron && !string.IsNullOrWhiteSpace(p.CronExpression) ? $" · {p.CronExpression}" : "")
                                                    @(p.IsActive ? "" : " · inactivo")
                                                    @* La proxima ventana es lo que responde "esto de verdad va a correr?". *@
                                                    @(p.NextRunAt is DateTimeOffset nr ? $" · proxima: {nr.ToLocalTime():dd MMM HH:mm}" : "")
                                                </div>
                                                @* Una programacion que se apago sola tiene que DECIR por que. *@
                                                @if (!string.IsNullOrWhiteSpace(p.DisabledReason))
                                                {
                                                    <div class="dc-probe off">Desactivada: @p.DisabledReason</div>
                                                }
                                                @* Parqueada esperando a que su agente vuelva: se reintenta sola al reconectar. *@
                                                @if (p.PendingSince is DateTimeOffset ps)
                                                {
                                                    <div class="dc-probe off">Esperando al agente desde @ps.ToLocalTime().ToString("dd MMM HH:mm"); se reintentara al reconectar.</div>
                                                }
                                                @if (_runResult.TryGetValue(p.Id, out var rr))
                                                {
                                                    <div class="dc-probe @(rr.Ok ? "on" : "off")">@rr.Message</div>
                                                }
                                                @* Bitacora: sin esto, una corrida automatica que falla de
                                                   madrugada es indistinguible de "no habia datos nuevos". *@
                                                @if (_runs.TryGetValue(p.Id, out var runs) && runs.Count > 0)
                                                {
                                                    <div class="dc-section-sub" style="margin-top:8px;">Ultimas ejecuciones</div>
                                                    <ul class="dc-runs">
                                                        @foreach (var r in runs)
                                                        {
                                                            <li>
                                                                <span class="dc-run-dot @RunDotClass(r.Result)"></span>
                                                                <span class="dc-run-when">@r.FiredAt.ToLocalTime().ToString("dd MMM HH:mm")</span>
                                                                <span class="dc-badge">@(r.Trigger == ImportRunTrigger.Scheduled ? "horario" : "manual")</span>
                                                                <span class="dc-run-detail">@RunSummary(r)</span>
                                                            </li>
                                                        }
                                                    </ul>
                                                }
                                            </div>
                                            <div style="display:flex;gap:4px;">
                                                @* "Actualizar datos": ejecuta ESTA programacion ahora.
                                                   Solo tiene sentido si la ejecuta un agente (tiene
                                                   cliente); sin cliente, no hay a quien pedirselo. *@
                                                @if (_canEdit && p.ClientName is not null)
                                                {
                                                    <button class="btn btn-sm btn-primary" @onclick="() => RunProcessAsync(p.Id)" disabled="@_busy"
                                                            title="Pide al agente que ejecute la consulta del conector y refresque la tabla destino.">
                                                        Actualizar datos
                                                    </button>
                                                }
                                                @if (_canEdit)
                                                {
                                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditProcess(p)" disabled="@_busy">Editar</button>
                                                }
                                                @if (_canDelete)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProcessAsync(p.Id)" disabled="@_busy">&times;</button>
                                                }
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                            @if (_canEdit)
                            {
                                <div class="dc-mini-form">
                                    <div class="dc-section-sub">@(_procEditId is null ? "Nuevo proceso" : "Editar proceso")</div>
                                    <input class="form-control" placeholder="Nombre" @bind="_procName" />
                                    <select class="form-control" @bind="_procConnector">
                                        <option value="">(Sin conector)</option>
                                        @foreach (var c in _connectors)
                                        {
                                            <option value="@c.Id">@c.Name</option>
                                        }
                                    </select>
                                    <select class="form-control" @bind="_procClient">
                                        <option value="">(Sin cliente)</option>
                                        @foreach (var c in _clients)
                                        {
                                            <option value="@c.Id">@c.Name</option>
                                        }
                                    </select>
                                    <select class="form-control" @bind="_procSchedule">
                                        <option value="@ImportScheduleKind.Manual">Manual</option>
                                        <option value="@ImportScheduleKind.Interval">Intervalo</option>
                                        <option value="@ImportScheduleKind.Cron">Cron</option>
                                    </select>
                                    @if (_procSchedule == ImportScheduleKind.Interval)
                                    {
                                        <input class="form-control" type="number" min="1" placeholder="Minutos" @bind="_procIntervalText" />
                                    }
                                    else if (_procSchedule == ImportScheduleKind.Cron)
                                    {
                                        <input class="form-control" placeholder="Expresion cron (ej. 0 * * * *)" @bind="_procCron" />
                                    }
                                    <label class="dc-req"><input type="checkbox" @bind="_procActive" /> Activo</label>
                                    @if (_procError is not null)
                                    {
                                        <div class="tk-field-error">@_procError</div>
                                    }
                                    <div style="display:flex;gap:6px;">
                                        <button class="btn btn-sm btn-primary" @onclick="SaveProcessAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_procName))">@(_procEditId is null ? "+ Agregar" : "Guardar")</button>
                                        @if (_procEditId is not null)
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="ResetProcessForm">Cancelar</button>
                                        }
                                    </div>
                                </div>
                            }
                            </DcAccordion>
                        </div>
                    </div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="CloseModal" disabled="@_busy">Cerrar</button>
            </div>
        </div>
    </div>
}

@* ===== Sub-modal: editor de una tabla (campos) ===== *@
@if (_tblOpen)
{
    <div class="modal-overlay" style="z-index:1060;">
        <div class="modal-dialog" style="max-width:640px;" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>@(_tblId is null ? "Nueva tabla" : "Editar tabla")</h3>
                <button class="modal-close" @onclick="() => _tblOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Nombre de la tabla</label>
                    <input class="form-control" @bind="_tblName" maxlength="120" placeholder="Ej. Facturas" />
                </div>
                <div class="field">
                    <label class="form-label">Descripcion (opcional)</label>
                    <input class="form-control" @bind="_tblDescription" maxlength="400" />
                </div>
                <div class="field">
                    <label class="form-label">Campos</label>
                    <div class="dc-cols">
                        @for (var i = 0; i < _tblColumns.Count; i++)
                        {
                            var idx = i;
                            var item = _tblColumns[idx];
                            <div class="dc-col-row">
                                <input class="form-control" placeholder="Nombre" @bind="item.Name" />
                                <select class="form-control" @bind="item.Type">
                                    <option value="@DataContainerColumnType.Text">Texto</option>
                                    <option value="@DataContainerColumnType.Number">Numero</option>
                                    <option value="@DataContainerColumnType.Decimal">Decimal</option>
                                    <option value="@DataContainerColumnType.Date">Fecha</option>
                                    <option value="@DataContainerColumnType.Boolean">Booleano</option>
                                    <option value="@DataContainerColumnType.Submodel">Submodelo</option>
                                </select>
                                <label class="dc-req"><input type="checkbox" @bind="item.IsRequired" /> Oblig.</label>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveColumn(idx)" title="Quitar campo">&times;</button>
                            </div>
                        }
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AddColumn" style="margin-top:6px;">+ Agregar campo</button>
                </div>
                @if (_tblError is not null)
                {
                    <div class="tk-field-error">@_tblError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _tblOpen = false" disabled="@_busy">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveTableAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_tblName))">@(_busy ? "Guardando..." : "Guardar tabla")</button>
            </div>
        </div>
    </div>
}

@* ===== Sub-modal: PUBLICAR la tabla como modulo del menu =====
     Al publicar, el item aparece en el menu Y en la matriz de "Roles y permisos" por si solo (el
     catalogo de modulos se deriva del menu, con la clave = la ruta). La ruta se congela al publicar:
     renombrar la tabla cambia la etiqueta del item, nunca su ruta, para no dejar huerfanos los
     permisos ya asignados. *@
@if (_pubOpen && _pubTable is not null)
{
    <div class="modal-overlay" style="z-index:1075;">
        <div class="modal-dialog" style="max-width:620px;" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>Publicar en el menu &#183; @_pubTable.Name</h3>
                <button class="modal-close" @onclick="() => _pubOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <p class="dc-cfg-note">
                    Publicar cuelga esta tabla del menu para que el usuario final gestione sus registros
                    sin entrar aqui. El modulo aparece solo en <b>Roles y permisos</b>, donde decides
                    quien puede ver, crear, editar o eliminar.
                </p>

                @if (_pubState?.IsPublished == true)
                {
                    <div class="dc-flash-ok">Publicada. Ruta: <b>/@_pubState.ModuleRoute</b></div>
                }
                else if (!string.IsNullOrWhiteSpace(_pubState?.ModuleRoute))
                {
                    <div class="dc-cfg-note">
                        Estuvo publicada antes. Al publicar de nuevo se reusa su ruta
                        (<b>/@_pubState.ModuleRoute</b>), asi los permisos que ya diste siguen valiendo.
                    </div>
                }

                <div class="field">
                    <label class="form-label">Vista de menu</label>
                    <select class="form-control" @bind="_pubViewId">
                        @foreach (var v in _pubViews)
                        {
                            <option value="@v.Id">@v.Name @(v.IsDefault ? "(por defecto)" : "")</option>
                        }
                    </select>
                </div>
                <div class="field">
                    <label class="form-label">Grupo del menu (donde aparece)</label>
                    <select class="form-control" @bind="_pubParentId">
                        <option value="">Raiz del menu</option>
                        @foreach (var g in _pubGroups)
                        {
                            <option value="@g.Id">@g.Label</option>
                        }
                    </select>
                </div>
                <div class="field">
                    <label class="form-label">Icono del item (opcional)</label>
                    @* Se elige, no se teclea: es el mismo selector del editor de menu, sobre el mismo
                       catalogo que pinta el sidebar, asi que lo que se ve aqui es lo que saldra alla. *@
                    <MenuIconPicker Value="@_pubIcon" ValueChanged="@(v => _pubIcon = v ?? "")" />
                </div>

                <div class="field">
                    <label class="form-label">Columnas de la grilla</label>
                    <div class="dc-pub-cols">
                        @foreach (var c in PublishableColumns())
                        {
                            var cid = c.Id;
                            <label class="dc-req">
                                <input type="checkbox" checked="@_pubListCols.Contains(cid)"
                                       @onchange="e => ToggleSet(_pubListCols, cid, e)" /> @c.Name
                            </label>
                        }
                    </div>
                    <span class="dc-cfg-note">Sin marcar ninguna se muestran todas.</span>
                </div>
                <div class="field">
                    <label class="form-label">Columnas con filtro</label>
                    <div class="dc-pub-cols">
                        @foreach (var c in PublishableColumns())
                        {
                            var cid = c.Id;
                            <label class="dc-req">
                                <input type="checkbox" checked="@_pubFilterCols.Contains(cid)"
                                       @onchange="e => ToggleSet(_pubFilterCols, cid, e)" /> @c.Name
                            </label>
                        }
                    </div>
                </div>

                @if (_pubError is not null) { <div class="tk-field-error">@_pubError</div> }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _pubOpen = false" disabled="@_busy">Cerrar</button>
                @if (_pubState?.IsPublished == true)
                {
                    <button class="btn btn-outline-danger" @onclick="UnpublishAsync" disabled="@_busy">Quitar del menu</button>
                }
                <button class="btn btn-primary" @onclick="PublishAsync" disabled="@_busy">
                    @(_busy ? "Guardando..." : _pubState?.IsPublished == true ? "Guardar cambios" : "Publicar")
                </button>
            </div>
        </div>
    </div>
}

@* ===== Sub-modal: DATOS de una tabla. La grilla y el editor de filas viven en el componente
     compartido DataRecordsGrid: aqui solo se pone el marco del modal. El mismo componente lo
     reusara el modulo publicado (la tabla colgada del menu), asi no hay dos editores. ===== *@
@if (_dataOpen && _dataTable is not null)
{
    <div class="modal-overlay" style="z-index:1070;">
        <div class="modal-dialog dc-data-dialog" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>Datos &#183; @_dataTable.Name</h3>
                <button class="modal-close" @onclick="() => _dataOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <DataRecordsGrid @ref="_recordsGrid"
                                 ContainerId="@_dataTable.Id"
                                 ActorUserId="@_actor"
                                 CanCreate="@_canEdit"
                                 CanEdit="@_canEdit"
                                 CanDelete="@_canDelete"
                                 OnRowSaved="OnRowSavedAsync"
                                 EmptyText="Sin filas. Importa un Excel o usa &quot;+ Fila&quot;.">
                    @* Los vinculos de relacion entran por el punto de extension del editor: la fila
                       nueva no tiene Id hasta guardarse, por eso se persisten en OnRowSaved. *@
                    <RowEditorExtras>
                        <RowRelationPicker @ref="_relationPicker"
                                           ContainerId="@_dataTable.Id"
                                           RowId="@context" />
                    </RowEditorExtras>
                </DataRecordsGrid>
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _dataOpen = false" disabled="@_busy">Cerrar</button>
            </div>
        </div>
    </div>
}

@* ===== Sub-modal: Importar desde API REST (descubrir campos + mapeo + importar) ===== *@
@if (_apiOpen && _apiConnector is not null)
{
    <div class="modal-overlay" style="z-index:1075;">
        <div class="modal-dialog dc-data-dialog" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>Importar desde API &#183; @_apiConnector.Name</h3>
                <button class="modal-close" @onclick="() => _apiOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="text-muted" style="font-size:12px;margin-bottom:8px;word-break:break-all;">
                    @(string.IsNullOrWhiteSpace(_apiConnector.HttpMethod) ? "GET" : _apiConnector.HttpMethod!.ToUpperInvariant()) @_apiConnector.EndpointUrl
                </div>
                <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;margin-bottom:8px;">
                    <div class="field" style="flex:1;min-width:180px;margin:0;">
                        <label class="form-label">Ruta del arreglo (opcional)</label>
                        <input class="form-control" @bind="_apiArrayPath" placeholder="vacio = auto (ej. data)" />
                    </div>
                    <button class="btn btn-outline-secondary" @onclick="ProbeApiAsync" disabled="@_busy">@(_busy ? "..." : "Descubrir campos")</button>
                </div>
                @if (_apiFlash is not null) { <div class="dc-flash-ok">@_apiFlash</div> }
                @if (_apiError is not null) { <div class="tk-field-error">@_apiError</div> }

                @if (_apiProbed)
                {
                    <div class="dc-section-title">Campos detectados (@_apiFields.Count) &#183; @_apiCount registros en el API</div>
                    <div style="display:flex;gap:16px;flex-wrap:wrap;">
                        <div style="flex:1;min-width:300px;">
                            <div class="field">
                                <label class="form-label">Tabla destino</label>
                                <select class="form-control" value="@(_apiTargetTableId?.ToString() ?? "")" @onchange="OnApiTargetChanged">
                                    <option value="">(elige tabla)</option>
                                    @foreach (var t in (_detail?.Tables ?? Enumerable.Empty<ModelTableDto>()))
                                    {
                                        <option value="@t.Id">@t.Name</option>
                                    }
                                </select>
                            </div>
                            @if (_apiTargetTableId is not null)
                            {
                                <div class="dc-section-title" style="margin-top:8px;">Mapeo: columna &#8592; campo del API</div>
                                @if (!ApiTargetColumns().Any())
                                {
                                    <div class="text-muted" style="font-size:12px;">La tabla destino no tiene columnas escalares. Agrega campos (Texto/Numero/...) a la tabla.</div>
                                }
                                @foreach (var col in ApiTargetColumns())
                                {
                                    <div class="dc-map-row">
                                        <span class="dc-map-col">@col.Name <span class="dc-th-type">@TypeShort(col.Type)</span></span>
                                        <select class="form-control" value="@GetMap(col.Id)" @onchange="e => SetMap(col.Id, e.Value?.ToString())">
                                            <option value="">(no importar)</option>
                                            @foreach (var f in _apiFields)
                                            {
                                                <option value="@f">@f</option>
                                            }
                                        </select>
                                    </div>
                                }
                                <div class="dc-section-title" style="margin-top:10px;">Modo de importacion (re-cargas)</div>
                                <div class="dc-map-row"><span class="dc-map-col">Al re-importar</span>
                                    <select class="form-control" @bind="_apiImportMode">
                                        <option value="@ApiImportMode.Append">Agregar (puede duplicar)</option>
                                        <option value="@ApiImportMode.Replace">Reemplazar (vaciar tabla antes)</option>
                                        <option value="@ApiImportMode.Upsert">Upsert (actualizar por clave)</option>
                                    </select>
                                </div>
                                @if (_apiImportMode == ApiImportMode.Upsert)
                                {
                                    <div class="dc-map-row"><span class="dc-map-col">Columna clave</span>
                                        <select class="form-control" value="@(_apiKeyColumnId?.ToString() ?? "")" @onchange="e => _apiKeyColumnId = Guid.TryParse(e.Value?.ToString(), out var g) ? g : (Guid?)null">
                                            <option value="">(elige columna clave)</option>
                                            @foreach (var col in ApiTargetColumns())
                                            {
                                                <option value="@col.Id">@col.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="text-muted" style="font-size:11px;">La clave debe estar mapeada a un campo (ej. id). Si el valor ya existe, la fila se actualiza; si no, se inserta.</div>
                                }

                                <div class="dc-section-title" style="margin-top:10px;">Paginacion</div>
                                <label class="dc-req"><input type="checkbox" @bind="_apiPageAll" /> Traer TODAS las paginas (recorre el API pagina por pagina)</label>
                                @if (_apiPageAll)
                                {
                                    <div class="dc-map-row"><span class="dc-map-col">Estilo</span>
                                        <select class="form-control" @bind="_apiPagingMode">
                                            <option value="@PagingMode.Offset">Desplazamiento (start/limit)</option>
                                            <option value="@PagingMode.Page">Numero de pagina (page)</option>
                                        </select>
                                    </div>
                                    @if (_apiPagingMode == PagingMode.Offset)
                                    {
                                        <div class="dc-map-row"><span class="dc-map-col">Parametro desplazamiento</span><input class="form-control" @bind="_apiOffsetParam" /></div>
                                    }
                                    else
                                    {
                                        <div class="dc-map-row"><span class="dc-map-col">Parametro pagina</span><input class="form-control" @bind="_apiPageParam" /></div>
                                        <div class="dc-map-row"><span class="dc-map-col">Pagina inicial</span><input class="form-control" type="number" @bind="_apiStartValue" /></div>
                                    }
                                    <div class="dc-map-row"><span class="dc-map-col">Parametro limite</span><input class="form-control" @bind="_apiLimitParam" /></div>
                                    <div class="dc-map-row"><span class="dc-map-col">Tamano de pagina</span><input class="form-control" type="number" @bind="_apiPageSize" /></div>
                                    <div class="dc-map-row"><span class="dc-map-col">Max paginas (tope)</span><input class="form-control" type="number" @bind="_apiMaxPages" /></div>
                                }
                                <button class="btn btn-primary" style="margin-top:10px;" @onclick="ImportApiAsync" disabled="@(_busy || _apiMap.Count == 0)">@(_busy ? "Importando..." : (_apiPageAll ? "Importar TODAS las paginas ahora" : $"Importar {_apiCount} registros ahora"))</button>
                            }
                        </div>
                        <div style="flex:1;min-width:280px;">
                            <div class="dc-section-title">Muestra (primer registro)</div>
                            <pre class="dc-api-sample">@_apiSample</pre>
                        </div>
                    </div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _apiOpen = false" disabled="@_busy">Cerrar</button>
            </div>
        </div>
    </div>
}

<style>
    .dc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }
    .dc-card { padding: 16px 18px; display: flex; flex-direction: column; gap: 8px; min-height: 150px; border: 1px solid var(--line, var(--border)); border-radius: 12px; background: var(--surface, var(--card)); }
    .dc-card-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
    .dc-card-name { font-weight: 700; font-size: 1.0rem; line-height: 1.25; }
    .dc-card-desc { color: var(--ink-3, var(--muted-foreground)); font-size: 0.85rem; line-height: 1.45; flex: 1; }
    .dc-card-meta { font-size: 0.78rem; color: var(--ink-3, var(--muted-foreground)); }
    .dc-card-actions { display: flex; gap: 6px; margin-top: auto; }
    .dc-badge { display: inline-block; font-size: 10.5px; font-weight: 700; padding: 2px 8px; border-radius: 999px; background: var(--surface-2, var(--accent)); color: var(--ink-2, var(--muted-foreground)); }

    /* Modal grande casi pantalla completa */
    .dc-model-dialog { max-width: 1400px; width: 96vw; height: 92vh; display: flex; flex-direction: column; }
    .dc-model-body { flex: 1; overflow: auto; }
    .dc-model-headform { display: flex; gap: 12px; flex-wrap: wrap; align-items: flex-end; }
    .dc-model-grid { display: grid; grid-template-columns: 1.7fr 1fr; gap: 16px; margin-top: 14px; }
    .dc-model-left { min-width: 0; display: flex; flex-direction: column; }
    .dc-model-right { min-width: 0; border-left: 1px solid var(--line, var(--border)); padding-left: 16px; }
    .dc-left-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }

    /* Lienzo ER */
    .dc-canvas { position: relative; overflow: auto; min-height: 520px; height: 60vh; border: 1px solid var(--line, var(--border)); border-radius: 12px; background:
        repeating-linear-gradient(0deg, transparent, transparent 23px, var(--line, var(--border)) 23px, var(--line, var(--border)) 24px),
        repeating-linear-gradient(90deg, transparent, transparent 23px, var(--line, var(--border)) 23px, var(--line, var(--border)) 24px),
        var(--surface, var(--card)); }
    .dc-canvas-svg { position: absolute; top: 0; left: 0; pointer-events: none; z-index: 1; }
    .dc-canvas-hint { position: absolute; top: 20px; left: 20px; color: var(--ink-3, var(--muted-foreground)); font-size: 13px; z-index: 2; }
    .dc-table-node { position: absolute; width: 220px; background: var(--surface, var(--card)); border: 1px solid var(--line, var(--border)); border-radius: 10px; box-shadow: 0 4px 14px rgba(0,0,0,.10); z-index: 3; user-select: none; }
    .dc-table-node.dragging { box-shadow: 0 8px 22px rgba(0,0,0,.20); opacity: .95; }
    .dc-node-head { display: flex; align-items: center; justify-content: space-between; gap: 6px; padding: 7px 10px; background: var(--t-violet, var(--primary)); color: #fff; border-radius: 9px 9px 0 0; cursor: grab; }
    .dc-node-head:active { cursor: grabbing; }
    .dc-node-title { font-weight: 700; font-size: 13px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .dc-node-tools { display: flex; gap: 2px; flex-shrink: 0; }
    .dc-node-btn { border: 0; background: rgba(255,255,255,.18); color: #fff; width: 20px; height: 20px; border-radius: 5px; font-size: 12px; line-height: 1; cursor: pointer; }
    .dc-node-btn-del { background: rgba(0,0,0,.18); }
    /* Tabla ya publicada en el menu: el banderin queda encendido. */
    .dc-node-btn-pub { background: rgba(90,200,120,.30); }
    .dc-pub-cols { display: flex; flex-wrap: wrap; gap: 8px 14px; margin-top: 4px; }
    .dc-node-fields { padding: 4px 0; max-height: 220px; overflow: auto; }
    .dc-node-field { display: flex; justify-content: space-between; gap: 8px; padding: 3px 10px; font-size: 12px; }
    .dc-node-field.is-rel { color: var(--t-violet, var(--primary)); font-weight: 600; }
    .dc-field-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .dc-field-type { color: var(--ink-3, var(--muted-foreground)); font-size: 10.5px; flex-shrink: 0; }
    .dc-node-empty { padding: 4px 10px; font-size: 11px; color: var(--ink-3, var(--muted-foreground)); }
    .dc-node-field.is-rel .dc-field-type { color: var(--t-violet, var(--primary)); }
    .dc-legend { display: flex; gap: 14px; flex-wrap: wrap; align-items: center; font-size: 11.5px; color: var(--ink-2, var(--muted-foreground)); margin-top: 8px; }
    .dc-lg { display: inline-block; width: 16px; height: 0; border-top: 2px solid; vertical-align: middle; margin-right: 4px; }
    .dc-lg-ref { border-color: #7c5cff; }
    .dc-lg-many { border-top-style: dashed; border-color: #e08b2f; }

    /* Editor de columnas */
    .dc-cols { display: flex; flex-direction: column; gap: 6px; }
    .dc-col-row { display: grid; grid-template-columns: 1.4fr 1fr auto auto; gap: 6px; align-items: center; }
    .dc-req { display: flex; align-items: center; gap: 4px; font-size: 12px; color: var(--ink-3, var(--muted-foreground)); white-space: nowrap; }
    .dc-rel-config { display: flex; align-items: center; gap: 8px; padding: 4px 0 4px 8px; border-left: 2px dashed var(--line, var(--border)); margin: 2px 0 4px; }
    .dc-rel-config select { max-width: 260px; }
    .dc-rel-list { display: flex; flex-direction: column; gap: 6px; margin-bottom: 8px; }
    .dc-rel-item { display: flex; align-items: center; gap: 8px; font-size: 12.5px; }
    .dc-rel-text { flex: 1; color: var(--ink, var(--foreground)); }
    .dc-rel-badge { font-size: 10px; font-weight: 700; padding: 1px 6px; border-radius: 999px; color: #fff; }
    .dc-rel-badge.n1 { background: #7c5cff; }
    .dc-rel-badge.nn { background: #e08b2f; }
    .dc-rel-add { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
    .dc-rel-add select, .dc-rel-add input { max-width: 160px; }

    /* Alimentacion (columna derecha) */
    .dc-cfg-title { font-weight: 800; font-size: 13px; text-transform: uppercase; letter-spacing: .04em; color: var(--ink-2, var(--muted-foreground)); margin-bottom: 10px; border-bottom: 1px solid var(--line, var(--border)); padding-bottom: 6px; }
    .dc-section-title { font-weight: 700; font-size: 12.5px; color: var(--ink-2, var(--muted-foreground)); margin: 8px 0 6px; }

    /* A que tabla alimenta el conector. "sin tabla" en ambar: no es un error (se elige al importar),
       pero si algo que conviene resolver para poder refrescar solo. */
    .dc-badge-target { background: rgba(16,185,129,.14); color: #047857; }
    .dc-badge-warn { background: rgba(245,158,11,.16); color: #92400e; }

    /* Resultado de "Probar conexion". */
    .dc-probe { font-size: 11px; margin-top: 3px; padding: 3px 7px; border-radius: 6px; display: inline-block; }
    .dc-probe.on { background: rgba(16,185,129,.14); color: #047857; }
    .dc-probe.off { background: rgba(245,158,11,.16); color: #92400e; }

    /* Bitacora de corridas. El punto de color permite ver "todo bien / algo fallo" de un vistazo,
       sin leer: es lo primero que busca quien entra a revisar si el horario esta corriendo. */
    .dc-runs { list-style: none; padding: 0; margin: 2px 0 0; }
    .dc-runs li { display: flex; align-items: center; gap: 6px; padding: 2px 0; font-size: 11px; color: var(--ink-2, var(--muted-foreground)); }
    .dc-run-dot { width: 7px; height: 7px; border-radius: 50%; flex: none; }
    .dc-run-dot.ok { background: #10b981; }
    .dc-run-dot.err { background: #ef4444; }
    .dc-run-dot.run { background: #f59e0b; }
    .dc-run-dot.wait { background: #f59e0b; }
    .dc-run-dot.skip { background: var(--line, var(--border)); }
    .dc-run-when { font-variant-numeric: tabular-nums; }
    .dc-run-detail { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    /* Acordeon de la columna Alimentacion (ver DcAccordion.razor). */
    .dc-acc { border: 1px solid var(--line, var(--border)); border-radius: 8px; margin-bottom: 8px; background: var(--surface, var(--card)); }
    .dc-acc-head { display: flex; align-items: center; gap: 8px; width: 100%; padding: 9px 10px; background: none; border: 0; cursor: pointer; text-align: left; }
    .dc-acc-head:hover { background: var(--hover, rgba(0,0,0,.03)); border-radius: 8px; }
    .dc-acc.open .dc-acc-head { border-bottom: 1px solid var(--line, var(--border)); border-radius: 8px 8px 0 0; }
    .dc-acc-caret { font-size: 10px; color: var(--ink-2, var(--muted-foreground)); width: 10px; }
    .dc-acc-title { font-weight: 700; font-size: 12.5px; flex: 1; }
    /* El resumen (ej. "2") se lee SIN desplegar: es la razon de ser del acordeon. */
    .dc-acc-badge { font-size: 11px; color: var(--ink-2, var(--muted-foreground)); background: var(--hover, rgba(0,0,0,.05)); border-radius: 10px; padding: 1px 7px; }
    .dc-acc-body { padding: 8px 10px 10px; }
    .dc-section-sub { font-weight: 700; font-size: 12px; color: var(--ink-3, var(--muted-foreground)); margin-bottom: 4px; }
    .dc-mini-list { list-style: none; padding: 0; margin: 0 0 8px; }
    .dc-mini-list li { display: flex; justify-content: space-between; align-items: center; gap: 8px; padding: 7px 0; border-bottom: 1px solid var(--line, var(--border)); }
    .dc-mini-form { display: flex; flex-direction: column; gap: 6px; border: 1px dashed var(--line, var(--border)); border-radius: 10px; padding: 10px 12px; margin-top: 6px; }
    .dc-secret { border: 1px solid var(--line, var(--border)); border-radius: 10px; padding: 10px 12px; margin-bottom: 10px; background: var(--surface-2, var(--accent)); }
    .dc-secret-row { display: flex; align-items: center; gap: 8px; margin-top: 4px; word-break: break-all; }

    @@media (max-width: 980px) { .dc-model-grid { grid-template-columns: 1fr; } .dc-model-right { border-left: 0; padding-left: 0; border-top: 1px solid var(--line, var(--border)); padding-top: 12px; } }

    /* Panel de DATOS de una tabla */
    .dc-data-dialog { max-width: 1100px; width: 92vw; max-height: 90vh; display: flex; flex-direction: column; }
    .dc-data-dialog .modal-body { flex: 1; overflow: auto; }
    .dc-data-toolbar { display: flex; gap: 8px; align-items: center; margin-bottom: 10px; flex-wrap: wrap; }
    .dc-file-btn { position: relative; overflow: hidden; cursor: pointer; }
    .dc-file-btn ::deep input[type=file], .dc-file-btn input[type=file] { position: absolute; inset: 0; opacity: 0; width: 100%; height: 100%; cursor: pointer; }
    .dc-flash-ok { background: #e9f8ef; color: #1c7a44; border: 1px solid #bfe6cd; border-radius: 8px; padding: 6px 10px; font-size: 12.5px; margin-bottom: 8px; }
    .dc-data-scroll { overflow: auto; border: 1px solid var(--line, var(--border)); border-radius: 10px; }
    .dc-data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .dc-data-table th, .dc-data-table td { text-align: left; padding: 7px 10px; border-bottom: 1px solid var(--line, var(--border)); white-space: nowrap; }
    .dc-data-table thead th { background: var(--surface-2, var(--accent)); font-size: 11.5px; text-transform: uppercase; letter-spacing: .03em; color: var(--ink-2, var(--muted-foreground)); position: sticky; top: 0; }
    .dc-th-type { font-size: 10px; color: var(--ink-3, var(--muted-foreground)); text-transform: none; letter-spacing: 0; font-weight: 400; }
    .dc-data-empty { text-align: center; color: var(--ink-3, var(--muted-foreground)); padding: 22px; font-style: italic; }
    .dc-data-actions { display: flex; gap: 4px; }
    .dc-data-ibtn { background: var(--surface-2, var(--accent)); color: var(--ink-2, var(--foreground)); }
    .dc-data-ibtn.dc-node-btn-del { background: rgba(224,60,60,.14); color: #c23b3b; }
    .dc-cell-empty { color: var(--ink-3, var(--muted-foreground)); }
    .dc-chip { display: inline-block; padding: 1px 8px; border-radius: 999px; background: var(--surface-2, var(--accent)); font-size: 11.5px; margin: 1px 2px; }
    .dc-chip-ref { background: rgba(124,92,255,.14); color: #6b4bd8; font-weight: 600; }
    .dc-nn-box { display: flex; flex-wrap: wrap; gap: 8px; padding: 6px 0; }
    .dc-nn-chip { display: inline-flex; align-items: center; gap: 5px; font-size: 12.5px; border: 1px solid var(--line, var(--border)); border-radius: 999px; padding: 3px 10px; cursor: pointer; }
    .dc-map-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; align-items: center; margin-bottom: 6px; }
    .dc-map-col { font-size: 13px; }
    .dc-api-sample { max-height: 340px; overflow: auto; background: var(--surface-2, var(--accent)); border: 1px solid var(--line, var(--border)); border-radius: 8px; padding: 10px; font-size: 11px; line-height: 1.5; white-space: pre-wrap; word-break: break-word; }
</style>

@code {
    private bool _loading = true;
    private bool _busy;
    private Guid _actor;
    private string? _pageError;

    // ---- Acordeon de la columna "Alimentacion" ----
    // Antes las cuatro secciones estaban abiertas a la vez y la columna era ilegible. Ahora se pliegan
    // y solo UNA queda abierta: al abrir una, la anterior se cierra sola (por eso el estado vive aqui
    // y no dentro de cada seccion).

    private enum Acc { Clientes, Conectores, Destino, Procesos }

    /// <summary>Arranca en Clientes: es la identidad del agente, lo primero que hay que configurar.</summary>
    private Acc _accOpen = Acc.Clientes;

    private void SetAcc(Acc which, bool open) => _accOpen = open ? which : default;

    /// <summary>
    /// Clientes remotos vive en un fragmento para poder pintarlo ARRIBA de la columna sin mover 50
    /// lineas de marcado ni duplicarlo.
    /// </summary>
    private RenderFragment RenderClientes => @<text>
        @* El alta/rotacion/revocacion de agentes colmena vive en su modulo propio (ADR-0045, Ola 4).
           Aqui solo se ELIGE el agente del proceso (mas abajo) y, como referencia, se lista su estado. *@
        <div class="text-muted" style="font-size:12px;margin-bottom:8px;">
            Los agentes colmena se registran y gestionan en su modulo.
            <a href="/agentes-colmena" target="_blank">Gestionar agentes -&gt;</a>
        </div>
        @if (_clients.Count > 0)
        {
            <ul class="dc-mini-list">
                @foreach (var c in _clients)
                {
                    <li>
                        <div>
                            <strong>@c.Name</strong> @(c.IsActive ? "" : "(inactivo)")
                            <div class="text-muted" style="font-size:11px;">@c.ClientId</div>
                            @if (_probe.TryGetValue(c.ClientId, out var estado))
                            {
                                <div class="dc-probe @(estado.Online ? "on" : "off")">@estado.Texto</div>
                            }
                        </div>
                        @* Probar = solo LECTURA (pregunta al registro del hub si ese ClientId esta conectado
                           ahora). El servidor no inicia la conexion: la abre el agente. *@
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ProbeClientAsync(c.ClientId)" disabled="@_busy"
                                title="Consulta si este cliente tiene un agente conectado en este momento.">
                            Probar conexion
                        </button>
                    </li>
                }
            </ul>
        }
        else
        {
            <div class="text-muted" style="font-size:12px;">Aun no hay agentes. Registra uno en el modulo Agentes Colmena.</div>
        }
    </text>;

    private const string ModuleKey = "contenedor-datos";
    private bool _canCreate = true;
    private bool _canEdit = true;
    private bool _canDelete = true;

    private List<DataModelDto> _models = new();

    // Modal del contenedor abierto.
    private bool _modalOpen;
    private Guid? _mId;
    private string _mName = "";
    private string _mDescription = "";
    private string? _headError;
    private DataModelDetailDto? _detail;

    // Posiciones de las tablas en el lienzo (overlay mutable sobre el detalle inmutable).
    private readonly Dictionary<Guid, (double X, double Y)> _pos = new();

    // Interop lienzo (arrastre).
    private DotNetObjectReference<ContenedorDatos>? _selfRef;
    private bool _canvasInit;

    // Editor de tabla.
    private bool _tblOpen;
    private Guid? _tblId;
    private string _tblName = "";
    private string _tblDescription = "";
    private List<ColumnDraft> _tblColumns = new();
    private string? _tblError;

    // Conectores.
    private IReadOnlyList<DataConnectorDto> _connectors = Array.Empty<DataConnectorDto>();
    private Guid? _conEditId;
    private string _conName = "";
    private ConnectorKind _conKind = ConnectorKind.Excel;
    private string _conEndpoint = "";
    private string _conMethod = "GET";
    private ConnectorAuthKind _conAuth = ConnectorAuthKind.None;
    private string _conEngine = "";
    private string _conHost = "";
    private string _conPort = "";
    private string _conDatabase = "";
    private string _conUser = "";
    private string _conCreds = "";
    private string _conQuery = "";
    private string _conMapping = "";
    private bool _conActive = true;
    private string? _conError;

    /// <summary>Tabla destino del conector (Guid como texto: el select lo maneja asi). "" = sin elegir.</summary>
    private string _conContainerId = "";

    // ---- "Actualizar datos": ejecuta una programacion AHORA ----

    private readonly Dictionary<Guid, (bool Ok, string Message)> _runResult = new();

    /// <summary>Ultimas corridas por programacion (la bitacora).</summary>
    private readonly Dictionary<Guid, IReadOnlyList<ImportRunDto>> _runs = new();

    private static string RunDotClass(ImportRunResult r) => r switch
    {
        ImportRunResult.Ok => "ok",
        ImportRunResult.Error => "err",
        ImportRunResult.Running => "run",
        ImportRunResult.PendingOffline => "wait",
        _ => "skip"
    };

    private static string RunSummary(ImportRunDto r) => r.Result switch
    {
        ImportRunResult.Ok => $"{r.Inserted} filas" + (r.Deleted > 0 ? $" (reemplazo {r.Deleted})" : ""),
        ImportRunResult.Running => "ejecutando...",
        ImportRunResult.PendingOffline => "agente offline; se reintentara",
        _ => r.Detail ?? r.Result.ToString()
    };

    /// <summary>
    /// Pide al agente que traiga los datos. El despacho es INMEDIATO pero la ingesta NO: el agente
    /// consulta su base y devuelve los chunks por el canal. Por eso aqui se espera el resultado real
    /// (con tope) en vez de decir "listo" al enviar la orden: "enviado" no es "cargado", y anunciar
    /// exito antes de tiempo es justo lo que hace que nadie confie en el boton.
    /// </summary>
    private Task RunProcessAsync(Guid processId) => GuardAsync(async () =>
    {
        _busy = true;
        _runResult[processId] = (true, "Pidiendo datos al agente...");
        try
        {
            var r = await Runner.RunNowAsync(processId);
            if (!r.Ok || r.CorrelationId is null)
            {
                _runResult[processId] = (false, r.Message);
                return;
            }

            // Espera del acuse. Este tope es solo de la PANTALLA (no dejar al operador mirando una
            // rueda): del lado servidor la peticion caduca aparte (AgentImportService.SweepAsync) y
            // cierra la corrida en la bitacora, aunque nadie tenga la pagina abierta.
            var limite = DateTime.UtcNow.AddSeconds(60);
            while (DateTime.UtcNow < limite)
            {
                await Task.Delay(700);
                if (Imports.TryGetOutcome(r.CorrelationId, out var o) && o is not null)
                {
                    _runResult[processId] = o.Ok
                        ? (true, $"Listo: {o.Inserted} filas cargadas" + (o.Deleted > 0 ? $" (se reemplazaron {o.Deleted})" : ""))
                        : (false, $"El agente no pudo: {o.Error}");
                    if (o.Ok && _mId is Guid mid) { await LoadDetailCoreAsync(mid); }
                    await LoadRunsAsync();
                    return;
                }
                StateHasChanged();
            }
            _runResult[processId] = (false, "El agente no respondio en 60s. Revisa su estado con 'Probar conexion'.");
        }
        catch (Exception ex) { _runResult[processId] = (false, ex.Message); }
        finally { _busy = false; }
    });

    // ---- "Probar conexion" de un cliente remoto ----
    // Resultado por ClientId. No se consulta al pintar la lista a proposito: el estado cambia solo
    // (el agente puede caerse en cualquier momento) y un dato viejo pintado como si fuera fresco
    // engana mas que no mostrar nada. Se pregunta cuando el operador lo pide.

    private readonly Dictionary<string, (bool Online, string Texto)> _probe = new(StringComparer.Ordinal);

    private Task ProbeClientAsync(string clientId) => GuardAsync(() =>
    {
        var p = Agents.Get(clientId);
        if (p is null)
        {
            // Que NO haya agente es lo normal si aun no lo instalaron: el texto lo explica en vez de
            // dejar un "error" seco que parezca una averia.
            _probe[clientId] = (false, "Sin agente conectado. Instala la colmena con este ClientId y su secreto.");
        }
        else
        {
            var desde = (DateTimeOffset.UtcNow - p.ConnectedAt).TotalMinutes;
            var equipo = string.IsNullOrWhiteSpace(p.Host) ? "" : $" desde {p.Host}";
            var version = string.IsNullOrWhiteSpace(p.Version) ? "" : $" (v{p.Version})";
            _probe[clientId] = (true, $"En linea{equipo}{version} · conectado hace {Math.Max(0, (int)desde)} min");
        }
        return Task.CompletedTask;
    });

    // Destino.
    private DestinationKind _destKind = DestinationKind.System;
    private string _destEngine = "";
    private string _destHost = "";
    private string _destPort = "";
    private string _destDatabase = "";
    private string _destUser = "";
    private string _destCreds = "";
    private bool _destHasCreds;
    private string? _destError;

    // Clientes: solo se LISTAN aqui como referencia (nombre + ClientId + probar). El alta/rotacion/
    // revocacion vive en el modulo propio "Agentes Colmena" (ADR-0045, Ola 4).
    private IReadOnlyList<DataClientDto> _clients = Array.Empty<DataClientDto>();

    // Procesos.
    private IReadOnlyList<ImportProcessDto> _processes = Array.Empty<ImportProcessDto>();
    private Guid? _procEditId;
    private string _procName = "";
    private string _procConnector = "";
    private string _procClient = "";
    private ImportScheduleKind _procSchedule = ImportScheduleKind.Manual;
    private string _procIntervalText = "";
    private string _procCron = "";
    private bool _procActive = true;
    private string? _procError;

    // Serializa el acceso a la BD del circuito (evita "A second operation was started on this context").
    private readonly SemaphoreSlim _dbGate = new(1, 1);

    private sealed class ColumnDraft
    {
        public Guid? Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public DataContainerColumnType Type { get; set; } = DataContainerColumnType.Text;
        public bool IsRequired { get; set; }
        public Guid? ChildContainerId { get; set; }
    }

    private async Task GuardAsync(Func<Task> op)
    {
        await _dbGate.WaitAsync();
        try { await op(); }
        finally { _dbGate.Release(); }
    }

    public void Dispose()
    {
        _selfRef?.Dispose();
        _dbGate.Dispose();
    }

    protected override async Task OnInitializedAsync()
    {
        var eff = await Perms.GetAsync();
        _canCreate = eff.Can(ModuleKey, PermissionAction.Create);
        _canEdit = eff.Can(ModuleKey, PermissionAction.Edit);
        _canDelete = eff.Can(ModuleKey, PermissionAction.Delete);

        var state = await AuthProvider.GetAuthenticationStateAsync();
        _actor = Guid.TryParse(state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;

        _models = (await ModelSvc.ListAsync()).ToList();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
        }
        if (_modalOpen && _detail is not null && _selfRef is not null && !_canvasInit)
        {
            _canvasInit = true;
            try { await JS.InvokeVoidAsync("ecorexDcCanvas.init", _selfRef); }
            catch { /* JS no disponible: el arrastre no funcionara, pero la pagina sigue */ }
        }
    }

    // ---------- Lista ----------
    private Task ReloadListAsync() => GuardAsync(async () => _models = (await ModelSvc.ListAsync()).ToList());

    private void OpenCreate()
    {
        _mId = null;
        _mName = "";
        _mDescription = "";
        _detail = null;
        _headError = null;
        _pos.Clear();
        _connectors = Array.Empty<DataConnectorDto>();
        _processes = Array.Empty<ImportProcessDto>();
        _clients = Array.Empty<DataClientDto>();
        ResetConnectorForm();
        ResetProcessForm();
        ResetDestinationForm();
        _modalOpen = true;
    }

    private Task OpenModelAsync(Guid id) => GuardAsync(async () =>
    {
        _headError = null;
        ResetConnectorForm();
        ResetProcessForm();
        await LoadDetailCoreAsync(id);
        await LoadFeedingCoreAsync(id);
        _modalOpen = true;
    });

    private async Task LoadDetailCoreAsync(Guid id)
    {
        _detail = await ModelSvc.GetAsync(id);
        if (_detail is null) { return; }
        _mId = _detail.Id;
        _mName = _detail.Name;
        _mDescription = _detail.Description ?? "";
        RebuildPositions();
        await LoadPublishedFlagsAsync();
    }

    private void RebuildPositions()
    {
        _pos.Clear();
        if (_detail is null) { return; }
        var i = 0;
        foreach (var t in _detail.Tables)
        {
            var x = t.CanvasX;
            var y = t.CanvasY;
            if (x == 0 && y == 0)
            {
                (x, y) = SlotFor(i);
            }
            _pos[t.Id] = (x, y);
            i++;
        }
    }

    private void CloseModal()
    {
        _modalOpen = false;
        _canvasInit = false;
        _detail = null;
        _ = ReloadListAsync();
    }

    private Task SaveModelHeaderAsync() => GuardAsync(async () =>
    {
        _headError = null;
        if (string.IsNullOrWhiteSpace(_mName)) { _headError = "El nombre es obligatorio."; return; }
        _busy = true;
        try
        {
            var req = new SaveDataModelRequest(_mId, _mName.Trim(), string.IsNullOrWhiteSpace(_mDescription) ? null : _mDescription.Trim());
            var saved = await ModelSvc.SaveModelAsync(req, _actor);
            if (saved is null) { _headError = "No se pudo guardar el contenedor."; return; }
            var isNew = _mId is null;
            _mId = saved.Id;
            await LoadDetailCoreAsync(saved.Id);
            if (isNew) { await LoadFeedingCoreAsync(saved.Id); }
        }
        catch (Exception ex) { _headError = ex.Message; }
        finally { _busy = false; }
    });

    private Task DeleteModelAsync(Guid id, string name) => GuardAsync(async () =>
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Eliminar el contenedor '{name}' y todas sus tablas?");
        if (!ok) { return; }
        _busy = true;
        _pageError = null;
        try
        {
            await ModelSvc.DeleteModelAsync(id, _actor);
            _models = (await ModelSvc.ListAsync()).ToList();
        }
        catch (Exception ex) { _pageError = ex.Message; }
        finally { _busy = false; }
    });

    // ---------- Lienzo: posiciones + aristas ----------
    private double GetX(Guid tableId) => _pos.TryGetValue(tableId, out var p) ? p.X : 40;
    private double GetY(Guid tableId) => _pos.TryGetValue(tableId, out var p) ? p.Y : 40;

    private const double NodeW = 220;

    private const double NodeGap = 40;
    private const double RowH = 230;
    private const int NodesPerRow = 3;

    /// <summary>
    /// Donde nace la caja numero <paramref name="index"/> del lienzo: una REJILLA, no una cascada.
    ///
    /// Antes cada sitio calculaba `40 + n*40` en AMBOS ejes con intencion de "que no se apilen", pero
    /// un paso de 40px no despeja una caja de 220 de ancho: la tabla nueva caia sobre el ENCABEZADO de
    /// la anterior y le tapaba los botones (ver datos / publicar / editar / borrar), que quedaban
    /// imposibles de pulsar hasta que alguien arrastrara la caja. Ademas el calculo estaba DUPLICADO
    /// (aqui se pinta, en SaveTableAsync se persiste): por eso vive en un solo sitio.
    /// </summary>
    private static (double X, double Y) SlotFor(int index) =>
        (40 + (index % NodesPerRow) * (NodeW + NodeGap),
         40 + (index / NodesPerRow) * RowH);

    private double NodeH(Guid tableId)
    {
        var t = _detail?.Tables.FirstOrDefault(x => x.Id == tableId);
        var cols = t?.Columns.Count ?? 0;
        return 40 + Math.Max(1, cols) * 22;
    }

    private bool TryEdge(ModelRelationDto rel, out double x1, out double y1, out double x2, out double y2)
    {
        x1 = y1 = x2 = y2 = 0;
        if (_detail is null) { return false; }
        var from = _detail.Tables.FirstOrDefault(t => t.Id == rel.FromTableId);
        var to = _detail.Tables.FirstOrDefault(t => t.Id == rel.ToTableId);
        if (from is null || to is null) { return false; }
        x1 = GetX(rel.FromTableId) + NodeW / 2;
        y1 = GetY(rel.FromTableId) + NodeH(rel.FromTableId) / 2;
        x2 = GetX(rel.ToTableId) + NodeW / 2;
        y2 = GetY(rel.ToTableId) + NodeH(rel.ToTableId) / 2;
        return true;
    }

