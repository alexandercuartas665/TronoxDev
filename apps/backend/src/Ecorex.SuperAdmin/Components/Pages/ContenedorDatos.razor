    private Task SaveTableAsync() => GuardAsync(async () =>
    {
        _tblError = null;
        if (_mId is not Guid modelId) { _tblError = "Guarda el contenedor primero."; return; }
        if (string.IsNullOrWhiteSpace(_tblName)) { _tblError = "El nombre es obligatorio."; return; }
        var cols = _tblColumns
            .Where(c => !string.IsNullOrWhiteSpace(c.Name))
            .Select((c, i) => new SaveDataColumnInput(
                c.Id, c.Name.Trim(), c.Description, c.Type, i, c.IsRequired,
                c.Type == DataContainerColumnType.Submodel ? c.ChildContainerId : null))
            .ToList();
        if (cols.Count == 0) { _tblError = "Define al menos un campo."; return; }
        _busy = true;
        try
        {
            double x, y;
            if (_tblId is Guid existing && _pos.TryGetValue(existing, out var p))
            {
                x = p.X; y = p.Y;
            }
            else
            {
                // Misma rejilla que RebuildPositions: aqui es donde la posicion se PERSISTE, asi que
                // si los dos calculos no coinciden, el arreglo de uno no sirve de nada.
                (x, y) = SlotFor(_detail?.Tables.Count ?? 0);
            }
            var req = new SaveModelTableRequest(modelId, _tblId, _tblName.Trim(),
                string.IsNullOrWhiteSpace(_tblDescription) ? null : _tblDescription.Trim(), x, y, cols);
            var saved = await ModelSvc.SaveTableAsync(req, _actor);
            if (saved is null) { _tblError = "No se pudo guardar la tabla."; return; }
            // Si la tabla esta publicada, el item del menu sigue su nombre (la RUTA nunca cambia:
            // es la clave del modulo en la matriz de roles).
            await ModuleSvc.SyncNodeNameAsync(saved.Id);
            _tblOpen = false;
            await LoadDetailCoreAsync(modelId);
        }
        catch (Exception ex) { _tblError = ex.Message; }
        finally { _busy = false; }
    });

