    private IEnumerable<DataContainerColumnDto> PublishableColumns()
        => _pubTable is null
            ? Enumerable.Empty<DataContainerColumnDto>()
            : _pubTable.Columns.Where(c => c.Type != DataContainerColumnType.Submodel).OrderBy(c => c.SortOrder);

    private Task OpenPublishAsync(ModelTableDto t) => GuardAsync(async () =>
    {
        _pubTable = t;
        _pubError = null;
        _pubState = await ModuleSvc.GetAsync(t.Id);

        _pubViews = await MenuSvc.ListViewsAsync();
        _pubViewId = _pubViews.FirstOrDefault(v => v.IsDefault)?.Id ?? _pubViews.FirstOrDefault()?.Id ?? Guid.Empty;
        await LoadPublishGroupsAsync();

        _pubIcon = _pubState?.ModuleIcon ?? "";
        _pubListCols.Clear();
        _pubFilterCols.Clear();
        if (_pubState is not null)
        {
            foreach (var id in _pubState.ListColumnIds) { _pubListCols.Add(id); }
            foreach (var id in _pubState.FilterColumnIds) { _pubFilterCols.Add(id); }
        }
        _pubOpen = true;
    });

    /// <summary>Grupos (Section/Subgroup) de la vista elegida, indentados por profundidad.</summary>
    private async Task LoadPublishGroupsAsync()
    {
        _pubGroups.Clear();
        if (_pubViewId == Guid.Empty) { return; }
        var treeRes = await MenuSvc.GetViewTreeAsync(_pubViewId);
        var tree = treeRes.IsOk ? treeRes.Value : null;
        if (tree is null) { return; }

        void Walk(IReadOnlyList<MenuEditorNodeDto> nodes, int depth)
        {
            foreach (var n in nodes)
            {
                if (n.Kind is MenuNodeKind.Section or MenuNodeKind.Subgroup)
                {
                    _pubGroups.Add((n.Id, new string('-', depth * 2) + (depth > 0 ? " " : "") + n.Name));
                    Walk(n.Children, depth + 1);
                }
            }
        }
        Walk(tree.Roots, 0);
    }

