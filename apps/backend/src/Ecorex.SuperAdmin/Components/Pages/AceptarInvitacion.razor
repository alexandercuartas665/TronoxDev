@page "/invitacion/{Token}"
@layout EmptyLayout
@attribute [AllowAnonymous]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@inject IAdvisorService AdvisorsSvc
@inject NavigationManager Nav
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

<PageTitle>Activar cuenta - ECOREX.tareas</PageTitle>

<div class="login-wrap">
    <div class="login-card" style="width:420px;">
        <div class="login-logo">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
        </div>

        @if (_loading)
        {
            <p><em>Cargando invitacion...</em></p>
        }
        else if (_info is null || !_info.Valid)
        {
            <div class="login-title">Invitacion no valida</div>
            <p class="text-muted" style="margin-top:10px;">Este link de invitacion no existe o ya expiro. Pide a tu agencia que te envie uno nuevo.</p>
            <a class="btn btn-outline-secondary" href="/login" style="margin-top:14px;">Ir al inicio de sesion</a>
        }
        else if (_done)
        {
            <div class="login-title">Cuenta activada</div>
            <p class="text-muted" style="margin-top:10px;">Tu cuenta de asesor quedo lista. Ya puedes iniciar sesion con tu correo y tu clave.</p>
            <a class="btn btn-primary" href="/login" style="margin-top:14px;width:100%;">Iniciar sesion</a>
        }
        else
        {
            <div class="login-title">Bienvenido a <span>@_info.TenantName</span></div>
            <p class="text-muted" style="margin:6px 0 18px;font-size:0.9rem;">Completa tu registro como asesor para activar tu cuenta.</p>

            <div class="field">
                <label class="form-label">Correo</label>
                <input class="form-control" value="@_info.Email" disabled />
            </div>

            <div class="field">
                <label class="form-label">Tu foto (opcional)</label>
                <div style="display:flex;align-items:center;gap:14px;">
                    @if (_avatarPreview is { } prev)
                    {
                        <img src="@prev" alt="" style="width:56px;height:56px;border-radius:50%;object-fit:cover;border:1px solid var(--border);" />
                    }
                    else
                    {
                        <span style="width:56px;height:56px;border-radius:50%;display:grid;place-items:center;background:var(--primary-soft);color:var(--primary);font-weight:700;">@Initials()</span>
                    }
                    <InputFile OnChange="OnPhotoSelected" accept="image/png,image/jpeg,image/webp" class="form-control" style="max-width:240px;" />
                </div>
            </div>

            <div class="field">
                <label class="form-label">Nombre a mostrar</label>
                <input class="form-control" @bind="_displayName" autocomplete="off" />
            </div>
            <div class="field">
                <label class="form-label">Crea tu clave</label>
                <input class="form-control" type="password" @bind="_password" autocomplete="new-password" />
            </div>
            <div class="field">
                <label class="form-label">Confirma tu clave</label>
                <input class="form-control" type="password" @bind="_password2" autocomplete="new-password" />
            </div>

            @if (_error is not null)
            {
                <div class="text-danger small" style="margin-bottom:10px;">@_error</div>
            }
            <button class="btn btn-primary" style="width:100%;" @onclick="AcceptAsync" disabled="@_busy">@(_busy ? "Activando..." : "Activar mi cuenta")</button>
        }
    </div>
</div>

@code {
    [Parameter] public string Token { get; set; } = "";

    private bool _loading = true;
    private bool _busy;
    private bool _done;
    private string? _error;
    private AdvisorInvitationInfo? _info;

    private string? _displayName;
    private string _password = "";
    private string _password2 = "";
    private IBrowserFile? _photoFile;
    private string? _avatarPreview;

    protected override async Task OnInitializedAsync()
    {
        _info = await AdvisorsSvc.GetInvitationAsync(Token);
        _loading = false;
    }

    private async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        var file = e.File;
        var allowed = new[] { "image/png", "image/jpeg", "image/webp" };
        if (!allowed.Contains(file.ContentType))
        {
            _error = "Formato no permitido (PNG, JPG o WEBP).";
            return;
        }
        if (file.Size > 2 * 1024 * 1024)
        {
            _error = "La foto no debe superar 2 MB.";
            return;
        }
        _photoFile = file;
        using var ms = new MemoryStream();
        await file.OpenReadStream(2 * 1024 * 1024).CopyToAsync(ms);
        _avatarPreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
    }

    private async Task AcceptAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_password) || _password.Length < 6)
        {
            _error = "La clave debe tener al menos 6 caracteres.";
            return;
        }
        if (_password != _password2)
        {
            _error = "Las claves no coinciden.";
            return;
        }
        _busy = true;
        try
        {
            string? avatarUrl = null;
            if (_photoFile is not null)
            {
                var ext = _photoFile.ContentType switch
                {
                    "image/jpeg" => ".jpg",
                    "image/webp" => ".webp",
                    _ => ".png"
                };
                var dir = Path.Combine(Env.WebRootPath, "uploads", "avatars");
                Directory.CreateDirectory(dir);
                var fileName = $"avatar-{Guid.NewGuid():N}{ext}";
                var path = Path.Combine(dir, fileName);
                await using (var fs = File.Create(path))
                await using (var rs = _photoFile.OpenReadStream(2 * 1024 * 1024))
                {
                    await rs.CopyToAsync(fs);
                }
                avatarUrl = $"/uploads/avatars/{fileName}";
            }

            var email = await AdvisorsSvc.AcceptInvitationAsync(
                new AcceptInvitationRequest(Token, _password, _displayName, avatarUrl));
            if (email is null)
            {
                _error = "No se pudo activar la cuenta. El link pudo expirar; pide uno nuevo.";
                return;
            }
            _done = true;
        }
        finally { _busy = false; }
    }

    private string Initials()
    {
        var s = _displayName ?? _info?.Email ?? "?";
        var parts = s.Split(new[] { ' ', '@', '.' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) { return "?"; }
        return (parts[0][..1] + (parts.Length > 1 ? parts[1][..1] : "")).ToUpperInvariant();
    }
}
