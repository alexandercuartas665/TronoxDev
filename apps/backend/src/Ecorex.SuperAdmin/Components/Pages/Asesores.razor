@page "/asesores"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@inject IAdvisorService AdvisorsSvc
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Asesores - ECOREX.tareas</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <span>Mi agencia</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Asesores</h1>
        <p class="page-sub" style="margin-bottom:0;">Tu equipo comercial: invita asesores, define su rol y que clientes puede ver cada uno.</p>
    </div>
    @if (_canManage)
    {
        <button class="btn btn-primary" @onclick="OpenInvite">+ Invitar asesor</button>
    }
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else if (!_canManage)
{
    <p class="text-muted">Solo el propietario o un administrador de la agencia puede gestionar asesores.</p>
}
else
{
    <div class="kpi-grid" style="margin-bottom:22px;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));max-width:840px;">
        <div class="kpi-card">
            <div class="kpi-top"><div class="kpi-icon tone-primary"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div></div>
            <div class="kpi-label">Total asesores</div>
            <div class="kpi-value">@_advisors.Count</div>
            <div class="kpi-hint">Miembros del equipo</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-top"><div class="kpi-icon tone-success"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg></div></div>
            <div class="kpi-label">Activos</div>
            <div class="kpi-value">@_advisors.Count(a => a.Status == PlatformUserStatus.Active)</div>
            <div class="kpi-hint">Con acceso</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-top"><div class="kpi-icon tone-gold"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div></div>
            <div class="kpi-label">Invitaciones pendientes</div>
            <div class="kpi-value">@_advisors.Count(a => a.InvitePending)</div>
            <div class="kpi-hint">Sin completar registro</div>
        </div>
    </div>

    @if (_advisors.Count == 0)
    {
        <p class="text-muted">Aun no has invitado asesores. Usa "Invitar asesor".</p>
    }
    else
    {
        <div class="ase-viewbar">
            <button class="ase-vtab @(_view == "cards" ? "on" : "")" @onclick='() => _view = "cards"'>Tarjetas</button>
            <button class="ase-vtab @(_view == "list" ? "on" : "")" @onclick='() => _view = "list"'>Lista</button>
        </div>

        @if (_view == "cards")
        {
            <div class="ase-cards">
                @foreach (var a in _advisors)
                {
                    <div class="ase-card">
                        <div class="ase-card-top">
                            @if (a.AvatarUrl is { } av)
                            {
                                <img src="@av" alt="" class="ase-card-avatar" />
                            }
                            else
                            {
                                <span class="ase-card-avatar" style="display:grid;place-items:center;color:#fff;font-weight:700;background:@AseColor(a.DisplayName ?? a.Email)">@Initials(a.DisplayName ?? a.Email)</span>
                            }
                            <div style="min-width:0;flex:1;">
                                <div class="ase-card-name">@(string.IsNullOrWhiteSpace(a.DisplayName) ? "(Sin nombre)" : a.DisplayName)</div>
                                <div class="ase-card-mail">@a.Email</div>
                            </div>
                            @if (a.InvitePending)
                            {
                                <span class="badge bg-warning">Pendiente</span>
                            }
                            else
                            {
                                <span class="badge bg-@StatusColor(a.Status)">@StatusText(a.Status)</span>
                            }
                        </div>
                        <div class="ase-card-meta">
                            <span class="badge bg-secondary">@RoleText(a.Role)</span>
                            <span class="ase-chip">Ve: @VisibilityText(a.LeadVisibility)</span>
                            @if (!string.IsNullOrWhiteSpace(a.DocumentCode)) { <span class="ase-chip">Doc: @a.DocumentCode</span> }
                            @if (!string.IsNullOrWhiteSpace(a.Phone)) { <span class="ase-chip">Tel: @a.Phone</span> }
                        </div>
                        <div class="ase-card-actions">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenEdit(a)">Editar</button>
                            @if (a.InvitePending && a.InvitationToken is { } tk)
                            {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => ShowLink(tk)">Ver link</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => ResetAsync(a)" disabled="@_busy">Restablecer clave</button>
                            }
                            @if (a.Status == PlatformUserStatus.Active)
                            {
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => SetStatusAsync(a, PlatformUserStatus.Suspended)">Suspender</button>
                            }
                            else if (!a.InvitePending)
                            {
                                <button class="btn btn-sm btn-outline-success" @onclick="() => SetStatusAsync(a, PlatformUserStatus.Active)">Activar</button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
        <div class="card" style="max-width:1040px;padding:6px 16px;">
            <table class="table table-hover align-middle" style="margin-bottom:0;">
                <thead>
                    <tr><th>Asesor</th><th>Rol</th><th>Ve clientes</th><th>Estado</th><th class="text-end">Acciones</th></tr>
                </thead>
                <tbody>
                    @foreach (var a in _advisors)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    @if (a.AvatarUrl is { } av)
                                    {
                                        <img src="@av" alt="" style="width:34px;height:34px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
                                    }
                                    else
                                    {
                                        <span style="width:34px;height:34px;border-radius:50%;flex-shrink:0;display:grid;place-items:center;color:#fff;font-weight:700;font-size:12px;background:@AseColor(a.DisplayName ?? a.Email)">@Initials(a.DisplayName ?? a.Email)</span>
                                    }
                                    <div style="min-width:0;">
                                        <div style="font-weight:600;">@(string.IsNullOrWhiteSpace(a.DisplayName) ? "(Sin nombre)" : a.DisplayName)</div>
                                        <div class="text-muted" style="font-size:12px;">@a.Email</div>
                                        @if (!string.IsNullOrWhiteSpace(a.DocumentCode) || !string.IsNullOrWhiteSpace(a.Phone))
                                        {
                                            <div class="text-muted" style="font-size:11.5px;">
                                                @if (!string.IsNullOrWhiteSpace(a.DocumentCode)) { <span>Doc: @a.DocumentCode</span> }
                                                @if (!string.IsNullOrWhiteSpace(a.DocumentCode) && !string.IsNullOrWhiteSpace(a.Phone)) { <span> &middot; </span> }
                                                @if (!string.IsNullOrWhiteSpace(a.Phone)) { <span>Tel: @a.Phone</span> }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge bg-secondary">@RoleText(a.Role)</span></td>
                            <td style="font-size:12.5px;">@VisibilityText(a.LeadVisibility)</td>
                            <td>
                                @if (a.InvitePending)
                                {
                                    <span class="badge bg-warning">Invitacion pendiente</span>
                                }
                                else
                                {
                                    <span class="badge bg-@StatusColor(a.Status)">@StatusText(a.Status)</span>
                                }
                            </td>
                            <td class="text-end" style="white-space:nowrap;">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenEdit(a)">Editar</button>
                                @if (a.InvitePending && a.InvitationToken is { } tk)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ShowLink(tk)">Ver link</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ResetAsync(a)" disabled="@_busy">Restablecer clave</button>
                                }
                                @if (a.Status == PlatformUserStatus.Active)
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => SetStatusAsync(a, PlatformUserStatus.Suspended)">Suspender</button>
                                }
                                else if (!a.InvitePending)
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => SetStatusAsync(a, PlatformUserStatus.Active)">Activar</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        }
    }
}

@* ===== Modal: invitar asesor ===== *@
@if (_inviteOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <h3>Invitar asesor</h3>
                <button class="modal-close" @onclick="() => _inviteOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Correo del asesor *</label>
                    <input class="form-control" type="email" @bind="_iv.Email" autocomplete="off" placeholder="asesor@agencia.com" />
                </div>
                <div class="field">
                    <label class="form-label">Nombre (opcional)</label>
                    <input class="form-control" @bind="_iv.DisplayName" autocomplete="off" />
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Codigo / documento</label>
                        <input class="form-control" @bind="_iv.DocumentCode" autocomplete="off" placeholder="Ej. V-001 o cedula" />
                    </div>
                    <div class="field">
                        <label class="form-label">Telefono</label>
                        <input class="form-control" @bind="_iv.Phone" autocomplete="off" />
                    </div>
                </div>
                <div class="field">
                    <label class="form-label">Que clientes puede ver</label>
                    <select class="form-control" @bind="_iv.LeadVisibility">
                        <option value="@LeadVisibility.OwnOnly">Solo sus clientes asignados</option>
                        <option value="@LeadVisibility.All">Todos los clientes de la agencia</option>
                    </select>
                </div>
                <p class="text-muted" style="font-size:12px;">Se genera un link de invitacion para que el asesor cree su clave y suba su foto. Comparteselo (correo, WhatsApp, etc.).</p>
                @if (_inviteError is not null)
                {
                    <div class="text-danger small">@_inviteError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _inviteOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="CreateAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_iv.Email))">Crear invitacion</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: editar asesor ===== *@
@if (_editOpen && _editing is not null)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <h3>Editar asesor</h3>
                <button class="modal-close" @onclick="() => _editOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Correo (login del asesor)</label>
                    <input class="form-control" type="email" @bind="_ef.Email" autocomplete="off" />
                    <p class="text-muted" style="font-size:11.5px;margin:4px 0 0;">Es el correo con el que inicia sesion. Cambiarlo actualiza su login.</p>
                </div>
                <div class="field">
                    <label class="form-label">Nombre</label>
                    <input class="form-control" @bind="_ef.DisplayName" />
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Codigo / documento</label>
                        <input class="form-control" @bind="_ef.DocumentCode" placeholder="Ej. V-001 o cedula" />
                    </div>
                    <div class="field">
                        <label class="form-label">Telefono</label>
                        <input class="form-control" @bind="_ef.Phone" />
                    </div>
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Rol</label>
                        <select class="form-control" @bind="_ef.Role">
                            <option value="@TenantRole.Advisor">Asesor</option>
                            <option value="@TenantRole.Supervisor">Supervisor</option>
                            <option value="@TenantRole.Admin">Administrador</option>
                            <option value="@TenantRole.Owner">Propietario</option>
                        </select>
                    </div>
                    <div class="field">
                        <label class="form-label">Ve clientes</label>
                        <select class="form-control" @bind="_ef.LeadVisibility">
                            <option value="@LeadVisibility.OwnOnly">Solo los suyos</option>
                            <option value="@LeadVisibility.All">Todos</option>
                        </select>
                    </div>
                </div>
                @if (_editError is not null)
                {
                    <div class="text-danger small">@_editError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _editOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveEditAsync" disabled="@_busy">Guardar</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: link de invitacion ===== *@
@if (_linkOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <h3>Link de invitacion</h3>
                <button class="modal-close" @onclick="() => _linkOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <p class="text-muted" style="font-size:12px;margin-top:0;">Comparte este link con el asesor. Al abrirlo, creara su clave y subira su foto para activar su cuenta.</p>
                <div style="display:flex;gap:8px;">
                    <input class="form-control" readonly value="@_inviteLink" style="font-size:12px;" @ref="_linkInput" />
                    <button class="btn btn-primary" style="white-space:nowrap;" @onclick="CopyLinkAsync">@(_copied ? "Copiado" : "Copiar")</button>
                </div>
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _linkOpen = false">Cerrar</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private bool _canManage;
    private List<AdvisorDto> _advisors = new();
    // Vista: "cards" (tarjetas) o "list" (tabla).
    private string _view = "cards";

    private bool _inviteOpen;
    private string? _inviteError;
    private InviteForm _iv = new();

    private bool _editOpen;
    private string? _editError;
    private AdvisorDto? _editing;
    private EditForm2 _ef = new();

    private bool _linkOpen;
    private string _inviteLink = "";
    private bool _copied;
    private ElementReference _linkInput;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            var role = state.User.FindFirst("tenant_role")?.Value;
            _canManage = role is "Owner" or "Admin";
        }
        if (_canManage)
        {
            await ReloadAsync();
        }
        _loading = false;
    }

    private async Task ReloadAsync() => _advisors = (await AdvisorsSvc.ListAsync()).ToList();

    private void OpenInvite()
    {
        _inviteError = null;
        _iv = new InviteForm();
        _inviteOpen = true;
    }

    private async Task CreateAsync()
    {
        _inviteError = null;
        if (string.IsNullOrWhiteSpace(_iv.Email))
        {
            _inviteError = "Escribe el correo del asesor.";
            return;
        }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var created = await AdvisorsSvc.CreateAsync(
                new CreateAdvisorRequest(_iv.Email, _iv.DisplayName, _iv.LeadVisibility, DocumentCode: _iv.DocumentCode, Phone: _iv.Phone), actor);
            if (created is null)
            {
                _inviteError = "No se pudo crear (quiza el correo ya es miembro de la agencia).";
                return;
            }
            _inviteOpen = false;
            await ReloadAsync();
            if (created.InvitationToken is { } tk)
            {
                ShowLink(tk);
            }
        }
        finally { _busy = false; }
    }

    private void OpenEdit(AdvisorDto a)
    {
        _editError = null;
        _editing = a;
        _ef = new EditForm2 { Email = a.Email, DisplayName = a.DisplayName, DocumentCode = a.DocumentCode, Phone = a.Phone, Role = a.Role, LeadVisibility = a.LeadVisibility };
        _editOpen = true;
    }

    private async Task SaveEditAsync()
    {
        if (_editing is null) { return; }
        _editError = null;
        if (string.IsNullOrWhiteSpace(_ef.Email))
        {
            _editError = "El correo no puede quedar vacio.";
            return;
        }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var updated = await AdvisorsSvc.UpdateAsync(_editing.Id,
                new UpdateAdvisorRequest(_ef.DisplayName, _ef.LeadVisibility, _ef.Role, DocumentCode: _ef.DocumentCode, Phone: _ef.Phone, Email: _ef.Email), actor);
            if (updated is null)
            {
                _editError = "No se pudo guardar (quiza el correo ya esta en uso por otra cuenta).";
                return;
            }
            _editOpen = false;
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task SetStatusAsync(AdvisorDto a, PlatformUserStatus status)
    {
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            await AdvisorsSvc.SetStatusAsync(a.Id, status, actor);
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task ResetAsync(AdvisorDto a)
    {
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var updated = await AdvisorsSvc.ResendInviteAsync(a.Id, actor);
            await ReloadAsync();
            if (updated?.InvitationToken is { } tk)
            {
                ShowLink(tk);
            }
        }
        finally { _busy = false; }
    }

    private void ShowLink(string token)
    {
        _inviteLink = $"{Nav.BaseUri}invitacion/{token}";
        _copied = false;
        _linkOpen = true;
    }

    private async Task CopyLinkAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _inviteLink);
            _copied = true;
        }
        catch { /* el usuario puede copiar manualmente */ }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private static string Initials(string s)
    {
        var parts = s.Split(new[] { ' ', '@', '.' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) { return "?"; }
        var first = parts[0][..1];
        var second = parts.Length > 1 ? parts[1][..1] : "";
        return (first + second).ToUpperInvariant();
    }

    private static string AseColor(string name)
    {
        if (string.IsNullOrEmpty(name)) { return "#6D28D9"; }
        var palette = new[] { "#A03DC9", "#D89A36", "#4F8A60", "#4E80B5", "#C7398B" };
        return palette[char.ToUpperInvariant(name[0]) % palette.Length];
    }

    private static string RoleText(TenantRole r) => r switch
    {
        TenantRole.Owner => "Propietario",
        TenantRole.Admin => "Administrador",
        TenantRole.Supervisor => "Supervisor",
        _ => "Asesor"
    };

    private static string VisibilityText(LeadVisibility v) =>
        v == LeadVisibility.All ? "Todos los clientes" : "Solo los suyos";

    private static string StatusText(PlatformUserStatus s) => s switch
    {
        PlatformUserStatus.Active => "Activo",
        PlatformUserStatus.Suspended => "Suspendido",
        PlatformUserStatus.Blocked => "Bloqueado",
        _ => "Invitado"
    };

    private static string StatusColor(PlatformUserStatus s) => s switch
    {
        PlatformUserStatus.Active => "success",
        PlatformUserStatus.Suspended or PlatformUserStatus.Blocked => "danger",
        _ => "warning"
    };

    private sealed class InviteForm
    {
        public string Email { get; set; } = "";
        public string? DisplayName { get; set; }
        public string? DocumentCode { get; set; }
        public string? Phone { get; set; }
        public LeadVisibility LeadVisibility { get; set; } = LeadVisibility.OwnOnly;
    }

    private sealed class EditForm2
    {
        public string? Email { get; set; }
        public string? DisplayName { get; set; }
        public string? DocumentCode { get; set; }
        public string? Phone { get; set; }
        public TenantRole Role { get; set; } = TenantRole.Advisor;
        public LeadVisibility LeadVisibility { get; set; } = LeadVisibility.OwnOnly;
    }
}
