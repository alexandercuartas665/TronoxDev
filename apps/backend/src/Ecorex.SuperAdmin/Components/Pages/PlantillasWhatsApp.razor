@page "/plantillas-whatsapp"
@attribute [Authorize(Policy = "PlantillasWhatsApp.Editar")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@inject IWhatsAppTemplateService TemplateSvc
@inject IWhatsAppLineService LineSvc

<PageTitle>Plantillas WhatsApp - ECOREX.tareas</PageTitle>

<nav class="ecorex-breadcrumb" aria-label="Ruta de navegacion">
    <a href="/inicio">Workspace</a>
    <span class="sep">/</span>
    <span>CRM</span>
    <span class="sep">/</span>
    <span class="cur">Plantillas WhatsApp</span>
</nav>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
            </div>
            <span>CRM (heredado) &#183; Plantillas HSM</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Plantillas de WhatsApp</h1>
        <p class="page-sub" style="margin-bottom:0;">Mensajes plantilla (HSM) con categoria, idioma, variables y ciclo de aprobacion.</p>
    </div>
    <div>
        <button class="btn btn-primary" @onclick="@(() => OpenEditorAsync(null))">+ Nueva plantilla</button>
    </div>
</div>

@* ===== Banner: integracion con Meta no implementada (deuda documentada, ADR-0029) ===== *@
<div class="wa-banner" role="note">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
    <div>
        <strong>Envio al proveedor no implementado.</strong>
        La integracion real con la WhatsApp Cloud API de Meta es una deuda documentada (ADR-0029).
        "Someter" solo cambia el estado a <em>Submitted</em> localmente; la sincronizacion de
        estado con el proveedor esta deshabilitada.
    </div>
</div>

<div class="wa-filters">
    <label class="pl-toggle" style="margin-left:auto;">
        <input type="checkbox" checked="@_includeInactive" @onchange="@(async e => { _includeInactive = (bool)e.Value!; await ReloadAsync(); })" />
        Ver archivadas
    </label>
</div>

@if (_loading)
{
    <p><em>Cargando plantillas...</em></p>
}
else if (_templates.Count == 0)
{
    <div class="coming-soon" style="padding:40px 24px;">
        <h3>Sin plantillas</h3>
        <p>No hay plantillas todavia. Crea la primera para empezar.</p>
        <button class="btn btn-primary" style="margin-top:14px;" @onclick="@(() => OpenEditorAsync(null))">+ Nueva plantilla</button>
    </div>
}
else
{
    <table class="table table-hover wa-templates-table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Idioma</th>
                <th>Categoria</th>
                <th>Linea</th>
                <th>Estado</th>
                <th style="text-align:right;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in _templates)
            {
                <tr class="@(t.IsActive ? "" : "inactive-row")">
                    <td><strong>@t.Name</strong></td>
                    <td class="muted-cell">@t.Language</td>
                    <td class="muted-cell">@t.Category</td>
                    <td class="muted-cell">@(t.WhatsAppLineName ?? "-")</td>
                    <td>
                        <span class="wa-badge @StatusClass(t.Status)">@StatusLabel(t.Status)</span>
                        @if (t.Status == WhatsAppTemplateStatus.Rejected && !string.IsNullOrEmpty(t.RejectionReason))
                        {
                            <small style="display:block;color:var(--danger, var(--destructive));">@t.RejectionReason</small>
                        }
                    </td>
                    <td style="text-align:right;white-space:nowrap;">
                        @if (CanSubmit(t.Status) && t.IsActive)
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="@(() => SubmitAsync(t))" disabled="@_busy">Someter</button>
                        }
                        <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => OpenEditorAsync(t.Id))" disabled="@(!CanEdit(t.Status))">Editar</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="@(() => ToggleActiveAsync(t))" disabled="@_busy">
                            @(t.IsActive ? "Archivar" : "Restaurar")
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (_pageError is not null)
    {
        <div class="tk-field-error">@_pageError</div>
    }
}

@* ===== Modal crear/editar plantilla ===== *@
@if (_showEditor)
{
    <div class="modal-overlay" @onclick="@(() => _showEditor = false)">
        <div class="modal-dialog" style="max-width:720px;" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>@(_editingId is null ? "Nueva plantilla" : $"Editar {_fName}")</h3>
                <button class="modal-close" @onclick="@(() => _showEditor = false)">&times;</button>
            </div>
            <div class="modal-body">
                <div class="row g-2">
                    <div class="col-md-6 field">
                        <label class="form-label">Nombre *</label>
                        <input class="form-control" @bind="_fName" maxlength="200" placeholder="ej. bienvenida_cliente" />
                    </div>
                    <div class="col-md-3 field">
                        <label class="form-label">Idioma *</label>
                        <input class="form-control" @bind="_fLanguage" maxlength="12" placeholder="es" />
                    </div>
                    <div class="col-md-3 field">
                        <label class="form-label">Categoria *</label>
                        <select class="form-control" @bind="_fCategory">
                            @foreach (var c in Enum.GetValues<WhatsAppTemplateCategory>())
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="field">
                    <label class="form-label">Linea de WhatsApp *</label>
                    <select class="form-control" @bind="_fLine">
                        <option value="">(Elige una linea)</option>
                        @foreach (var l in _lines)
                        {
                            <option value="@l.Id">@l.InstanceName</option>
                        }
                    </select>
                    @if (_lines.Count == 0)
                    {
                        <em class="muted-cell">No hay lineas de WhatsApp. Crea una en Lineas WhatsApp del CRM.</em>
                    }
                </div>
                <div class="field">
                    <label class="form-label">Encabezado (texto, opcional)</label>
                    <input class="form-control" @bind="_fHeaderText" maxlength="60" />
                </div>
                <div class="field">
                    <label class="form-label">Cuerpo *</label>
                    <textarea class="form-control" rows="4" maxlength="1024" @bind="_fBodyText"
                              placeholder="Hola {{cliente}}, gracias por contactar a {{empresa}}."></textarea>
                    <small class="muted-cell">Usa tokens como @("{{cliente}}"), @("{{empresa}}"). Variables detectadas: @DetectedTokens</small>
                </div>
                <div class="field">
                    <label class="form-label">Pie (opcional)</label>
                    <input class="form-control" @bind="_fFooterText" maxlength="60" />
                </div>

                @if (_editorError is not null)
                {
                    <div class="tk-field-error">@_editorError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="@(() => _showEditor = false)" disabled="@_busy">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_busy">@(_editingId is null ? "Crear plantilla" : "Guardar")</button>
            </div>
        </div>
    </div>
}

<style>
    .wa-banner { display: flex; gap: 10px; align-items: flex-start; padding: 12px 14px; margin-bottom: 16px; border-radius: 10px; background: var(--surface-2, var(--accent)); border: 1px solid var(--line, var(--border)); color: var(--ink-2, var(--muted-foreground)); font-size: 13px; }
    .wa-banner svg { width: 18px; height: 18px; flex: none; margin-top: 1px; color: var(--t-blue, var(--primary)); }
    .wa-banner strong { color: var(--ink, var(--foreground)); }
    .wa-filters { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 16px; }
    .wa-badge { display: inline-block; font-size: 11.5px; font-weight: 700; padding: 2px 9px; border-radius: 999px; }
    .wa-badge.wa-draft { background: var(--surface-2, var(--accent)); color: var(--ink-2, var(--muted-foreground)); }
    .wa-badge.wa-submitted { background: var(--t-blue-bg, var(--primary-soft)); color: var(--t-blue, var(--primary)); }
    .wa-badge.wa-approved { background: var(--t-green-bg, #dcfce7); color: var(--t-green, #16a34a); }
    .wa-badge.wa-rejected { background: var(--t-red-bg, #fee2e2); color: var(--danger, var(--destructive)); }
    .wa-badge.wa-paused { background: var(--t-amber-bg, #fef3c7); color: var(--t-amber, #d97706); }
</style>

@code {
    private bool _loading = true;
    private bool _busy;
    private bool _includeInactive;
    private string? _pageError;

    private IReadOnlyList<WhatsAppTemplateDto> _templates = [];
    private IReadOnlyList<WhatsAppLineDto> _lines = [];

    // Editor
    private bool _showEditor;
    private Guid? _editingId;
    private string _fName = "";
    private string _fLanguage = "es";
    private WhatsAppTemplateCategory _fCategory = WhatsAppTemplateCategory.Utility;
    private string _fLine = "";
    private string? _fHeaderText;
    private string _fBodyText = "";
    private string? _fFooterText;
    private string? _editorError;

    private string DetectedTokens
    {
        get
        {
            var tokens = WhatsAppTemplateCalculations.ExtractTokens(_fBodyText);
            return tokens.Count == 0 ? "(ninguna)" : string.Join(", ", tokens);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _lines = await LineSvc.ListAsync();
        await ReloadAsync();
        _loading = false;
    }

    private async Task ReloadAsync()
    {
        _templates = await TemplateSvc.ListAsync(_includeInactive);
    }

    private void OpenEditorAsync_Reset()
    {
        _editorError = null;
        _fName = "";
        _fLanguage = "es";
        _fCategory = WhatsAppTemplateCategory.Utility;
        _fLine = _lines.Count > 0 ? _lines[0].Id.ToString() : "";
        _fHeaderText = null;
        _fBodyText = "";
        _fFooterText = null;
    }

    private async Task OpenEditorAsync(Guid? id)
    {
        OpenEditorAsync_Reset();
        if (id is Guid tid)
        {
            var detail = await TemplateSvc.GetAsync(tid);
            if (detail is null) { return; }
            _editingId = tid;
            _fName = detail.Name;
            _fLanguage = detail.Language;
            _fCategory = detail.Category;
            _fLine = detail.WhatsAppLineId.ToString();
            _fHeaderText = detail.HeaderText;
            _fBodyText = detail.BodyText;
            _fFooterText = detail.FooterText;
        }
        else
        {
            _editingId = null;
        }
        _showEditor = true;
    }

    private async Task SaveAsync()
    {
        _busy = true;
        _editorError = null;
        if (!Guid.TryParse(_fLine, out var lineId))
        {
            _editorError = "Elige la linea por la que se someteria.";
            _busy = false;
            return;
        }
        var request = new SaveWhatsAppTemplateRequest(
            _fName,
            _fLanguage,
            _fCategory,
            _fBodyText,
            lineId,
            HeaderText: _fHeaderText,
            FooterText: _fFooterText,
            Variables: WhatsAppTemplateCalculations.ExtractTokens(_fBodyText)
                .Select(tok => new WhatsAppTemplateVariable(
                    tok, WhatsAppTemplateVariableCatalog.Find(tok)?.DefaultExample ?? tok)).ToList());
        var result = _editingId is null
            ? await TemplateSvc.CreateAsync(request)
            : await TemplateSvc.UpdateAsync(_editingId.Value, request);
        if (!result.IsOk)
        {
            _editorError = result.Error;
            _busy = false;
            return;
        }
        _showEditor = false;
        _busy = false;
        await ReloadAsync();
    }

    private async Task SubmitAsync(WhatsAppTemplateDto template)
    {
        _busy = true;
        _pageError = null;
        var result = await TemplateSvc.SubmitAsync(template.Id);
        if (!result.IsOk)
        {
            _pageError = result.Error;
        }
        else
        {
            await ReloadAsync();
        }
        _busy = false;
    }

    private async Task ToggleActiveAsync(WhatsAppTemplateDto template)
    {
        _busy = true;
        _pageError = null;
        var result = await TemplateSvc.SetActiveAsync(template.Id, !template.IsActive);
        if (!result.IsOk)
        {
            _pageError = result.Error;
        }
        else
        {
            await ReloadAsync();
        }
        _busy = false;
    }

    private static bool CanEdit(WhatsAppTemplateStatus status)
        => WhatsAppTemplateCalculations.CanEdit(status);

    private static bool CanSubmit(WhatsAppTemplateStatus status)
        => WhatsAppTemplateCalculations.CanSubmit(status);

    private static string StatusClass(WhatsAppTemplateStatus status) => status switch
    {
        WhatsAppTemplateStatus.Draft => "wa-draft",
        WhatsAppTemplateStatus.Submitted => "wa-submitted",
        WhatsAppTemplateStatus.Approved => "wa-approved",
        WhatsAppTemplateStatus.Rejected => "wa-rejected",
        WhatsAppTemplateStatus.Paused => "wa-paused",
        _ => "wa-draft"
    };

    private static string StatusLabel(WhatsAppTemplateStatus status) => status switch
    {
        WhatsAppTemplateStatus.Draft => "Borrador",
        WhatsAppTemplateStatus.Submitted => "Sometida",
        WhatsAppTemplateStatus.Approved => "Aprobada",
        WhatsAppTemplateStatus.Rejected => "Rechazada",
        WhatsAppTemplateStatus.Paused => "Pausada",
        WhatsAppTemplateStatus.Disabled => "Deshabilitada",
        _ => status.ToString()
    };
}
