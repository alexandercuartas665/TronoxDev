    {
        _stepError = null;
        _showStepEditor = true;
        _editingStepId = s?.Id;
        _sKind = s?.Kind ?? ScrapeStepKind.Navigate;
        _sName = s?.Name ?? "";
        _sUrl = s?.Url ?? "";
        _sScript = s?.Script ?? "";
        _sSelector = s?.Selector ?? "";
        _sWaitMs = s?.WaitMs?.ToString() ?? "";
        _sMappingJson = s?.MappingJson ?? "";
        _sInstruction = s?.Instruction ?? "";
        _sTargetContainer = s?.TargetContainerId?.ToString() ?? "";
        _sToolAllow = "";
        _sMaxSteps = s?.MaxSteps?.ToString() ?? "";
        _sMaxSeconds = s?.MaxSeconds?.ToString() ?? "";
        _sAiProviderId = s?.AiProviderId?.ToString() ?? "";
        _sWarnLabel = s?.WarningLabel ?? "";
        _sWarnAction = s?.WarningAction ?? ScrapeWarningAction.None;
    }

    private async Task SaveStepAsync()
    {
        if (_selected is null) { return; }
        _stepError = null;
        _busy = true;
        try
        {
            var order = _editingStepId is null ? _selected.Steps.Count : _selected.Steps.First(x => x.Id == _editingStepId).Order;
            var toolJson = string.IsNullOrWhiteSpace(_sToolAllow) ? null
                : System.Text.Json.JsonSerializer.Serialize(_sToolAllow.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
            var req = new SaveScrapeStepRequest(
                _editingStepId, _selected.Id, order, _sKind, _sName,
                WaitMs: ParseInt(_sWaitMs), Url: NullIfBlank(_sUrl), Script: NullIfBlank(_sScript),
                Selector: NullIfBlank(_sSelector), MappingJson: NullIfBlank(_sMappingJson),
                Instruction: NullIfBlank(_sInstruction), TargetContainerId: ParseGuid(_sTargetContainer),
                ToolAllowListJson: toolJson, MaxSteps: ParseInt(_sMaxSteps), MaxSeconds: ParseInt(_sMaxSeconds),
                AiProviderId: ParseGuid(_sAiProviderId), AiModel: null,
                WarningLabel: NullIfBlank(_sWarnLabel), WarningAction: _sWarnAction);
            var saved = await FlowSvc.SaveStepAsync(req, _actor);
            if (saved is null) { _stepError = "No se pudo guardar el paso."; return; }
            _showStepEditor = false;
            await SelectFlowAsync(_selected.Id);
            await ReloadFlowsAsync();
        }
        catch (Exception ex) { _stepError = ex.Message; }
        finally { _busy = false; }
    }

    private async Task DeleteStepAsync(Guid stepId)
    {
        if (_selected is null) { return; }
        _busy = true;
        try
        {
            await FlowSvc.DeleteStepAsync(stepId, _actor);
            await SelectFlowAsync(_selected.Id);
            await ReloadFlowsAsync();
        }
        catch (Exception ex) { Flash(ex.Message, true); }
        finally { _busy = false; }
    }

    private async Task MoveStepAsync(int index, int delta)
    {
        if (_selected is null) { return; }
        var ids = _selected.Steps.Select(s => s.Id).ToList();
        var target = index + delta;
        if (target < 0 || target >= ids.Count) { return; }
        (ids[index], ids[target]) = (ids[target], ids[index]);
        _busy = true;
        try
        {
            await FlowSvc.ReorderStepsAsync(_selected.Id, ids, _actor);
            await SelectFlowAsync(_selected.Id);
        }
        catch (Exception ex) { Flash(ex.Message, true); }
        finally { _busy = false; }
    }

