    private List<ScrapeFlowSummaryDto> FilteredFlows =>
        string.IsNullOrWhiteSpace(_search)
            ? _flows.ToList()
            : _flows.Where(f => f.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        _actor = Guid.TryParse(state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
        _clients = await ConfigSvc.ListClientsAsync();
        _containers = await FlowSvc.ListContainersAsync();
        _aiProviders = await AiSvc.ListEnabledAsync();
        await ReloadFlowsAsync();
    }

    private async Task ReloadFlowsAsync() => _flows = await FlowSvc.ListAsync();

    private async Task SelectFlowAsync(Guid id)
    {
        _isNew = false;
        _editHeader = false;
        _showStepEditor = false;
        _showVarEditor = false;
        _selected = await FlowSvc.GetAsync(id);
        if (_selected is not null)
        {
            _hClient = _selected.ClientId?.ToString() ?? "";
            _hContainer = _selected.ContainerId?.ToString() ?? "";
            _runs = await FlowSvc.ListRunsAsync(id);
            _schedule = await FlowSvc.GetScheduleAsync(id);
            _schError = null;
            if (_schedule is not null)
            {
                _schKind = _schedule.Kind;
                _schInterval = _schedule.IntervalMinutes ?? 60;
                _schCron = _schedule.CronExpression ?? "";
                _schActive = _schedule.IsActive;
            }
            else { _schKind = ImportScheduleKind.Manual; _schInterval = 60; _schCron = ""; _schActive = true; }
        }
        else { _runs = Array.Empty<ScrapeFlowRunDto>(); _schedule = null; }
    }

    private async Task SaveScheduleAsync()
    {
        if (_selected is null) { return; }
        _schError = null;
        _busy = true;
        try
        {
            _schedule = await FlowSvc.SaveScheduleAsync(new SaveScrapeScheduleRequest(
                _selected.Id, _schKind,
                _schKind == ImportScheduleKind.Interval ? _schInterval : null,
                _schKind == ImportScheduleKind.Cron ? NullIfBlank(_schCron) : null,
                _schActive), _actor);
            Flash("Programacion guardada.");
        }
        catch (Exception ex) { _schError = ex.Message; }
        finally { _busy = false; }
    }

    private async Task RunFlowAsync()
    {
        if (_selected is null) { return; }
        if (Tenant.TenantId is not Guid tenantId) { Flash("No se pudo resolver el tenant.", true); return; }
        _busy = true;
        try
        {
            var result = await RunSvc.RunFlowNowAsync(_selected.Id, tenantId, ImportRunTrigger.Manual);
            if (result.Offline)
            {
                Flash("El agente asignado no esta en linea. La corrida quedo esperando a que vuelva.");
            }
            else if (!result.Dispatched)
            {
                Flash(result.Error ?? "No se pudo ejecutar el flujo.", true);
            }
            else
            {
                Flash("Flujo despachado al agente. El resultado aparecera en el historial al completarse.");
            }
            // Recarga la bitacora y el flujo (LastRunAt/estado pudieron cambiar).
            await SelectFlowAsync(_selected.Id);
            await ReloadFlowsAsync();
        }
        catch (Exception ex) { Flash(ex.Message, true); }
        finally { _busy = false; }
    }

    private void NewFlow()
    {
        _isNew = true;
        _selected = null;
        _headError = null;
        _hName = ""; _hUrl = "";
    }

    private void CancelNew() => _isNew = false;

    private async Task CreateFlowAsync()
    {
        _headError = null;
        _busy = true;
        try
        {
            var saved = await FlowSvc.SaveFlowAsync(new SaveScrapeFlowRequest(
