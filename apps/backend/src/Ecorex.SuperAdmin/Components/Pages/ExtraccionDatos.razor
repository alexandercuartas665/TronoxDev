    // ---- Agente colmena: test de conexion + alta ----

    private async Task OnAgentChanged()
    {
        _probe = null; // el estado del agente anterior no aplica al recien elegido.
        await SaveAssignmentsAsync();
    }

    private void TestConnectionAsync()
    {
        // Le pregunta al REGISTRO del hub si el ClientId del agente elegido tiene una conexion viva. No
        // se guarda ni se cachea: el agente puede caerse en cualquier momento, y un dato viejo enganaria.
        var clientId = _clients.FirstOrDefault(c => c.Id.ToString() == _hClient)?.ClientId;
        if (clientId is null) { _probe = (false, "Elige un agente primero."); return; }
        var p = Agents.Get(clientId);
        if (p is null)
        {
            _probe = (false, $"Sin agente conectado. Instala la colmena con el ClientId '{clientId}' y su secreto.");
        }
        else
        {
            var mins = Math.Max(0, (int)(DateTimeOffset.UtcNow - p.ConnectedAt).TotalMinutes);
            var host = string.IsNullOrWhiteSpace(p.Host) ? "" : $" desde {p.Host}";
            var ver = string.IsNullOrWhiteSpace(p.Version) ? "" : $" (v{p.Version})";
            _probe = (true, $"En linea{host}{ver} · conectado hace {mins} min");
        }
    }

