@page "/pipeline"
@attribute [Authorize]
@* prerender:false evita que OnInitializedAsync corra dos veces (SSR + circuito) y choque el DbContext scoped al cargar por URL directa. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@implements IDisposable
@inject IPipelineService PipelineSvc
@inject ILeadService LeadsSvc
@inject ITenantUserService UsersSvc
@inject IChatService ChatSvc
@inject IMessageTemplateService TemplatesSvc
@inject IWhatsAppLineService LinesSvc
@inject IWebHostEnvironment Env
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject Ecorex.Application.Common.IQuotePdfRenderer PdfRenderer
@inject Ecorex.Application.Tenancy.IQuoteTemplateService QuoteTplSvc
@inject Ecorex.Application.Tenancy.IBusinessUnitService BizUnitSvc
@using Microsoft.AspNetCore.SignalR.Client

<PageTitle>Pipeline - ECOREX.tareas</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M8 7v7"/><path d="M12 7v4"/><path d="M16 7v9"/></svg>
            </div>
            <span>Operacion Comercial</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Pipeline <span>comercial</span></h1>
        <p class="page-sub" style="margin-bottom:0;">Embudo Kanban con etapas configurables por agencia para mover leads hasta el cierre.</p>
    </div>
    <div style="display:flex;gap:8px;">
        @if (_canManage)
        {
            <button class="btn btn-outline-secondary" @onclick="OpenConfig">Configurar embudo</button>
            <button class="btn btn-outline-secondary" @onclick="OpenUnits">Unidades de negocio</button>
        }
        <button class="btn btn-outline-secondary" @onclick="OpenHistoryAsync">Historial</button>
        <button class="btn btn-primary" @onclick="() => OpenNewLead(null)" disabled="@(_stages.Count == 0)">+ Nuevo lead</button>
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else if (_stages.Count == 0)
{
    <p class="text-muted">No hay etapas configuradas todavia.</p>
}
else
{
    <div class="kpi-grid" style="margin-bottom:22px;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));max-width:840px;">
        <div class="kpi-card">
            <div class="kpi-top"><div class="kpi-icon tone-primary"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div></div>
            <div class="kpi-label">Total leads</div>
            <div class="kpi-value">@_leads.Count</div>
            <div class="kpi-hint">@CountOpen() abiertos en el embudo</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-top"><div class="kpi-icon tone-success"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="m19 9-5 5-4-4-3 3"/></svg></div></div>
            <div class="kpi-label">Tasa de conversion</div>
            <div class="kpi-value">@_conversion%</div>
            <div class="kpi-hint">@CountWon() ganados de @_leads.Count</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-top"><div class="kpi-icon tone-gold"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div></div>
            <div class="kpi-label">Valor del pipeline</div>
            <div class="kpi-value">@PipelineValue()</div>
            <div class="kpi-hint">Suma de leads abiertos</div>
        </div>
    </div>

    @* ===== Barra: busqueda + orden + filtros ===== *@
    <div class="pl-toolbar">
        <div class="pl-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input placeholder="Buscar cliente o destino..." @bind="_search" @bind:event="oninput" />
            @if (!string.IsNullOrEmpty(_search))
            {
                <button class="pl-search-clear" @onclick="() => _search = string.Empty" title="Limpiar">&times;</button>
            }
        </div>
        <div class="pl-sort">
            <span class="pl-sort-lbl">Ordenar:</span>
            <select @bind="_sortBy">
                <option value="time">Tiempo en columna</option>
                <option value="recent">Mas recientes primero</option>
                <option value="arrival">Mas antiguos primero</option>
                <option value="name">Nombre (A-Z)</option>
                <option value="unanswered">Sin responder primero</option>
            </select>
        </div>
        <div class="pl-view" role="group" aria-label="Modo de vista">
            <button class="pl-view-btn @(_boardView == "kanban" ? "on" : "")" @onclick='() => _boardView = "kanban"' title="Vista Kanban">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="6" height="18" rx="1"/><rect x="9" y="3" width="6" height="12" rx="1"/><rect x="15" y="3" width="6" height="9" rx="1"/></svg>
                Kanban
            </button>
            <button class="pl-view-btn @(_boardView == "list" ? "on" : "")" @onclick='() => _boardView = "list"' title="Vista lista">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                Lista
            </button>
        </div>
        <div class="pl-filt-anchor">
            <button class="btn btn-outline-secondary @(FiltersActive ? "pl-filt-on" : "")" @onclick="() => _filtersOpen = !_filtersOpen">
                Filtros@(FiltersActive ? $" ({ActiveFilterCount})" : "")
            </button>
            @if (_filtersOpen)
            {
                <div class="pl-filters">
                    <div class="pl-filters-head">
                <span>Filtros avanzados</span>
                <button class="pl-link" @onclick="ClearFilters">Limpiar</button>
            </div>
            <div class="pl-filt-group">
                <div class="pl-filt-lbl">Asesor</div>
                <div class="pl-chips">
                    @foreach (var u in _team)
                    {
                        <button class="pl-fchip @(_filterAsesores.Contains(u.Id) ? "on" : "")" @onclick="() => ToggleAsesor(u.Id)">
                            <span class="dot" style="background:@AseColor(TeamLabel(u))"></span>@FirstName(TeamLabel(u))
                        </button>
                    }
                    <button class="pl-fchip @(_filterSinAsesor ? "on" : "")" @onclick="() => _filterSinAsesor = !_filterSinAsesor">
                        <span class="dot" style="background:var(--muted-foreground);"></span>Sin asesor
                    </button>
                </div>
            </div>
            <div class="pl-filt-group">
                <div class="pl-filt-lbl">Etapa</div>
                <div class="pl-chips">
                    @foreach (var s in _stages)
                    {
                        <button class="pl-fchip @(_filterStages.Contains(s.Id) ? "on" : "")" @onclick="() => ToggleStage(s.Id)">@s.Name</button>
                    }
                </div>
            </div>
            @if (_businessUnits.Count > 0)
            {
                <div class="pl-filt-group">
                    <div class="pl-filt-lbl">Unidad de negocio</div>
                    <div class="pl-chips">
                        @foreach (var bu in _businessUnits)
                        {
                            <button class="pl-fchip @(_filterUnits.Contains(bu.Id) ? "on" : "")" @onclick="() => ToggleUnit(bu.Id)">
                                <span class="dot" style="background:@bu.Color"></span>@bu.Name
                            </button>
                        }
                    </div>
                </div>
            }
            @if (DistinctDestinations().Count > 0)
            {
                <div class="pl-filt-group">
                    <div class="pl-filt-lbl">Destino</div>
                    <div class="pl-chips">
                        @foreach (var dest in DistinctDestinations())
                        {
                            <button class="pl-fchip @(_filterDestinos.Contains(dest) ? "on" : "")" @onclick="() => ToggleDestino(dest)">@dest</button>
                        }
                    </div>
                </div>
            }
            @foreach (var ff in FilterableFields())
            {
                var ffVals = DistinctFieldValues(ff.FieldKey);
                @if (ffVals.Count > 0)
                {
                    <div class="pl-filt-group">
                        <div class="pl-filt-lbl">@ff.Label</div>
                        <div class="pl-chips">
                            @foreach (var val in ffVals)
                            {
                                <button class="pl-fchip @(FieldFilterOn(ff.FieldKey, val) ? "on" : "")" @onclick="() => ToggleFieldFilter(ff.FieldKey, val)">@val</button>
                            }
                        </div>
                    </div>
                }
            }
            <div class="pl-filt-group">
                <div class="pl-filt-lbl">Atencion</div>
                <label class="pl-toggle">
                    <input type="checkbox" checked="@_onlyUnanswered" @onchange="@(e => _onlyUnanswered = (bool)e.Value!)" />
                    <span>Solo clientes sin respuesta</span>
                </label>
            </div>
            <div class="pl-filt-group">
                <div class="pl-filt-lbl">Valor del pipeline</div>
                <div class="pl-chips">
                    <button class="pl-fchip @(_filterValue.Contains("lt2") ? "on" : "")" @onclick="@(() => ToggleValue("lt2"))">&lt; $2M</button>
                    <button class="pl-fchip @(_filterValue.Contains("2to5") ? "on" : "")" @onclick="@(() => ToggleValue("2to5"))">$2M - $5M</button>
                    <button class="pl-fchip @(_filterValue.Contains("gt5") ? "on" : "")" @onclick="@(() => ToggleValue("gt5"))">$5M+</button>
                </div>
            </div>
                </div>
            }
        </div>
    </div>

    @if (_boardView == "list")
    {
        var listLeads = AllFilteredLeads();
        <div class="pl-list">
            @if (listLeads.Count == 0)
            {
                <div class="text-muted" style="font-size:13px;padding:18px 2px;">No hay leads que coincidan con la busqueda o los filtros.</div>
            }
            else
            {
                <table class="data-table pl-list-table">
                    <thead>
                        <tr>
                            <th>Cliente</th><th>Etapa</th><th>Destino</th><th>Fecha</th><th>Pax</th>
                            <th>Valor</th><th>Asesor</th><th>Estado</th><th>En etapa</th><th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lead in listLeads)
                        {
                            var lpend = PendingFor(lead);
                            <tr class="@(lpend is not null ? "pl-row-reply" : "")" style="cursor:pointer;" @onclick="() => OpenLeadAsync(lead.Id)">
                                <td>
                                    <div style="font-weight:600;">@lead.ContactName</div>
                                    @if (!string.IsNullOrWhiteSpace(lead.ContactPhone))
                                    {
                                        <div class="text-muted" style="font-size:11.5px;">@lead.ContactPhone</div>
                                    }
                                    @if (lpend is { } lp)
                                    {
                                        <div class="pl-row-tag">@lp.UnansweredCount sin responder · @WaitingLabel(lp.WaitingSince)</div>
                                    }
                                </td>
                                <td>@StageName(lead.StageId)</td>
                                <td>@RouteFrom(lead)@(RouteTo(lead) is { } rt ? $" → {rt}" : "")</td>
                                <td>@(Field(lead, "fechaTentativa") ?? "—")</td>
                                <td>@(PaxLabel(lead) ?? "—")</td>
                                <td>@(lead.EstimatedValue is decimal v ? Money(v, lead.Currency) : "—")</td>
                                <td>@(AsesorName(lead) ?? "Sin asesor")</td>
                                <td><span class="pl-chip">@StatusText(lead.Status)</span></td>
                                <td class="text-muted">@TimeInStageLabel(lead)</td>
                                <td>
                                    <button class="btn-icon" title="Llevar a historial" @onclick="() => OpenArchive(lead)" @onclick:stopPropagation="true">
                                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="5" x="2" y="3" rx="1"/><path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/><path d="M10 12h4"/></svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
    else
    {
    <div class="kanban">
        @foreach (var stage in _stages)
        {
            if (_filterStages.Count > 0 && !_filterStages.Contains(stage.Id)) { continue; }
            var leadsInStage = VisibleLeads(stage.Id);
            <div class="kb-col" data-stage-id="@stage.Id">
                <div class="kb-col-head">
                    <div>
                        <div class="kb-col-title">@stage.Name</div>
                        <div class="kb-col-meta">@StageTag(stage)</div>
                    </div>
                    <span class="kb-col-count">@leadsInStage.Count</span>
                </div>
                <div class="kb-body">
                    @if (leadsInStage.Count == 0)
                    {
                        <div class="kb-empty">Sin leads en esta etapa</div>
                    }
                    else
                    {
                        @foreach (var lead in leadsInStage)
                        {
                            var pend = PendingFor(lead);
                            <div class="@CardCss(lead, pend)" draggable="true" data-lead-id="@lead.Id"
                                 style="@CardStyle(lead)"
                                 @onclick="() => OpenLeadAsync(lead.Id)">
                                <div class="kb-top">
                                    <span class="kb-time">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                        @TimeInStageLabel(lead) aqui
                                    </span>
                                    @if (pend is { } p)
                                    {
                                        <span class="kb-badge reply">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                            @WaitingLabel(p.WaitingSince)
                                        </span>
                                    }
                                    else if (IsStale(lead))
                                    {
                                        <span class="kb-badge stale">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                            @StaleLabel(lead)
                                        </span>
                                    }
                                    <button class="kb-archive" title="Llevar a historial" @onclick="() => OpenArchive(lead)" @onclick:stopPropagation="true">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="5" x="2" y="3" rx="1"/><path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/><path d="M10 12h4"/></svg>
                                    </button>
                                </div>

                                <div class="nm">@lead.ContactName</div>

                                @if (UnitOf(lead) is { } bu)
                                {
                                    <div style="display:inline-flex;align-items:center;gap:5px;margin:0 0 7px;padding:2px 9px;border-radius:999px;font-size:11px;font-weight:700;background:@(bu.Color)22;color:@bu.Color;">
                                        <span style="width:7px;height:7px;border-radius:50%;background:@bu.Color;"></span>@bu.Name
                                    </div>
                                }

                                @if (pend is { } pc)
                                {
                                    <div class="kb-unread">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                        @pc.UnansweredCount @(pc.UnansweredCount == 1 ? "mensaje sin responder" : "mensajes sin responder")
                                    </div>
                                }

                                <div class="kb-route">
                                    <span class="codes">
                                        @RouteFrom(lead)
                                        @if (RouteTo(lead) is { } rt)
                                        {
                                            <span class="arr">&rarr;</span> @rt
                                        }
                                    </span>
                                    <span class="date">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                                        @(Field(lead, "fechaTentativa") ?? "Sin fecha")
                                    </span>
                                </div>

                                @if (Field(lead, "comentarios") is { } cm)
                                {
                                    <div class="kb-comment">@cm</div>
                                }

                                @if (lead.EstimatedValue is decimal v)
                                {
                                    <div class="val" style="margin-bottom:8px;">@Money(v, lead.Currency)</div>
                                }

                                <div class="kb-foot">
                                    <span class="kb-ase">
                                        <span class="kb-ase-dot" style="background:@AseColor(AsesorName(lead))"></span>
                                        <span class="nmtxt">@(AsesorName(lead) ?? "Sin asesor")</span>
                                    </span>
                                    @if (PaxLabel(lead) is { } px)
                                    {
                                        <span class="kb-pax">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                                            @px
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
                <button class="add-card-btn" style="margin:8px;padding:8px;border:1px dashed var(--border);border-radius:8px;background:none;color:var(--muted-foreground);font-size:12px;font-weight:600;cursor:pointer;width:calc(100% - 16px);"
                        @onclick="() => OpenNewLead(stage.Id)">
                    + Agregar lead
                </button>
            </div>
        }
    </div>
    }
}

@* ===== Modal: nuevo lead ===== *@
@if (_newLeadOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <h3>Nuevo lead</h3>
                <button class="modal-close" @onclick="() => _newLeadOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Nombre del contacto *</label>
                    <input class="form-control" @bind="_nl.ContactName" autocomplete="off" />
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Telefono</label>
                        <input class="form-control" @bind="_nl.ContactPhone" autocomplete="off" />
                    </div>
                    <div class="field">
                        <label class="form-label">Destino</label>
                        <input class="form-control" @bind="_nl.Destination" autocomplete="off" />
                    </div>
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Valor estimado</label>
                        <input class="form-control" type="text" inputmode="numeric" value="@FormatMoneyDecimal(_nl.EstimatedValue)" @onchange="e => _nl.EstimatedValue = ParseMoneyNullable(e.Value?.ToString())" />
                    </div>
                    <div class="field">
                        <label class="form-label">Moneda</label>
                        <select class="form-control" @bind="_nl.Currency">
                            @if (!string.IsNullOrWhiteSpace(_nl.Currency) && !CommonCurrencies.Any(c => c.Code == _nl.Currency))
                            {
                                <option value="@_nl.Currency">@_nl.Currency</option>
                            }
                            @foreach (var c in CommonCurrencies)
                            {
                                <option value="@c.Code">@c.Label</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Etapa inicial</label>
                        <select class="form-control" @bind="_nl.StageId">
                            @foreach (var s in _stages)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label class="form-label">Unidad de negocio</label>
                        <select class="form-control" value="@(_nl.BusinessUnitId?.ToString() ?? "")" @onchange="e => _nl.BusinessUnitId = ParseGuid(e.Value?.ToString())">
                            <option value="">Sin unidad</option>
                            @foreach (var bu in _businessUnits)
                            {
                                <option value="@bu.Id">@bu.Name</option>
                            }
                        </select>
                    </div>
                </div>
                @if (_newLeadError is not null)
                {
                    <div class="text-danger small">@_newLeadError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _newLeadOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveNewLeadAsync" disabled="@_busy">Crear lead</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: unidades de negocio ===== *@
@if (_unitsOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <h3>Unidades de negocio</h3>
                <button class="modal-close" @onclick="() => _unitsOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <p class="text-muted small" style="margin-top:0;">Canales del cliente. El color clasifica las tarjetas del pipeline.</p>
                <div style="border:1px solid var(--border);border-radius:8px;margin-bottom:14px;">
                    @foreach (var u in _businessUnits)
                    {
                        <div style="display:flex;align-items:center;gap:10px;padding:8px 10px;border-bottom:1px solid var(--border);">
                            <span style="width:14px;height:14px;border-radius:4px;background:@u.Color;flex:0 0 auto;"></span>
                            <span style="font-weight:600;flex:1 1 auto;@(u.IsActive ? "" : "opacity:.5;text-decoration:line-through;")">@u.Name</span>
                            <button class="pl-link" @onclick="() => EditUnit(u)">Editar</button>
                            <button class="pl-link" @onclick="() => ToggleUnitActiveAsync(u)">@(u.IsActive ? "Ocultar" : "Activar")</button>
                            <button class="pl-link" style="color:#C7398B;" @onclick="() => DeleteUnitAsync(u)">Eliminar</button>
                        </div>
                    }
                    @if (_businessUnits.Count == 0)
                    {
                        <div class="text-muted small" style="padding:10px;">No hay unidades configuradas.</div>
                    }
                </div>
                <div class="pl-stagegroup-title" style="margin-bottom:8px;">@(_editingUnitId is null ? "Nueva unidad" : "Editar unidad")</div>
                <div class="field-row">
                    <div class="field" style="flex:2 1 auto;">
                        <label class="form-label">Nombre *</label>
                        <input class="form-control" @bind="_uf.Name" autocomplete="off" />
                    </div>
                    <div class="field" style="flex:0 0 90px;">
                        <label class="form-label">Color</label>
                        <input class="form-control" type="color" @bind="_uf.Color" style="padding:2px;height:38px;" />
                    </div>
                </div>
                @if (_unitsError is not null)
                {
                    <div class="text-danger small">@_unitsError</div>
                }
            </div>
            <div class="modal-foot">
                @if (_editingUnitId is not null)
                {
                    <button class="btn btn-outline-secondary" @onclick="CancelUnitEdit">Cancelar edicion</button>
                }
                <button class="btn btn-outline-secondary" @onclick="() => _unitsOpen = false">Cerrar</button>
                <button class="btn btn-primary" @onclick="SaveUnitAsync">@(_editingUnitId is null ? "Agregar" : "Guardar")</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: detalle del lead ===== *@
@if (_leadOpen && _editLead is not null)
{
    var curIdx = _stages.FindIndex(s => s.Id == _editStageId);
    <div class="modal-overlay">
        <div class="modal-dialog pl-lead-dialog mob-@_leadMobileView">
          <div class="pl-lead-mobtabs">
              <button class="@(_leadMobileView == "datos" ? "active" : "")" @onclick='() => _leadMobileView = "datos"'>Datos</button>
              <button class="@(_leadMobileView == "chat" ? "active" : "")" @onclick='() => _leadMobileView = "chat"'>Chat</button>
          </div>
          <div class="pl-lead-left">
            <div class="modal-head">
                <div style="min-width:0;">
                    <h3>@(_el.ContactName)</h3>
                    <div class="pl-tags">
                        <span class="pl-state-pill">@StageName(_editStageId)</span>
                        @if (!string.IsNullOrWhiteSpace(_el.Destination))
                        {
                            <span class="pl-chip">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
                                @_el.Destination
                            </span>
                        }
                        @if (_el.EstimatedValue is decimal ev && ev > 0)
                        {
                            <span class="pl-chip">@ev.ToString("N0") @(_el.Currency ?? "COP")</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(_el.ContactPhone))
                        {
                            <span class="pl-chip">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                @_el.ContactPhone
                            </span>
                        }
                    </div>
                </div>
                <button class="modal-close" @onclick="CloseLead">&times;</button>
            </div>
            <div class="modal-body">
                <div class="pl-lead-tabs">
                    <button class="pl-lead-tab @(_leadTab == "datos" ? "active" : "")" @onclick='() => _leadTab = "datos"'>Datos</button>
                    <button class="pl-lead-tab @(_leadTab == "notas" ? "active" : "")" @onclick='() => _leadTab = "notas"'>Notas @(_notes.Count > 0 ? $"({_notes.Count})" : "")</button>
                    <button class="pl-lead-tab @(_leadTab == "archivos" ? "active" : "")" @onclick='() => _leadTab = "archivos"'>Archivos @(_files.Count > 0 ? $"({_files.Count})" : "")</button>
                    <button class="pl-lead-tab @(_leadTab == "actividad" ? "active" : "")" @onclick='() => _leadTab = "actividad"'>Actividad @(_activities.Count > 0 ? $"({_activities.Count})" : "")</button>
                </div>

                @if (_leadTab == "datos")
                {
                <div @oninput="MarkLeadDirty">
                @* Stepper de etapas *@
                <div style="display:grid;grid-template-columns:repeat(@_stages.Count,1fr);gap:4px;margin-bottom:18px;">
                    @for (var i = 0; i < _stages.Count; i++)
                    {
                        var s = _stages[i];
                        var done = i < curIdx;
                        var current = i == curIdx;
                        <button @onclick="() => MoveToStageAsync(s.Id)" title="Mover a @s.Name"
                                style="background:none;border:none;cursor:pointer;text-align:center;padding:2px;">
                            <div style="height:4px;border-radius:999px;margin-bottom:5px;background:@((done || current) ? "var(--primary)" : "var(--border)");"></div>
                            <div style="font-size:9px;text-transform:uppercase;letter-spacing:0.06em;font-weight:700;color:@(current ? "var(--primary)" : "var(--muted-foreground)");">@s.Name</div>
                        </button>
                    }
                </div>

                @* Datos de contacto (core) *@
                <div class="pl-stagegroup">
                    <div class="pl-stagegroup-title">Datos de contacto</div>
                    <div class="pl-fields">
                        <div class="pl-field col2">
                            <label class="form-label">Nombre *</label>
                            <input class="form-control" @bind="_el.ContactName" />
                        </div>
                        <div class="pl-field">
                            <label class="form-label">Telefono</label>
                            <input class="form-control" @bind="_el.ContactPhone" />
                        </div>
                        <div class="pl-field">
                            <label class="form-label">Origen destino</label>
                            <input class="form-control" @bind="_el.Destination" />
                        </div>
                        <div class="pl-field">
                            <label class="form-label">Moneda</label>
                            <select class="form-control" @bind="_el.Currency">
                                @if (!string.IsNullOrWhiteSpace(_el.Currency) && !CommonCurrencies.Any(c => c.Code == _el.Currency))
                                {
                                    <option value="@_el.Currency">@_el.Currency</option>
                                }
                                @foreach (var c in CommonCurrencies)
                                {
                                    <option value="@c.Code">@c.Label</option>
                                }
                            </select>
                        </div>
                        <div class="pl-field col2">
                            <label class="form-label">Asesor asignado</label>
                            @if (_canManage)
                            {
                                <select class="form-control" value="@(_editLead.AssignedToTenantUserId?.ToString() ?? "")" @onchange="OnAssignChangedAsync">
                                    <option value="">Sin asignar</option>
                                    @foreach (var u in _team)
                                    {
                                        <option value="@u.Id">@TeamLabel(u)</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input class="form-control" value="@AssignedLabel()" disabled />
                            }
                        </div>
                        <div class="pl-field col2">
                            <label class="form-label">Unidad de negocio</label>
                            <select class="form-control" value="@(_el.BusinessUnitId?.ToString() ?? "")" @onchange="OnEditUnitChanged">
                                <option value="">Sin unidad</option>
                                @foreach (var bu in _businessUnits)
                                {
                                    <option value="@bu.Id">@bu.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                @* Campos configurables por etapa (hasta la etapa actual) *@
                @for (var i = 0; i <= curIdx && i < _stages.Count; i++)
                {
                    var s = _stages[i];
                    var stageFields = _fields.Where(f => f.StageId == s.Id).OrderBy(f => f.SortOrder).ToList();
                    if (stageFields.Count == 0) { continue; }
                    <div class="pl-stagegroup">
                        <div class="pl-stagegroup-title">@s.Name</div>
                        <div class="pl-fields">
                            @foreach (var f in stageFields)
                            {
                                if (f.FieldType == PipelineFieldType.Separator)
                                {
                                    <div class="pl-field-separator col2"><span>@f.Label</span></div>
                                    continue;
                                }
                                <div class="pl-field @(f.Column == 2 ? "col2" : "")">
                                    <label class="form-label">@f.Label</label>
                                    @if (!string.IsNullOrWhiteSpace(f.Description))
                                    {
                                        <div class="pl-field-help">@f.Description</div>
                                    }
                                    @if (!string.IsNullOrEmpty(f.RepeatWithFieldKey))
                                    {
                                        var rc = RepeatCount(f.RepeatWithFieldKey!);
                                        if (rc <= 0)
                                        {
                                            <div class="text-muted" style="font-size:11.5px;">Indica "@FieldLabel(f.RepeatWithFieldKey!)" para capturar @f.Label.</div>
                                        }
                                        else
                                        {
                                            var rlist = MultiList(f.FieldKey, rc);
                                            for (int ri = 0; ri < rc; ri++)
                                            {
                                                var ci = ri;
                                                <div class="pl-multi-row">
                                                    <span class="pl-multi-idx">@(ci + 1)</span>
                                                    @if (f.FieldType == PipelineFieldType.Currency)
                                                    {
                                                        <div class="pl-money-input" style="flex:1;">
                                                            <span class="pl-money-sign">@CurrencySymbol(_el.Currency)</span>
                                                            <input class="form-control" type="text" inputmode="numeric" value="@FormatThousands(rlist[ci])" @onchange="e => rlist[ci] = DigitsToRaw(e.Value?.ToString())" />
                                                        </div>
                                                    }
                                                    else if (f.FieldType == PipelineFieldType.Number)
                                                    {
                                                        <input class="form-control" type="number" @bind="rlist[ci]" />
                                                    }
                                                    else if (f.FieldType == PipelineFieldType.Date)
                                                    {
                                                        <input class="form-control" type="date" value="@rlist[ci]" @onchange="e => rlist[ci] = e.Value?.ToString()" />
                                                    }
                                                    else if (f.FieldType == PipelineFieldType.Phone)
                                                    {
                                                        <input class="form-control" type="tel" @bind="rlist[ci]" />
                                                    }
                                                    else
                                                    {
                                                        <input class="form-control" @bind="rlist[ci]" />
                                                    }
                                                </div>
                                            }
                                        }
                                    }
                                    else if (f.AllowMultiple)
                                    {
                                        var mlist = MultiList(f.FieldKey, -1);
                                        var dlist = f.MultiWithDetail ? DetailList(f.FieldKey, mlist.Count) : null;
                                        for (int mi = 0; mi < mlist.Count; mi++)
                                        {
                                            var ci = mi;
                                            <div class="pl-multi-row">
                                                @if (f.MultiWithDetail && dlist is not null)
                                                {
                                                    <input class="form-control pl-multi-detail" placeholder="Detalle" @bind="dlist[ci]" />
                                                }
                                                @if (f.FieldType == PipelineFieldType.Currency)
                                                {
                                                    <div class="pl-money-input" style="flex:1;">
                                                        <span class="pl-money-sign">@CurrencySymbol(_el.Currency)</span>
                                                        <input class="form-control" type="text" inputmode="numeric" value="@FormatThousands(mlist[ci])" @onchange="e => mlist[ci] = DigitsToRaw(e.Value?.ToString())" />
                                                    </div>
                                                }
                                                else if (f.FieldType == PipelineFieldType.Number)
                                                {
                                                    <input class="form-control" type="number" @bind="mlist[ci]" />
                                                }
                                                else if (f.FieldType == PipelineFieldType.Date)
                                                {
                                                    <input class="form-control" type="date" value="@mlist[ci]" @onchange="e => mlist[ci] = e.Value?.ToString()" />
                                                }
                                                else if (f.FieldType == PipelineFieldType.Phone)
                                                {
                                                    <input class="form-control" type="tel" @bind="mlist[ci]" />
                                                }
                                                else
                                                {
                                                    <input class="form-control" @bind="mlist[ci]" />
                                                }
                                                <button type="button" class="pl-multi-del" title="Quitar" @onclick="() => RemoveMulti(f.FieldKey, ci)">&times;</button>
                                            </div>
                                        }
                                        <button type="button" class="pl-multi-add" @onclick="() => AddMulti(f.FieldKey)">+ Agregar</button>
                                    }
                                    else
                                    {
                                        @switch (f.FieldType)
                                        {
                                            case PipelineFieldType.TextArea:
                                                <textarea class="form-control" rows="2" @bind="_editValues[f.FieldKey]"></textarea>
                                                break;
                                            case PipelineFieldType.Number:
                                                <input class="form-control" type="number" @bind="_editValues[f.FieldKey]" />
                                                break;
                                            case PipelineFieldType.Currency:
                                                <div class="pl-money-input">
                                                    <span class="pl-money-sign">@CurrencySymbol(_el.Currency)</span>
                                                    <input class="form-control" type="text" inputmode="numeric" value="@FormatThousands(_editValues[f.FieldKey])" @onchange="e => _editValues[f.FieldKey] = DigitsToRaw(e.Value?.ToString())" />
                                                </div>
                                                break;
                                            case PipelineFieldType.Date:
                                                <input class="form-control" type="date" value="@_editValues[f.FieldKey]" @onchange="e => _editValues[f.FieldKey] = e.Value?.ToString()" />
                                                break;
                                            case PipelineFieldType.Time:
                                                <input class="form-control" type="time" value="@_editValues[f.FieldKey]" @onchange="e => _editValues[f.FieldKey] = e.Value?.ToString()" />
                                                break;
                                            case PipelineFieldType.TimeRange:
                                                <div style="display:flex;gap:6px;align-items:center;">
                                                    <input class="form-control" type="time" title="Salida" value="@TimeRangePart(_editValues[f.FieldKey], 0)" @onchange="e => _editValues[f.FieldKey] = SetTimeRange(_editValues[f.FieldKey], 0, e.Value?.ToString())" />
                                                    <span class="text-muted" style="font-size:12px;">a</span>
                                                    <input class="form-control" type="time" title="Llegada" value="@TimeRangePart(_editValues[f.FieldKey], 1)" @onchange="e => _editValues[f.FieldKey] = SetTimeRange(_editValues[f.FieldKey], 1, e.Value?.ToString())" />
                                                </div>
                                                break;
                                            case PipelineFieldType.Phone:
                                                <input class="form-control" type="tel" @bind="_editValues[f.FieldKey]" placeholder="+57 300 000 0000" />
                                                break;
                                            case PipelineFieldType.Select:
                                                <select class="form-control" @bind="_editValues[f.FieldKey]">
                                                    <option value="">—</option>
                                                    @foreach (var opt in SelectOptions(f))
                                                    {
                                                        <option value="@opt">@opt</option>
                                                    }
                                                </select>
                                                break;
                                            case PipelineFieldType.Total:
                                                <div class="pl-money-input">
                                                    <span class="pl-money-sign">@CurrencySymbol(_el.Currency)</span>
                                                    <input class="form-control pl-total-field" type="text" readonly value="@FormatMoneyDecimal(ComputeTotal(f))" />
                                                </div>
                                                break;
                                            default:
                                                <input class="form-control" @bind="_editValues[f.FieldKey]" />
                                                break;
                                        }
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                </div>
                }

                @if (_leadTab == "notas")
                {
                    <div class="pl-notes-composer">
                        <textarea class="form-control" rows="2" placeholder="Escribe una observacion sobre el cliente..." @bind="_noteText" @bind:event="oninput"></textarea>
                        <div class="pl-notes-bar">
                            <div class="pl-notes-colors">
                                @foreach (var c in NoteColors)
                                {
                                    <button type="button" class="pl-note-swatch @(c == _noteColor ? "on" : "")"
                                            style="background:@NoteColorHex(c);" title="@c" @onclick="() => _noteColor = c"></button>
                                }
                            </div>
                            <button class="btn btn-primary btn-sm" @onclick="AddNoteAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_noteText))">Agregar nota</button>
                        </div>
                    </div>

                    @if (_notes.Count == 0)
                    {
                        <div class="text-muted" style="font-size:13px;padding:14px 2px;">Aun no hay notas de seguimiento para este lead.</div>
                    }
                    else
                    {
                        <div class="pl-notes-list">
                            @foreach (var n in _notes)
                            {
                                <div class="pl-note" style="background:@NoteColorHex(n.Color);border-color:@NoteColorBorder(n.Color);">
                                    <button class="pl-note-del" title="Eliminar nota" @onclick="() => DeleteNoteAsync(n.Id)">&times;</button>
                                    <div class="pl-note-text">@n.Content</div>
                                    <div class="pl-note-meta">
                                        <span>@(string.IsNullOrWhiteSpace(n.ActorName) ? "Sistema" : n.ActorName)</span>
                                        &middot; @n.CreatedAt.LocalDateTime.ToString("dd MMM yyyy HH:mm")
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }

                @if (_leadTab == "archivos")
                {
                    <div class="pl-files-upload">
                        <label class="pl-files-drop">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                            <span>@(_fileBusy ? "Subiendo..." : "Subir documento del cliente (PDF, imagen, etc.)")</span>
                            <InputFile OnChange="OnLeadFileAsync" accept="*/*" style="display:none;" disabled="@_fileBusy" />
                        </label>
                        @if (_fileError is not null)
                        {
                            <div class="text-danger small" style="margin-top:6px;">@_fileError</div>
                        }
                    </div>

                    @if (_files.Count == 0)
                    {
                        <div class="text-muted" style="font-size:13px;padding:14px 2px;">Aun no hay documentos adjuntos para este lead.</div>
                    }
                    else
                    {
                        <div class="pl-files-list">
                            @foreach (var f in _files)
                            {
                                <div class="pl-file">
                                    <div class="pl-file-ico">@FileExt(f.FileName)</div>
                                    <div class="pl-file-info">
                                        <a href="@f.Url" target="_blank" class="pl-file-name" title="@f.FileName">@f.FileName</a>
                                        <div class="pl-file-meta">
                                            @FileSize(f.SizeBytes)
                                            &middot; @(string.IsNullOrWhiteSpace(f.ActorName) ? "Sistema" : f.ActorName)
                                            &middot; @f.CreatedAt.LocalDateTime.ToString("dd MMM yyyy HH:mm")
                                        </div>
                                    </div>
                                    <a href="@f.Url" target="_blank" class="btn-icon" title="Descargar" download>
                                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                    </a>
                                    <button class="btn-icon" title="Eliminar archivo" @onclick="() => DeleteLeadFileAsync(f.Id)">
                                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                }

                @if (_leadTab == "actividad")
                {
                    @if (_activities.Count == 0)
                    {
                        <div class="text-muted" style="font-size:13px;padding:14px 2px;">Aun no hay actividad registrada para este lead.</div>
                    }
                    else
                    {
                        <div class="pl-timeline">
                            @foreach (var a in _activities)
                            {
                                <div class="pl-tl-item">
                                    <div class="pl-tl-dot"></div>
                                    <div class="pl-tl-body">
                                        <div class="pl-tl-desc">@a.Description</div>
                                        <div class="pl-tl-meta">
                                            <span class="pl-tl-actor">@(string.IsNullOrWhiteSpace(a.ActorName) ? "Sistema" : a.ActorName)</span>
                                            &middot; @a.CreatedAt.LocalDateTime.ToString("dd MMM yyyy HH:mm")
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }

                @if (_leadError is not null)
                {
                    <div class="text-danger small">@_leadError</div>
                }
            </div>
            <div class="modal-foot" style="justify-content:space-between;">
                <div style="display:flex;gap:6px;">
                    @if (curIdx > 0)
                    {
                        <button class="btn btn-outline-secondary" @onclick="() => MoveToStageAsync(_stages[curIdx - 1].Id)" disabled="@_busy">&larr; @_stages[curIdx - 1].Name</button>
                    }
                    @if (curIdx >= 0 && curIdx < _stages.Count - 1)
                    {
                        <button class="btn btn-outline-secondary" @onclick="() => MoveToStageAsync(_stages[curIdx + 1].Id)" disabled="@_busy">@_stages[curIdx + 1].Name &rarr;</button>
                    }
                </div>
                <div style="display:flex;gap:8px;align-items:center;">
                    @if (_leadSaved && !_leadDirty)
                    {
                        <span class="pl-saved-flag">Guardado</span>
                    }
                    <button class="btn btn-outline-secondary" @onclick="CloseLead">Cerrar</button>
                    <button class="btn @(_leadDirty ? "pl-save-dirty" : "btn-primary")" @onclick="SaveLeadAsync" disabled="@_busy">@(_busy ? "Guardando..." : _leadDirty ? "Guardar cambios" : "Guardar")</button>
                </div>
            </div>
          </div>

          @* ===== Panel de chat WhatsApp ===== *@
          <div class="pl-chat">
            <div class="pl-chat-head">
                <div class="pl-chat-avatar">@Initials(_el.ContactName)</div>
                <div style="flex:1;min-width:0;">
                    <div class="nm">@(_el.ContactName)</div>
                    <div class="sub">En linea &middot; WhatsApp</div>
                    @if (_chatLines.Count > 0)
                    {
                        <div class="pl-chat-line">
                            <select @bind="_chatLineId" title="Linea WhatsApp para responder">
                                @foreach (var ln in _chatLines)
                                {
                                    <option value="@ln.Id">@(string.IsNullOrWhiteSpace(ln.PhoneNumber) ? ln.InstanceName : $"{ln.InstanceName} ({ln.PhoneNumber})")</option>
                                }
                            </select>
                        </div>
                    }
                </div>
                <span class="pl-chat-more">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg>
                    Mas
                </span>
            </div>
            <div class="pl-chat-bodywrap" id="pl-chat-drop">
              <div class="pl-chat-dropmask">Suelta el documento para enviarlo</div>
              <div class="pl-chat-body">
                @if (string.IsNullOrWhiteSpace(_el.ContactPhone))
                {
                    <div class="pl-chat-empty">Agrega un telefono al lead para iniciar la conversacion por WhatsApp.</div>
                }
                else if (_chatLines.Count == 0)
                {
                    <div class="pl-chat-empty">No hay lineas WhatsApp conectadas. Conecta una en el modulo Lineas.</div>
                }
                else if (_messages.Count == 0)
                {
                    <div class="pl-chat-empty">Aun no hay mensajes. Escribe el primero abajo.</div>
                }
                else
                {
                    DateTime? lastDay = null;
                    @foreach (var m in _messages)
                    {
                        var day = m.SentAt.LocalDateTime.Date;
                        if (lastDay != day)
                        {
                            lastDay = day;
                            <div class="pl-date-divider">@day.ToString("dd 'DE' MMMM").ToUpperInvariant()</div>
                        }
                        <div class="pl-bubble @(m.Direction == MessageDirection.Outbound ? "out" : "in")">
                            @switch (m.MediaType)
                            {
                                case MessageMediaType.Image:
                                    <img class="pl-media-img" src="@m.MediaUrl" alt="imagen" />
                                    break;
                                case MessageMediaType.Video:
                                    <video class="pl-media-img" src="@m.MediaUrl" controls></video>
                                    break;
                                case MessageMediaType.Audio:
                                    <audio src="@m.MediaUrl" controls style="max-width:220px;"></audio>
                                    break;
                                case MessageMediaType.Document:
                                    <a class="pl-media-doc" href="@m.MediaUrl" target="_blank">Documento adjunto</a>
                                    break;
                                case MessageMediaType.Location:
                                    <a class="pl-media-doc" href="@MapsLink(m.MediaUrl)" target="_blank">Ver ubicacion en el mapa</a>
                                    break;
                            }
                            @if (!string.IsNullOrWhiteSpace(m.Body))
                            {
                                <div>@m.Body</div>
                            }
                            <div class="t">
                                @if (m.Direction == MessageDirection.Outbound && !string.IsNullOrWhiteSpace(m.SentByName))
                                {
                                    <span>@m.SentByName &middot; </span>
                                }
                                @m.SentAt.LocalDateTime.ToString("hh:mm tt")
                            </div>
                        </div>
                    }
                }
              </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(_el.ContactPhone) && _chatLines.Count > 0)
            {
                <div class="pl-chat-quick">
                    <div class="pl-qr-head">
                        <span>Mensajes pregrabados</span>
                        <div class="pl-qr-tabs">
                            @foreach (var cat in QrCategories)
                            {
                                <button class="pl-qr-tab @(cat.Key == _qrCategory ? "active" : "")" @onclick="() => _qrCategory = cat.Key">@cat.Label</button>
                            }
                            <button class="pl-qr-tab" style="border:1px solid var(--border);" @onclick="OpenTemplateManager" title="Crear/editar pregrabados">+ Gestionar</button>
                        </div>
                    </div>
                    <div class="pl-qr-list">
                        @foreach (var tpl in CurrentTemplates())
                        {
                            var filled = FillTemplate(tpl.Body);
                            var label = tpl.MediaType == MessageMediaType.None ? filled : $"{MediaIcon(tpl.MediaType)} {(string.IsNullOrWhiteSpace(filled) ? tpl.MediaType.ToString() : filled)}";
                            <button class="pl-quick-chip" title="@filled" @onclick="() => UseTemplateAsync(tpl)">@label</button>
                        }
                        @if (CurrentTemplates().Count == 0)
                        {
                            <span class="text-muted" style="font-size:11px;">Sin pregrabados en esta categoria. Usa "+ Gestionar".</span>
                        }
                    </div>
                </div>
                <div class="pl-chat-input">
                    <div class="pl-attach">
                        <button class="pl-attach-btn" title="Adjuntar" @onclick="() => _attachOpen = !_attachOpen" disabled="@_chatBusy">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                        </button>
                        @if (_attachOpen)
                        {
                            <div class="pl-attach-menu">
                                <label class="pl-attach-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21"/></svg>
                                    Imagen
                                    <InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Image))" accept="image/*" style="display:none;" />
                                </label>
                                <label class="pl-attach-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8Z"/><rect x="2" y="6" width="14" height="12" rx="2"/></svg>
                                    Video
                                    <InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Video))" accept="video/*" style="display:none;" />
                                </label>
                                <label class="pl-attach-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
                                    Audio
                                    <InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Audio))" accept="audio/*" style="display:none;" />
                                </label>
                                <label class="pl-attach-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/></svg>
                                    Documento
                                    <InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Document))" accept="*/*" style="display:none;" />
                                </label>
                                <button class="pl-attach-item" @onclick="OpenLocation">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                                    Ubicacion
                                </button>
                            </div>
                        }
                    </div>
                    <input placeholder="Escribe un mensaje..." @bind="_chatDraft" @bind:event="oninput" @onkeydown="ChatKeyDown" disabled="@_chatBusy" />
                    <button class="pl-chat-send" @onclick="SendChatAsync" disabled="@(_chatBusy || string.IsNullOrWhiteSpace(_chatDraft))" title="Enviar">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    </button>
                </div>
                @if (_chatError is not null)
                {
                    <div class="text-danger small" style="padding:0 12px 8px;">@_chatError</div>
                }
            }
            <div class="pl-quote-actions">
                @if (_quoteTemplates.Count > 0)
                {
                    <select class="form-control pl-quote-tplsel" @bind="_selectedQuoteTemplateId" disabled="@_quoteBusy" title="Plantilla de cotizacion a usar">
                        @foreach (var t in _quoteTemplates)
                        {
                            <option value="@t.Id">@t.Name @(t.IsDefault ? "(predeterminada)" : "")</option>
                        }
                    </select>
                }
                <button class="btn btn-outline-secondary" @onclick="VerCotizacionAsync" disabled="@_quoteBusy">
                    <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;margin-right:5px;"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                    Ver cotizacion
                </button>
                @if (!_sendConfirm)
                {
                    <button class="btn btn-primary" @onclick="() => { _sendConfirm = true; _quoteMsg = null; }"
                            disabled="@(_quoteBusy || _conversation is null || _chatLineId == Guid.Empty)"
                            title="@(_conversation is null || _chatLineId == Guid.Empty ? "Necesitas una linea activa en la conversacion" : "")">
                        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;margin-right:5px;"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                        Enviar cotizacion
                    </button>
                }
                else
                {
                    <span class="pl-quote-confirm">Enviar la cotizacion al cliente por WhatsApp?</span>
                    <button class="btn btn-primary" @onclick="EnviarCotizacionAsync" disabled="@_quoteBusy">@(_quoteBusy ? "Enviando..." : "Si, enviar")</button>
                    <button class="btn btn-link" @onclick="() => _sendConfirm = false" disabled="@_quoteBusy">Cancelar</button>
                }
                @if (_quoteMsg is not null) { <span class="pl-quote-msg">@_quoteMsg</span> }
            </div>
          </div>
        </div>
    </div>
}

@* ===== Modal: gestor de mensajes pregrabados ===== *@
@if (_tplManagerOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:620px;">
            <div class="modal-head">
                <h3>Mensajes pregrabados</h3>
                <button class="modal-close" @onclick="() => _tplManagerOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Categoria</label>
                    <input class="form-control" list="pl-tpl-cats" @bind="_tplFormCategory" placeholder="Elige una o escribe una nueva" autocomplete="off" />
                    <datalist id="pl-tpl-cats">
                        @foreach (var cat in QrCategories)
                        {
                            <option value="@cat.Key">@cat.Label</option>
                        }
                    </datalist>
                    <div class="text-muted" style="font-size:11px;margin-top:3px;">Escribe un nombre nuevo para crear otra categoria.</div>
                </div>
                <div class="field">
                    <label class="form-label">Mensaje</label>
                    <textarea class="form-control" rows="2" @bind="_tplFormBody" placeholder="Usa {asesor} y {destino} para personalizar"></textarea>
                </div>
                <div class="field">
                    <label class="form-label">Adjunto (opcional)</label>
                    @if (_tplFormMediaUrl is not null)
                    {
                        <div style="display:flex;align-items:center;gap:8px;">
                            <span class="pl-chip">@MediaIcon(_tplFormMediaType) @_tplFormMediaType</span>
                            <button class="btn btn-outline-danger" style="padding:2px 8px;" @onclick="ClearTemplateMedia">Quitar</button>
                        </div>
                    }
                    else
                    {
                        <InputFile OnChange="OnTemplateMediaAsync" accept="image/*,video/*,audio/*" class="form-control" style="max-width:280px;" />
                    }
                </div>
                @if (_tplFormError is not null)
                {
                    <div class="text-danger small">@_tplFormError</div>
                }
                <div style="display:flex;gap:8px;margin:4px 0 14px;">
                    <button class="btn btn-primary" @onclick="SaveTemplateAsync" disabled="@_tplBusy">@(_tplEditId is null ? "+ Agregar" : "Guardar cambios")</button>
                    @if (_tplEditId is not null)
                    {
                        <button class="btn btn-outline-secondary" @onclick="ResetTemplateForm">Cancelar edicion</button>
                    }
                </div>

                <hr style="border-color:var(--border);" />
                @foreach (var cat in QrCategories)
                {
                    var items = _templates.Where(t => t.Category == cat.Key).OrderBy(t => t.SortOrder).ToList();
                    <div class="pl-stagegroup-title" style="margin-top:10px;">@cat.Label (@items.Count)</div>
                    @foreach (var t in items)
                    {
                        <div class="cfg-row">
                            <div class="grow">
                                <div style="font-size:13px;">
                                    @if (t.MediaType != MessageMediaType.None) { <span>@MediaIcon(t.MediaType) </span> }
                                    @(string.IsNullOrWhiteSpace(t.Body) ? "(solo adjunto)" : t.Body)
                                </div>
                            </div>
                            <button class="btn btn-outline-secondary" style="padding:2px 8px;" @onclick="() => EditTemplate(t)">Editar</button>
                            <button class="btn btn-outline-danger" style="padding:2px 8px;" @onclick="() => DeleteTemplateAsync(t.Id)" disabled="@_tplBusy">Eliminar</button>
                        </div>
                    }
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _tplManagerOpen = false">Listo</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: enviar ubicacion ===== *@
@if (_locationOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:420px;">
            <div class="modal-head">
                <h3>Enviar ubicacion</h3>
                <button class="modal-close" @onclick="() => _locationOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Nombre del lugar (opcional)</label>
                    <input class="form-control" @bind="_locName" placeholder="Hotel, aeropuerto, oficina..." />
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Latitud *</label>
                        <input class="form-control" @bind="_locLat" placeholder="10.3997" />
                    </div>
                    <div class="field">
                        <label class="form-label">Longitud *</label>
                        <input class="form-control" @bind="_locLng" placeholder="-75.5144" />
                    </div>
                </div>
                <div class="text-muted" style="font-size:11px;">Pega coordenadas desde Google Maps (clic derecho &rarr; copiar).</div>
                @if (_locError is not null)
                {
                    <div class="text-danger small">@_locError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _locationOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="SendLocationAsync" disabled="@_chatBusy">Enviar</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: llevar a historial ===== *@
@if (_archiveLead is not null)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:460px;">
            <div class="modal-head">
                <h3>Llevar a historial</h3>
                <button class="modal-close" @onclick="() => _archiveLead = null">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size:13px;color:var(--muted-foreground);margin-top:0;">
                    <strong>@_archiveLead.ContactName</strong> se quitara del tablero y quedara en el historial. Indica el motivo.
                </p>
                <div class="field">
                    <label class="form-label">Motivo *</label>
                    <select class="form-control" @bind="_archiveReason">
                        @foreach (var m in ArchiveReasons)
                        {
                            <option value="@m">@m</option>
                        }
                    </select>
                </div>
                <div class="field">
                    <label class="form-label">Observacion</label>
                    <textarea class="form-control" rows="3" @bind="_archiveNote" placeholder="Detalle del motivo (opcional)"></textarea>
                </div>
                @if (_archiveError is not null)
                {
                    <div class="text-danger small">@_archiveError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _archiveLead = null">Cancelar</button>
                <button class="btn btn-primary" @onclick="ConfirmArchiveAsync" disabled="@_busy">Enviar a historial</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: historial ===== *@
@if (_historyOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:1180px;">
            <div class="modal-head">
                <h3>Historial de clientes</h3>
                <button class="modal-close" @onclick="() => _historyOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="text-muted" style="font-size:12px;margin-bottom:10px;">Clientes enviados a historial. @( _canManage ? "Ves todos los del equipo." : "Ves los que te corresponden segun tu rol.")</div>

                @* Borrado total del historial: SOLO administrador del tenant, con doble comprobacion. *@
                @if (_isTenantAdmin && _history.Count > 0)
                {
                    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:12px;padding:8px 10px;border:1px solid #f1c9c4;background:#fdf3f2;border-radius:8px;">
                        @if (_purgeStep == 0)
                        {
                            <button style="border:1px solid #d92d20;background:#fff;color:#b42318;padding:6px 12px;border-radius:6px;font-size:12px;cursor:pointer;font-weight:600;" @onclick="() => { _purgeStep = 1; _purgeMsg = null; }">Borrar todo el historial</button>
                        }
                        else if (_purgeStep == 1)
                        {
                            <span style="color:#b42318;font-size:12px;font-weight:600;flex:1;min-width:220px;">Vas a borrar PERMANENTEMENTE @_history.Count cliente(s) del historial y todos sus datos (notas, archivos, tareas). Es irreversible.</span>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => _purgeStep = 0" disabled="@_purgeBusy">Cancelar</button>
                            <button style="border:none;background:#d92d20;color:#fff;padding:6px 12px;border-radius:6px;font-size:12px;cursor:pointer;font-weight:600;" @onclick="() => _purgeStep = 2" disabled="@_purgeBusy">Entiendo, continuar</button>
                        }
                        else
                        {
                            <span style="color:#b42318;font-size:12px;font-weight:700;flex:1;min-width:220px;">Confirmacion final: se eliminara TODO el historial sin posibilidad de recuperarlo.</span>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => _purgeStep = 0" disabled="@_purgeBusy">Cancelar</button>
                            <button style="border:none;background:#b42318;color:#fff;padding:6px 12px;border-radius:6px;font-size:12px;cursor:pointer;font-weight:700;" @onclick="PurgeHistoryAsync" disabled="@_purgeBusy">@(_purgeBusy ? "Borrando..." : "Si, borrar definitivamente")</button>
                        }
                    </div>
                }
                @if (_purgeMsg is not null)
                {
                    <div class="text-muted" style="font-size:12px;margin-bottom:10px;color:#0a7d33;">@_purgeMsg</div>
                }

                @if (_history.Count == 0)
                {
                    <div class="text-muted" style="font-size:13px;padding:14px 2px;">No hay clientes en historial todavia.</div>
                }
                else
                {
                    <div class="pl-hist-filters">
                        <div class="pl-search" style="flex:1;min-width:200px;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                            <input placeholder="Buscar cliente, telefono o destino..." @bind="_histSearch" @bind:event="oninput" />
                            @if (!string.IsNullOrEmpty(_histSearch))
                            {
                                <button class="pl-search-clear" @onclick="() => _histSearch = string.Empty" title="Limpiar">&times;</button>
                            }
                        </div>
                        <select class="form-control" style="max-width:220px;" @bind="_histReason">
                            <option value="">Todos los motivos</option>
                            @foreach (var r in _history.Where(h => !string.IsNullOrWhiteSpace(h.ArchiveReason)).Select(h => h.ArchiveReason!).Distinct())
                            {
                                <option value="@r">@r</option>
                            }
                        </select>
                        <select class="form-control" style="max-width:220px;" @bind="_histAsesor">
                            <option value="">Todos los asesores</option>
                            @foreach (var u in _team)
                            {
                                <option value="@u.Id">@u.Email</option>
                            }
                        </select>
                    </div>

                    var histRows = FilteredHistory();
                    @if (!histRows.Any())
                    {
                        <div class="text-muted" style="font-size:13px;padding:14px 2px;">Ningun cliente del historial coincide con los filtros.</div>
                    }
                    else
                    {
                        <div style="overflow-x:auto;">
                            <table class="data-table pl-hist-table" style="width:100%;font-size:12.5px;">
                                <thead>
                                    <tr>
                                        <th>Cliente</th><th>Destino</th><th>Etapa</th><th>Valor</th><th>Asesor</th>
                                        <th>Datos</th><th>Motivo</th><th>Observacion</th><th>Archivado</th><th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var h in histRows)
                                    {
                                        <tr>
                                            <td>
                                                <div style="font-weight:600;">@h.ContactName</div>
                                                @if (!string.IsNullOrWhiteSpace(h.ContactPhone))
                                                {
                                                    <div class="text-muted" style="font-size:11.5px;">@h.ContactPhone</div>
                                                }
                                            </td>
                                            <td>@(string.IsNullOrWhiteSpace(h.Destination) ? "—" : h.Destination)</td>
                                            <td>@StageName(h.StageId)</td>
                                            <td>@(h.EstimatedValue is decimal v ? Money(v, h.Currency) : "—")</td>
                                            <td>@ArchAsesor(h)</td>
                                            <td class="text-muted" style="max-width:220px;">@HistDatos(h)</td>
                                            <td><span class="pl-chip">@(h.ArchiveReason ?? "—")</span></td>
                                            <td style="color:var(--muted-foreground);max-width:200px;">@(string.IsNullOrWhiteSpace(h.ArchiveNote) ? "—" : h.ArchiveNote)</td>
                                            <td style="color:var(--muted-foreground);white-space:nowrap;">
                                                @(h.ArchivedAt is { } a ? a.LocalDateTime.ToString("dd MMM yyyy") : "—")
                                                @if (!string.IsNullOrWhiteSpace(h.ArchivedByName)) { <text><br />&middot; @h.ArchivedByName</text> }
                                            </td>
                                            <td style="white-space:nowrap;">
                                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => RestoreFromHistoryAsync(h)" disabled="@_busy" title="Quitar del historial y regresar al tablero">
                                                    Regresar al tablero
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _historyOpen = false">Cerrar</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: configurar embudo ===== *@
@if (_configOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:640px;">
            <div class="modal-head">
                <h3>Configurar embudo</h3>
                <button class="modal-close" @onclick="() => _configOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Unidad de negocio a configurar</label>
                    <select class="form-control" value="@(_cfgUnitId?.ToString() ?? "")" @onchange="e => _cfgUnitId = ParseGuid(e.Value?.ToString())">
                        @foreach (var bu in _businessUnits)
                        {
                            <option value="@bu.Id">@bu.Name</option>
                        }
                    </select>
                    <div class="text-muted" style="font-size:11px;margin-top:4px;">
                        Los campos de las unidades se muestran en el modal del lead, organizados por etapa.
                    </div>
                </div>
                <hr style="margin:14px 0;border-color:var(--border);" />
                <div class="pl-stagegroup-title">Etapas</div>
                @for (var i = 0; i < _stages.Count; i++)
                {
                    var s = _stages[i];
                    var idx = i;
                    <div class="cfg-row">
                        <div style="display:flex;flex-direction:column;gap:2px;">
                            <button class="btn btn-outline-secondary" style="padding:0 6px;line-height:1.4;" disabled="@(idx == 0 || _busy)" @onclick="() => MoveStageAsync(idx, idx - 1)">&uarr;</button>
                            <button class="btn btn-outline-secondary" style="padding:0 6px;line-height:1.4;" disabled="@(idx == _stages.Count - 1 || _busy)" @onclick="() => MoveStageAsync(idx, idx + 1)">&darr;</button>
                        </div>
                        <div class="grow">
                            <input class="form-control" value="@s.Name" @onchange="@(e => RenameStageAsync(s, e.Value?.ToString()))" />
                            <div style="display:flex;gap:14px;margin-top:6px;font-size:12px;">
                                <label style="display:flex;align-items:center;gap:5px;cursor:pointer;">
                                    <input type="checkbox" checked="@s.IsClosedWon" @onchange="@(e => ToggleStageFlagAsync(s, won: (bool)e.Value!))" /> Cierre ganado
                                </label>
                                <label style="display:flex;align-items:center;gap:5px;cursor:pointer;">
                                    <input type="checkbox" checked="@s.IsClosedLost" @onchange="@(e => ToggleStageFlagAsync(s, lost: (bool)e.Value!))" /> Cierre perdido
                                </label>
                            </div>
                        </div>
                        <button class="btn btn-outline-danger" style="padding:2px 8px;" disabled="@_busy" @onclick="() => DeleteStageAsync(s)">Eliminar</button>
                    </div>
                }
                <div style="display:flex;gap:8px;margin:10px 0 4px;">
                    <input class="form-control" placeholder="Nueva etapa" @bind="_newStageName" />
                    <button class="btn btn-primary" style="white-space:nowrap;" disabled="@_busy" @onclick="AddStageAsync">+ Etapa</button>
                </div>
                @if (_cfgStageMsg is not null)
                {
                    <div class="text-danger small">@_cfgStageMsg</div>
                }

                <hr style="margin:18px 0;border-color:var(--border);" />

                @{
                <div class="pl-stagegroup-title">Campos por etapa</div>
                <div class="field">
                    <label class="form-label">Etapa</label>
                    <select class="form-control" @bind="_cfgStageId">
                        @foreach (var s in _stages)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
                var cfgFields = _fields.Where(f => f.StageId == _cfgStageId).OrderBy(f => f.SortOrder).ToList();
                var numericFields = cfgFields.Where(x => x.FieldType is PipelineFieldType.Number && (_editingFieldId is null || x.Id != _editingFieldId)).ToList();
                @for (int fi = 0; fi < cfgFields.Count; fi++)
                {
                    var f = cfgFields[fi];
                    var idx = fi;
                    <div class="cfg-row">
                        <div style="display:flex;flex-direction:column;gap:2px;flex:none;">
                            <button class="btn btn-outline-secondary" style="padding:0 6px;line-height:1.3;" disabled="@(idx == 0 || _busy)" @onclick="() => MoveFieldAsync(cfgFields, idx, idx - 1)" title="Subir">&uarr;</button>
                            <button class="btn btn-outline-secondary" style="padding:0 6px;line-height:1.3;" disabled="@(idx == cfgFields.Count - 1 || _busy)" @onclick="() => MoveFieldAsync(cfgFields, idx, idx + 1)" title="Bajar">&darr;</button>
                        </div>
                        <div class="grow">
                            <div style="font-weight:600;font-size:13px;">
                                @f.Label
                                @if (f.AllowMultiple) { <span class="cfg-tag">multiple</span> }
                                @if (!string.IsNullOrEmpty(f.RepeatWithFieldKey)) { <span class="cfg-tag">x @FieldLabel(f.RepeatWithFieldKey!)</span> }
                            </div>
                            <div class="text-muted" style="font-size:11px;">@f.FieldType &middot; col @f.Column &middot; @f.FieldKey</div>
                            @if (!string.IsNullOrWhiteSpace(f.Description))
                            {
                                <div class="text-muted" style="font-size:11px;font-style:italic;">@f.Description</div>
                            }
                        </div>
                        <button class="btn btn-outline-secondary" style="padding:2px 8px;" disabled="@_busy" @onclick="() => MoveFieldColumnAsync(f)" title="Mover a la otra columna">&#8644; col @(f.Column == 2 ? 1 : 2)</button>
                        @if (_stages.Count > 1)
                        {
                            <select class="form-control" style="padding:2px 6px;max-width:150px;font-size:11.5px;flex:none;" disabled="@_busy" title="Mover el campo a otra etapa" @onchange="e => MoveFieldStageAsync(f, e.Value?.ToString())">
                                <option value="">Mover a etapa...</option>
                                @foreach (var st in _stages.Where(s => s.Id != f.StageId))
                                {
                                    <option value="@st.Id">@st.Name</option>
                                }
                            </select>
                        }
                        <button class="btn btn-outline-secondary" style="padding:2px 8px;" disabled="@_busy" @onclick="() => EditField(f)">Editar</button>
                        <button class="btn btn-outline-danger" style="padding:2px 8px;" disabled="@_busy" @onclick="() => DeleteFieldAsync(f.Id)">Eliminar</button>
                    </div>
                }
                <div style="border:1px solid var(--border);border-radius:0.6rem;padding:12px;margin-top:8px;">
                    <div style="font-weight:600;font-size:12px;margin-bottom:8px;">@(_editingFieldId is null ? "Nuevo campo" : "Editar campo")</div>
                    <div class="field-row">
                        <div class="field">
                            <label class="form-label">Etiqueta</label>
                            <input class="form-control" @bind="_nf.Label" />
                        </div>
                        <div class="field">
                            <label class="form-label">Tipo</label>
                            <select class="form-control" @bind="_nf.FieldType">
                                <option value="@PipelineFieldType.Text">Texto</option>
                                <option value="@PipelineFieldType.Number">Numero</option>
                                <option value="@PipelineFieldType.Currency">Moneda</option>
                                <option value="@PipelineFieldType.Date">Fecha</option>
                                <option value="@PipelineFieldType.Time">Hora</option>
                                <option value="@PipelineFieldType.TimeRange">Hora salida/llegada</option>
                                <option value="@PipelineFieldType.Phone">Telefono</option>
                                <option value="@PipelineFieldType.TextArea">Texto largo</option>
                                <option value="@PipelineFieldType.Select">Lista</option>
                                <option value="@PipelineFieldType.Total">Total (suma de campos)</option>
                                <option value="@PipelineFieldType.Separator">Separador (linea divisoria)</option>
                            </select>
                        </div>
                    </div>
                    <div class="field-row">
                        <div class="field">
                            <label class="form-label">Columna</label>
                            <select class="form-control" @bind="_nf.Column">
                                <option value="1">1 (media)</option>
                                <option value="2">2 (completa)</option>
                            </select>
                        </div>
                        <div class="field">
                            <label class="form-label">Opciones (una por linea)</label>
                            <input class="form-control" @bind="_nf.Options" placeholder="solo para tipo Lista" />
                        </div>
                    </div>
                    <div class="field">
                        <label class="form-label">Descripcion / contexto <span class="text-muted" style="font-weight:400;">(para que sirve; ayuda al asesor y a la IA)</span></label>
                        <textarea class="form-control" rows="2" @bind="_nf.Description" placeholder="Ej: Edad de cada nino para calcular tarifas y cupos."></textarea>
                    </div>
                    <div class="field-row" style="align-items:end;">
                        <div class="field">
                            <label class="form-label">Repetir segun campo</label>
                            <select class="form-control" @bind="_nf.RepeatWithFieldKey">
                                <option value="">(no repetir)</option>
                                @foreach (var nfield in numericFields)
                                {
                                    <option value="@nfield.FieldKey">@nfield.Label</option>
                                }
                            </select>
                            <div class="text-muted" style="font-size:11px;">Genera un input por cada unidad del campo numerico elegido (ej. edades x ninos).</div>
                        </div>
                        <div class="field">
                            <label class="form-check" style="display:flex;align-items:center;gap:8px;font-weight:500;">
                                <input type="checkbox" @bind="_nf.AllowMultiple" />
                                Permitir varios valores (ej. varios telefonos)
                            </label>
                            @if (_nf.AllowMultiple)
                            {
                                <label class="form-check" style="display:flex;align-items:center;gap:8px;font-weight:500;margin-top:8px;">
                                    <input type="checkbox" @bind="_nf.MultiWithDetail" />
                                    Incluir detalle por valor (un texto antes de cada valor)
                                </label>
                            }
                            <label class="form-check" style="display:flex;align-items:center;gap:8px;font-weight:500;margin-top:8px;">
                                <input type="checkbox" @bind="_nf.ShowInFilter" />
                                Mostrar como filtro en el tablero (un chip por cada valor)
                            </label>
                        </div>
                    </div>
                    @if (_nf.FieldType == PipelineFieldType.Total)
                    {
                        var summables = cfgFields.Where(x => x.FieldType is PipelineFieldType.Number or PipelineFieldType.Currency && (_editingFieldId is null || x.Id != _editingFieldId)).ToList();
                        <div class="field">
                            <label class="form-label">Campos a sumar</label>
                            @if (summables.Count == 0)
                            {
                                <div class="text-muted" style="font-size:11.5px;">No hay campos numericos o de moneda en esta etapa. Crea primero los campos a sumar.</div>
                            }
                            else
                            {
                                <div style="display:flex;flex-direction:column;gap:4px;">
                                    @foreach (var sf in summables)
                                    {
                                        var skey = sf.FieldKey;
                                        <label class="form-check" style="display:flex;align-items:center;gap:8px;font-weight:500;">
                                            <input type="checkbox" checked="@_nf.TotalSourceKeys.Contains(skey)" @onchange="e => ToggleTotalSource(skey, (bool)(e.Value ?? false))" />
                                            @sf.Label @(sf.AllowMultiple ? "(suma todos los registros)" : "")
                                        </label>
                                    }
                                </div>
                                <div class="text-muted" style="font-size:11px;">El total se calcula solo y es de solo lectura.</div>
                            }
                        </div>
                    }
                    @if (_cfgFieldMsg is not null)
                    {
                        <div class="text-danger small">@_cfgFieldMsg</div>
                    }
                    <div style="margin-top:6px;display:flex;gap:8px;align-items:center;">
                        <button class="btn btn-primary" disabled="@_busy" @onclick="AddFieldAsync">@(_editingFieldId is null ? "+ Agregar campo" : "Guardar cambios")</button>
                        @if (_editingFieldId is not null)
                        {
                            <button class="btn btn-link" disabled="@_busy" @onclick="CancelEditField">Cancelar</button>
                        }
                    </div>
                </div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _configOpen = false">Listo</button>
            </div>
        </div>
    </div>
}

@code {
