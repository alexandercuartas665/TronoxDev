            var rel = url.TrimStart('/').Replace('/', System.IO.Path.DirectorySeparatorChar);
            var path = System.IO.Path.Combine(Env.WebRootPath, rel);
            if (System.IO.File.Exists(path)) { System.IO.File.Delete(path); }
        }
        catch { /* el registro ya se elimino; el binario huerfano no es critico */ }
    }

    private static string FileExt(string name)
    {
        var ext = System.IO.Path.GetExtension(name).TrimStart('.').ToUpperInvariant();
        return string.IsNullOrEmpty(ext) ? "DOC" : ext;
    }

    private static string FileSize(long bytes)
    {
        if (bytes < 1024) { return $"{bytes} B"; }
        if (bytes < 1024 * 1024) { return $"{bytes / 1024.0:N0} KB"; }
        return $"{bytes / (1024.0 * 1024.0):N1} MB";
    }

    // Leads filtrados y ordenados de forma global (vista lista, sin agrupar por etapa).
    private List<LeadDto> AllFilteredLeads()
    {
        var all = new List<LeadDto>();
        foreach (var stage in _stages)
        {
            if (_filterStages.Count > 0 && !_filterStages.Contains(stage.Id)) { continue; }
            all.AddRange(VisibleLeads(stage.Id));
        }
        return _sortBy switch
        {
            "name" => all.OrderBy(l => l.ContactName, StringComparer.OrdinalIgnoreCase).ToList(),
            "unanswered" => all.OrderByDescending(l => PendingFor(l)?.UnansweredCount ?? 0).ThenBy(l => l.StageChangedAt).ToList(),
            "recent" => all.OrderByDescending(l => l.CreatedAt).ToList(),
            "arrival" => all.OrderBy(l => l.CreatedAt).ToList(),
            _ => all.OrderBy(l => l.StageChangedAt).ToList()
        };
    }

