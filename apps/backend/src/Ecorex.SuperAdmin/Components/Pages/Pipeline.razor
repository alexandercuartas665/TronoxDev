    private string _tplFormCategory = "saludo";
    private string? _tplFormBody;
    private MessageMediaType _tplFormMediaType = MessageMediaType.None;
    private string? _tplFormMediaUrl;
    private string? _tplFormMediaMime;

    // Envio de ubicacion
    private bool _locationOpen;
    private string? _locName;
    private string? _locLat;
    private string? _locLng;
    private string? _locError;

    // Categorias = las estandar + las personalizadas que existan en las plantillas del tenant.
    private List<(string Key, string Label)> QrCategories
    {
        get
        {
            var keys = MessageTemplateCategories.All.Select(c => c.Key).ToList();
            foreach (var t in _templates)
            {
                if (!keys.Contains(t.Category)) { keys.Add(t.Category); }
            }
            return keys.Select(k => (k, CategoryLabel(k))).ToList();
        }
    }

    private static string CategoryLabel(string key)
    {
        var lbl = MessageTemplateCategories.Label(key);
        if (lbl == key && key.Length > 0) { return char.ToUpperInvariant(key[0]) + key[1..]; }
        return lbl;
    }

    private List<MessageTemplateDto> CurrentTemplates()
        => _templates.Where(t => t.Category == _qrCategory).OrderBy(t => t.SortOrder).ToList();

    private string FillTemplate(string template)
    {
        var destino = string.IsNullOrWhiteSpace(_el.Destination)
            ? "tu destino"
            : _el.Destination!.Split('→', '>').Last().Trim();
        var asesor = AssignedFirstName() ?? "tu asesor";
        return template
            .Replace("{destino}", destino)
            .Replace("{asesor}", asesor);
    }

    private string? AssignedFirstName()
    {
        if (_editLead?.AssignedToTenantUserId is not Guid id) { return null; }
        var u = _team.FirstOrDefault(t => t.Id == id);
        var label = u is null ? null : TeamLabel(u);
        return string.IsNullOrWhiteSpace(label) ? null : label.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
    }

    private static string MediaIcon(MessageMediaType t) => t switch
    {
        MessageMediaType.Image => "Imagen",
        MessageMediaType.Video => "Video",
        MessageMediaType.Audio => "Audio",
        MessageMediaType.Document => "Doc",
        MessageMediaType.Location => "Ubicacion",
        _ => ""
    };

    private static string MapsLink(string? coords) => $"https://www.google.com/maps?q={coords}";

    // ===== Adjuntos del chat =====
    private async Task UseTemplateAsync(MessageTemplateDto t)
    {
        _chatError = null;
        if (t.MediaType == MessageMediaType.None)
        {
            _chatDraft = FillTemplate(t.Body);
            return;
        }
        if (_conversation is null || _chatLineId == Guid.Empty || t.MediaUrl is null) { return; }
        _chatBusy = true;
        try
        {
            var b64 = await ReadLocalBase64Async(t.MediaUrl);
            if (b64 is null) { _chatError = "No se encontro el archivo del pregrabado."; return; }
            var actor = await ActorAsync();
            var caption = FillTemplate(t.Body);
            var r = await ChatSvc.SendMediaViaLineAsync(_conversation.Id, _chatLineId, t.MediaType, b64, t.MediaUrl, t.MediaMimeType, System.IO.Path.GetFileName(t.MediaUrl), caption, actor);
            if (!r.Ok) { _chatError = r.Error; return; }
            if (r.Message is not null) { _messages.Add(r.Message); }
        }
        finally { _chatBusy = false; }
    }

    private async Task OnAttachAsync(InputFileChangeEventArgs e, MessageMediaType type)
    {
        _attachOpen = false;
        _chatError = null;
        if (_conversation is null || _chatLineId == Guid.Empty) { return; }
        var saved = await SaveChatFileAsync(e.File, type);
        if (saved is null) { _chatError = "Archivo invalido o supera 16 MB."; return; }
        _chatBusy = true;
        try
        {
            var actor = await ActorAsync();
            var caption = string.IsNullOrWhiteSpace(_chatDraft) ? null : _chatDraft!.Trim();
            var r = await ChatSvc.SendMediaViaLineAsync(_conversation.Id, _chatLineId, type, saved.Value.Base64, saved.Value.Url, saved.Value.Mime, saved.Value.Name, caption, actor);
            if (!r.Ok) { _chatError = r.Error; return; }
            if (r.Message is not null) { _messages.Add(r.Message); }
            _chatDraft = null;
        }
        finally { _chatBusy = false; }
    }

    private void OpenLocation()
    {
        _attachOpen = false;
        _locName = null; _locLat = null; _locLng = null; _locError = null;
        _locationOpen = true;
    }

    private async Task SendLocationAsync()
    {
        _locError = null;
        var ci = System.Globalization.CultureInfo.InvariantCulture;
        if (!double.TryParse(_locLat, System.Globalization.NumberStyles.Any, ci, out var lat)
            || !double.TryParse(_locLng, System.Globalization.NumberStyles.Any, ci, out var lng))
        {
            _locError = "Latitud y longitud invalidas.";
            return;
        }
        if (_conversation is null || _chatLineId == Guid.Empty) { _locError = "Selecciona una linea."; return; }
        _chatBusy = true;
        try
        {
            var actor = await ActorAsync();
            var r = await ChatSvc.SendLocationViaLineAsync(_conversation.Id, _chatLineId, lat, lng, _locName, actor);
            if (!r.Ok) { _locError = r.Error; return; }
            if (r.Message is not null) { _messages.Add(r.Message); }
            _locationOpen = false;
        }
        finally { _chatBusy = false; }
    }

    // ===== Gestor de pregrabados =====
    private void OpenTemplateManager()
    {
        _attachOpen = false;
        ResetTemplateForm();
        _tplFormCategory = _qrCategory;
        _tplManagerOpen = true;
    }

    private void EditTemplate(MessageTemplateDto t)
    {
        _tplEditId = t.Id;
        _tplFormCategory = t.Category;
        _tplFormBody = t.Body;
        _tplFormMediaType = t.MediaType;
        _tplFormMediaUrl = t.MediaUrl;
        _tplFormMediaMime = t.MediaMimeType;
        _tplFormError = null;
    }

    private void ResetTemplateForm()
    {
        _tplEditId = null;
        _tplFormBody = null;
        _tplFormMediaType = MessageMediaType.None;
        _tplFormMediaUrl = null;
        _tplFormMediaMime = null;
        _tplFormError = null;
    }

    private void ClearTemplateMedia()
    {
        _tplFormMediaType = MessageMediaType.None;
        _tplFormMediaUrl = null;
        _tplFormMediaMime = null;
    }

    private async Task OnTemplateMediaAsync(InputFileChangeEventArgs e)
    {
        _tplFormError = null;
        var mime = e.File.ContentType ?? "";
        var type = mime.StartsWith("image") ? MessageMediaType.Image
            : mime.StartsWith("video") ? MessageMediaType.Video
            : mime.StartsWith("audio") ? MessageMediaType.Audio
            : MessageMediaType.Document;
        var saved = await SaveChatFileAsync(e.File, type);
        if (saved is null) { _tplFormError = "Archivo invalido o supera 16 MB."; return; }
        _tplFormMediaType = type;
        _tplFormMediaUrl = saved.Value.Url;
        _tplFormMediaMime = saved.Value.Mime;
    }

    private async Task SaveTemplateAsync()
    {
        _tplFormError = null;
        if (string.IsNullOrWhiteSpace(_tplFormBody) && _tplFormMediaUrl is null)
        {
            _tplFormError = "Escribe un mensaje o adjunta un archivo.";
            return;
        }
        _tplBusy = true;
        try
        {
            var actor = await ActorAsync();
            if (_tplEditId is null)
            {
                await TemplatesSvc.CreateAsync(new CreateMessageTemplateRequest(_tplFormCategory, _tplFormBody ?? "", _tplFormMediaType, _tplFormMediaUrl, _tplFormMediaMime), actor);
            }
            else
            {
                await TemplatesSvc.UpdateAsync(_tplEditId.Value, new UpdateMessageTemplateRequest(_tplFormCategory, _tplFormBody ?? "", _tplFormMediaType, _tplFormMediaUrl, _tplFormMediaMime), actor);
            }
            _templates = (await TemplatesSvc.ListAsync()).ToList();
            ResetTemplateForm();
        }
        finally { _tplBusy = false; }
    }

    private async Task DeleteTemplateAsync(Guid id)
    {
        _tplBusy = true;
        try
        {
            var actor = await ActorAsync();
            await TemplatesSvc.DeleteAsync(id, actor);
            _templates = (await TemplatesSvc.ListAsync()).ToList();
            if (_tplEditId == id) { ResetTemplateForm(); }
        }
        finally { _tplBusy = false; }
    }

    // Guarda el archivo en wwwroot/uploads/chat y devuelve url local + base64 para Evolution.
    private async Task<(string Url, string Base64, string Mime, string Name)?> SaveChatFileAsync(IBrowserFile file, MessageMediaType type)
    {
        const long max = 16L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { return null; }
        using var ms = new MemoryStream();
        await file.OpenReadStream(max).CopyToAsync(ms);
        var bytes = ms.ToArray();
        var ext = System.IO.Path.GetExtension(file.Name);
        if (string.IsNullOrWhiteSpace(ext))
        {
            ext = type switch
            {
                MessageMediaType.Image => ".jpg",
                MessageMediaType.Video => ".mp4",
                MessageMediaType.Audio => ".ogg",
                _ => ".bin"
            };
        }
        var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", "chat");
        System.IO.Directory.CreateDirectory(dir);
        var name = $"chat-{Guid.NewGuid():N}{ext}";
        await System.IO.File.WriteAllBytesAsync(System.IO.Path.Combine(dir, name), bytes);
        var mime = string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType;
        return ($"/uploads/chat/{name}", Convert.ToBase64String(bytes), mime, file.Name);
    }

    private async Task<string?> ReadLocalBase64Async(string localUrl)
    {
        var rel = localUrl.TrimStart('/').Replace('/', System.IO.Path.DirectorySeparatorChar);
        var path = System.IO.Path.Combine(Env.WebRootPath, rel);
        if (!System.IO.File.Exists(path)) { return null; }
        return Convert.ToBase64String(await System.IO.File.ReadAllBytesAsync(path));
    }

