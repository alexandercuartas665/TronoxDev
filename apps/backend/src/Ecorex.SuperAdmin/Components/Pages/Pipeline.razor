    // Borrado total del historial (solo admin del tenant; el backend revalida el rol). Tras borrar
    // en BD, elimina los binarios de los archivos del disco (best-effort).
    private async Task PurgeHistoryAsync()
    {
        _purgeBusy = true;
        _purgeMsg = null;
        try
        {
            var result = await LeadsSvc.PurgeArchivedHistoryAsync();
            if (result is null)
            {
                _purgeMsg = "No tienes permiso para borrar el historial.";
                _purgeStep = 0;
                return;
            }
            foreach (var url in result.FileUrls)
            {
                try
                {
                    if (string.IsNullOrWhiteSpace(url)) { continue; }
                    var rel = url.TrimStart('/').Replace('/', System.IO.Path.DirectorySeparatorChar);
                    var path = System.IO.Path.Combine(Env.WebRootPath, rel);
                    if (System.IO.File.Exists(path)) { System.IO.File.Delete(path); }
                }
                catch { /* binario huerfano, se ignora */ }
            }
            _history.Clear();
            RecalcKpis();
            _purgeStep = 0;
            _purgeMsg = $"Historial borrado: {result.DeletedLeads} cliente(s).";
        }
        finally { _purgeBusy = false; }
    }

    private IEnumerable<ArchivedLeadDto> FilteredHistory()
    {
        IEnumerable<ArchivedLeadDto> q = _history;
        if (!string.IsNullOrWhiteSpace(_histSearch))
        {
            var s = _histSearch.Trim();
            q = q.Where(h => (h.ContactName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                          || (h.Destination?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                          || (h.ContactPhone?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false));
        }
        if (!string.IsNullOrWhiteSpace(_histReason))
        {
            q = q.Where(h => h.ArchiveReason == _histReason);
        }
        if (Guid.TryParse(_histAsesor, out var aid))
        {
            q = q.Where(h => h.AssignedToTenantUserId == aid);
        }
        return q;
    }

