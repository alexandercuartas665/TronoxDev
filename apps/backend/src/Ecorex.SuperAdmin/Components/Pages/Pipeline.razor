    private async Task LoadChatAsync(Guid leadId)
    {
        _conversation = null;
        _messages = new();
        _chatLines = new();
        _chatError = null;
        _chatDraft = null;
        _qrCategory = "saludo";

        if (string.IsNullOrWhiteSpace(_el.ContactPhone)) { return; }

        var lines = await LinesSvc.ListAsync();
        _chatLines = lines.Where(l => l.Status == WhatsAppLineStatus.Connected).ToList();
        if (_chatLines.Count == 0) { return; }

        _conversation = await ChatSvc.GetOrCreateForLeadAsync(leadId);
        if (_conversation is null) { return; }

        _messages = (await ChatSvc.ListMessagesAsync(_conversation.Id)).ToList();
        _scrollChatPending = true;
        var preferred = _conversation.WhatsAppLineId is Guid lid && _chatLines.Any(l => l.Id == lid)
            ? lid
            : _chatLines[0].Id;
        _chatLineId = preferred;

        await TemplatesSvc.SeedDefaultsAsync();
        _templates = (await TemplatesSvc.ListAsync()).ToList();

        await JoinConversationRealtimeAsync(_conversation.Id);
    }

    private async Task EnsureHubAsync()
    {
        if (_hub is not null) { return; }
        try
        {
            _hub = new HubConnectionBuilder()
                .WithUrl(Nav.ToAbsoluteUri("/hubs/chat"))
                .WithAutomaticReconnect()
                .Build();

            _hub.On<MessageDto>("MessageAdded", async msg =>
            {
                if (_conversation is null || msg.ConversationId != _conversation.Id) { return; }
                if (_messages.Any(m => m.Id == msg.Id)) { return; }
                _messages.Add(msg);
                _scrollChatPending = true;
                await InvokeAsync(StateHasChanged);
            });

            // Cualquier mensaje del tenant: recalcular el estado "sin responder" del tablero.
            _hub.On("BoardChanged", async () =>
            {
                _pending = await ChatSvc.GetUnansweredByPhoneAsync();
                await InvokeAsync(StateHasChanged);
            });

            await _hub.StartAsync();
            if (!string.IsNullOrEmpty(_tenantId))
            {
                await _hub.SendAsync("JoinTenant", _tenantId);
            }
        }
        catch
        {
            // El tiempo real es un complemento; si falla la conexion el tablero sigue funcionando.
        }
    }

    private async Task JoinConversationRealtimeAsync(Guid conversationId)
    {
        await EnsureHubAsync();
        if (_hub is null) { return; }
        try
        {
            if (_joinedConversation is not null && _joinedConversation != conversationId.ToString())
            {
                await _hub.SendAsync("LeaveConversation", _joinedConversation);
            }
            await _hub.SendAsync("JoinConversation", conversationId.ToString());
            _joinedConversation = conversationId.ToString();
        }
        catch { }
    }


