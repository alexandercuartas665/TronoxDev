    // ===== Archivos del lead =====
    private async Task OnLeadFileAsync(InputFileChangeEventArgs e)
    {
        if (_editLead is null) { return; }
        _fileError = null;
        var file = e.File;
        const long max = 25L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max)
        {
            _fileError = "El archivo supera el limite de 25 MB.";
            return;
        }
        _fileBusy = true;
        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(max).CopyToAsync(ms);
            var bytes = ms.ToArray();
            var ext = System.IO.Path.GetExtension(file.Name);
            var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", "leads");
            System.IO.Directory.CreateDirectory(dir);
            var stored = $"lead-{Guid.NewGuid():N}{ext}";
            await System.IO.File.WriteAllBytesAsync(System.IO.Path.Combine(dir, stored), bytes);
            var url = $"/uploads/leads/{stored}";
            var mime = string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType;

            var saved = await LeadsSvc.AddFileAsync(_editLead.Id, file.Name, url, mime, file.Size, await ActorAsync());
            if (saved is not null) { _files.Insert(0, saved); }
        }
        catch
        {
            _fileError = "No se pudo subir el archivo.";
        }
        finally { _fileBusy = false; }
    }

    private async Task DeleteLeadFileAsync(Guid fileId)
    {
