    // Hora salida/llegada: se guarda como "salida - llegada". Devuelve la parte idx (0=salida, 1=llegada).
    private static string TimeRangePart(string? combined, int idx)
    {
        if (string.IsNullOrWhiteSpace(combined)) { return string.Empty; }
        var parts = combined.Split('-', 2);
        return idx < parts.Length ? parts[idx].Trim() : string.Empty;
    }

    // Actualiza una de las dos horas y recompone el valor "salida - llegada".
    private static string SetTimeRange(string? combined, int idx, string? value)
    {
        var salida = idx == 0 ? (value ?? "").Trim() : TimeRangePart(combined, 0);
        var llegada = idx == 1 ? (value ?? "").Trim() : TimeRangePart(combined, 1);
        if (string.IsNullOrEmpty(salida) && string.IsNullOrEmpty(llegada)) { return string.Empty; }
        return $"{salida} - {llegada}";
    }

