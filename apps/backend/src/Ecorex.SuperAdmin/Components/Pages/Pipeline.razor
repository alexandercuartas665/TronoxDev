    // Genera el PDF de la cotizacion y lo envia por WhatsApp usando la linea activa de la conversacion.
    private async Task EnviarCotizacionAsync()
    {
        _quoteMsg = null;
        if (_editLead is null || _conversation is null || _chatLineId == Guid.Empty) { _quoteMsg = "Necesitas una linea activa."; _sendConfirm = false; return; }
        _quoteBusy = true;
        try
        {
            // Formato segun la plantilla SELECCIONADA: imagen (PNG) o PDF adjunto.
            var tpl = _quoteTemplates.FirstOrDefault(t => t.Id == _selectedQuoteTemplateId)
                      ?? _quoteTemplates.FirstOrDefault(t => t.IsDefault);
            var asImage = tpl?.SendAsImage ?? false;

            var q = _selectedQuoteTemplateId != Guid.Empty ? $"?templateId={_selectedQuoteTemplateId}" : "";
            var url = $"{Nav.BaseUri.TrimEnd('/')}/cotizacion/{_editLead.Id}{q}";
            var bytes = asImage ? await PdfRenderer.RenderUrlToImageAsync(url) : await PdfRenderer.RenderUrlToPdfAsync(url);
            if (bytes.Length == 0) { _quoteMsg = "No se pudo generar la cotizacion."; return; }

            var ext = asImage ? "png" : "pdf";
            var mediaType = asImage ? MessageMediaType.Image : MessageMediaType.Document;
            var mime = asImage ? "image/png" : "application/pdf";
            var sendName = asImage ? "Cotizacion.png" : "Cotizacion.pdf";

            // Guarda el archivo servible y lo registra como media del mensaje.
            var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", "cotizaciones");
            System.IO.Directory.CreateDirectory(dir);
            var fileName = $"cotizacion-{Guid.NewGuid():N}.{ext}";
            await System.IO.File.WriteAllBytesAsync(System.IO.Path.Combine(dir, fileName), bytes);
            var localUrl = $"/uploads/cotizaciones/{fileName}";
            var b64 = Convert.ToBase64String(bytes);

            var actor = await ActorAsync();
            var caption = $"Hola {_el.ContactName}, te compartimos tu cotizacion.";
            var result = await ChatSvc.SendMediaViaLineAsync(_conversation.Id, _chatLineId, mediaType,
                b64, localUrl, mime, sendName, caption, actor);
            if (!result.Ok) { _quoteMsg = result.Error ?? "No se pudo enviar."; return; }
            if (result.Message is not null) { _messages.Add(result.Message); }
            _quoteMsg = "Cotizacion enviada.";
            _sendConfirm = false;
        }
        catch (Exception ex)
        {
            _quoteMsg = "Error al enviar la cotizacion: " + ex.Message;
        }
        finally { _quoteBusy = false; }
    }

