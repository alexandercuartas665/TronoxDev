                _multiDetails[f.FieldKey] = details;
            }
            else if (f.AllowMultiple || !string.IsNullOrEmpty(f.RepeatWithFieldKey))
            {
                _multiValues[f.FieldKey] = ParseMulti(raw);
            }
            else
            {
                _editValues[f.FieldKey] = raw;
            }
        }
        // Plantillas de cotizacion para el selector (preselecciona la predeterminada).
        _quoteTemplates = (await QuoteTplSvc.ListAsync()).ToList();
        var def = _quoteTemplates.FirstOrDefault(t => t.IsDefault) ?? _quoteTemplates.FirstOrDefault();
        _selectedQuoteTemplateId = def?.Id ?? Guid.Empty;

        _leadOpen = true;
        await LoadChatAsync(leadId);
