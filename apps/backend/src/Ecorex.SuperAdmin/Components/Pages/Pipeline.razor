    // ===== Campos multiples / repetidos =====
    private List<string?> ParseMulti(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) { return new List<string?>(); }
        var t = raw.TrimStart();
        if (t.StartsWith("["))
        {
            try
            {
                var arr = System.Text.Json.JsonSerializer.Deserialize<List<string?>>(raw);
                if (arr is not null) { return arr; }
            }
            catch { /* no era JSON: se trata como valor unico */ }
        }
        return new List<string?> { raw };
    }

    private static string? SerializeMulti(List<string?> list)
    {
        var clean = list.Select(x => x?.Trim()).Where(x => !string.IsNullOrEmpty(x)).ToList();
        return clean.Count == 0 ? null : System.Text.Json.JsonSerializer.Serialize(clean);
    }

    // Cantidad de repeticiones segun el valor numerico del campo referenciado (0..20).
    private int RepeatCount(string repeatFieldKey)
    {
        var raw = _editValues.TryGetValue(repeatFieldKey, out var v) ? v : null;
        if (int.TryParse(raw, out var n)) { return Math.Clamp(n, 0, 20); }
        return 0;
    }

    // Devuelve la lista del campo, ajustada al tamano pedido (fixedCount>=0 para repetidos;
    // -1 para "multiples": garantiza al menos 1 fila para capturar).
    private List<string?> MultiList(string key, int fixedCount)
    {
        if (!_multiValues.TryGetValue(key, out var list)) { list = new List<string?>(); _multiValues[key] = list; }
        if (fixedCount >= 0)
        {
            while (list.Count < fixedCount) { list.Add(null); }
            while (list.Count > fixedCount) { list.RemoveAt(list.Count - 1); }
        }
        else if (list.Count == 0) { list.Add(null); }
        return list;
    }

    private void AddMulti(string key)
    {
        if (!_multiValues.TryGetValue(key, out var list)) { list = new List<string?>(); _multiValues[key] = list; }
        list.Add(null);
        if (_multiDetails.TryGetValue(key, out var dets)) { dets.Add(null); }
    }

    private void RemoveMulti(string key, int index)
    {
        if (_multiValues.TryGetValue(key, out var list) && index >= 0 && index < list.Count)
        {
            list.RemoveAt(index);
            if (_multiDetails.TryGetValue(key, out var dets) && index < dets.Count) { dets.RemoveAt(index); }
            if (list.Count == 0) { list.Add(null); if (_multiDetails.ContainsKey(key)) { _multiDetails[key].Add(null); } }
        }
    }

    // Lista de detalles paralela a los valores del campo multiple (mismo tamano).
    private List<string?> DetailList(string key, int count)
    {
        if (!_multiDetails.TryGetValue(key, out var list)) { list = new List<string?>(); _multiDetails[key] = list; }
        while (list.Count < count) { list.Add(null); }
        while (list.Count > count) { list.RemoveAt(list.Count - 1); }
        return list;
    }

    private sealed class MultiDetailItem { public string? d { get; set; } public string? v { get; set; } }

    // Lee el arreglo JSON de objetos {d,v}. Tolera el formato viejo (arreglo simple de strings).
    private (List<string?> details, List<string?> values) ParseMultiDetail(string? raw)
    {
        var details = new List<string?>();
        var values = new List<string?>();
        if (string.IsNullOrWhiteSpace(raw)) { return (details, values); }
        if (raw.TrimStart().StartsWith("["))
        {
            try
            {
                var arr = System.Text.Json.JsonSerializer.Deserialize<List<MultiDetailItem>>(raw);
                if (arr is not null)
                {
                    foreach (var it in arr) { details.Add(it.d); values.Add(it.v); }
                    return (details, values);
                }
            }
            catch
            {
                // Formato anterior: arreglo simple de valores sin detalle.
                foreach (var s in ParseMulti(raw)) { details.Add(null); values.Add(s); }
                return (details, values);
            }
        }
        details.Add(null);
        values.Add(raw);
        return (details, values);
    }

    private static string? SerializeMultiDetail(List<string?> details, List<string?> values)
    {
        var items = new List<MultiDetailItem>();
        var n = Math.Max(details.Count, values.Count);
        for (var i = 0; i < n; i++)
        {
            var d = i < details.Count ? details[i]?.Trim() : null;
            var v = i < values.Count ? values[i]?.Trim() : null;
            if (string.IsNullOrEmpty(d) && string.IsNullOrEmpty(v)) { continue; }
            items.Add(new MultiDetailItem { d = d, v = v });
        }
        return items.Count == 0 ? null : System.Text.Json.JsonSerializer.Serialize(items);
    }

    // ===== Datos enriquecidos de la tarjeta =====
    private string? Field(LeadDto l, string key) =>
        l.FieldValues.TryGetValue(key, out var v) && !string.IsNullOrWhiteSpace(v) ? v.Trim() : null;

    private string TimeInStageLabel(LeadDto l)
    {
        var span = DateTimeOffset.UtcNow - l.StageChangedAt;
        var d = (int)span.TotalDays;
        var h = span.Hours;
        if (d > 0) { return h > 0 ? $"{d}d {h}h" : $"{d}d"; }
        if (h > 0) { return $"{h}h"; }
        return "Nuevo";
    }

    private string CardCss(LeadDto l, LeadChatStateDto? pend)
    {
        var c = "kb-card";
        if (IsStale(l)) { c += " stale"; }
        if (pend is not null) { c += " needsreply"; }
        if (_seenLoaded && !_seenLeadIds.Contains(l.Id)) { c += " unseen"; }
        return c;
    }

    // ===== Tarjetas no vistas (localStorage por tenant) =====
    private string SeenKey => $"ecorex.pl.seen.{_tenantId}";

    private async Task LoadSeenLeadsAsync()
    {
        if (string.IsNullOrEmpty(_tenantId)) { _seenLoaded = true; return; }
        try
        {
            var raw = await JS.InvokeAsync<string?>("localStorage.getItem", SeenKey);
            _seenLeadIds.Clear();
            if (string.IsNullOrWhiteSpace(raw))
            {
                // Primera visita: marca lo que ya existe como visto (no resaltar leads viejos).
                foreach (var l in _leads) { _seenLeadIds.Add(l.Id); }
                await PersistSeenAsync();
            }
            else
            {
                foreach (var part in raw.Split(',', StringSplitOptions.RemoveEmptyEntries))
                {
                    if (Guid.TryParse(part, out var id)) { _seenLeadIds.Add(id); }
                }
            }
        }
        catch { /* localStorage no disponible: sin resaltado */ }
        _seenLoaded = true;
    }

    private async Task PersistSeenAsync()
    {
        if (string.IsNullOrEmpty(_tenantId)) { return; }
        try { await JS.InvokeVoidAsync("localStorage.setItem", SeenKey, string.Join(',', _seenLeadIds)); }
        catch { /* best-effort */ }
    }

    private async Task MarkSeenAsync(Guid leadId)
    {
        if (_seenLeadIds.Add(leadId)) { await PersistSeenAsync(); }
    }

    // ===== Unidades de negocio =====
    private BusinessUnitDto? UnitOf(LeadDto? l) =>
        l?.BusinessUnitId is Guid id ? _businessUnits.FirstOrDefault(u => u.Id == id) : null;

    // Pinta un borde izquierdo con el color de la unidad de negocio del lead.
    private string CardStyle(LeadDto l) =>
        UnitOf(l) is { } bu ? $"border-left:4px solid {bu.Color};" : string.Empty;

    private static Guid? ParseGuid(string? s) => Guid.TryParse(s, out var g) ? g : (Guid?)null;

    private void OnEditUnitChanged(ChangeEventArgs e)
    {
        _el.BusinessUnitId = ParseGuid(e.Value?.ToString());
        _leadDirty = true;
    }

    private void ToggleUnit(Guid id) { if (!_filterUnits.Add(id)) { _filterUnits.Remove(id); } }

    // ===== Configuracion de unidades de negocio =====
    private void OpenUnits()
    {
        _unitsError = null;
        _editingUnitId = null;
        _uf = new UnitForm();
        _unitsOpen = true;
    }

    private void EditUnit(BusinessUnitDto u)
    {
        _editingUnitId = u.Id;
        _uf = new UnitForm { Name = u.Name, Color = u.Color, ModalKind = u.ModalKind };
        _unitsError = null;
    }

    private void CancelUnitEdit()
    {
        _editingUnitId = null;
        _uf = new UnitForm();
        _unitsError = null;
    }

    private async Task SaveUnitAsync()
    {
        if (string.IsNullOrWhiteSpace(_uf.Name))
        {
            _unitsError = "El nombre es obligatorio.";
            return;
        }
        var actor = await ActorAsync();
        var req = new SaveBusinessUnitRequest(_uf.Name.Trim(),
            string.IsNullOrWhiteSpace(_uf.Color) ? "#A03DC9" : _uf.Color.Trim(), _uf.ModalKind);
        if (_editingUnitId is Guid id) { await BizUnitSvc.UpdateAsync(id, req, actor); }
        else { await BizUnitSvc.CreateAsync(req, actor); }
        _businessUnits = (await BizUnitSvc.ListAsync()).ToList();
        CancelUnitEdit();
    }

    private async Task ToggleUnitActiveAsync(BusinessUnitDto u)
    {
        var actor = await ActorAsync();
        await BizUnitSvc.SetActiveAsync(u.Id, !u.IsActive, actor);
        _businessUnits = (await BizUnitSvc.ListAsync()).ToList();
    }

    private async Task DeleteUnitAsync(BusinessUnitDto u)
    {
        var actor = await ActorAsync();
        await BizUnitSvc.DeleteAsync(u.Id, actor);
        _businessUnits = (await BizUnitSvc.ListAsync()).ToList();
        _leads = (await LeadsSvc.ListAsync()).ToList();
        if (_editingUnitId == u.Id) { CancelUnitEdit(); }
    }

    // ===== Busqueda, orden y filtros =====
    private bool FiltersActive => _filterAsesores.Count > 0 || _filterSinAsesor || _filterStages.Count > 0 || _filterValue.Count > 0 || _filterDestinos.Count > 0 || _filterUnits.Count > 0 || _filterFields.Count > 0 || _onlyUnanswered;
    private int ActiveFilterCount => _filterAsesores.Count + (_filterSinAsesor ? 1 : 0) + _filterStages.Count + _filterValue.Count + _filterDestinos.Count + _filterUnits.Count + _filterFields.Sum(kv => kv.Value.Count) + (_onlyUnanswered ? 1 : 0);

    private void ClearFilters()
    {
        _filterAsesores.Clear();
        _filterSinAsesor = false;
        _filterStages.Clear();
        _filterValue.Clear();
        _filterDestinos.Clear();
        _filterUnits.Clear();
        _filterFields.Clear();
        _onlyUnanswered = false;
    }
    private void ToggleAsesor(Guid id) { if (!_filterAsesores.Add(id)) { _filterAsesores.Remove(id); } }
    private void ToggleStage(Guid id) { if (!_filterStages.Add(id)) { _filterStages.Remove(id); } }
    private void ToggleValue(string k) { if (!_filterValue.Add(k)) { _filterValue.Remove(k); } }
    private void ToggleDestino(string d) { if (!_filterDestinos.Add(d)) { _filterDestinos.Remove(d); } }

    private List<string> DistinctDestinations() =>
        _leads.Where(l => !string.IsNullOrWhiteSpace(l.Destination))
            .Select(l => l.Destination!.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(d => d, StringComparer.OrdinalIgnoreCase)
            .ToList();

    // ===== Filtros por campo dinamico (ShowInFilter) =====
    // Campos marcados para filtrar, distintos por clave (un mismo campo puede existir en varias etapas).
    private List<PipelineFieldDto> FilterableFields() =>
        _fields.Where(f => f.ShowInFilter)
            .GroupBy(f => f.FieldKey)
            .Select(g => g.First())
            .OrderBy(f => f.Label, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private List<string> DistinctFieldValues(string key) =>
        _leads.Select(l => Field(l, key))
            .Where(v => !string.IsNullOrWhiteSpace(v))
            .Select(v => v!.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(v => v, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private bool FieldFilterOn(string key, string val) =>
        _filterFields.TryGetValue(key, out var set) && set.Contains(val);

    private void ToggleFieldFilter(string key, string val)
    {
        if (!_filterFields.TryGetValue(key, out var set))
        {
            set = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            _filterFields[key] = set;
        }
        if (!set.Add(val)) { set.Remove(val); }
        if (set.Count == 0) { _filterFields.Remove(key); }
    }
    private static string FirstName(string label)
    {
        var n = label.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return n.Length > 0 ? n[0] : label;
    }

    private List<LeadDto> VisibleLeads(Guid stageId)
    {
        IEnumerable<LeadDto> q = _leads.Where(l => l.StageId == stageId);

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(l => (l.ContactName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                          || (l.Destination?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false));
        }
        if (_filterAsesores.Count > 0 || _filterSinAsesor)
        {
            q = q.Where(l =>
                (l.AssignedToTenantUserId is Guid id && _filterAsesores.Contains(id))
                || (_filterSinAsesor && l.AssignedToTenantUserId is null));
        }
        if (_filterDestinos.Count > 0)
        {
            q = q.Where(l => l.Destination is not null && _filterDestinos.Contains(l.Destination.Trim()));
        }
        if (_filterUnits.Count > 0)
        {
            q = q.Where(l => l.BusinessUnitId is Guid bu && _filterUnits.Contains(bu));
        }
        if (_onlyUnanswered)
        {
            q = q.Where(l => PendingFor(l) is not null);
        }
        if (_filterValue.Count > 0)
        {
            q = q.Where(MatchesValue);
        }
        foreach (var kv in _filterFields)
        {
            var key = kv.Key;
            var vals = kv.Value;
            q = q.Where(l => Field(l, key) is string fv && vals.Contains(fv));
        }

        q = _sortBy switch
        {
            "name" => q.OrderBy(l => l.ContactName, StringComparer.OrdinalIgnoreCase),
            "unanswered" => q.OrderByDescending(l => PendingFor(l)?.UnansweredCount ?? 0).ThenBy(l => l.StageChangedAt),
            "recent" => q.OrderByDescending(l => l.CreatedAt),
            "arrival" => q.OrderBy(l => l.CreatedAt),
            _ => q.OrderBy(l => l.StageChangedAt) // tiempo en columna: el que mas lleva, primero
        };
        return q.ToList();
    }

    private bool MatchesValue(LeadDto l)
    {
        var v = l.EstimatedValue ?? 0m;
        foreach (var k in _filterValue)
        {
            if (k == "lt2" && v < 2_000_000m) { return true; }
            if (k == "2to5" && v >= 2_000_000m && v <= 5_000_000m) { return true; }
            if (k == "gt5" && v > 5_000_000m) { return true; }
        }
        return false;
    }

    // Estado "sin responder" del chat (mensajes entrantes tras la ultima respuesta).
    private LeadChatStateDto? PendingFor(LeadDto l)
    {
        if (string.IsNullOrWhiteSpace(l.ContactPhone)) { return null; }
        var key = new string(l.ContactPhone.Where(char.IsDigit).ToArray());
        return _pending.TryGetValue(key, out var st) ? st : null;
    }

    private string WaitingLabel(DateTimeOffset since)
    {
        var span = DateTimeOffset.UtcNow - since;
        var d = (int)span.TotalDays;
        var h = span.Hours;
        var m = span.Minutes;
        if (d > 0) { return h > 0 ? $"{d}d {h}h sin responder" : $"{d}d sin responder"; }
        if (h > 0) { return $"{h}h sin responder"; }
        return $"{Math.Max(m, 1)}m sin responder";
    }

    // Senal de atencion por tiempo en la etapa (proxy de "sin responder" hasta enlazar el chat).
    private bool IsStale(LeadDto l) => l.Status == LeadStatus.Open && (DateTimeOffset.UtcNow - l.StageChangedAt).TotalDays >= 2;
    private string StaleLabel(LeadDto l)
    {
        var d = (int)(DateTimeOffset.UtcNow - l.StageChangedAt).TotalDays;
        return $"{d}d sin avance";
    }

    private static readonly char[] RouteSeparators = { '→', '–', '>', '-' };
    private string[] RouteParts(LeadDto l) =>
        (l.Destination ?? string.Empty)
            .Split(RouteSeparators, StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim())
            .Where(s => s.Length > 0)
            .ToArray();
    private string RouteFrom(LeadDto l)
    {
        var parts = RouteParts(l);
        return parts.Length > 0 ? parts[0] : "Sin ruta";
    }
    private string? RouteTo(LeadDto l)
    {
        var parts = RouteParts(l);
        return parts.Length >= 2 ? parts[1] : null;
    }

    private string? AsesorName(LeadDto l)
    {
        var field = Field(l, "asesor");
        if (field is not null) { return field; }
        return l.AssignedToTenantUserId is Guid id ? UserEmail(id) : null;
    }

    private static string AseColor(string? name)
    {
        if (string.IsNullOrEmpty(name)) { return "var(--primary)"; }
        var palette = new[] { "#A03DC9", "#D89A36", "#4F8A60", "#4E80B5", "#C7398B" };
        return palette[char.ToUpperInvariant(name[0]) % palette.Length];
    }

    private static int LeadingNumber(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) { return 0; }
        var digits = new string(s.TrimStart().TakeWhile(char.IsDigit).ToArray());
        return int.TryParse(digits, out var n) ? n : 0;
    }
    private string? PaxLabel(LeadDto l)
    {
        var adults = LeadingNumber(Field(l, "adultos"));
        var kids = LeadingNumber(Field(l, "ninos"));
        if (adults == 0 && kids == 0) { return null; }
        var total = adults + kids;
        return kids > 0 ? $"{adults}+{kids} pax" : $"{total} pax";
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

