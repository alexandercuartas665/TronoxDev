    private static string Money(decimal v, string? currency) => $"$ {v:N0}{(string.IsNullOrWhiteSpace(currency) ? "" : " " + currency)}";

    // Convencion del sistema: coma = separador de miles, punto = decimal (3,500,000.50).
    // Da formato a un decimal: 3500000 -> "3,500,000".
    private static string FormatMoneyDecimal(decimal? v)
    {
        if (v is not decimal d) { return string.Empty; }
        var c = System.Globalization.CultureInfo.InvariantCulture;
        return d == Math.Truncate(d) ? d.ToString("#,##0", c) : d.ToString("#,##0.##", c);
    }

    // Convierte el valor crudo guardado (invariante: punto = decimal) al texto con separadores de miles.
    private static string FormatThousands(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) { return string.Empty; }
        // El valor guardado esta en formato invariante (ej "1000000" o "1000000.5").
        if (!decimal.TryParse(raw, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var value)
            && !TryParseMoney(raw!, out value))
        {
            return raw!;
        }
        return FormatMoneyDecimal(value);
    }

    // Limpia el texto editado (coma = miles, punto = decimal) y lo guarda en formato invariante.
    private static string DigitsToRaw(string? formatted)
    {
        if (string.IsNullOrWhiteSpace(formatted)) { return string.Empty; }
        if (!TryParseMoney(formatted!, out var value)) { return string.Empty; }
        return value == Math.Truncate(value)
            ? ((long)value).ToString(System.Globalization.CultureInfo.InvariantCulture)
            : value.ToString(System.Globalization.CultureInfo.InvariantCulture);
    }

    // Igual que DigitsToRaw pero devuelve decimal? para los campos fijos (Valor estimado).
    private static decimal? ParseMoneyNullable(string? formatted)
    {
        if (string.IsNullOrWhiteSpace(formatted)) { return null; }
        return TryParseMoney(formatted!, out var value) ? value : null;
    }

    // Texto del usuario: la coma es separador de miles y el punto es decimal (formato del sistema).
    private static bool TryParseMoney(string s, out decimal value)
    {
        var cleaned = new string(s.Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray());
        if (cleaned.Length == 0) { value = 0; return false; }
        cleaned = cleaned.Replace(",", string.Empty); // quitar separador de miles; el punto queda como decimal
        return decimal.TryParse(cleaned, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out value);
    }

    // Suma de un campo Total: recorre sus campos origen; los multiples/repetidos suman todos sus registros.
    private decimal ComputeTotal(PipelineFieldDto totalField)
    {
        if (string.IsNullOrWhiteSpace(totalField.TotalSourceKeys)) { return 0m; }
        var keys = totalField.TotalSourceKeys.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        decimal sum = 0m;
        foreach (var key in keys)
        {
            if (_multiValues.TryGetValue(key, out var list))
            {
                foreach (var item in list) { if (TryNum(item, out var n)) { sum += n; } }
            }
            else if (_editValues.TryGetValue(key, out var sv) && TryNum(sv, out var nv))
            {
                sum += nv;
            }
        }
        return sum;
    }

    private static bool TryNum(string? s, out decimal value)
    {
        value = 0m;
        if (string.IsNullOrWhiteSpace(s)) { return false; }
        return decimal.TryParse(s, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out value)
            || TryParseMoney(s!, out value);
    }

