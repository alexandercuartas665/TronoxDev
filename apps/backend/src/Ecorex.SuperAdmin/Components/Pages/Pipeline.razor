    private async Task SaveLeadAsync()
    {
        if (_editLead is null) { return; }
        if (string.IsNullOrWhiteSpace(_el.ContactName))
        {
            _leadError = "El nombre del contacto es obligatorio.";
            return;
        }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var values = new Dictionary<string, string?>(_editValues);
            // Campos de multiples valores / repetidos: se guardan como arreglo JSON.
            foreach (var kv in _multiValues)
            {
                if (_multiDetails.TryGetValue(kv.Key, out var dets))
                {
                    // Campo multiple con detalle: arreglo de objetos {d:detalle, v:valor}.
                    values[kv.Key] = SerializeMultiDetail(dets, kv.Value);
                }
                else
                {
                    values[kv.Key] = SerializeMulti(kv.Value);
                }
            }
            // Campos Total: se calculan y se guardan como valor invariante para vistas/reportes/API.
            foreach (var tf in _fields.Where(x => x.FieldType == PipelineFieldType.Total))
            {
                var total = ComputeTotal(tf);
                values[tf.FieldKey] = total.ToString(System.Globalization.CultureInfo.InvariantCulture);
            }
            var req = new UpdateLeadRequest(_el.ContactName, _el.ContactPhone, _el.Destination,
                _el.EstimatedValue, _el.Currency, values, _el.BusinessUnitId);
            var updated = await LeadsSvc.UpdateAsync(_editLead.Id, req, actor);
            if (updated is not null)
            {
                ReplaceLead(updated);
                _editLead = updated;
            }
            // No cerramos el modal: el usuario sigue editando y cierra cuando quiera.
            _leadDirty = false;
            _leadSaved = true;
            _leadError = null;
        }
        finally
        {
            _busy = false;
        }
    }

