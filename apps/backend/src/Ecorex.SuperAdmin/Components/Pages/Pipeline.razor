            await JS.InvokeVoidAsync("ecorexPipeline.init", _selfRef);
        }
        // Carga el set de "no vistos" una sola vez, ya con los leads cargados (no en el render de loading).
        if (!_seenLoaded && !_loading)
        {
            await LoadSeenLeadsAsync();
            StateHasChanged();
        }
        if (_scrollChatPending)
        {
            _scrollChatPending = false;
            try { await JS.InvokeVoidAsync("ecorexScrollChat"); } catch { }
        }
        // Activa el arrastrar-y-soltar de archivos sobre la conversacion (idempotente).
        if (_leadOpen && _selfRef is not null)
        {
            try { await JS.InvokeVoidAsync("ecorexPipeline.initChatDrop", "pl-chat-drop", _selfRef); } catch { }
        }
    }

    // Recibe un archivo soltado sobre la conversacion (desde JS) y lo envia por la linea activa.
    [JSInvokable]
    public async Task OnChatFileDropped(string fileName, string mime, string base64)
    {
        _chatError = null;
        if (_conversation is null || _chatLineId == Guid.Empty) { _chatError = "Selecciona una linea activa para enviar."; await InvokeAsync(StateHasChanged); return; }
        if (string.IsNullOrEmpty(base64)) { return; }

        var type = (mime ?? "").StartsWith("image/") ? MessageMediaType.Image
            : (mime ?? "").StartsWith("video/") ? MessageMediaType.Video
            : (mime ?? "").StartsWith("audio/") ? MessageMediaType.Audio
            : MessageMediaType.Document;

        _chatBusy = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            byte[] bytes;
            try { bytes = Convert.FromBase64String(base64); } catch { _chatError = "Archivo invalido."; return; }
            const long max = 16L * 1024 * 1024;
            if (bytes.Length == 0 || bytes.Length > max) { _chatError = "Archivo invalido o supera 16 MB."; return; }

            var ext = System.IO.Path.GetExtension(fileName);
            if (string.IsNullOrWhiteSpace(ext)) { ext = ".bin"; }
            var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", "chat");
            System.IO.Directory.CreateDirectory(dir);
            var stored = $"chat-{Guid.NewGuid():N}{ext}";
            await System.IO.File.WriteAllBytesAsync(System.IO.Path.Combine(dir, stored), bytes);
            var localUrl = $"/uploads/chat/{stored}";
            var safeMime = string.IsNullOrWhiteSpace(mime) ? "application/octet-stream" : mime;

            var actor = await ActorAsync();
            var caption = string.IsNullOrWhiteSpace(_chatDraft) ? null : _chatDraft!.Trim();
            var r = await ChatSvc.SendMediaViaLineAsync(_conversation.Id, _chatLineId, type, base64, localUrl, safeMime, fileName, caption, actor);
            if (!r.Ok) { _chatError = r.Error; return; }
            if (r.Message is not null) { _messages.Add(r.Message); }
            _chatDraft = null;
            _scrollChatPending = true;
        }
        catch (Exception ex)
        {
            _chatError = "No se pudo enviar el archivo: " + ex.Message;
        }
        finally
        {
            _chatBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

