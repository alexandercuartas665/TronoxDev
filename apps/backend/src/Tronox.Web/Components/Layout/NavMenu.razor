@implements IDisposable
@inject NavigationManager Navigation
@* Los servicios de tenant/suscripcion/plan NO se inyectan en el circuito: se resuelven en un
   scope aislado dentro de OnInitializedAsync para no compartir el DbContext de la peticion. *@
@inject IServiceScopeFactory ScopeFactory
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.EntityFrameworkCore
@using Tronox.Application.MenuConfig
@using Tronox.Domain.Enums

@* Enlace de pantalla del sidebar (prototipo .menu-sub-link). Se define una sola vez para
   reutilizarlo tanto en las pantallas directas del modulo como en las de una sub-seccion.

   SOLO SE GENERA <a> SI EL NODO ES PANTALLA Y TIENE RUTA (ver EsPantallaNavegable). Un nodo
   agrupador -Seccion o Grupo/modulo- NUNCA se pinta como enlace: su Route existe porque es la
   LLAVE DE PERMISOS (RF09 5.9.3) y de ella se deriva el catalogo de modulos de RF05, pero no
   corresponde a ninguna pagina. Cuando el sidebar los hacia navegables, el clic terminaba en un
   404 (o, peor, en "/" si la ruta venia vacia) y de ahi al login. *@
@{
    RenderFragment<MenuNodeDto> SubLink = leaf =>
        @<text>
        @if (EsPantallaNavegable(leaf))
        {
            <NavLink class="tx-menu-sub-link" href="@leaf.Route">
                @MenuIcons.Render(leaf.IconKey)
                <span class="msl-label">@leaf.Name</span>
                @if (!string.IsNullOrWhiteSpace(leaf.LegacyCode))
                {
                    <span class="menu-rf" title="@leaf.LegacyCode">@leaf.LegacyCode</span>
                }
            </NavLink>
        }
        else
        {
            @* Pantalla sin ruta: se muestra, pero no navega (no hay destino que abrir). *@
            <span class="tx-menu-sub-link is-static" title="Sin pantalla asociada">
                @MenuIcons.Render(leaf.IconKey)
                <span class="msl-label">@leaf.Name</span>
                @if (!string.IsNullOrWhiteSpace(leaf.LegacyCode))
                {
                    <span class="menu-rf" title="@leaf.LegacyCode">@leaf.LegacyCode</span>
                }
            </span>
        }
        </text>;
}

@if (_showAdmin)
{
    @* Consola de plataforma: marca configurable (Super Admin -> Marca) con icono de tablero. *@
    <div class="tronox-brand">
        <div class="tronox-logo">
            @if (!string.IsNullOrWhiteSpace(_brandLogoUrl))
            {
                <img src="@_brandLogoUrl" alt="@(_brandName ?? "Logo")" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;" />
            }
            else
            {
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="3"/><path d="m7.5 12 2 2 4-4.5"/><path d="M16.5 16h.01"/></svg>
            }
        </div>
        <div>
            @if (string.IsNullOrWhiteSpace(_brandName) || _brandName == "TRONOX SGDEA")
            {
                <div class="tronox-brand-name">TRONOX<span> SGDEA</span></div>
            }
            else
            {
                <div class="tronox-brand-name">@_brandName</div>
            }
            <div class="tronox-brand-sub">@(_brandTagline ?? "Gestion Documental")</div>
        </div>
    </div>
}
else
{
    @* Cabecera del sidebar del workspace: logo TRONOX + "SGDEA" (prototipo .sidebar-logo).
       El nombre del tenant ya NO va aqui: se movio al chip del pie (prototipo .sidebar-tenant),
       igual que en la referencia. *@
    <a class="tx-sb-logo" href="inicio">
        <span class="tx-sb-logo-mark"><img src="marca/tronox-icon.png" alt="TRONOX" /></span>
        <span class="tx-sb-logo-text">
            <span class="tx-sb-logo-word">TRONOX</span>
            <span class="tx-sb-logo-sub">SGDEA</span>
        </span>
    </a>
}

@* Buscador global del prototipo (Cmd/Ctrl+K). Placeholder: se activa junto con el contenido real. *@
<div class="tronox-search" title="Busqueda global (proximamente)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    <input type="search" placeholder="Buscar" disabled />
    <span class="kbd">Ctrl K</span>
</div>

@if (_showAdmin)
{
    <div class="tronox-agency">
        <div class="lbl">Plataforma</div>
        <div class="name">TRONOX SGDEA</div>
        <div class="meta">Consola de gobierno</div>
    </div>
}

<nav class="tronox-nav tx-sb-nav">
    @if (_showTenant && _menu is not null)
    {
        @* ===== Menu DATA-DRIVEN (Ola 1 del menu por perfil): el arbol resuelto viene de
               IMenuConfigService.GetMenuForTenantUserAsync segun la vista del usuario (o la
               IsDefault). Se filtra por permiso de "Ver" antes de llegar aqui.

               JERARQUIA VISUAL DEL PROTOTIPO (aplanada):
                 Seccion  -> encabezado de grupo NO colapsable (.tx-menu-section, eyebrow gris).
                 Modulo   -> item DIRECTAMENTE visible bajo la seccion. Con hijos = disclosure
                             (.tx-menu-mod, <details> con chevron + punto de estado); sin hijos =
                             enlace hoja (.tx-menu-link con icono). Los tres tipos de nodo del
                             modelo (Seccion/Subgrupo/Item) se conservan; solo cambia como se pinta.
                 Pantalla -> subitem bajo el modulo (.tx-menu-sub-link).
               data-acc = slug del nodo (Route) para persistir apertura del modulo. ===== *@
        @foreach (var quick in _menu.Roots.Where(n => n.Kind == MenuNodeKind.QuickLink && EsPantallaNavegable(n)))
        {
            <div class="tx-menu-item">
                <NavLink class="tx-menu-link" href="@quick.Route" Match="@(quick.Route == "inicio" ? NavLinkMatch.All : NavLinkMatch.Prefix)">
                    <span class="tx-menu-icon">@MenuIcons.Render(quick.IconKey)</span>
                    <span class="tx-menu-title">@quick.Name</span>
                    @if (string.Equals(quick.Route, "anuncios", StringComparison.Ordinal))
                    {
                        <span class="tx-menu-badge" title="Anuncios sin leer (placeholder)">0</span>
                    }
                </NavLink>
            </div>
        }

        @foreach (var section in _menu.Roots.Where(n => n.Kind == MenuNodeKind.Section))
        {
            <div class="tx-menu-group">
                @* Seccion = encabezado de grupo, no colapsable (eyebrow del prototipo). *@
                <div class="tx-menu-section">@section.Name</div>
                <div class="tx-menu-groupitems">
                    @foreach (var child in section.Children)
                    {
                        if (child.Kind == MenuNodeKind.Subgroup)
                        {
                            @* Modulo con pantallas: disclosure visible bajo la seccion. Abre solo
                               si contiene la ruta activa; el toggle del usuario se persiste. *@
                            var subSlug = child.Route ?? child.Id.ToString();
                            <details class="tx-menu-item tx-menu-mod" data-acc="@subSlug" open="@IsGroupOpen(subSlug)">
                                @* Prototipo: la fila del modulo es caret + nombre + punto de estado.
                                   El codigo REQ/RF solo se rotula en las pantallas (menu-sub-link),
                                   no en el modulo: meterlo aqui recortaba los nombres largos. *@
                                <summary class="tx-menu-modtoggle" title="@child.Name">
                                    <svg class="tx-menu-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                                    <span class="tx-menu-title">@child.Name</span>
                                    <span class="tx-menu-state @StateDot(child.State)" title="@StateTitle(child.State)"></span>
                                </summary>
                                <div class="tx-menu-modscreens">
                                    <div class="tx-menu-sub">
                                        @* Pantallas del modulo. Un hijo Subgroup es una sub-seccion del
                                           prototipo (ej. req001 General/Organizacional/Sistema): se pinta
                                           como encabezado interno y debajo van sus pantallas. *@
                                        @foreach (var node in child.Children)
                                        {
                                            if (node.Kind == MenuNodeKind.Subgroup)
                                            {
                                                <div class="tx-menu-subsection">@node.Name</div>
                                                @foreach (var leaf in node.Children.Where(n => n.Kind == MenuNodeKind.Item))
                                                {
                                                    @SubLink(leaf)
                                                }
                                            }
                                            else if (node.Kind == MenuNodeKind.Item)
                                            {
                                                @SubLink(node)
                                            }
                                        }
                                    </div>
                                </div>
                            </details>
                        }
                        else if (EsPantallaNavegable(child))
                        {
                            @* Pantalla suelta de la seccion: enlace hoja con icono
                               (prototipo .menu-link) + punto de estado. *@
                            <div class="tx-menu-item">
                                <NavLink class="tx-menu-link" href="@child.Route">
                                    <span class="tx-menu-icon">@MenuIcons.Render(child.IconKey)</span>
                                    <span class="tx-menu-title">@child.Name</span>
                                    <span class="tx-menu-state @StateDot(child.State)" title="@StateTitle(child.State)"></span>
                                </NavLink>
                            </div>
                        }
                        else
                        {
                            @* Agrupador vacio (Seccion/Grupo sin pantallas visibles) o pantalla sin
                               ruta: se rotula, NO se enlaza. Su Route -si la tiene- es llave de
                               permisos, no destino de navegacion. *@
                            <div class="tx-menu-item">
                                <span class="tx-menu-link is-static" title="@child.Name">
                                    <span class="tx-menu-icon">@MenuIcons.Render(child.IconKey)</span>
                                    <span class="tx-menu-title">@child.Name</span>
                                    <span class="tx-menu-state @StateDot(child.State)" title="@StateTitle(child.State)"></span>
                                </span>
                            </div>
                        }
                    }
                </div>
            </div>
        }
    }

