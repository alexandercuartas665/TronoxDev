@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    /// <summary>
    /// Un nodo del menu es NAVEGABLE solo si es una PANTALLA (Item o QuickLink) y tiene ruta.
    ///
    /// Los nodos Section y Subgroup son AGRUPADORES: la seccion es un encabezado y el modulo es un
    /// desplegable. Tienen Route (los slugs "configuracion", "req001", "req001-organizacional"...)
    /// porque esa ruta es la LLAVE DE PERMISOS del nodo (RF09 5.9.3) y de las rutas de item se
    /// deriva el catalogo de modulos de RF05; pero NO existe ninguna pagina que las atienda. Si el
    /// sidebar las convierte en enlaces, el clic da 404 -y una ruta vacia da "/", que hasta ahora
    /// exigia platform_role y terminaba expulsando al login-. Por eso la ruta se CONSERVA como
    /// llave y lo que se corrige es el sidebar: aqui no se genera <a> para esos tipos de nodo.
    /// </summary>
    private static bool EsPantallaNavegable(MenuNodeDto node)
        => (node.Kind == MenuNodeKind.Item || node.Kind == MenuNodeKind.QuickLink)
           && !string.IsNullOrWhiteSpace(node.Route);

    // El menu se arma por rol: el operador de plataforma (platform_role) ve el grupo
    // Super Admin SaaS y previsualiza el workspace del tenant; el usuario de empresa
    // (tenant_id) ve las secciones Principal / Modulos / Sistema y el CRM heredado.
    private bool _showAdmin;
    private bool _showTenant;
    private bool _isSuperAdmin;
    private string? _userName;
    private string? _tenantName;
    private string? _planName;
    // Marca de la plataforma (Super Admin -> Marca): logo, nombre y bajada del sidebar.
    private string? _brandName;
    private string? _brandTagline;
    private string? _brandLogoUrl;
    private string _roleLabel = "Operador de plataforma";
    private string _avatar = "SA";

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;

        // Marca de la plataforma configurada en Super Admin -> Marca (logo + nombre + bajada). Scope
        // aislado para no compartir el DbContext del circuito. Si falla, el markup usa los valores por defecto.
        try
        {
            await using var brandScope = ScopeFactory.CreateAsyncScope();
            var branding = brandScope.ServiceProvider.GetRequiredService<Tronox.Application.Admin.IPlatformBrandingService>();
            var b = await branding.GetAsync();
            _brandName = b.PlatformName;
            _brandTagline = b.Tagline;
            _brandLogoUrl = b.LoginLogoUrl;
        }
        catch { /* sin branding: se usa el logo/nombre por defecto */ }

        if (AuthState is null)
        {
            return;
        }

        var state = await AuthState;
        var isPlatformOperator = state.User.FindFirst("platform_role") is not null;
        var tenantClaim = state.User.FindFirst("tenant_id")?.Value;
        var isTenantUser = tenantClaim is not null;

        _showAdmin = isPlatformOperator;
        _showTenant = isPlatformOperator || isTenantUser;
        _isSuperAdmin = state.User.FindFirst("platform_role")?.Value == "SuperAdmin";

        _userName = state.User.Identity?.Name;
        _avatar = Initials(_userName);

        if (isPlatformOperator)
        {
            _roleLabel = "Operador de plataforma";
        }
        else if (isTenantUser)
        {
            _roleLabel = state.User.FindFirst("tenant_role")?.Value ?? "Miembro";
            if (long.TryParse(tenantClaim, out var tenantId))
            {
                // Nombre del tenant y plan activo para la cabecera del workspace
                // ("Plan Empresa - TRONOX"), en un scope AISLADO.
                //
                // POR QUE AISLADO: estos tres servicios comparten el DbContext del scope de la
                // peticion, y durante el prerender MainLayout y la propia pagina se inicializan en
                // paralelo con este componente. Al resolverlos desde el scope compartido, dos
                // consultas caian sobre el mismo DbContext y el render fallaba de forma
                // intermitente con "A second operation was started on this context instance".
                // Es el mismo motivo por el que LoadMenuAsync y la carga de la marca ya abren su
                // propio scope; a estas dos consultas simplemente no se les habia aplicado.
                try
                {
                    await using var wsScope = ScopeFactory.CreateAsyncScope();
                    var tenants = wsScope.ServiceProvider.GetRequiredService<ITenantAdminService>();
                    _tenantName = (await tenants.GetAsync(tenantId))?.Name;

                    var subs = wsScope.ServiceProvider.GetRequiredService<ISubscriptionAdminService>();
                    var sub = (await subs.ListByTenantAsync(tenantId)).FirstOrDefault();
                    if (sub is not null)
                    {
                        var plans = wsScope.ServiceProvider.GetRequiredService<IPlanAdminService>();
                        _planName = (await plans.GetAsync(sub.PlanId))?.Name;
                    }
                }
                catch { /* sin nombre/plan visible: se muestra la bajada generica */ }

                // Menu configurable (Ola 1): resuelve el arbol de la vista del usuario (o la
                // IsDefault del tenant) en un scope aislado, como la marca. Si falla, _menu queda
                // null y el bloque tenant simplemente no renderiza (fallback seguro).
                await LoadMenuAsync(tenantId, state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value);
            }
        }
    }

    /// <summary>Arbol resuelto del menu del workspace (Ola 1). Null = no renderiza el bloque tenant.</summary>
    private ResolvedMenuDto? _menu;

    private async Task LoadMenuAsync(long tenantId, string? platformUserIdClaim)
    {
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var menuSvc = scope.ServiceProvider.GetRequiredService<IMenuConfigService>();

            // Vista asignada al usuario (o null -> el servicio cae a la IsDefault del tenant).
            long? assignedViewId = null;
            Tronox.Application.Roles.EffectivePermissions? permissions = null;
            if (long.TryParse(platformUserIdClaim, out var platformUserId))
            {
                // El tenant se fija de forma AMBIENTAL a partir del claim del AuthenticationState
                // (que es de donde viene tenantId), no del HttpContext: en un circuito Blazor no
                // hay HttpContext y el filtro global de EF no encontraria ni el TenantUser ni sus
                // roles. Con el enforcement FAIL-CLOSED eso ya no "no restringe": ahora seria lo
                // contrario, la resolucion daria SIN PERMISOS y el menu se podaria entero.
                using var ambient = Tronox.Web.Auth.AmbientTenantContext.Begin(tenantId, platformUserId);

                var db = scope.ServiceProvider.GetRequiredService<Tronox.Application.Common.IApplicationDbContext>();
                assignedViewId = await db.TenantUsers
                    .Where(u => u.PlatformUserId == platformUserId)
                    .Select(u => u.MenuViewId)
                    .FirstOrDefaultAsync();

                // Permisos efectivos para FILTRAR el menu por "Ver". FAIL-CLOSED: un usuario sin
                // roles vigentes resuelve a SIN PERMISOS y el menu queda podado, no intacto.
                var roles = scope.ServiceProvider.GetRequiredService<Tronox.Application.Roles.IRolService>();
                permissions = await roles.ResolveEffectivePermissionsAsync(platformUserId);
            }

            var resolved = await menuSvc.GetMenuForTenantUserAsync(tenantId, assignedViewId);
            // Poda los modulos (Item con Route) sin permiso de Ver; oculta secciones que quedan vacias.
            _menu = Tronox.Application.MenuConfig.MenuPermissionFilter.Filter(resolved, permissions);

            // La expansion dinamica de "grupos de procesos" del backbone dependia del catalogo de
            // Conceptos y del motor BPMN, ambos fuera del alcance de TRONOX. Los menus dinamicos que
            // si aplican (Contratos/Convenios de RQ12 y Personal/Procesos de RQ17) se construyen desde
            // las series de la TRD y se implementan con su modulo.
        }
        catch { /* sin menu configurado: el bloque tenant no renderiza (fallback seguro) */ }
    }

    /// <summary>Inicial del tenant para el chip del pie (prototipo: "S" de SKY SYSTEM).</summary>
    private string TenantInitial => string.IsNullOrWhiteSpace(_tenantName) ? "E" : _tenantName.Trim()[..1].ToUpperInvariant();

    /// <summary>
    /// Punto de estado por modulo (prototipo .menu-state: verde=listo, ambar=prototipo, gris=spec).
    /// Se mapea al estado REAL del nodo (menu_nodes.state) para que signifique algo, en vez de pintar
    /// N puntos verdes iguales: Ready->listo, InDevelopment->prototipo, Disabled->spec. La semilla
    /// actual nace toda en Ready, asi que hoy salen verdes; el punto cobra sentido cuando el editor
    /// del menu (RF09) marque modulos en desarrollo o deshabilitados.
    /// </summary>
    private static string StateDot(MenuNodeState state) => state switch
    {
        MenuNodeState.InDevelopment => "prototipo",
        MenuNodeState.Disabled => "spec",
        _ => "listo",
    };

    private static string StateTitle(MenuNodeState state) => state switch
    {
        MenuNodeState.InDevelopment => "En desarrollo",
        MenuNodeState.Disabled => "Deshabilitado",
        _ => "Listo",
    };

    /// <summary>
    /// Estado inicial (server-side) de cada acordeon de MODULOS: abierto SOLO si contiene la
    /// ruta activa, para que el menu arranque cerrado y se vea donde esta uno parado. Antes
    /// tres grupos (misproc/auto/sg-comercial) abrian siempre, replicando el estado en que el
    /// prototipo quedo capturado; eso no era una regla, y al entrar llenaba el sidebar de items
    /// que nadie pidio. Las rutas de cada grupo se derivan del arbol resuelto (Ola 1). El toggle
    /// del usuario se persiste en localStorage y lo reaplica el script de MainLayout.
    /// </summary>
    private bool IsGroupOpen(string key)
    {
        var rel = Navigation.ToBaseRelativePath(Navigation.Uri)
            .Split('?', '#')[0]
            .TrimEnd('/')
            .ToLowerInvariant();
        var routes = RoutesForSlug(key);
        return routes.Any(r => rel == r || rel.StartsWith(r + "/", StringComparison.Ordinal));
    }

    /// <summary>Rutas hoja bajo la seccion/subgrupo con ese slug (data-acc), derivadas del arbol resuelto.</summary>
    private IEnumerable<string> RoutesForSlug(string slug)
    {
        if (_menu is null) { yield break; }
        foreach (var section in _menu.Roots.Where(n => n.Kind == MenuNodeKind.Section || n.Kind == MenuNodeKind.Subgroup))
        {
            if (!string.Equals(section.Route, slug, StringComparison.Ordinal)) { continue; }
            foreach (var route in LeafRoutes(section))
            {
                yield return route.ToLowerInvariant();
            }
        }
        // Subgrupos: buscar tambien anidados dentro de secciones.
        foreach (var section in _menu.Roots.Where(n => n.Kind == MenuNodeKind.Section))
        {
            foreach (var sub in section.Children.Where(c => c.Kind == MenuNodeKind.Subgroup
                && string.Equals(c.Route, slug, StringComparison.Ordinal)))
            {
                foreach (var route in LeafRoutes(sub))
                {
                    yield return route.ToLowerInvariant();
                }
            }
        }
    }

    private static IEnumerable<string> LeafRoutes(MenuNodeDto node)
    {
        foreach (var child in node.Children)
        {
            if (child.Kind == MenuNodeKind.Item && !string.IsNullOrEmpty(child.Route))
            {
                yield return child.Route!;
            }
            foreach (var deeper in LeafRoutes(child))
            {
                yield return deeper;
            }
        }
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1
            ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant()
            : $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e) => StateHasChanged();
    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;

