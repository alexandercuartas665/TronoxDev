@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject IServiceScopeFactory ScopeFactory
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.AspNetCore.SignalR.Client

<div class="tronox-shell @(_isTenantWorkspace ? "ws-tenant" : "")">
    <!-- Toggle solo-CSS del menu (off-canvas en movil). Funciona en cualquier render mode. -->
    <input type="checkbox" id="tronox-nav-toggle" class="tronox-nav-toggle" autocomplete="off" />

    @* El rail vertical de iconos que heredamos del backbone se retiro: el prototipo TRONOX
       (index.html) tiene UN solo sidebar. Ademas la mitad de sus destinos (actividades,
       flujos, formularios, metricas) eran rutas del backbone que en TRONOX no existen. *@

    <aside class="tronox-sidebar">
        <NavMenu />
    </aside>

    <!-- Capa oscura: al tocarla se cierra el menu (es un label del checkbox). -->
    <label for="tronox-nav-toggle" class="tronox-nav-overlay" aria-hidden="true"></label>

    <div class="tronox-main">
        <div class="tronox-topbar">
            <label for="tronox-nav-toggle" class="tronox-hamburger" aria-label="Abrir menu">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M3 6h18"/><path d="M3 12h18"/><path d="M3 18h18"/></svg>
            </label>
            <span class="tronox-topbar-brand">TRONOX<span>.tareas</span></span>

            <AuthorizeView>
                <Authorized>
                    @if (_isTenantWorkspace)
                    {
                        @* Toggle de colapso del sidebar (prototipo: 34x34 r9, icono panel).
                           JS plano + localStorage: funciona en SSR y persiste entre sesiones. *@
                        <button type="button" class="tronox-collapse" title="Mostrar u ocultar el menu"
                                onclick="window.tronoxSidebar && window.tronoxSidebar.toggle()">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M9 4v16"/></svg>
                        </button>
                        @* Breadcrumb del prototipo: Equipos / {tenant} / {seccion}. *@
                        <nav class="tronox-topbar-crumb" aria-label="Ubicacion">
                            <span>Equipos</span>
                            <span class="sep">/</span>
                            <span>@(_tenantName ?? "Mi empresa")</span>
                            <span class="sep">/</span>
                            <span class="cur">@SectionLabel</span>
                        </nav>
                        <span style="flex:1;"></span>
                        @* Boton Compartir del prototipo: placeholder deshabilitado hasta que exista la funcion. *@
                        <button type="button" class="tronox-share" title="Proximamente" disabled>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="m8.6 13.5 6.8 4M15.4 6.5 8.6 10.5"/></svg>
                            Compartir
                        </button>
                        <NavLink class="tronox-bell" href="notificaciones" title="Notificaciones">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                            @if (_unread > 0)
                            {
                                <span class="count" aria-label="@_unread notificaciones sin leer">@(_unread > 99 ? "99+" : _unread.ToString())</span>
                            }
                        </NavLink>
                    }
                    else
                    {
                        <span class="tronox-user-chip">@(context.User.FindFirst("platform_role") is not null ? "Operador" : "Workspace") · <strong>@context.User.Identity?.Name</strong></span>
                    }
                    <form method="post" action="/auth/logout" class="m-0">
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Salir</button>
                    </form>
                </Authorized>
            </AuthorizeView>
        </div>

        <div class="tronox-content">
            @Body
        </div>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Ha ocurrido un error.
    <a href="." class="reload">Recargar</a>
    <span class="dismiss">🗙</span>
</div>

<script>
    // Vigia del asistente TaskWizard para la pagina /crear-actividad: cuando el overlay
    // desaparece del DOM (el usuario cerro o creo la actividad) redirige a /actividades.
    // Se detiene solo si el usuario ya salio de /crear-actividad por otra via.
    window.tronoxWatchWizard = function () {
        if (window.__tronoxWizardTimer) { clearInterval(window.__tronoxWizardTimer); }
        var seen = false;
        window.__tronoxWizardTimer = setInterval(function () {
            if (!window.location.pathname.startsWith('/crear-actividad')) {
                clearInterval(window.__tronoxWizardTimer); window.__tronoxWizardTimer = null; return;
            }
            var open = !!document.querySelector('.tk-wizard');
            if (open) { seen = true; }
            else if (seen) {
                clearInterval(window.__tronoxWizardTimer); window.__tronoxWizardTimer = null;
                window.location.assign('/actividades');
            }
        }, 300);
    };

    // Cierra el menu movil al tocar un enlace de navegacion (complementa el cierre por overlay
    // y el reseteo en navegaciones de pagina completa).
    document.addEventListener('click', function (e) {
        if (e.target.closest && e.target.closest('.tronox-nav-link, .tronox-acc-item')) {
            var t = document.getElementById('tronox-nav-toggle');
            if (t) t.checked = false;
        }
    });

    // Acordeones del sidebar (details[data-acc]): el servidor decide el estado inicial
    // (grupo activo o abierto por defecto) y aqui se persiste el toggle del usuario en
    // localStorage, reaplicandolo tras cada re-render (navegacion mejorada de Blazor).
    (function () {
        var KEY = 'tronox-acc';
        function saved() { try { return JSON.parse(localStorage.getItem(KEY) || '{}'); } catch (e) { return {}; } }
        function apply() {
            var st = saved();
            document.querySelectorAll('details[data-acc]').forEach(function (d) {
                var k = d.getAttribute('data-acc');
                if (st[k] === true && !d.open) { d.setAttribute('open', ''); }
                // No se cierra el grupo que contiene la ruta activa aunque este guardado cerrado.
                else if (st[k] === false && d.open && !d.querySelector('.tronox-acc-item.active')) { d.removeAttribute('open'); }
            });
        }
        document.addEventListener('click', function (e) {
            var s = e.target.closest && e.target.closest('details[data-acc] > summary');
            if (!s) { return; }
            var d = s.parentElement;
            setTimeout(function () {
                var st = saved();
                st[d.getAttribute('data-acc')] = d.open;
                try { localStorage.setItem(KEY, JSON.stringify(st)); } catch (e2) { }
            }, 0);
        });
        // Reaplica el estado guardado cuando Blazor parchea el DOM (enhanced navigation).
        new MutationObserver(function () { apply(); }).observe(document.body, { childList: true, subtree: true });
        apply();
    })();
</script>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    // El breadcrumb solo aplica al workspace del tenant. Los operadores de plataforma
    // (PlatformAdmin) conservan su chrome actual: ws-tenant NO se aplica, asi sus botones
    // primarios siguen violeta (no se rompe su estilo).
    private bool _isTenantWorkspace;  // tenant sin platform_role (breadcrumb + botones negros)
    private string? _tenantName;
    private int _unread;   // notificaciones no leidas del usuario (badge de la campana)
    // #4b: refresco en vivo del badge por SignalR.
    private HubConnection? _notifHub;
    private long _platformUserId;
    private long? _tenantUserId;

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;

        if (AuthState is null) { return; }
        var state = await AuthState;
        var isOperator = state.User.FindFirst("platform_role") is not null;
        var tenantClaim = state.User.FindFirst("tenant_id")?.Value;

        _isTenantWorkspace = tenantClaim is not null && !isOperator;

        if (_isTenantWorkspace && long.TryParse(tenantClaim, out var tenantId))
        {
            // Scope aislado para no compartir el DbContext con NavMenu/paginas durante el render.
            try
            {
                await using var scope = ScopeFactory.CreateAsyncScope();
                var tenants = scope.ServiceProvider.GetRequiredService<Tronox.Application.Admin.ITenantAdminService>();
                _tenantName = (await tenants.GetAsync(tenantId))?.Name;

                // Ola 7: conteo de notificaciones no leidas para el badge de la campana.
                if (long.TryParse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var platformUserId))
                {
                    _platformUserId = platformUserId;
                    var notifs = scope.ServiceProvider.GetRequiredService<Tronox.Application.Notifications.INotificationService>();
                    _unread = await notifs.UnreadCountForPlatformUserAsync(platformUserId);
                    _tenantUserId = await notifs.ResolveTenantUserIdAsync(platformUserId);
                }
            }
            catch { /* sin nombre/conteo: se muestra el generico */ }

            // #4b: suscripcion en vivo del badge (fuera del scope aislado; el hub vive con el circuito).
            await SetupNotificationHubAsync();
        }
    }

    /// <summary>#4b: conecta al hub de notificaciones y refresca el badge al recibir "NotificationAdded".</summary>
    private async Task SetupNotificationHubAsync()
    {
        if (_tenantUserId is not long tenantUserId) { return; }
        try
        {
            _notifHub = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/notifications"))
                .WithAutomaticReconnect()
                .Build();
            _notifHub.On("NotificationAdded", async () => await InvokeAsync(RefreshUnreadAsync));
            await _notifHub.StartAsync();
            await _notifHub.SendAsync("JoinUser", tenantUserId.ToString());
        }
        catch
        {
            _notifHub = null; // sin tiempo real el badge se actualiza al navegar/recargar
        }
    }

    private async Task RefreshUnreadAsync()
    {
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var notifs = scope.ServiceProvider.GetRequiredService<Tronox.Application.Notifications.INotificationService>();
            _unread = await notifs.UnreadCountForPlatformUserAsync(_platformUserId);
            StateHasChanged();
        }
        catch { /* si falla el refresco, el badge queda en su valor anterior */ }
    }

    /// <summary>Etiqueta de la seccion actual para el breadcrumb (Equipos / tenant / seccion).</summary>
    private string SectionLabel
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri);
            var seg = path.Split('?', '#')[0].Split('/', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "";
            return seg.ToLowerInvariant() switch
            {
                "" or "inicio" => "Resumen",
                "anuncios" => "Anuncios",
                "tableros" or "tablero" => "Tableros",
                "actividades" => "Actividades",
                "crear-actividad" => "Crear una actividad",
                "modulo" => "Modulos",
                "asesores" => "Asesores",
                "proyectos" or "proyecto" => "Proyectos",
                "flujos" => "Flujos del proceso",
                "formularios" => "Formularios",
                "reglas" => "Reglas",
                "dependencias" => "Dependencias",
                "modulos-web" => "Modulos web",
                "configuracion" => "Configuracion",
                "mi-cuenta" => "Mi cuenta",
                "pipeline" => "Pipeline comercial",
                "conversaciones" => "Conversaciones",
                "plantillas" => "Plantillas",
                "lineas" => "Lineas WhatsApp",
                "agentes" => "Agentes de IA",
                "bitacora-agente" => "Bitacora del agente",
                "automatizaciones" => "Automatizaciones",
                "lista-negra" => "Lista negra",
                "metricas" => "Metricas",
                _ => char.ToUpperInvariant(seg[0]) + seg[1..]
            };
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e) => StateHasChanged();
    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        if (_notifHub is not null) { _ = _notifHub.DisposeAsync(); } // #4b: cierra el hub al destruir el layout
    }
}
