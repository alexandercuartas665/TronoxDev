@page "/dependencias"
@attribute [Authorize(Policy = "Dependencias.Ver")]
@* Policy por modulo (paso 1: mismo requisito que TenantMember, nombre estable). TODO: derivar del Module Registry. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Tronox.Application.Archivistica
@using Tronox.Application.Organization
@using Tronox.Application.Tenancy
@using Tronox.Domain.Enums
@inject IOrgUnitService OrgSvc
@inject ITenantUserService UsersSvc
@inject IFondoService FondoSvc
@inject Tronox.Application.Common.ITenantContext Tenant

@* RQ01 - RF03 (Estructura Organica) y RF04 (Cargos) sobre el arbol UNICO con clasificador
   del ADR-003. La pantalla expone los atributos propios de cada clasificador:
   Dependencia -> fondo, codigo, vigencias y sucesora; Cargo -> codigos y nivel jerarquico.
   Se conservan las cuatro conductas probadas del backbone: validacion de ciclos fail-closed,
   archivado en vez de borrado, raices tolerantes a huerfanos y aviso de cuantos usuarios
   afecta mover un Cargo (ADR-003, Addendum punto 2). *@

<PageTitle>Dependencias - TRONOX SGDEA</PageTitle>

<div class="tx-dep">

    <nav class="tronox-breadcrumb" aria-label="Ruta de navegación">
        <a href="/inicio">Inicio</a>
        <span class="sep">/</span>
        <span>Configuración Organizacional</span>
        <span class="sep">/</span>
        <span class="cur">Dependencias</span>
    </nav>

    <div class="tx-ent-head">
        <div>
            <div class="tx-ent-eyebrow"><i class="bi bi-diagram-3"></i><span>RQ01 &middot; RF03 / RF04</span></div>
            <h1 class="tx-ent-title">Dependencias</h1>
            <p class="tx-ent-sub">
                Estructura orgánica de la entidad. Es <strong>un solo árbol</strong> con nodos de distinto tipo
                (Dependencia, Cargo, Funcionario), no dos catálogos separados: la dependencia de un usuario se
                deriva subiendo por su cargo.
            </p>
        </div>
        <div>
            <button type="button" class="tx-ent-btn primary" @onclick="@(() => OpenEditor(null, null))">
                <i class="bi bi-plus-lg"></i> Crear dependencia
            </button>
        </div>
    </div>

    @if (_pageError is not null)
    {
        <div class="tx-ent-alert err"><i class="bi bi-exclamation-triangle-fill"></i><span>@_pageError</span></div>
    }

    @* ===== KPIs ===== *@
    <div class="tx-dep-kpis">
        <div class="tx-dep-kpi">
            <div class="tx-dep-kpi-icon"><i class="bi bi-diagram-3"></i></div>
            <div>
                <div class="tx-dep-kpi-val">@_countDependencias</div>
                <div class="tx-dep-kpi-lbl">Dependencias</div>
            </div>
        </div>
        <div class="tx-dep-kpi">
            <div class="tx-dep-kpi-icon tone-violet"><i class="bi bi-person-badge"></i></div>
            <div>
                <div class="tx-dep-kpi-val">@_countCargos</div>
                <div class="tx-dep-kpi-lbl">Cargos</div>
            </div>
        </div>
        <div class="tx-dep-kpi">
            <div class="tx-dep-kpi-icon tone-green"><i class="bi bi-people"></i></div>
            <div>
                <div class="tx-dep-kpi-val">@(_kpis?.AssignedUsers ?? 0)</div>
                <div class="tx-dep-kpi-lbl">Usuarios asignados</div>
            </div>
        </div>
        <div class="tx-dep-kpi">
            <div class="tx-dep-kpi-icon tone-slate"><i class="bi bi-archive"></i></div>
            <div>
                <div class="tx-dep-kpi-val">@_countArchivadas</div>
                <div class="tx-dep-kpi-lbl">Archivadas</div>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="tx-ent-card"><div class="tx-ent-card-body"><em>Cargando organigrama...</em></div></div>
    }
    else if (_tree.Count == 0 && string.IsNullOrWhiteSpace(_search))
    {
        <div class="tx-ent-card">
            <div class="tx-ent-card-body">
                <div class="tx-ent-empty">
                    <i class="bi bi-diagram-3"></i>
                    <div>
                        <strong>Sin dependencias todavía</strong><br />
                        Crea la primera dependencia para armar el organigrama de la entidad.
                        Recuerda que una Dependencia necesita un fondo documental (principio de procedencia).
                    </div>
                    <button type="button" class="tx-ent-btn primary" @onclick="@(() => OpenEditor(null, null))">
                        <i class="bi bi-plus-lg"></i> Crear dependencia
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="tx-dep-layout">

            @* ---------- Arbol ---------- *@
            <div class="tx-ent-card">
                <div class="tx-dep-toolbar">
                    <div class="tx-dep-search">
                        <i class="bi bi-search"></i>
                        <input class="tx-ent-input" placeholder="Buscar por código o nombre..."
                               value="@_search" @oninput="OnSearch" />
                    </div>
                    <label class="tx-ent-hint" style="margin:0;display:inline-flex;align-items:center;gap:6px;cursor:pointer">
                        <input type="checkbox" checked="@_includeArchived"
                               @onchange="@(async e => { _includeArchived = (bool)e.Value!; await LoadAsync(); })" />
                        Ver archivadas
                    </label>
                </div>

                <div class="tx-dep-tree">
                    @if (!string.IsNullOrWhiteSpace(_search))
                    {
                        @* Con busqueda activa se muestra una lista plana de coincidencias: en un
                           arbol filtrado el usuario pierde la referencia de donde esta cada nodo. *@
                        @foreach (var node in Buscar())
                        {
                            <div class="tx-dep-node @(node.Id == _selected?.Id ? "on" : "") @(node.IsArchived ? "archivada" : "")"
                                 @onclick="@(() => SelectAsync(node.Id))">
                                <span class="tx-dep-chev ph"></span>
                                @NodoInterior(node.Classifier, node.Codigo ?? node.CodigoCargo, node.Name, node.IsArchived, node.MemberCount)
                            </div>
                        }
                        @if (Buscar().Count == 0)
                        {
                            <div class="tx-ent-hint" style="padding:14px">Ninguna unidad coincide con la búsqueda.</div>
                        }
                    }
                    else
                    {
                        @foreach (var row in FlattenTree())
                        {
                            var node = row.Node;
                            <div class="tx-dep-node @(node.Id == _selected?.Id ? "on" : "") @(node.IsArchived ? "archivada" : "")"
                                 style="margin-left:@(row.Depth * 20)px" @onclick="@(() => SelectAsync(node.Id))">
                                @if (node.Children.Count > 0)
                                {
                                    <button type="button" class="tx-dep-chev @(_collapsed.Contains(node.Id) ? "" : "open")"
                                            title="@(_collapsed.Contains(node.Id) ? "Expandir" : "Contraer")"
                                            @onclick="@(() => ToggleCollapse(node.Id))" @onclick:stopPropagation="true">
                                        <i class="bi bi-chevron-right"></i>
                                    </button>
                                }
                                else
                                {
                                    <span class="tx-dep-chev ph"></span>
                                }
                                @NodoInterior(node.Classifier, node.Codigo ?? node.CodigoCargo, node.Name, node.IsArchived, node.MemberCount)
                                <button type="button" class="tx-dep-add" title="Agregar unidad hija"
                                        @onclick="@(() => OpenEditor(null, node.Id))" @onclick:stopPropagation="true">+</button>
                            </div>
                        }
                    }
                </div>
            </div>

            @* ---------- Detalle ---------- *@
            <div class="tx-ent-card">
                @if (_selected is null)
                {
                    <div class="tx-ent-card-body">
                        <div class="tx-ent-empty">
                            <i class="bi bi-hand-index"></i>
                            <div>Selecciona una unidad del organigrama para ver su detalle.</div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="tx-ent-card-head" style="align-items:flex-start">
                        <div style="flex:1;min-width:0">
                            <div class="tx-ent-card-title" style="font-size:16px">@_selected.Name</div>
                            <div class="tx-ent-card-sub">@_selectedPath</div>
                        </div>
                        <span class="tx-ent-badge sm @ClasificadorClase(_selected.Classifier)">@ClassifierLabel(_selected.Classifier)</span>
                    </div>
                    <div class="tx-ent-card-body" style="padding-top:6px">

                        <div class="tx-dep-detail-row">
                            <div class="tx-dep-detail-icon"><i class="bi @(_selected.IsArchived ? "bi-archive" : "bi-check-circle")"></i></div>
                            <div>
                                <div class="tx-dep-detail-lbl">Estado</div>
                                <div class="tx-dep-detail-val">@(_selected.IsArchived ? "Archivada" : "Activa")</div>
                            </div>
                        </div>

                        @if (_selected.Classifier == OrgUnitClassifier.Dependencia)
                        {
                            <div class="tx-dep-detail-row">
                                <div class="tx-dep-detail-icon"><i class="bi bi-hash"></i></div>
                                <div>
                                    <div class="tx-dep-detail-lbl">Código</div>
                                    <div class="tx-dep-detail-val">@(_selected.Codigo ?? "--")</div>
                                </div>
                            </div>
                            <div class="tx-dep-detail-row">
                                <div class="tx-dep-detail-icon"><i class="bi bi-folder2"></i></div>
                                <div>
                                    <div class="tx-dep-detail-lbl">Fondo documental</div>
                                    <div class="tx-dep-detail-val">@(_selected.FondoNombre ?? "-- sin fondo --")</div>
                                </div>
                            </div>
                            <div class="tx-dep-detail-row">
                                <div class="tx-dep-detail-icon"><i class="bi bi-calendar3"></i></div>
                                <div>
                                    <div class="tx-dep-detail-lbl">Vigente desde</div>
                                    <div class="tx-dep-detail-val">@Fecha(_selected.VigenteDesde)</div>
                                </div>
                            </div>
                            <div class="tx-dep-detail-row">
                                <div class="tx-dep-detail-icon"><i class="bi bi-calendar-x"></i></div>
                                <div>
                                    <div class="tx-dep-detail-lbl">Vigente hasta</div>
                                    <div class="tx-dep-detail-val">@(_selected.VigenteHasta is null ? "Vigente actualmente" : Fecha(_selected.VigenteHasta))</div>
                                </div>
                            </div>
                            @if (_selected.SucesoraId is long sucesoraId)
                            {
                                <div class="tx-dep-detail-row">
                                    <div class="tx-dep-detail-icon"><i class="bi bi-arrow-right-circle"></i></div>
                                    <div>
                                        <div class="tx-dep-detail-lbl">Sucedida por</div>
                                        <div class="tx-dep-detail-val">@NombreDe(sucesoraId)</div>
                                    </div>
                                </div>
                            }
                        }

                        @if (_selected.Classifier == OrgUnitClassifier.Cargo)
                        {
                            <div class="tx-dep-detail-row">
                                <div class="tx-dep-detail-icon"><i class="bi bi-layers"></i></div>
                                <div>
                                    <div class="tx-dep-detail-lbl">Nivel jerárquico</div>
                                    <div class="tx-dep-detail-val">@(_selected.NivelJerarquico?.ToString() ?? "--")</div>
                                </div>
                            </div>
                            <div class="tx-dep-detail-row">
                                <div class="tx-dep-detail-icon"><i class="bi bi-hash"></i></div>
                                <div>
                                    <div class="tx-dep-detail-lbl">Código del cargo</div>
                                    <div class="tx-dep-detail-val">@(_selected.CodigoCargo ?? "--")</div>
                                </div>
                            </div>
                            <div class="tx-dep-detail-row">
                                <div class="tx-dep-detail-icon"><i class="bi bi-patch-check"></i></div>
                                <div>
                                    <div class="tx-dep-detail-lbl">Código DAFP</div>
                                    <div class="tx-dep-detail-val">@(_selected.CodigoDafp ?? "--")</div>
                                </div>
                            </div>
                        }

                        @if (_selected.Classifier == OrgUnitClassifier.Funcionario && _selected.OccupantName is string ocupante)
                        {
                            <div class="tx-dep-detail-row">
                                <div class="tx-dep-detail-icon"><i class="bi bi-person"></i></div>
                                <div>
                                    <div class="tx-dep-detail-lbl">Ocupa el puesto</div>
                                    <div class="tx-dep-detail-val">@ocupante</div>
                                </div>
                            </div>
                        }

                        <div class="tx-dep-detail-row">
                            <div class="tx-dep-detail-icon"><i class="bi bi-person-check"></i></div>
                            <div>
                                <div class="tx-dep-detail-lbl">Responsable</div>
                                <div class="tx-dep-detail-val">@(_selected.ResponsibleName ?? "Sin responsable")</div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_selected.Description))
                        {
                            <div class="tx-dep-detail-row">
                                <div class="tx-dep-detail-icon"><i class="bi bi-card-text"></i></div>
                                <div>
                                    <div class="tx-dep-detail-lbl">Descripción</div>
                                    <div class="tx-dep-detail-val" style="font-weight:400">@_selected.Description</div>
                                </div>
                            </div>
                        }

                        <div class="tx-ent-sep" style="margin:14px 0"></div>

                        <div class="tx-dep-detail-lbl">Miembros (@_members.Count)</div>
                        @foreach (var m in _members)
                        {
                            <div class="tx-dep-member">
                                <span class="tx-dep-avatar">@Initials(m.DisplayName ?? m.Email)</span>
                                <span class="tx-dep-member-name">
                                    @* Nombre + correo: con solo uno de los dos, dos homonimos son
                                       indistinguibles y un correo suelto no dice quien es. *@
                                    @(m.DisplayName ?? m.Email)
                                    @if (m.IsResponsible)
                                    {
                                        <span class="tx-ent-badge sm ok" style="margin-left:6px">Jefe</span>
                                    }
                                    <span class="tx-dep-member-mail">
                                        @m.Email@(string.IsNullOrWhiteSpace(m.Role) ? "" : $" · {m.Role}")
                                    </span>
                                </span>
                                <button type="button" class="tx-ent-btn sm @(m.IsResponsible ? "primary" : "")"
                                        title="@(m.IsResponsible ? "Quitar como jefe/responsable" : "Marcar como jefe/responsable")"
                                        @onclick="@(() => ToggleResponsibleAsync(m))" disabled="@_busy">
                                    @(m.IsResponsible ? "Jefe" : "Hacer jefe")
                                </button>
                                <button type="button" class="tx-ent-btn sm danger" @onclick="@(() => RemoveMemberAsync(m))" disabled="@_busy">Quitar</button>
                            </div>
                        }

                        <div style="display:flex;gap:6px;margin-top:10px;flex-wrap:wrap">
                            <select class="tx-ent-input" style="max-width:210px" @bind="_newMemberUserId">
                                <option value="">-- Usuario --</option>
                                @foreach (var u in _users.Where(u => _members.All(m => m.TenantUserId != u.Id)))
                                {
                                    <option value="@u.Id">@(u.DisplayName ?? u.Email)</option>
                                }
                            </select>
                            <input class="tx-ent-input" style="max-width:150px" placeholder="Rol (opcional)" maxlength="100" @bind="_newMemberRole" />
                            <button type="button" class="tx-ent-btn sm primary" @onclick="AddMemberAsync"
                                    disabled="@(_busy || string.IsNullOrEmpty(_newMemberUserId))">Agregar</button>
                        </div>

                        @if (_detailError is not null)
                        {
                            <div class="tx-ent-fielderr">@_detailError</div>
                        }

                        <div style="display:flex;gap:8px;margin-top:18px">
                            <button type="button" class="tx-ent-btn sm" @onclick="@(() => OpenEditor(_selected, null))">Editar</button>
                            <button type="button" class="tx-ent-btn sm danger" @onclick="ToggleArchiveAsync" disabled="@_busy">
                                @(_selected.IsArchived ? "Restaurar" : "Archivar")
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* ===== Modal crear/editar unidad ===== *@
    @if (_showEditor)
    {
        <div class="modal-overlay" @onclick="@(() => _showEditor = false)">
            <div class="modal-dialog" style="max-width:620px" @onclick:stopPropagation="true">
                <div class="modal-head">
                    <h3>@(_editing is null ? "Nueva unidad organizacional" : $"Editar {_editing.Name}")</h3>
                    <button class="modal-close" @onclick="@(() => _showEditor = false)">&times;</button>
                </div>
                <div class="modal-body tx-dep">
                    <div class="tx-ent-grid c2">
                        <div class="tx-ent-field">
                            <label>Clasificación <span class="req">*</span></label>
                            <select class="tx-ent-input" @bind="_fClassifier" @bind:after="OnClassifierChanged">
                                <option value="@OrgUnitClassifier.Dependencia">Dependencia</option>
                                <option value="@OrgUnitClassifier.Cargo">Cargo</option>
                                <option value="@OrgUnitClassifier.Funcionario">Funcionario</option>
                            </select>
                            <div class="tx-ent-hint">Un solo árbol con nodos de distinto tipo (ADR-003).</div>
                        </div>
                        <div class="tx-ent-field">
                            <label>Nombre <span class="req">*</span></label>
                            <input class="tx-ent-input" @bind="_fName" maxlength="200" placeholder="Ej. Secretaría General" />
                        </div>
                    </div>

                    <div class="tx-ent-grid c2">
                        <div class="tx-ent-field">
                            <label>Unidad padre</label>
                            <select class="tx-ent-input" value="@_fParentId" @onchange="OnParentChangedAsync">
                                <option value="">(Raíz del organigrama)</option>
                                @foreach (var u in _flat.Where(x => x.Id != _editing?.Id))
                                {
                                    <option value="@u.Id">@ClassifierLabel(u.Classifier): @u.Name</option>
                                }
                            </select>
                        </div>
                        <div class="tx-ent-field">
                            <label>Orden entre hermanos</label>
                            <input type="number" class="tx-ent-input" @bind="_fSortOrder" />
                        </div>
                    </div>

                    @* ---- Campos propios de DEPENDENCIA (RF03) ---- *@
                    @if (_fClassifier == OrgUnitClassifier.Dependencia)
                    {
                        <div class="tx-ent-agn obligatorio">
                            <div class="tx-ent-agn-head"><i class="bi bi-folder2"></i><span>Datos de la Dependencia (RF03)</span></div>
                            <div class="tx-ent-grid c2">
                                <div class="tx-ent-field">
                                    <label>Fondo documental <span class="req">*</span></label>
                                    <select class="tx-ent-input" @bind="_fFondoId">
                                        <option value="">-- Seleccione un fondo --</option>
                                        @foreach (var f in _fondos)
                                        {
                                            <option value="@f.Id">@f.CodigoFondo - @f.NombreFondo</option>
                                        }
                                    </select>
                                    <div class="tx-ent-hint">Principio de procedencia: la dependencia cuelga de un fondo.</div>
                                </div>
                                <div class="tx-ent-field">
                                    <label>Código <span class="req">*</span></label>
                                    <input class="tx-ent-input mono upper" @bind="_fCodigo" maxlength="20" placeholder="100.1" />
                                    <div class="tx-ent-hint">Único entre hermanos bajo el mismo padre, no en todo el árbol.</div>
                                </div>
                            </div>
                            <div class="tx-ent-grid c2" style="margin-top:14px">
                                <div class="tx-ent-field">
                                    <label>Vigente desde <span class="req">*</span></label>
                                    <input type="date" class="tx-ent-input" @bind="_fVigenteDesde" />
                                </div>
                                <div class="tx-ent-field">
                                    <label>Vigente hasta <span class="opt">(vacío = vigente)</span></label>
                                    <input type="date" class="tx-ent-input" @bind="_fVigenteHasta" />
                                </div>
                            </div>
                            <div class="tx-ent-field" style="margin-top:14px">
                                <label>Dependencia sucesora <span class="opt">(fusiones o reestructuraciones)</span></label>
                                <select class="tx-ent-input" @bind="_fSucesoraId">
                                    <option value="">(Ninguna)</option>
                                    @foreach (var u in _flat.Where(x => x.Classifier == OrgUnitClassifier.Dependencia && x.Id != _editing?.Id))
                                    {
                                        <option value="@u.Id">@u.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    }

                    @* ---- Campos propios de CARGO (RF04) ---- *@
                    @if (_fClassifier == OrgUnitClassifier.Cargo)
                    {
                        <div class="tx-ent-agn obligatorio">
                            <div class="tx-ent-agn-head"><i class="bi bi-person-badge"></i><span>Datos del Cargo (RF04)</span></div>
                            <div class="tx-ent-grid c3">
                                <div class="tx-ent-field">
                                    <label>Nivel jerárquico <span class="req">*</span></label>
                                    <select class="tx-ent-input" @bind="_fNivelJerarquico">
                                        @foreach (var n in Enum.GetValues<NivelJerarquico>())
                                        {
                                            <option value="@n">@n</option>
                                        }
                                    </select>
                                </div>
                                <div class="tx-ent-field">
                                    <label>Código del cargo <span class="opt">(opcional)</span></label>
                                    <input class="tx-ent-input mono" @bind="_fCodigoCargo" maxlength="20" />
                                </div>
                                <div class="tx-ent-field">
                                    <label>Código DAFP <span class="opt">(entidades públicas)</span></label>
                                    <input class="tx-ent-input mono" @bind="_fCodigoDafp" maxlength="20" />
                                </div>
                            </div>
                            <div class="tx-ent-hint" style="margin-top:10px">
                                <i class="bi bi-shield-lock"></i> El cargo es <strong>metadato organizacional</strong>: no otorga permisos.
                                Los permisos vienen únicamente de la matriz de RF05.
                            </div>
                        </div>
                    }

                    @* ---- Campos propios de FUNCIONARIO ---- *@
                    @if (_fClassifier == OrgUnitClassifier.Funcionario)
                    {
                        <div class="tx-ent-field">
                            <label>Usuario que ocupa el puesto <span class="req">*</span></label>
                            <select class="tx-ent-input" @bind="_fTenantUserId">
                                <option value="">-- Usuario del tenant --</option>
                                @foreach (var u in _users)
                                {
                                    <option value="@u.Id">@(u.DisplayName ?? u.Email)</option>
                                }
                            </select>
                        </div>
                    }

                    <div class="tx-ent-field">
                        <label>Responsable <span class="opt">(opcional)</span></label>
                        <select class="tx-ent-input" @bind="_fResponsibleId">
                            <option value="">(Sin responsable)</option>
                            @foreach (var u in _users)
                            {
                                <option value="@u.Id">@(u.DisplayName ?? u.Email)</option>
                            }
                        </select>
                    </div>

                    <div class="tx-ent-field">
                        <label>Descripción</label>
                        <textarea class="tx-ent-input" rows="2" maxlength="600" @bind="_fDescription"></textarea>
                    </div>

                    @* Aviso del Addendum de ADR-003: reubicar un Cargo cambia la visibilidad
                       documental de todos sus ocupantes sin que nadie edite esos usuarios. *@
                    @if (_avisoCargoAfectados > 0)
                    {
                        <div class="tx-dep-warn">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span>
                                Estás moviendo un <strong>Cargo</strong>: cambia la dependencia derivada de
                                <strong>@_avisoCargoAfectados usuario(s)</strong> y, con ella, su visibilidad documental.
                                El movimiento queda en la pista de auditoría.
                            </span>
                        </div>
                    }

                    @if (_editorError is not null)
                    {
                        <div class="tx-ent-fielderr">@_editorError</div>
                    }
                </div>
                <div class="modal-foot">
                    <button class="tx-ent-btn" @onclick="@(() => _showEditor = false)" disabled="@_busy">Cancelar</button>
                    <button class="tx-ent-btn primary" @onclick="SaveAsync" disabled="@_busy">
                        @(_editing is null ? "Crear unidad" : "Guardar")
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private bool _busy;
    private bool _includeArchived;
    private string? _pageError;
    private string _search = "";

    private OrgKpisDto? _kpis;
    private IReadOnlyList<OrgUnitNodeDto> _tree = [];
    private IReadOnlyList<OrgUnitDto> _flat = [];
    private IReadOnlyList<TenantUserDto> _users = [];
    private IReadOnlyList<FondoDto> _fondos = [];
    private readonly HashSet<long> _collapsed = [];

    private int _countDependencias;
    private int _countCargos;
    private int _countArchivadas;

    private OrgUnitDto? _selected;
    private string _selectedPath = "";
    private IReadOnlyList<OrgUnitMemberDto> _members = [];
    private string? _detailError;
    private string _newMemberUserId = "";
    private string? _newMemberRole;

    // ---- Editor ----
    private bool _showEditor;
    private OrgUnitDto? _editing;
    private string _fName = "";
    private OrgUnitClassifier _fClassifier = OrgUnitClassifier.Dependencia;
    private string _fTenantUserId = "";
    private string _fParentId = "";
    private string _fResponsibleId = "";
    private string? _fDescription;
    private int _fSortOrder;
    private string? _editorError;
    private int _avisoCargoAfectados;

    // Atributos de Dependencia (RF03).
    private string _fFondoId = "";
    private string? _fCodigo;
    private DateOnly? _fVigenteDesde;
    private DateOnly? _fVigenteHasta;
    private string _fSucesoraId = "";

    // Atributos de Cargo (RF04).
    private string? _fCodigoCargo;
    private string? _fCodigoDafp;
    private NivelJerarquico _fNivelJerarquico = NivelJerarquico.Profesional;

    protected override async Task OnInitializedAsync()
    {
        _users = await UsersSvc.ListAsync();
        try
        {
            _fondos = await FondoSvc.ListAsync();
        }
        catch (Exception ex)
        {
            // Sin fondos no se puede crear una Dependencia; se avisa en vez de fallar en silencio.
            _pageError = $"No se pudo cargar el catalogo de fondos documentales: {ex.Message}";
        }
        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        _kpis = await OrgSvc.GetKpisAsync();
        _tree = await OrgSvc.GetTreeAsync(_includeArchived);
        _flat = await OrgSvc.ListAsync(includeArchived: true);
        _countDependencias = _flat.Count(u => u.Classifier == OrgUnitClassifier.Dependencia && !u.IsArchived);
        _countCargos = _flat.Count(u => u.Classifier == OrgUnitClassifier.Cargo && !u.IsArchived);
        _countArchivadas = _flat.Count(u => u.IsArchived);
        if (_selected is not null)
        {
            await SelectAsync(_selected.Id);
        }
    }

    private void OnSearch(ChangeEventArgs e) => _search = e.Value?.ToString() ?? "";

    private IReadOnlyList<OrgUnitDto> Buscar()
    {
        var q = _search.Trim();
        if (q.Length == 0) { return []; }
        return _flat
            .Where(u => (_includeArchived || !u.IsArchived)
                        && (u.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
                            || (u.Codigo ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                            || (u.CodigoCargo ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(u => u.Name)
            .ToList();
    }

    private IEnumerable<(OrgUnitNodeDto Node, int Depth)> FlattenTree()
    {
        IEnumerable<(OrgUnitNodeDto, int)> Walk(IReadOnlyList<OrgUnitNodeDto> nodes, int depth)
        {
            foreach (var node in nodes)
            {
                yield return (node, depth);
                if (!_collapsed.Contains(node.Id))
                {
                    foreach (var child in Walk(node.Children, depth + 1))
                    {
                        yield return child;
                    }
                }
            }
        }
        return Walk(_tree, 0);
    }

    private void ToggleCollapse(long id)
    {
        if (!_collapsed.Remove(id))
        {
            _collapsed.Add(id);
        }
    }

    private async Task SelectAsync(long unitId)
    {
        _detailError = null;
        _selected = await OrgSvc.GetAsync(unitId);
        if (_selected is null)
        {
            _members = [];
            _selectedPath = "";
            return;
        }
        _members = await OrgSvc.ListMembersAsync(unitId);
        _selectedPath = BuildPath(_selected);
    }

    private string BuildPath(OrgUnitDto unit)
    {
        var nameById = _flat.ToDictionary(u => u.Id, u => u);
        var parts = new List<string>();
        var current = unit.ParentId;
        var guard = 0;
        // Guarda de 20 saltos: si el arbol estuviera corrupto, esto NO se cuelga.
        while (current is long id && nameById.TryGetValue(id, out var parent) && guard++ < 20)
        {
            parts.Insert(0, parent.Name);
            current = parent.ParentId;
        }
        return parts.Count == 0 ? "Raiz del organigrama" : string.Join(" > ", parts);
    }

    private string NombreDe(long unitId)
        => _flat.FirstOrDefault(u => u.Id == unitId)?.Name ?? $"Unidad {unitId}";

    // ---- Miembros ----

    private async Task AddMemberAsync()
    {
        if (_selected is null || !long.TryParse(_newMemberUserId, out var userId)) { return; }
        _busy = true;
        _detailError = null;
        var result = await OrgSvc.AddMemberAsync(_selected.Id, userId, _newMemberRole);
        if (!result.IsOk)
        {
            _detailError = result.Error;
        }
        else
        {
            _newMemberUserId = "";
            _newMemberRole = null;
            await LoadAsync();
        }
        _busy = false;
    }

    private async Task RemoveMemberAsync(OrgUnitMemberDto member)
    {
        _busy = true;
        _detailError = null;
        var result = await OrgSvc.RemoveMemberAsync(member.Id);
        if (!result.IsOk)
        {
            _detailError = result.Error;
        }
        else
        {
            await LoadAsync();
        }
        _busy = false;
    }

    private async Task ToggleResponsibleAsync(OrgUnitMemberDto member)
    {
        _busy = true;
        _detailError = null;
        var result = await OrgSvc.SetMemberResponsibleAsync(member.Id, !member.IsResponsible);
        if (!result.IsOk)
        {
            _detailError = result.Error;
        }
        else
        {
            await LoadAsync();
        }
        _busy = false;
    }

    private async Task ToggleArchiveAsync()
    {
        if (_selected is null) { return; }
        _busy = true;
        _detailError = null;
        // Archivar, nunca borrar (invariante 8): el servicio exige que no queden hijos activos.
        var result = await OrgSvc.SetArchivedAsync(_selected.Id, !_selected.IsArchived, Tenant.UserId ?? 0);
        if (!result.IsOk)
        {
            _detailError = result.Error;
        }
        else
        {
            await LoadAsync();
        }
        _busy = false;
    }

    // ---- Editor ----

    private void OpenEditor(OrgUnitDto? unit, long? presetParentId)
    {
        _editing = unit;
        _fName = unit?.Name ?? "";
        _fClassifier = unit?.Classifier ?? OrgUnitClassifier.Dependencia;
        _fTenantUserId = unit?.TenantUserId?.ToString() ?? "";
        _fParentId = (unit?.ParentId ?? presetParentId)?.ToString() ?? "";
        _fResponsibleId = unit?.ResponsibleTenantUserId?.ToString() ?? "";
        _fDescription = unit?.Description;
        _fSortOrder = unit?.SortOrder ?? 0;

        _fFondoId = unit?.FondoId?.ToString() ?? (_fondos.Count == 1 ? _fondos[0].Id.ToString() : "");
        _fCodigo = unit?.Codigo;
        // Una Dependencia nueva nace vigente desde hoy: VigenteDesde es obligatoria en RF03 y
        // dejarla vacia solo produce un error de validacion previsible.
        _fVigenteDesde = unit?.VigenteDesde ?? DateOnly.FromDateTime(DateTime.Today);
        _fVigenteHasta = unit?.VigenteHasta;
        _fSucesoraId = unit?.SucesoraId?.ToString() ?? "";

        _fCodigoCargo = unit?.CodigoCargo;
        _fCodigoDafp = unit?.CodigoDafp;
        _fNivelJerarquico = unit?.NivelJerarquico ?? NivelJerarquico.Profesional;

        _avisoCargoAfectados = 0;
        _editorError = null;
        _showEditor = true;
    }

    private void OnClassifierChanged()
    {
        // Cambiar de clasificador NO limpia los campos del otro: el servicio los persiste en
        // null segun el clasificador, asi que volver atras no obliga a reescribirlos.
        _avisoCargoAfectados = 0;
    }

    private async Task OnParentChangedAsync(ChangeEventArgs e)
    {
        _fParentId = e.Value?.ToString() ?? "";
        _avisoCargoAfectados = 0;

        // ADR-003 (Addendum, punto 2): mover un Cargo cambia la visibilidad documental de todos
        // sus ocupantes sin que nadie edite esos usuarios. Se avisa ANTES de guardar.
        if (_editing is { Classifier: OrgUnitClassifier.Cargo }
            && _fParentId != (_editing.ParentId?.ToString() ?? ""))
        {
            _avisoCargoAfectados = await OrgSvc.CountAffectedUsersAsync(_editing.Id);
        }
    }

    private async Task SaveAsync()
    {
        _busy = true;
        _editorError = null;

        var esDependencia = _fClassifier == OrgUnitClassifier.Dependencia;
        var esCargo = _fClassifier == OrgUnitClassifier.Cargo;

        var request = new SaveOrgUnitRequest(
            _fName,
            _fClassifier,
            long.TryParse(_fParentId, out var parentId) ? parentId : null,
            long.TryParse(_fResponsibleId, out var responsibleId) ? responsibleId : null,
            _fDescription,
            _fSortOrder,
            long.TryParse(_fTenantUserId, out var occupantId) ? occupantId : null,
            // RF03: solo tienen sentido en una Dependencia. El servicio los anula igual en los
            // demas clasificadores, pero no se le mandan para que el request sea honesto.
            FondoId: esDependencia && long.TryParse(_fFondoId, out var fondoId) ? fondoId : null,
            Codigo: esDependencia ? _fCodigo : null,
            VigenteDesde: esDependencia ? _fVigenteDesde : null,
            VigenteHasta: esDependencia ? _fVigenteHasta : null,
            SucesoraId: esDependencia && long.TryParse(_fSucesoraId, out var sucesoraId) ? sucesoraId : null,
            // RF04: solo tienen sentido en un Cargo.
            CodigoCargo: esCargo ? _fCodigoCargo : null,
            CodigoDafp: esCargo ? _fCodigoDafp : null,
            NivelJerarquico: esCargo ? _fNivelJerarquico : null);

        var actorUserId = Tenant.UserId ?? 0;
        var result = _editing is null
            ? await OrgSvc.CreateAsync(request, actorUserId)
            : await OrgSvc.UpdateAsync(_editing.Id, request, actorUserId);
        if (!result.IsOk)
        {
            _editorError = result.Error;
        }
        else
        {
            _showEditor = false;
            await LoadAsync();
            if (result.Value is not null)
            {
                await SelectAsync(result.Value.Id);
            }
        }
        _busy = false;
    }

    // ---- Helpers de presentacion ----

    private static string ClassifierLabel(OrgUnitClassifier classifier) => classifier switch
    {
        OrgUnitClassifier.Dependencia => "Dependencia",
        OrgUnitClassifier.Cargo => "Cargo",
        _ => "Funcionario"
    };

    private static string ClasificadorClase(OrgUnitClassifier classifier) => classifier switch
    {
        OrgUnitClassifier.Dependencia => "violet",
        OrgUnitClassifier.Cargo => "info",
        _ => "ok"
    };

    private static string Fecha(DateOnly? fecha) => fecha?.ToString("dd/MM/yyyy") ?? "--";

    private static string Initials(string name)
    {
        var parts = name.Split([' ', '@', '.'], StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) { return "?"; }
        return parts.Length == 1
            ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant()
            : string.Concat(char.ToUpperInvariant(parts[0][0]), char.ToUpperInvariant(parts[1][0]));
    }

    /// <summary>Interior comun de la fila del arbol y de la lista de resultados de busqueda.</summary>
    private RenderFragment NodoInterior(
        OrgUnitClassifier classifier, string? codigo, string name, bool archivada, int memberCount) => builder =>
    {
        var seq = 0;
        if (!string.IsNullOrWhiteSpace(codigo))
        {
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "tx-dep-node-code");
            builder.AddContent(seq++, codigo);
            builder.CloseElement();
        }
        builder.OpenElement(seq++, "span");
        builder.AddAttribute(seq++, "class", "tx-dep-node-name");
        builder.AddContent(seq++, name);
        builder.CloseElement();

        builder.OpenElement(seq++, "span");
        builder.AddAttribute(seq++, "class", "tx-dep-node-right");

        builder.OpenElement(seq++, "span");
        builder.AddAttribute(seq++, "class", $"tx-ent-badge sm {ClasificadorClase(classifier)}");
        builder.AddContent(seq++, ClassifierLabel(classifier));
        builder.CloseElement();

        if (archivada)
        {
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "tx-ent-badge sm off");
            builder.AddContent(seq++, "Archivada");
            builder.CloseElement();
        }

        if (memberCount > 0)
        {
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "tx-ent-hint");
            builder.AddAttribute(seq++, "style", "margin:0");
            builder.AddAttribute(seq++, "title", "Miembros");
            builder.AddContent(seq++, $"· {memberCount}");
            builder.CloseElement();
        }

        builder.CloseElement();
    };
}
