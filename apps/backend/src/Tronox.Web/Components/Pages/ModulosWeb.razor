@page "/modulos-web"
@attribute [Authorize(Policy = "ModulosWeb.Administrar")]
@* Policy por modulo (paso 1: mismo requisito que TenantMember, nombre estable). TODO: derivar del Module Registry. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Tronox.Application.Modules
@using Tronox.Domain.Enums
@inject IModuleRegistryService RegistrySvc


<PageTitle>Modulos web - TRONOX.tareas</PageTitle>

<nav class="tronox-breadcrumb" aria-label="Ruta de navegacion">
    <a href="/inicio">Workspace</a>
    <span class="sep">/</span>
    <span>Sistema</span>
    <span class="sep">/</span>
    <span class="cur">Modulos web</span>
</nav>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
            </div>
            <span>Modulo 000109 &#183; Sistema</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Modulos web</h1>
        <p class="page-sub" style="margin-bottom:0;">Registro de todos los modulos del sistema: estado y variables por tenant. El catalogo global lo administra la plataforma.</p>
    </div>
</div>

@* ===== KPIs (como el prototipo: registrados / activos / nucleo) ===== *@
<div class="kpi-grid" style="margin-bottom:22px;max-width:760px;">
    <div class="kpi-card">
        <div class="kpi-top">
            <div class="kpi-icon tone-primary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
            </div>
        </div>
        <div class="kpi-value">@_rows.Count</div>
        <div class="kpi-label">Modulos registrados</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-top">
            <div class="kpi-icon tone-success">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
        </div>
        <div class="kpi-value">@_rows.Count(r => r.IsEnabled)</div>
        <div class="kpi-label">Activos</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-top">
            <div class="kpi-icon tone-gold">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
        </div>
        <div class="kpi-value">@_rows.Count(r => r.IsCore)</div>
        <div class="kpi-label">Nucleo</div>
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando el registro de modulos...</em></p>
}
else
{
    <div class="mw-panel">
        <div class="mw-panel-head">
            <span>Modulos registrados</span>
            <input class="form-control" style="max-width:260px;font-size:13px;" placeholder="Buscar modulo o codigo..."
                   value="@_search" @oninput="@(e => _search = e.Value?.ToString() ?? "")" />
        </div>
        @if (_error is not null)
        {
            <div class="tk-field-error" style="margin-bottom:10px;">@_error</div>
        }
        <div style="overflow-x:auto;">
            <table class="table table-hover align-middle" style="margin-bottom:0;">
                <thead>
                    <tr>
                        <th style="width:90px;">Codigo</th>
                        <th>Modulo</th>
                        <th style="width:140px;">Area</th>
                        <th style="width:150px;">Ruta</th>
                        <th style="width:120px;">Estado</th>
                        <th style="width:110px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Filtered())
                    {
                        <tr>
                            <td><span class="tk-number">@row.LegacyCode</span></td>
                            <td>
                                <div style="font-weight:600;">
                                    @row.Name
                                    @if (row.IsCore)
                                    {
                                        <span class="tk-status st-pending" style="margin-left:6px;" title="Modulo nucleo: no se puede deshabilitar">Nucleo</span>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(row.Description))
                                {
                                    <small class="text-muted">@row.Description</small>
                                }
                            </td>
                            <td><span class="tk-status @AreaClass(row.Area)">@AreaLabel(row.Area)</span></td>
                            <td>
                                @if (row.Route is string route)
                                {
                                    <a href="@route" style="font-size:12.5px;">@route</a>
                                }
                                else
                                {
                                    <small class="text-muted">(sin UI)</small>
                                }
                            </td>
                            <td>
                                <label class="mw-switch @(row.IsEnabled ? "on" : "") @(CanToggle(row) ? "" : "locked")"
                                       title="@ToggleTitle(row)">
                                    <input type="checkbox" checked="@row.IsEnabled" disabled="@(!CanToggle(row) || _busy)"
                                           @onchange="@(() => ToggleAsync(row))" />
                                    <span class="mw-switch-track"><span class="mw-switch-thumb"></span></span>
                                    <span class="mw-switch-label">@(row.IsEnabled ? "Activo" : "Inactivo")</span>
                                </label>
                            </td>
                            <td style="text-align:right;">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => OpenSettings(row))" disabled="@(!_canManage)">Settings</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!_canManage)
        {
            <p style="margin:12px 0 0;"><small class="text-muted">Solo el owner/admin del tenant (o la plataforma) puede cambiar el estado y los settings de los modulos.</small></p>
        }
    </div>
}

@* ===== Modal settings JSON del modulo (por tenant) ===== *@
@if (_showSettings && _settingsRow is not null)
{
    <div class="modal-overlay" @onclick="@(() => _showSettings = false)">
        <div class="modal-dialog" style="max-width:560px;" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>Settings de @_settingsRow.Name (@_settingsRow.LegacyCode)</h3>
                <button class="modal-close" @onclick="@(() => _showSettings = false)">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Configuracion del modulo para este tenant (objeto JSON)</label>
                    <textarea class="form-control" rows="8" style="font-family:monospace;font-size:12.5px;"
                              placeholder='{"clave":"valor"}' @bind="_settingsJson"></textarea>
                </div>
                <p style="margin:0;"><small class="text-muted">Se valida que sea un objeto JSON. Vacio = sin settings.</small></p>
                @if (_settingsError is not null)
                {
                    <div class="tk-field-error" style="margin-top:8px;">@_settingsError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="@(() => _showSettings = false)" disabled="@_busy">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveSettingsAsync" disabled="@_busy">Guardar settings</button>
            </div>
        </div>
    </div>
}

<style>
    .mw-panel { background: var(--surface, var(--card)); border: 1px solid var(--line, var(--border)); border-radius: var(--rad, 14px); padding: 18px 20px; }
    .mw-panel-head { display: flex; justify-content: space-between; align-items: center; gap: 12px; font-weight: 700; font-size: 15px; color: var(--ink, var(--foreground)); margin-bottom: 14px; flex-wrap: wrap; }
    .mw-switch { display: inline-flex; align-items: center; gap: 8px; cursor: pointer; margin: 0; }
    .mw-switch.locked { cursor: not-allowed; opacity: .55; }
    .mw-switch input { display: none; }
    .mw-switch-track { width: 34px; height: 19px; border-radius: 999px; background: var(--surface-3, var(--muted)); border: 1px solid var(--line-2, var(--border)); position: relative; transition: background .15s; flex: none; }
    .mw-switch.on .mw-switch-track { background: var(--ok, #22c55e); border-color: transparent; }
    .mw-switch-thumb { position: absolute; top: 2px; left: 2px; width: 13px; height: 13px; border-radius: 999px; background: #fff; box-shadow: 0 1px 2px rgba(0,0,0,.25); transition: left .15s; }
    .mw-switch.on .mw-switch-thumb { left: 17px; }
    .mw-switch-label { font-size: 12px; color: var(--ink-2, var(--muted-foreground)); }
    .mw-area-sistema { background: var(--t-violet-bg, var(--primary-soft)); color: var(--t-violet, var(--primary)); }
    .mw-area-principal { background: var(--t-blue-bg, var(--primary-soft)); color: var(--t-blue, var(--primary)); }
    .mw-area-operaciones { background: var(--t-amber-bg, var(--muted)); color: var(--t-amber, var(--muted-foreground)); }
    .mw-area-automatizacion { background: var(--t-green-bg, var(--muted)); color: var(--t-green, var(--muted-foreground)); }
    .mw-area-crm { background: var(--t-rose-bg, var(--muted)); color: var(--t-rose, var(--muted-foreground)); }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private bool _canManage;
    private string _search = "";
    private string? _error;
    private IReadOnlyList<ModuleCatalogRowDto> _rows = [];

    private bool _showSettings;
    private ModuleCatalogRowDto? _settingsRow;
    private string? _settingsJson;
    private string? _settingsError;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var user = (await AuthState).User;
            var tenantRole = user.FindFirst("tenant_role")?.Value;
            // Habilitar/deshabilitar: owner o admin del tenant, o un operador de plataforma.
            _canManage = tenantRole is nameof(TenantRole.Owner) or nameof(TenantRole.Admin)
                || user.FindFirst("platform_role") is not null;
        }
        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        _rows = await RegistrySvc.ListCatalogAsync();
    }

    private IEnumerable<ModuleCatalogRowDto> Filtered()
    {
        if (string.IsNullOrWhiteSpace(_search)) { return _rows; }
        var term = _search.Trim();
        return _rows.Where(r =>
            r.LegacyCode.Contains(term, StringComparison.OrdinalIgnoreCase)
            || r.Name.Contains(term, StringComparison.OrdinalIgnoreCase)
            || (r.Description?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private bool CanToggle(ModuleCatalogRowDto row)
        => _canManage && !(row.IsCore && row.IsEnabled);

    private string ToggleTitle(ModuleCatalogRowDto row)
    {
        if (!_canManage) { return "Solo owner/admin del tenant puede cambiar el estado"; }
        if (row.IsCore && row.IsEnabled) { return "Modulo nucleo: no se puede deshabilitar"; }
        return row.IsEnabled ? "Deshabilitar para este tenant" : "Habilitar para este tenant";
    }

    private async Task ToggleAsync(ModuleCatalogRowDto row)
    {
        _busy = true;
        _error = null;
        var result = await RegistrySvc.SetModuleEnabledAsync(row.ModuleDefinitionId, !row.IsEnabled);
        if (!result.IsOk)
        {
            _error = result.Error;
        }
        await LoadAsync();
        _busy = false;
    }

    private void OpenSettings(ModuleCatalogRowDto row)
    {
        _settingsRow = row;
        _settingsJson = row.SettingsJson;
        _settingsError = null;
        _showSettings = true;
    }

    private async Task SaveSettingsAsync()
    {
        if (_settingsRow is null) { return; }
        _busy = true;
        _settingsError = null;
        var result = await RegistrySvc.UpdateSettingsAsync(_settingsRow.ModuleDefinitionId, _settingsJson);
        if (!result.IsOk)
        {
            _settingsError = result.Error;
        }
        else
        {
            _showSettings = false;
            await LoadAsync();
        }
        _busy = false;
    }

    private static string AreaLabel(ModuleArea area) => area switch
    {
        ModuleArea.Principal => "Principal",
        ModuleArea.Operaciones => "Operaciones",
        ModuleArea.Automatizacion => "Automatizacion",
        ModuleArea.Sistema => "Sistema",
        ModuleArea.Crm => "CRM",
        _ => area.ToString()
    };

    private static string AreaClass(ModuleArea area) => area switch
    {
        ModuleArea.Principal => "mw-area-principal",
        ModuleArea.Operaciones => "mw-area-operaciones",
        ModuleArea.Automatizacion => "mw-area-automatizacion",
        ModuleArea.Sistema => "mw-area-sistema",
        ModuleArea.Crm => "mw-area-crm",
        _ => "st-pending"
    };
}
