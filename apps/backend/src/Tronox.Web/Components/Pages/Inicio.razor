@page "/inicio"
@attribute [Authorize(Policy = "TenantMember")]
@inject IServiceScopeFactory ScopeFactory
@using Microsoft.Extensions.DependencyInjection

@* Destino del usuario de tenant tras autenticarse (Program.cs redirige aqui). Reproduce el
   "Panel de Control" del prototipo (Prototipo/index.html): hero, KPIs, graficas Chart.js y
   galeria de indicadores. Es una MAQUETA: los numeros son datos de demostracion, marcados como
   tales en el aviso superior. El tablero lo construye js/inicio-dashboard.js en el cliente. *@

<PageTitle>Panel de Control - TRONOX SGDEA</PageTitle>

<div class="tx-inicio" data-user="@(_userName ?? "funcionario")" data-tenant="@(_tenantName ?? "su entidad")">

    @* Aviso honesto: el panel es una maqueta con datos de ejemplo. *@
    <div class="tx-demo-note">
        <i class="bi bi-info-circle"></i>
        <span>Datos de demostracion: los indicadores de este panel son de ejemplo y aun no reflejan informacion real de la entidad.</span>
    </div>

    @* ============ HERO / BIENVENIDA ============ *@
    <div class="home-hero dash-hero">
        <div class="h-eyebrow">Sistema de Gestion Documental Electronico de Archivo</div>
        <div class="h-title">Panel de Control</div>
        <div class="h-sub" id="dash-greeting">Resumen operativo de la plataforma TRONOX.</div>
        <div class="hero-actions">
            <button class="hero-btn primary" data-bs-toggle="modal" data-bs-target="#galleryModal"><i class="bi bi-grid-3x3-gap"></i>Galeria de indicadores</button>
            <a class="hero-btn" href="modulo/radicacion"><i class="bi bi-box-arrow-in-down"></i>Radicar documento</a>
            <a class="hero-btn" href="modulo/pqrsd"><i class="bi bi-megaphone"></i>Gestionar PQRSD</a>
            <a class="hero-btn" href="modulo/analitica-dashboard-ejecutivo"><i class="bi bi-graph-up-arrow"></i>Ver analitica</a>
        </div>
    </div>

    @* ============ TOOLBAR ============ *@
    <div class="dash-toolbar">
        <div>
            <div class="dt-title">Mis indicadores</div>
            <div class="dt-sub" id="dashCount">Selecciona los indicadores que quieres ver.</div>
        </div>
        <div class="dt-actions">
            <button class="btn btn-active-light btn-sm" id="btnReset"><i class="bi bi-arrow-counterclockwise me-1"></i>Restablecer</button>
            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#galleryModal"><i class="bi bi-plus-lg me-1"></i>Agregar indicador</button>
        </div>
    </div>

    @* ============ GRID DE INDICADORES ============ *@
    <div class="row g-4" id="dashGrid"></div>
    <div id="dashEmpty" style="display:none">
        <div class="dash-empty">
            <div class="de-icon"><i class="bi bi-bar-chart-line"></i></div>
            <div class="de-title">Tu panel esta vacio</div>
            <div class="de-desc">Abre la galeria y elige los indicadores que quieres seguir.</div>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#galleryModal"><i class="bi bi-grid-3x3-gap me-1"></i>Abrir galeria de indicadores</button>
        </div>
    </div>

    @* ============ MODAL GALERIA ============ *@
    <div class="modal fade" id="galleryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <div class="modal-title">Galeria de indicadores</div>
                        <div style="font-size:12px;color:var(--kt-text-gray-500);margin-top:2px">Activa o desactiva los indicadores. Los cambios se aplican al instante.</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div class="gallery-grid" id="galleryGrid"></div>
                </div>
                <div class="modal-footer">
                    <span style="font-size:12px;color:var(--kt-text-gray-500);margin-right:auto" id="gallerySel"></span>
                    <button type="button" class="btn btn-active-light" data-bs-dismiss="modal">Cerrar</button>
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal"><i class="bi bi-check2 me-1"></i>Listo</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string? _userName;
    private string? _tenantName;

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null) { return; }
        var state = await AuthState;

        _userName = state.User.Identity?.Name;

        // El tenant sale del claim del AuthenticationState, NUNCA del IHttpContextAccessor. El nombre
        // se resuelve en un scope aislado (como NavMenu) para no compartir el DbContext del render.
        var tenantClaim = state.User.FindFirst("tenant_id")?.Value;
        if (long.TryParse(tenantClaim, out var tenantId))
        {
            try
            {
                await using var scope = ScopeFactory.CreateAsyncScope();
                var tenants = scope.ServiceProvider.GetRequiredService<ITenantAdminService>();
                _tenantName = (await tenants.GetAsync(tenantId))?.Name;
            }
            catch { /* sin nombre: el saludo usa el generico */ }
        }
    }
}
