@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@inject Tronox.Application.Admin.IPlatformBrandingService BrandingSvc
@inject Tronox.Application.Admin.IGoogleAuthConfigService GoogleCfg
@inject Microsoft.Extensions.Configuration.IConfiguration Config

@* Reconstruido sobre la pagina auth-signin-cover.html de Velzon minimal
   (PLAN DE ARRANQUE seccion 3, regla 4: cada pantalla parte de su equivalente
   en la plantilla). Se conserva la estructura original
   auth-page-wrapper > auth-page-content > card overflow-hidden > row g-0 > 2x col-lg-6
   y el carrusel de testimonios se sustituye por el bloque de marca TRONOX
   (PLAN seccion 3.1). El mecanismo de autenticacion NO cambia: sigue siendo un
   form POST plano a /auth/login con los campos email / password / remember. *@

<PageTitle>Ingresar - @_brand.PlatformName</PageTitle>

<div class="auth-page-wrapper auth-bg-cover py-5 d-flex justify-content-center align-items-center min-vh-100">
    <div class="bg-overlay"></div>

    <div class="auth-page-content overflow-hidden pt-lg-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xxl-9 col-lg-11 col-md-12">
                    <div class="card overflow-hidden border-0">
                        <div class="row g-0">

                            @* ---------------- Panel izquierdo: marca TRONOX ---------------- *@
                            <div class="col-lg-6">
                                <div class="p-lg-5 p-4 auth-one-bg h-100">
                                    <div class="bg-overlay"></div>
                                    <div class="position-relative h-100 d-flex flex-column">

                                        <div class="mb-4">
                                            <a href="/login" class="tronox-auth-logo">
                                                @if (!string.IsNullOrWhiteSpace(_brand.LoginLogoUrl))
                                                {
                                                    <img src="@_brand.LoginLogoUrl" alt="@_brand.PlatformName" height="28" />
                                                }
                                                else
                                                {
                                                    <span class="tronox-auth-logo-mark" aria-hidden="true">T</span>
                                                    <span class="tronox-auth-logo-word">TRONOX</span>
                                                }
                                            </a>
                                            <p class="tronox-auth-kicker mt-3 mb-0">
                                                Sistema de gestion documental electronico de archivo
                                            </p>
                                        </div>

                                        <div class="mt-auto">
                                            <h4 class="text-white mb-3">Bienvenido a la plataforma TRONOX</h4>
                                            <p class="text-white-50 mb-4">
                                                Gestione expedientes, documentos y comunicaciones oficiales conforme a la
                                                normativa del Archivo General de la Nacion, con trazabilidad completa.
                                            </p>

                                            <ul class="tronox-auth-features mb-4">
                                                <li>
                                                    <span class="tronox-auth-feature-icon"><i class="ri-history-line"></i></span>
                                                    <span>Trazabilidad y pistas de auditoria de cada operacion</span>
                                                </li>
                                                <li>
                                                    <span class="tronox-auth-feature-icon"><i class="ri-folders-line"></i></span>
                                                    <span>Expedientes conforme a la Tabla de Retencion Documental</span>
                                                </li>
                                                <li>
                                                    <span class="tronox-auth-feature-icon"><i class="ri-shield-check-line"></i></span>
                                                    <span>Firma electronica y digital certificada</span>
                                                </li>
                                            </ul>

                                            <p class="tronox-auth-copyright mb-0">
                                                &copy; @DateTime.Now.Year TRONOX. Todos los derechos reservados.
                                            </p>
                                        </div>

                                    </div>
                                </div>
                            </div>
                            <!-- end col -->

                            @* ---------------- Panel derecho: formulario ---------------- *@
                            <div class="col-lg-6">
                                <div class="p-lg-5 p-4">
                                    <div>
                                        <h5 class="text-primary">Iniciar sesion</h5>
                                        <p class="text-muted">Ingrese sus credenciales para acceder a su entidad.</p>
                                    </div>

                                    @if (Error == 1)
                                    {
                                        <div class="alert alert-danger mt-3 mb-0" role="alert">
                                            Credenciales invalidas o cuenta sin acceso.
                                        </div>
                                    }
                                    @if (Reset == 1)
                                    {
                                        <div class="alert alert-success mt-3 mb-0" role="alert">
                                            Su contrasena se actualizo. Ya puede iniciar sesion.
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(GError))
                                    {
                                        <div class="alert alert-danger mt-3 mb-0" role="alert">@GError</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(RegError))
                                    {
                                        <div class="alert alert-danger mt-3 mb-0" role="alert">@RegError</div>
                                    }

                                    <div class="mt-4">
                                        <form method="post" action="/auth/login">

                                            <div class="mb-3">
                                                <label for="login-email" class="form-label">Usuario o correo electronico</label>
                                                <div class="position-relative">
                                                    <input type="text" class="form-control pe-5" id="login-email"
                                                           name="email" required autocomplete="username"
                                                           placeholder="usuario@entidad.gov.co" />
                                                    <span class="position-absolute end-0 top-0 d-flex align-items-center h-100 pe-3 text-muted">
                                                        <i class="ri-user-3-line"></i>
                                                    </span>
                                                </div>
                                            </div>

                                            <div class="mb-3">
                                                <div class="float-end">
                                                    <a href="/recuperar" class="text-muted">Olvide mi contrasena</a>
                                                </div>
                                                <label class="form-label" for="password-input">Contrasena</label>
                                                <div class="position-relative auth-pass-inputgroup mb-3">
                                                    <input type="password" class="form-control pe-5 password-input"
                                                           id="password-input" name="password" required
                                                           autocomplete="current-password" placeholder="Su contrasena" />
                                                    <button class="btn btn-link position-absolute end-0 top-0 text-decoration-none text-muted password-addon"
                                                            type="button" id="password-addon">
                                                        <i class="ri-eye-fill align-middle"></i>
                                                    </button>
                                                </div>
                                            </div>

                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" value="true"
                                                       id="auth-remember-check" name="remember" checked />
                                                <label class="form-check-label" for="auth-remember-check">Recordarme</label>
                                            </div>

                                            <div class="mt-4">
                                                <button class="btn btn-primary w-100" type="submit">Ingresar</button>
                                            </div>
                                        </form>

                                        <div class="mt-4 text-center">
                                            <div class="signin-other-title">
                                                <h5 class="fs-13 mb-4 title">O ingrese con</h5>
                                            </div>

                                            @* RQ05 seccion B (firma con certificado digital) es hito futuro:
                                               el boton forma parte del diseno y NO se elimina; se renderiza
                                               deshabilitado mientras el flag Features:FirmaCertificadoDigital
                                               este en false. *@
                                            <button type="button"
                                                    class="btn btn-outline-primary w-100 tronox-btn-cert"
                                                    disabled="@(!_certificadoDigitalHabilitado)"
                                                    title="@(_certificadoDigitalHabilitado ? null : "Disponible en una proxima version (RQ05)")">
                                                <i class="ri-shield-keyhole-line align-bottom me-1"></i>
                                                Ingresar con certificado digital
                                            </button>

                                            @if (_googleEnabled)
                                            {
                                                <a class="btn btn-outline-secondary w-100 mt-2" href="/connect/google">
                                                    <i class="ri-google-fill align-bottom me-1"></i>
                                                    Continuar con Google
                                                </a>
                                            }
                                        </div>
                                    </div>

                                    <div class="mt-4 text-center">
                                        <span class="tronox-tenant-chip">
                                            <span class="tronox-tenant-dot" aria-hidden="true"></span>
                                            @_tenantChip
                                        </span>
                                    </div>

                                    <div class="mt-3 text-center">
                                        <p class="mb-0 text-muted">
                                            Problemas para ingresar?
                                            <a href="/recuperar" class="fw-semibold text-primary text-decoration-underline">Contacte a soporte</a>
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <!-- end col -->

                        </div>
                        <!-- end row -->
                    </div>
                    <!-- end card -->
                </div>
            </div>
        </div>
    </div>
    <!-- end auth page content -->
</div>
<!-- end auth-page-wrapper -->

@* Equivalente a assets/js/pages/password-addon.init.js de la plantilla, que no se
   copio al repo. Usa los mismos hooks de Velzon: #password-addon sobre .password-input. *@
<script>
    (function () {
        var addon = document.getElementById('password-addon');
        var input = document.getElementById('password-input');
        if (!addon || !input) { return; }
        addon.addEventListener('click', function () {
            var show = input.type === 'password';
            input.type = show ? 'text' : 'password';
            var icon = addon.querySelector('i');
            if (icon) {
                icon.classList.toggle('ri-eye-fill', !show);
                icon.classList.toggle('ri-eye-off-fill', show);
            }
        });
    })();
</script>

@code {
    [SupplyParameterFromQuery] public int? Error { get; set; }
    [SupplyParameterFromQuery] public int? Reset { get; set; }
    [SupplyParameterFromQuery(Name = "regerror")] public string? RegError { get; set; }
    [SupplyParameterFromQuery(Name = "gerror")] public string? GError { get; set; }

    private Tronox.Application.Admin.PlatformBrandingDto _brand = Tronox.Application.Admin.PlatformBrandingDto.Default;
    private bool _googleEnabled;
    private bool _certificadoDigitalHabilitado;
    private string _tenantChip = "Alcaldia Demo - Plan Institucional";

    protected override async Task OnInitializedAsync()
    {
        _brand = await BrandingSvc.GetAsync();
        _googleEnabled = (await GoogleCfg.GetAsync())?.IsEnabled == true;
        _certificadoDigitalHabilitado = Config.GetValue<bool>("Features:FirmaCertificadoDigital");
        _tenantChip = Config["Branding:TenantChip"] ?? _tenantChip;
    }
}
