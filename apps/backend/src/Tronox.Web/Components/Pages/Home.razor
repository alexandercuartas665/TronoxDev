@page "/"
@attribute [Authorize]
@inject ITenantAdminService TenantsSvc
@inject IPlanAdminService PlansSvc
@inject NavigationManager Nav

@* RAIZ DEL SISTEMA. Antes exigia la policy PlatformOperator (claim platform_role), asi que un
   usuario de tenant que llegara a "/" no pasaba la autorizacion y Routes.razor lo mandaba al
   login: seguia autenticado, pero parecia que se le cerraba la sesion.

   Ahora "/" solo exige ESTAR AUTENTICADO y reparte por rol:
     - operador de plataforma (platform_role) -> esta consola de gobierno;
     - usuario de tenant (tenant_id)          -> /inicio, el panel de su workspace;
     - autenticado sin ninguno de los dos     -> /acceso-denegado (fail-closed: no se le inventa
       un destino ni se le concede la consola).

   El super administrador no pierde nada: sigue teniendo platform_role, asi que ve este panel. *@

<PageTitle>Dashboard - TRONOX SGDEA</PageTitle>

@if (_isPlatformOperator)
{
<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
            </div>
            <span>Super Admin SaaS</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Dashboard</h1>
        <p class="page-sub" style="margin-bottom:0;">Resumen operativo de TRONOX<span style="color:var(--primary)">.tareas</span>.</p>
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-top">
                <div class="kpi-icon tone-primary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/></svg>
                </div>
            </div>
            <div class="kpi-label">Empresas</div>
            <div class="kpi-value">@_totalTenants</div>
            <div class="kpi-hint">Tenants registrados</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-top">
                <div class="kpi-icon tone-success">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                </div>
            </div>
            <div class="kpi-label">Empresas activas</div>
            <div class="kpi-value">@_activeTenants</div>
            <div class="kpi-hint">Operando hoy</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-top">
                <div class="kpi-icon tone-gold">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
                </div>
            </div>
            <div class="kpi-label">Planes</div>
            <div class="kpi-value">@_totalPlans</div>
            <div class="kpi-hint">Oferta comercial</div>
        </div>
    </div>
}
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _isPlatformOperator;
    private int _totalTenants;
    private int _activeTenants;
    private int _totalPlans;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null)
        {
            return;
        }
        var state = await AuthState;
        _isPlatformOperator = state.User.FindFirst("platform_role") is not null;

        if (!_isPlatformOperator)
        {
            // Usuario de tenant -> su panel. Autenticado sin tenant ni rol de plataforma ->
            // acceso denegado (fail-closed): no se le abre la consola de gobierno "por si acaso".
            var destino = state.User.FindFirst("tenant_id") is not null ? "inicio" : "acceso-denegado";
            Nav.NavigateTo(destino, replace: true);
            return;
        }

        // Solo el operador de plataforma consulta el gobierno multi-tenant.
        var tenants = await TenantsSvc.ListAsync();
        var plans = await PlansSvc.ListAsync();
        _totalTenants = tenants.Count;
        _activeTenants = tenants.Count(t => t.Status == TenantStatus.Active);
        _totalPlans = plans.Count;
        _loading = false;
    }
}
