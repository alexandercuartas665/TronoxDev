@page "/admin-usuarios"
@attribute [Authorize(Policy = "Perm:admin-usuarios:View")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.IO
@using Tronox.Application.Archivistica
@using Tronox.Application.Common
@using Tronox.Application.MenuConfig
@using Tronox.Application.Organization
@using Tronox.Application.Roles
@using Tronox.Application.Tenancy
@using Tronox.Domain.Enums
@using Tronox.Web.Auth
@using Tronox.Web.Services
@inject ITenantUserService UsersSvc
@inject IOrgUnitService OrgSvc
@inject ISedeService SedesSvc
@inject IMenuConfigService MenuSvc
@inject IRolService RolesSvc
@inject ITenantContext TenantCtx
@inject ICurrentPermissions Perms
@inject IWebHostEnvironment Env

@* RQ01 - RF06 (Gestion de Usuarios / Funcionarios).

   El funcionario es el MISMO TenantUser del backbone, ampliado con sus datos personales. No hay
   un modelo paralelo de personas (invariante 2 aplicado hacia dentro: los actores EXTERNOS viven
   en terceros; los internos, aqui).

   Dos reglas que gobiernan la pantalla:
   1. El usuario se ancla a UN nodo CARGO del organigrama (ADR-003, Addendum). La DEPENDENCIA no
      se captura: se DERIVA subiendo el arbol, y se muestra como dato de solo lectura.
   2. Para quedar ACTIVO necesita dependencia + cargo + al menos un rol (criterio 2 de 5.6.3).
      El boton de activar explica que falta en vez de fallar en silencio.

   PENDIENTE P-01 (5.6.3 punto 5) - DELEGACION TEMPORAL de funciones documentales entre usuarios
   activos: NO se implementa. Esta a la espera de confirmacion del Product Owner (alcance de la
   delegacion, que pasa con lo delegado al vencer el periodo y como se audita). *@

<PageTitle>Usuarios / Funcionarios - TRONOX SGDEA</PageTitle>

<div class="tx-mod tx-usuarios">

    <nav class="tronox-breadcrumb" aria-label="Ruta de navegación">
        <a href="/inicio">Inicio</a>
        <span class="sep">/</span>
        <span>Configuración Organizacional</span>
        <span class="sep">/</span>
        <span class="cur">Usuarios / Funcionarios</span>
    </nav>

    <div class="tx-ent-head">
        <div>
            <div class="tx-ent-eyebrow"><i class="bi bi-people"></i><span>RQ01 &middot; RF06</span></div>
            <h1 class="tx-ent-title">Usuarios / Funcionarios</h1>
            <p class="tx-ent-sub">
                Registro de los funcionarios de la entidad y su vínculo con la estructura organizacional.
                El <strong>correo es el usuario de acceso</strong>; la <strong>dependencia se deriva del cargo</strong>.
            </p>
        </div>
        @if (_canCreate)
        {
            <div>
                <button type="button" class="tx-ent-btn primary" @onclick="@(() => OpenEditor(null))">
                    <i class="bi bi-person-plus"></i> Nuevo funcionario
                </button>
            </div>
        }
    </div>

    @if (_pageError is not null)
    {
        <div class="tx-ent-alert err"><i class="bi bi-exclamation-triangle-fill"></i><span>@_pageError</span></div>
    }
    @if (_pageOk is not null)
    {
        <div class="tx-ent-alert ok"><i class="bi bi-check-circle-fill"></i><span>@_pageOk</span></div>
    }

    @* ===== KPIs ===== *@
    <div class="tx-dep-kpis">
        <div class="tx-dep-kpi">
            <div class="tx-dep-kpi-icon"><i class="bi bi-people"></i></div>
            <div>
                <div class="tx-dep-kpi-val">@_usuarios.Count</div>
                <div class="tx-dep-kpi-lbl">Funcionarios</div>
            </div>
        </div>
        <div class="tx-dep-kpi">
            <div class="tx-dep-kpi-icon tone-green"><i class="bi bi-person-check"></i></div>
            <div>
                <div class="tx-dep-kpi-val">@_usuarios.Count(u => u.Status == PlatformUserStatus.Active)</div>
                <div class="tx-dep-kpi-lbl">Activos</div>
            </div>
        </div>
        <div class="tx-dep-kpi">
            <div class="tx-dep-kpi-icon tone-slate"><i class="bi bi-person-dash"></i></div>
            <div>
                <div class="tx-dep-kpi-val">@_usuarios.Count(u => u.Status != PlatformUserStatus.Active)</div>
                <div class="tx-dep-kpi-lbl">Sin acceso</div>
            </div>
        </div>
        <div class="tx-dep-kpi">
            <div class="tx-dep-kpi-icon tone-violet"><i class="bi bi-exclamation-triangle"></i></div>
            <div>
                <div class="tx-dep-kpi-val">@_usuarios.Count(u => u.MotivoNoActivable is not null)</div>
                <div class="tx-dep-kpi-lbl">Vinculación incompleta</div>
            </div>
        </div>
    </div>

    <div class="tx-ent-card">
        <div class="tx-dep-toolbar">
            <div class="tx-dep-search">
                <i class="bi bi-search"></i>
                <input class="tx-ent-input" placeholder="Buscar por nombre, documento o correo..."
                       value="@_search" @oninput="@(e => _search = e.Value?.ToString() ?? "")" />
            </div>
            <select class="tx-ent-input" style="max-width:190px" @bind="_filtroEstado">
                <option value="">Todos los estados</option>
                @foreach (var s in EstadosGestionables)
                {
                    <option value="@s">@EstadoLabel(s)</option>
                }
            </select>
        </div>

        @if (_loading)
        {
            <div class="tx-ent-card-body"><em>Cargando funcionarios...</em></div>
        }
        else if (Filtrados().Count == 0)
        {
            <div class="tx-ent-card-body">
                <div class="tx-ent-empty">
                    <i class="bi bi-people"></i>
                    <div>
                        @if (_usuarios.Count == 0)
                        {
                            <span><strong>Todavía no hay funcionarios</strong><br />Registra el primero para habilitar el acceso a la entidad.</span>
                        }
                        else
                        {
                            <span>Ningún funcionario coincide con el filtro.</span>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="tx-ent-table-wrap">
                <table class="tx-ent-table">
                    <thead>
                        <tr>
                            <th>Funcionario</th>
                            <th>Documento</th>
                            <th>Cargo</th>
                            <th>Dependencia</th>
                            <th>Roles</th>
                            <th>Estado</th>
                            <th class="right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Filtrados())
                        {
                            <tr>
                                <td>
                                    <strong>@u.NombreCompleto</strong>
                                    <div class="muted">@u.Email</div>
                                </td>
                                <td class="mono">@(u.NumeroDocumento is null ? "--" : $"{u.TipoDocumento} {u.NumeroDocumento}")</td>
                                <td>
                                    @(u.CargoNombre ?? "--")
                                    @if (u.SedeNombre is string sede)
                                    {
                                        <div class="muted">@sede</div>
                                    }
                                </td>
                                <td>
                                    @if (u.DependenciaNombre is string dep)
                                    {
                                        @dep
                                        <div class="muted" title="La dependencia no se captura: se deriva del cargo (ADR-003).">derivada del cargo</div>
                                    }
                                    else
                                    {
                                        <span class="muted">Sin área documental</span>
                                    }
                                </td>
                                <td>
                                    @if (u.Roles.Count == 0)
                                    {
                                        <span class="muted">Sin rol</span>
                                    }
                                    else
                                    {
                                        @foreach (var r in u.Roles)
                                        {
                                            <span class="tx-ent-badge sm info" style="margin-right:4px">@r.RolNombre</span>
                                        }
                                    }
                                </td>
                                <td>
                                    <span class="tx-ent-badge sm @EstadoClase(u.Status)">@EstadoLabel(u.Status)</span>
                                    @if (u.MotivoNoActivable is string motivo)
                                    {
                                        <div class="muted" title="@motivo">vinculación incompleta</div>
                                    }
                                </td>
                                <td class="right">
                                    @if (_canEdit)
                                    {
                                        <button type="button" class="tx-ent-btn sm" @onclick="@(() => OpenEditor(u))">Editar</button>
                                        <button type="button" class="tx-ent-btn sm" @onclick="@(() => OpenPassword(u))">Clave</button>
                                    }
                                    @if (_canDelete)
                                    {
                                        @if (u.Status == PlatformUserStatus.Active)
                                        {
                                            <button type="button" class="tx-ent-btn sm danger" disabled="@_busy"
                                                    @onclick="@(() => CambiarEstadoAsync(u, PlatformUserStatus.Inactive))">
                                                Inactivar
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="tx-ent-btn sm" disabled="@(_busy || u.MotivoNoActivable is not null)"
                                                    title="@(u.MotivoNoActivable ?? "Activar el funcionario")"
                                                    @onclick="@(() => CambiarEstadoAsync(u, PlatformUserStatus.Active))">
                                                Activar
                                            </button>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="tx-ent-hint">
        <i class="bi bi-info-circle"></i>
        Inactivar a un funcionario le quita el acceso pero <strong>conserva intactos</strong> sus documentos,
        expedientes y pistas de auditoría (criterio 4 de RF06): nunca hay eliminación real.
        La <strong>delegación temporal</strong> de funciones (5.6.3 punto 5) está pendiente de definición
        del Product Owner (P-01) y todavía no se implementa.
    </div>

    @* ===== Modal crear/editar funcionario ===== *@
    @if (_showEditor)
    {
        <div class="modal-overlay" @onclick="@(() => _showEditor = false)">
            <div class="modal-dialog" style="max-width:760px" @onclick:stopPropagation="true">
                <div class="modal-head">
                    <h3>@(_editing is null ? "Nuevo funcionario" : $"Editar {_editing.NombreCompleto}")</h3>
                    <button class="modal-close" @onclick="@(() => _showEditor = false)">&times;</button>
                </div>
                <div class="modal-body tx-mod tx-usuarios">

                    @* ---- Datos personales (5.6.1) ---- *@
                    <div class="tx-ent-card-head" style="padding:0 0 10px 0;border-bottom:none">
                        <div class="tx-ent-card-icon"><i class="bi bi-person-vcard"></i></div>
                        <div>
                            <div class="tx-ent-card-title">Datos personales</div>
                            <div class="tx-ent-card-sub">El correo es el usuario de acceso y es único en la entidad.</div>
                        </div>
                    </div>

                    <div class="tx-ent-grid c2">
                        <div class="tx-ent-field">
                            <label>Tipo de documento <span class="req">*</span></label>
                            <select class="tx-ent-input" @bind="_fTipoDocumento">
                                @foreach (var t in Enum.GetValues<TipoDocumento>())
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>
                        <div class="tx-ent-field">
                            <label>Número de documento <span class="req">*</span></label>
                            <input class="tx-ent-input mono" @bind="_fNumeroDocumento" maxlength="20" />
                        </div>
                    </div>

                    <div class="tx-ent-grid c2">
                        <div class="tx-ent-field">
                            <label>Nombres <span class="req">*</span></label>
                            <input class="tx-ent-input" @bind="_fNombres" maxlength="100" />
                        </div>
                        <div class="tx-ent-field">
                            <label>Apellidos <span class="req">*</span></label>
                            <input class="tx-ent-input" @bind="_fApellidos" maxlength="100" />
                        </div>
                    </div>

                    <div class="tx-ent-grid c2">
                        <div class="tx-ent-field">
                            <label>Correo electrónico <span class="req">*</span></label>
                            <input class="tx-ent-input" type="email" @bind="_fCorreo" maxlength="150"
                                   placeholder="funcionario@entidad.gov.co" />
                            <div class="tx-ent-hint">Es el identificador de acceso (login).</div>
                        </div>
                        <div class="tx-ent-field">
                            <label>Teléfono <span class="opt">(opcional)</span></label>
                            <input class="tx-ent-input" @bind="_fTelefono" maxlength="20" />
                        </div>
                    </div>

                    <div class="tx-ent-sep"></div>

                    @* ---- Datos organizacionales ---- *@
                    <div class="tx-ent-card-head" style="padding:0 0 10px 0;border-bottom:none">
                        <div class="tx-ent-card-icon tone-violet"><i class="bi bi-diagram-3"></i></div>
                        <div>
                            <div class="tx-ent-card-title">Vinculación organizacional</div>
                            <div class="tx-ent-card-sub">Cargo del catálogo (RF04) + roles de permisos (RF05).</div>
                        </div>
                    </div>

                    <div class="tx-ent-grid c2">
                        <div class="tx-ent-field">
                            <label>Cargo <span class="req">*</span></label>
                            <select class="tx-ent-input" @bind="_fCargoId" @bind:after="OnCargoChanged">
                                <option value="">-- Seleccione un cargo --</option>
                                @foreach (var c in _cargos)
                                {
                                    <option value="@c.Id">@(c.CodigoCargo is null ? c.Name : $"{c.CodigoCargo} - {c.Name}")</option>
                                }
                            </select>
                            <div class="tx-ent-hint">Catálogo global (RF04). El cargo es metadato: no otorga permisos.</div>
                        </div>
                        <div class="tx-ent-field">
                            <label>Dependencia <span class="opt">(derivada, no se edita)</span></label>
                            <input class="tx-ent-input" value="@(_dependenciaDerivada ?? "-- sin área documental --")" readonly disabled />
                            <div class="tx-ent-hint">
                                Se resuelve subiendo por el cargo hasta la primera dependencia (ADR-003).
                                Sin dependencia el funcionario no puede activarse.
                            </div>
                        </div>
                    </div>

                    <div class="tx-ent-grid c2">
                        <div class="tx-ent-field">
                            <label>Sede <span class="opt">(opcional)</span></label>
                            <select class="tx-ent-input" @bind="_fSedeId">
                                <option value="">(Sin sede)</option>
                                @foreach (var s in _sedes)
                                {
                                    <option value="@s.Id">@s.NombreSede</option>
                                }
                            </select>
                        </div>
                        <div class="tx-ent-field">
                            <label>Fecha de vinculación <span class="opt">(opcional)</span></label>
                            <input type="date" class="tx-ent-input" @bind="_fFechaVinculacion" />
                        </div>
                    </div>

                    <div class="tx-ent-field">
                        <label>Roles de permisos <span class="req">*</span></label>
                        <div class="tx-usr-roles">
                            @if (_roles.Count == 0)
                            {
                                <span class="tx-ent-hint" style="margin:0">
                                    No hay roles definidos todavía. Créalos en Roles y permisos (RF05).
                                </span>
                            }
                            @foreach (var r in _roles)
                            {
                                <label class="tx-usr-role">
                                    <input type="checkbox" checked="@_fRolIds.Contains(r.Id)"
                                           @onchange="@(e => ToggleRol(r.Id, (bool)e.Value!))" />
                                    <span>@r.Name</span>
                                </label>
                            }
                        </div>
                        <div class="tx-ent-hint">
                            Un usuario puede tener varios roles: sus permisos son la unión de todos.
                            Sin ningún rol vigente queda <strong>sin permisos</strong> (fail-closed), nunca con acceso total.
                        </div>
                    </div>

                    <div class="tx-ent-grid c2">
                        <div class="tx-ent-field">
                            <label>Rol orgánico</label>
                            <select class="tx-ent-input" @bind="_fTenantRole">
                                @foreach (var r in AllTenantRoles)
                                {
                                    <option value="@r">@TenantRoleLabel(r)</option>
                                }
                            </select>
                            <div class="tx-ent-hint">Poder orgánico dentro del tenant. No concede permisos de módulo.</div>
                        </div>
                        <div class="tx-ent-field">
                            <label>Vista de menú <span class="opt">(opcional)</span></label>
                            <select class="tx-ent-input" @bind="_fViewId">
                                <option value="">Predeterminada</option>
                                @foreach (var v in _views)
                                {
                                    <option value="@v.Id">@v.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    @if (_editing is null)
                    {
                        <div class="tx-ent-field">
                            <label>Contraseña inicial <span class="opt">(opcional)</span></label>
                            <input class="tx-ent-input" type="password" @bind="_fPassword" autocomplete="new-password"
                                   placeholder="Dejar vacío para invitar por correo" />
                            <div class="tx-ent-hint">
                                El funcionario nace <strong>Invitado</strong>: se activa desde el listado, y solo cuando
                                tiene dependencia, cargo y al menos un rol.
                            </div>
                        </div>
                    }

                    @if (_editing is not null)
                    {
                        <div class="tx-ent-sep"></div>

                        @* ---- Firma manuscrita ---- *@
                        <div class="tx-ent-card-head" style="padding:0 0 10px 0;border-bottom:none">
                            <div class="tx-ent-card-icon tone-amber"><i class="bi bi-pen"></i></div>
                            <div>
                                <div class="tx-ent-card-title">Imagen de firma</div>
                                <div class="tx-ent-card-sub">Firma manuscrita escaneada. Se guarda la ruta, nunca el archivo en la base de datos.</div>
                            </div>
                        </div>
                        <div class="tx-usr-firma">
                            <div class="tx-usr-firma-box">
                                @if (!string.IsNullOrWhiteSpace(_fFirmaPath))
                                {
                                    <img src="@_fFirmaPath" alt="Firma" />
                                }
                                else
                                {
                                    <i class="bi bi-pen"></i>
                                    <span>Sin firma</span>
                                }
                            </div>
                            <div>
                                <label class="tx-ent-btn sm" style="position:relative;overflow:hidden">
                                    <i class="bi bi-upload"></i> Subir imagen
                                    <InputFile OnChange="OnFirmaSelected" accept="@ImageUploadGuard.Accept"
                                               style="position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%" />
                                </label>
                                @if (!string.IsNullOrWhiteSpace(_fFirmaPath))
                                {
                                    <button type="button" class="tx-ent-btn sm danger" @onclick="@(() => _fFirmaPath = null)">Quitar</button>
                                }
                                <div class="tx-ent-hint">@ImageUploadGuard.FormatosTexto &middot; Máx. 2 MB &middot; fondo transparente o blanco.</div>
                                @if (_firmaError is not null)
                                {
                                    <div class="tx-ent-fielderr">@_firmaError</div>
                                }
                            </div>
                        </div>
                    }

                    @if (_editorError is not null)
                    {
                        <div class="tx-ent-fielderr">@_editorError</div>
                    }
                </div>
                <div class="modal-foot">
                    <button class="tx-ent-btn" @onclick="@(() => _showEditor = false)" disabled="@_busy">Cancelar</button>
                    <button class="tx-ent-btn primary" @onclick="SaveAsync" disabled="@_busy">
                        @(_editing is null ? "Crear funcionario" : "Guardar")
                    </button>
                </div>
            </div>
        </div>
    }

    @* ===== Modal cambiar clave ===== *@
    @if (_passwordTarget is not null)
    {
        <div class="modal-overlay" @onclick="ClosePassword">
            <div class="modal-dialog" style="max-width:480px" @onclick:stopPropagation="true">
                <div class="modal-head">
                    <h3>Cambiar clave</h3>
                    <button class="modal-close" @onclick="ClosePassword">&times;</button>
                </div>
                <div class="modal-body tx-mod tx-usuarios">
                    <p class="tx-ent-sub">Asigna una nueva clave a <strong>@_passwordTarget.Email</strong>.</p>
                    <div class="tx-ent-field">
                        <label>Nueva clave <span class="req">*</span></label>
                        <input class="tx-ent-input" type="password" @bind="_fPassword" autocomplete="new-password" placeholder="Mínimo 6 caracteres" />
                    </div>
                    <div class="tx-ent-field">
                        <label>Confirmar clave <span class="req">*</span></label>
                        <input class="tx-ent-input" type="password" @bind="_fPasswordConfirm" autocomplete="new-password" />
                    </div>
                    @if (_editorError is not null)
                    {
                        <div class="tx-ent-fielderr">@_editorError</div>
                    }
                </div>
                <div class="modal-foot">
                    <button class="tx-ent-btn" @onclick="ClosePassword" disabled="@_busy">Cancelar</button>
                    <button class="tx-ent-btn primary" @onclick="ResetPasswordAsync" disabled="@_busy">Cambiar clave</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private const string ModuleKey = "admin-usuarios";
    private const long MaxFirmaBytes = 2 * 1024 * 1024;

    private static readonly TenantRole[] AllTenantRoles =
        [TenantRole.Owner, TenantRole.Admin, TenantRole.Supervisor, TenantRole.Advisor];

    /// <summary>
    /// Estados que un administrador GESTIONA (5.6.2). Blocked lo pone el SISTEMA tras intentos
    /// fallidos y PendingActivation el auto-registro: no se ofrecen como opcion manual, pero si
    /// se muestran si un usuario ya esta en ellos.
    /// </summary>
    private static readonly PlatformUserStatus[] EstadosGestionables =
        [PlatformUserStatus.Active, PlatformUserStatus.Inactive, PlatformUserStatus.Suspended,
         PlatformUserStatus.Blocked, PlatformUserStatus.Invited];

    private bool _loading = true;
    private bool _busy;
    private string _search = "";
    private string _filtroEstado = "";
    private string? _pageError;
    private string? _pageOk;

    // Gateo por permiso. FAIL-CLOSED (invariante 10): se parte de NEGADO.
    private bool _canCreate;
    private bool _canEdit;
    private bool _canDelete;

    private IReadOnlyList<FuncionarioDto> _usuarios = [];
    private IReadOnlyList<OrgUnitDto> _cargos = [];
    private IReadOnlyList<SedeDto> _sedes = [];
    private IReadOnlyList<RolDto> _roles = [];
    private IReadOnlyList<MenuViewDto> _views = [];

    // ---- Editor ----
    private bool _showEditor;
    private FuncionarioDto? _editing;
    private TipoDocumento _fTipoDocumento = TipoDocumento.CC;
    private string? _fNumeroDocumento;
    private string? _fNombres;
    private string? _fApellidos;
    private string _fCorreo = "";
    private string? _fTelefono;
    private string _fCargoId = "";
    private string _fSedeId = "";
    private DateOnly? _fFechaVinculacion;
    private TenantRole _fTenantRole = TenantRole.Advisor;
    private string _fViewId = "";
    private readonly HashSet<long> _fRolIds = [];
    private string? _fFirmaPath;
    private string? _dependenciaDerivada;
    private string? _editorError;
    private string? _firmaError;

    // ---- Clave ----
    private FuncionarioDto? _passwordTarget;
    private string _fPassword = "";
    private string _fPasswordConfirm = "";

    protected override async Task OnInitializedAsync()
    {
        var eff = await Perms.GetAsync();
        _canCreate = eff.Can(ModuleKey, PermissionAction.Create);
        _canEdit = eff.Can(ModuleKey, PermissionAction.Edit);
        _canDelete = eff.Can(ModuleKey, PermissionAction.Delete);

        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        _usuarios = await UsersSvc.ListFuncionariosAsync();
        // Solo cargos ACTIVOS: un cargo inactivo salio del catalogo y no debe poder asignarse.
        _cargos = (await OrgSvc.ListAsync(includeArchived: false))
            .Where(u => u.Classifier == OrgUnitClassifier.Cargo)
            .OrderBy(u => u.Name)
            .ToList();
        _sedes = await SedesSvc.ListAsync(soloActivas: true);
        _roles = await RolesSvc.ListAsync();
        _views = await MenuSvc.ListViewsAsync();
    }

    private IReadOnlyList<FuncionarioDto> Filtrados()
    {
        var q = _search.Trim();
        return _usuarios
            .Where(u => q.Length == 0
                        || u.NombreCompleto.Contains(q, StringComparison.OrdinalIgnoreCase)
                        || u.Email.Contains(q, StringComparison.OrdinalIgnoreCase)
                        || (u.NumeroDocumento ?? "").Contains(q, StringComparison.OrdinalIgnoreCase))
            .Where(u => _filtroEstado.Length == 0 || u.Status.ToString() == _filtroEstado)
            .ToList();
    }

    // ---- Editor ----

    private void OpenEditor(FuncionarioDto? u)
    {
        _editing = u;
        _fTipoDocumento = u?.TipoDocumento ?? TipoDocumento.CC;
        _fNumeroDocumento = u?.NumeroDocumento;
        _fNombres = u?.Nombres;
        _fApellidos = u?.Apellidos;
        _fCorreo = u?.Email ?? "";
        _fTelefono = u?.Telefono;
        _fCargoId = u?.CargoOrgUnitId?.ToString() ?? "";
        _fSedeId = u?.SedeId?.ToString() ?? "";
        _fFechaVinculacion = u?.FechaVinculacion;
        _fTenantRole = u?.TenantRole ?? TenantRole.Advisor;
        _fViewId = u?.MenuViewId?.ToString() ?? "";
        _fFirmaPath = u?.FirmaImagenPath;
        _fRolIds.Clear();
        foreach (var r in u?.Roles ?? [])
        {
            _fRolIds.Add(r.RolId);
        }
        _fPassword = "";
        _dependenciaDerivada = u?.DependenciaNombre;
        _editorError = null;
        _firmaError = null;
        _pageOk = null;
        _pageError = null;
        _showEditor = true;
    }

    private void ToggleRol(long rolId, bool marcado)
    {
        if (marcado) { _fRolIds.Add(rolId); } else { _fRolIds.Remove(rolId); }
    }

    /// <summary>
    /// Al cambiar de cargo se recalcula la dependencia DERIVADA para mostrarla al instante: es el
    /// dato que decide el area documental del funcionario y no se captura a mano (ADR-003).
    /// </summary>
    private async Task OnCargoChanged()
    {
        if (!long.TryParse(_fCargoId, out var cargoId))
        {
            _dependenciaDerivada = null;
            return;
        }
        var dependenciaId = await OrgSvc.ResolveDependenciaAsync(cargoId);
        _dependenciaDerivada = dependenciaId is long id ? (await OrgSvc.GetAsync(id))?.Name : null;
    }

    private async Task SaveAsync()
    {
        _busy = true;
        _editorError = null;
        try
        {
            var request = new SaveFuncionarioRequest(
                _editing?.Id,
                _fTipoDocumento,
                _fNumeroDocumento,
                _fNombres,
                _fApellidos,
                _fCorreo,
                _fTelefono,
                CargoOrgUnitId: long.TryParse(_fCargoId, out var cargoId) ? cargoId : null,
                SedeId: long.TryParse(_fSedeId, out var sedeId) ? sedeId : null,
                FechaVinculacion: _fFechaVinculacion,
                TenantRole: _fTenantRole,
                Password: string.IsNullOrWhiteSpace(_fPassword) ? null : _fPassword);

            var actor = TenantCtx.UserId ?? 0;
            var result = await UsersSvc.SaveFuncionarioAsync(request, actor);
            if (!result.IsOk)
            {
                _editorError = result.Error;
                return;
            }

            var guardado = result.Value!;

            // Los roles se asignan por su propio servicio: es el unico camino que deja la
            // asignacion en la pista de auditoria (criterio 6 de 5.6.3).
            var rolesActuales = guardado.Roles.Select(r => r.RolId).ToHashSet();
            if (!rolesActuales.SetEquals(_fRolIds))
            {
                var asignaciones = _fRolIds.Select(id => new RolAsignacionDto(id, null, null, null)).ToList();
                var rolesResult = await RolesSvc.SetUserRolesAsync(guardado.Id, asignaciones, actor);
                if (!rolesResult.IsOk)
                {
                    _editorError = rolesResult.Error;
                    return;
                }
            }

            await MenuSvc.AssignUserToViewAsync(guardado.Id, long.TryParse(_fViewId, out var vid) ? vid : null);

            if (_editing is not null && _fFirmaPath != _editing.FirmaImagenPath)
            {
                await UsersSvc.SetFirmaImagenAsync(guardado.Id, _fFirmaPath, actor);
            }

            _showEditor = false;
            _pageOk = _editing is null
                ? "Funcionario creado. Queda Invitado: actívalo cuando tenga dependencia, cargo y rol."
                : "Cambios guardados.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _editorError = $"No se pudo guardar: {ex.Message}";
        }
        finally { _busy = false; }
    }

    // ---- Estado ----

    private async Task CambiarEstadoAsync(FuncionarioDto u, PlatformUserStatus estado)
    {
        _busy = true;
        _pageError = null;
        _pageOk = null;
        try
        {
            var motivo = estado == PlatformUserStatus.Active
                ? "Activacion desde la gestion de usuarios (RF06)"
                : "Inactivacion desde la gestion de usuarios (RF06)";
            var result = await UsersSvc.SetFuncionarioEstadoAsync(u.Id, estado, motivo, TenantCtx.UserId ?? 0);
            if (!result.IsOk)
            {
                _pageError = result.Error;
                return;
            }
            _pageOk = estado == PlatformUserStatus.Active ? "Funcionario activado." : "Funcionario inactivado.";
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    // ---- Firma ----

    private async Task OnFirmaSelected(InputFileChangeEventArgs e)
    {
        _firmaError = null;
        var file = e.File;
        if (file is null) { return; }
        if (file.Size > MaxFirmaBytes)
        {
            _firmaError = "La imagen de firma no puede superar 2 MB.";
            return;
        }

        var ext = ImageUploadGuard.ResolveExtension(file.Name);
        if (ext is null)
        {
            _firmaError = $"Formato no permitido. Se aceptan {ImageUploadGuard.FormatosTexto}.";
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(MaxFirmaBytes);
            using var buffer = new MemoryStream();
            await stream.CopyToAsync(buffer);
            var bytes = buffer.ToArray();

            // La extension y el content-type los pone el CLIENTE: lo que decide son los BYTES.
            if (!ImageUploadGuard.MatchesSignature(bytes, ext))
            {
                _firmaError = "El archivo no es una imagen valida.";
                return;
            }

            var carpeta = Path.Combine(Env.WebRootPath, "uploads");
            Directory.CreateDirectory(carpeta);
            var nombre = ImageUploadGuard.BuildStoredFileName("firma", ext);
            await File.WriteAllBytesAsync(Path.Combine(carpeta, nombre), bytes);
            // Solo la RUTA: los bytes JAMAS van a la base de datos (invariante 9).
            _fFirmaPath = $"/uploads/{nombre}";
        }
        catch (Exception ex)
        {
            _firmaError = $"No se pudo cargar la firma: {ex.Message}";
        }
    }

    // ---- Clave ----

    private void OpenPassword(FuncionarioDto u)
    {
        _passwordTarget = u;
        _fPassword = "";
        _fPasswordConfirm = "";
        _editorError = null;
    }

    private void ClosePassword()
    {
        _passwordTarget = null;
        _editorError = null;
    }

    private async Task ResetPasswordAsync()
    {
        if (_passwordTarget is null) { return; }
        if (string.IsNullOrWhiteSpace(_fPassword) || _fPassword.Length < 6)
        {
            _editorError = "La clave debe tener al menos 6 caracteres.";
            return;
        }
        if (_fPassword != _fPasswordConfirm)
        {
            _editorError = "Las claves no coinciden.";
            return;
        }
        _busy = true;
        try
        {
            var updated = await UsersSvc.ResetPasswordAsync(_passwordTarget.Id, _fPassword, TenantCtx.UserId ?? 0);
            if (updated is null)
            {
                _editorError = "No se pudo cambiar la clave.";
                return;
            }
            _passwordTarget = null;
            _pageOk = "Clave actualizada.";
            await LoadAsync();
        }
        catch (ArgumentException ex)
        {
            _editorError = ex.Message;
        }
        finally { _busy = false; }
    }

