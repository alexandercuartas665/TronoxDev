    private static string EstadoLabel(PlatformUserStatus estado) => estado switch
    {
        PlatformUserStatus.Active => "Activo",
        PlatformUserStatus.Inactive => "Inactivo",
        PlatformUserStatus.Invited => "Invitado",
        PlatformUserStatus.Blocked => "Bloqueado",
        PlatformUserStatus.Suspended => "Suspendido",
        PlatformUserStatus.PendingActivation => "Pendiente",
        _ => estado.ToString(),
    };

    private static string EstadoClase(PlatformUserStatus estado) => estado switch
    {
        PlatformUserStatus.Active => "ok",
        PlatformUserStatus.Blocked => "warn",
        PlatformUserStatus.Suspended => "warn",
        PlatformUserStatus.Invited => "info",
        _ => "off",
    };

    private static string TenantRoleLabel(TenantRole role) => role switch
    {
        TenantRole.Owner => "Propietario",
        TenantRole.Admin => "Administrador",
        TenantRole.Supervisor => "Supervisor",
        TenantRole.Advisor => "Funcionario",
        _ => role.ToString(),
    };
