@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    // Tema activo renderizado POR EL SERVIDOR desde la cookie 'tronox_theme'. Es lo que hace
    // que la navegacion mejorada de Blazor NO pierda el tema ni haya parpadeo: cada respuesta
    // (carga completa o navegacion) ya trae el atributo correcto en <html>, asi que el morph
    // del DOM nunca lo quita. La cookie la escribe js/tronox-theme.js al elegir un tema.
    // Fallback: si no hay cookie, classic-light (azul corporativo), igual que el snippet del head.
    var temasValidos = new[] { "classic-light", "fresh-light", "deep-dark", "aurora-dark", "metronic" };
    var temaCookie = HttpContextAccessor.HttpContext?.Request.Cookies["tronox_theme"];
    var temaId = temasValidos.Contains(temaCookie) ? temaCookie! : "classic-light";
    // 'metronic' es el :root base de custom.css: se activa QUITANDO el atributo (queda null).
    string? temaAttr = temaId == "metronic" ? null : temaId;
    string? bsThemeAttr = (temaId == "deep-dark" || temaId == "aurora-dark") ? "dark" : null;
}
<!DOCTYPE html>
@* Los data-* de Velzon controlan el layout (PLAN DE ARRANQUE seccion 3, regla 3): el
   comportamiento lo maneja velzon/js/layout.js, no se reescribe markup para cambiarlo. *@
<html lang="es"
      data-layout="vertical"
      data-topbar="light"
      data-sidebar="light"
      data-sidebar-size="lg"
      data-sidebar-image="none"
      data-preloader="disable"
      data-tronox-theme="@temaAttr"
      data-bs-theme="@bsThemeAttr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        // Paleta de la plataforma: el mismo mecanismo del prototipo (atributo
        // data-tronox-theme en <html>, data-bs-theme para los oscuros, clave
        // localStorage 'tronox_theme'). Corre ANTES de las hojas para que la primera
        // pintura ya salga con el tema elegido y no haya destello.
        // Por defecto: classic-light (azul corporativo #0c478a), NO metronic.
        // El panel de seleccion lo construye js/tronox-theme.js al final del body.
        (function () {
            var IDS = ['classic-light', 'fresh-light', 'deep-dark', 'aurora-dark', 'metronic'];
            var DARK = { 'deep-dark': 1, 'aurora-dark': 1 };
            // FUENTE DE VERDAD: la cookie 'tronox_theme' (la misma que lee App.razor en el
            // servidor). Asi cliente y servidor SIEMPRE coinciden y la navegacion mejorada no
            // pierde el tema ni parpadea. localStorage es solo para MIGRAR una eleccion vieja
            // (sesiones antes de la cookie) y sembrar la cookie una vez.
            function ck(n) { var m = document.cookie.match('(?:^|; )' + n + '=([^;]*)'); return m ? m[1] : null; }
            var id = 'classic-light';
            var cookieId = ck('tronox_theme');
            if (IDS.indexOf(cookieId) >= 0) {
                id = cookieId;
            } else {
                try {
                    var v = localStorage.getItem('tronox_theme');
                    if (IDS.indexOf(v) >= 0) {
                        id = v;
                        // Migrar la eleccion vieja a la cookie para que el servidor la vea desde ya.
                        document.cookie = 'tronox_theme=' + v + ';path=/;max-age=31536000;samesite=lax';
                    }
                } catch (e) { /* sin storage: tema por defecto */ }
            }
            // 'metronic' es el :root base de custom.css: se activa quitando el atributo.
            if (id !== 'metronic') { document.documentElement.setAttribute('data-tronox-theme', id); }
            if (DARK[id]) { document.documentElement.setAttribute('data-bs-theme', 'dark'); }
            // Colapso del sidebar del workspace (boton panel del topbar, prototipo):
            // clase en <html> restaurada antes del primer render + persistencia.
            try {
                if (localStorage.getItem('tronox-sidebar') === 'collapsed') {
                    document.documentElement.classList.add('sidebar-collapsed');
                }
            } catch (e) { /* sin storage: sidebar visible */ }
            window.tronoxSidebar = {
                toggle: function () {
                    var c = document.documentElement.classList.toggle('sidebar-collapsed');
                    try { localStorage.setItem('tronox-sidebar', c ? 'collapsed' : 'open'); } catch (e) { }
                }
            };
        })();
    </script>
    @* Config de layout de Velzon: va ANTES de las hojas, como en la plantilla. *@
    <script src="@Assets["velzon/js/layout.js"]"></script>

    @* --- Plantilla Velzon minimal, en el orden de la plantilla y SIN modificar --- *@
    <link rel="stylesheet" href="@Assets["velzon/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["velzon/css/icons.min.css"]" />
    <link rel="stylesheet" href="@Assets["velzon/css/app.min.css"]" />

    @* Bootstrap Icons (MIT, v1.11.3), la misma familia que el prototipo TRONOX y la que
       ADR-001 fija como clave de icono del menu ("bi-*"). Velzon minimal trae remixicon,
       boxicons, materialdesign y lineawesome, pero NO Bootstrap Icons: por eso se vendoriza
       aparte en wwwroot/vendor en lugar de tocar icons.min.css de la plantilla. *@
    <link rel="stylesheet" href="@Assets["vendor/bootstrap-icons/bootstrap-icons.min.css"]" />

    @* Hoja heredada del backbone: sigue vistiendo las pantallas que aun no se han
       migrado a Velzon. Se carga despues de app.min.css para no alterarlas. *@
    <link rel="stylesheet" href="@Assets["app.css"]" />

    @* Punto de extension de la plantilla. custom.min.css viene vacio; TODA la
       personalizacion de marca TRONOX vive en custom.css (regla 2 del PLAN). *@
    <link rel="stylesheet" href="@Assets["velzon/css/custom.min.css"]" />
    <link rel="stylesheet" href="@Assets["velzon/css/custom.css"]" />

    <link rel="stylesheet" href="@Assets["Tronox.Web.styles.css"]" />
    <ImportMap />
    @* Marca del cliente (logos oficiales del prototipo en wwwroot/marca), no la de la
       plantilla comercial. Sustituye al favicon heredado del backbone. *@
    <link rel="icon" type="image/png" href="marca/tronox-icon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>

    @* JS de la plantilla Velzon (mismo set que sus paginas de autenticacion). *@
    <script src="@Assets["velzon/libs/bootstrap/js/bootstrap.bundle.min.js"]"></script>
    <script src="@Assets["velzon/libs/simplebar/simplebar.min.js"]"></script>
    <script src="@Assets["velzon/libs/node-waves/waves.min.js"]"></script>
    <script src="@Assets["velzon/libs/feather-icons/feather.min.js"]"></script>
    <script src="@Assets["velzon/js/plugins.js"]"></script>

    <script src="js/wompi.js?v=3"></script>
    <script src="js/pipeline-dnd.js?v=3"></script>
    <script src="js/agent-editor.js?v=3"></script>
    <script src="js/task-timer.js?v=1"></script>
    <script src="js/menu-config.js?v=1"></script>
    <script src="js/dc-canvas.js?v=2"></script>
    <script src="js/form-capture.js?v=1"></script>
    @* Panel de Control (/inicio): KPIs y graficas Chart.js con datos de demostracion.
       Carga Chart.js vendorizado bajo demanda; se re-inicia en cada navegacion mejorada. *@
    <script src="js/inicio-dashboard.js?v=1"></script>
    @* Selector de las 5 paletas TRONOX (boton flotante + panel), portado del prototipo. *@
    <script src="js/tronox-theme.js?v=1"></script>
</body>

</html>
