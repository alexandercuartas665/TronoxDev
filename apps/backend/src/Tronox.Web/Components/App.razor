<!DOCTYPE html>
@* Los data-* de Velzon controlan el layout (PLAN DE ARRANQUE seccion 3, regla 3): el
   comportamiento lo maneja velzon/js/layout.js, no se reescribe markup para cambiarlo. *@
<html lang="es"
      data-layout="vertical"
      data-topbar="light"
      data-sidebar="light"
      data-sidebar-size="lg"
      data-sidebar-image="none"
      data-preloader="disable">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        // Modo oscuro por clase en <html> con persistencia en localStorage. Corre antes
        // del CSS para evitar el destello claro. window.tronoxTheme.toggle() lo conmuta
        // (boton luna del sidebar); funciona igual en SSR y en paginas interactivas.
        (function () {
            try {
                if (localStorage.getItem('tronox-theme') === 'dark') {
                    document.documentElement.classList.add('dark');
                }
            } catch (e) { /* sin storage: modo claro */ }
            window.tronoxTheme = {
                toggle: function () {
                    var dark = document.documentElement.classList.toggle('dark');
                    try { localStorage.setItem('tronox-theme', dark ? 'dark' : 'light'); } catch (e) { }
                }
            };
            // Colapso del sidebar del workspace (boton panel del topbar, prototipo):
            // clase en <html> restaurada antes del primer render + persistencia.
            try {
                if (localStorage.getItem('tronox-sidebar') === 'collapsed') {
                    document.documentElement.classList.add('sidebar-collapsed');
                }
            } catch (e) { /* sin storage: sidebar visible */ }
            window.tronoxSidebar = {
                toggle: function () {
                    var c = document.documentElement.classList.toggle('sidebar-collapsed');
                    try { localStorage.setItem('tronox-sidebar', c ? 'collapsed' : 'open'); } catch (e) { }
                }
            };
        })();
    </script>
    @* Config de layout de Velzon: va ANTES de las hojas, como en la plantilla. *@
    <script src="@Assets["velzon/js/layout.js"]"></script>

    @* --- Plantilla Velzon minimal, en el orden de la plantilla y SIN modificar --- *@
    <link rel="stylesheet" href="@Assets["velzon/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["velzon/css/icons.min.css"]" />
    <link rel="stylesheet" href="@Assets["velzon/css/app.min.css"]" />

    @* Hoja heredada del backbone: sigue vistiendo las pantallas que aun no se han
       migrado a Velzon. Se carga despues de app.min.css para no alterarlas. *@
    <link rel="stylesheet" href="@Assets["app.css"]" />

    @* Punto de extension de la plantilla. custom.min.css viene vacio; TODA la
       personalizacion de marca TRONOX vive en custom.css (regla 2 del PLAN). *@
    <link rel="stylesheet" href="@Assets["velzon/css/custom.min.css"]" />
    <link rel="stylesheet" href="@Assets["velzon/css/custom.css"]" />

    <link rel="stylesheet" href="@Assets["Tronox.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>

    @* JS de la plantilla Velzon (mismo set que sus paginas de autenticacion). *@
    <script src="@Assets["velzon/libs/bootstrap/js/bootstrap.bundle.min.js"]"></script>
    <script src="@Assets["velzon/libs/simplebar/simplebar.min.js"]"></script>
    <script src="@Assets["velzon/libs/node-waves/waves.min.js"]"></script>
    <script src="@Assets["velzon/libs/feather-icons/feather.min.js"]"></script>
    <script src="@Assets["velzon/js/plugins.js"]"></script>

    <script src="js/wompi.js?v=3"></script>
    <script src="js/pipeline-dnd.js?v=3"></script>
    <script src="js/agent-editor.js?v=3"></script>
    <script src="js/task-timer.js?v=1"></script>
    <script src="js/menu-config.js?v=1"></script>
    <script src="js/dc-canvas.js?v=2"></script>
    <script src="js/form-capture.js?v=1"></script>
</body>

</html>
