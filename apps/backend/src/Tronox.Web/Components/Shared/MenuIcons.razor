@* ===================================================================================
   Catalogo COMPARTIDO de iconos del menu configurable. Fuente unica de verdad para:
   (1) el sidebar data-driven (NavMenu.razor), (2) el arbol y el selector de iconos del
   editor (ConfiguracionMenu.razor) y (3) la vista previa del editor. Asi un icono elegido
   en el editor renderiza IDENTICO en el sidebar.

   ADR-001: la clave de icono es una CLASE DE BOOTSTRAP ICONS ("bi-*"), la misma familia
   que usa el prototipo TRONOX. Nunca se guarda un SVG en base de datos, solo la clave.
   Por eso este componente ya no dibuja trazos: emite <i class="bi bi-x"></i> y deja que
   la fuente (wwwroot/vendor/bootstrap-icons, MIT) lo pinte. Velzon trae remixicon,
   boxicons, materialdesign y lineawesome, pero NO Bootstrap Icons: se anadio aparte.

   Compatibilidad: las claves cortas heredadas del backbone ("home", "gear", "layout"...)
   se siguen resolviendo via Alias, para no romper vistas de menu ya guardadas por un
   tenant. Una clave desconocida cae a un icono neutro para no romper el render.
   =================================================================================== *@

@code {
    /// <summary>Icono neutro cuando la clave falta o no se reconoce.</summary>
    public const string ClaveGenerica = "bi-app";

    /// <summary>
    /// Claves cortas heredadas del backbone -> clase Bootstrap Icons equivalente. Solo existen
    /// para no romper los nodos que un tenant guardo antes de ADR-001; el selector ya ofrece
    /// claves "bi-*" directamente.
    /// </summary>
    private static readonly IReadOnlyDictionary<string, string> Alias =
        new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["home"] = "bi-house",
            ["megaphone"] = "bi-megaphone",
            ["list"] = "bi-list-ul",
            ["briefcase"] = "bi-briefcase",
            ["automation"] = "bi-diagram-2",
            ["robot"] = "bi-robot",
            ["cube"] = "bi-box-seam",
            ["check-square"] = "bi-check2-square",
            ["users"] = "bi-people",
            ["crm"] = "bi-person-vcard",
            ["gear"] = "bi-gear",
            ["folder"] = "bi-folder",
            ["chart"] = "bi-bar-chart",
            ["flow"] = "bi-diagram-3",
            ["form"] = "bi-ui-checks-grid",
            ["rule"] = "bi-shield-lock",
            ["bell"] = "bi-bell",
            ["shield"] = "bi-shield-check",
            ["file"] = "bi-file-earmark-text",
            ["tag"] = "bi-tags",
            ["link"] = "bi-link-45deg",
            ["database"] = "bi-hdd-stack",
            ["layout"] = "bi-grid-1x2",
            ["sparkles"] = "bi-stars"
        };

    /// <summary>
    /// Claves ofrecidas en el selector grid del editor (orden estable). Son las que usa el arbol
    /// canonico (MenuCatalogo) mas las de uso general, para que el tenant reencuentre en el
    /// selector el mismo icono que ve en el sidebar.
    /// </summary>
    public static readonly IReadOnlyList<string> Keys = new[]
    {
        "bi-house", "bi-grid-1x2", "bi-sliders", "bi-gear", "bi-building", "bi-buildings",
        "bi-diagram-3", "bi-person-badge", "bi-person-lock", "bi-people", "bi-person-circle",
        "bi-person-plus", "bi-person-vcard", "bi-shield-lock", "bi-shield-check", "bi-envelope-at",
        "bi-calendar3", "bi-calendar-x", "bi-hash", "bi-stars", "bi-bank", "bi-archive",
        "bi-clock-history", "bi-collection", "bi-list-ul", "bi-list-task", "bi-list-nested",
        "bi-table", "bi-tags", "bi-box-seam", "bi-cloud-arrow-up", "bi-folder", "bi-folder2-open",
        "bi-folder-symlink", "bi-bookmarks", "bi-journals", "bi-journal-text",
        "bi-file-earmark-text", "bi-file-earmark-plus", "bi-file-earmark-richtext",
        "bi-file-earmark-medical", "bi-file-earmark-ruled", "bi-file-earmark-bar-graph", "bi-files",
        "bi-share", "bi-check2-square", "bi-check-circle", "bi-x-circle", "bi-hourglass-split",
        "bi-send", "bi-pen", "bi-ui-checks-grid", "bi-inbox", "bi-inboxes", "bi-envelope",
        "bi-envelope-open", "bi-diagram-2", "bi-flag", "bi-activity", "bi-speedometer2",
        "bi-box-arrow-in-down", "bi-box-arrow-up", "bi-arrow-left-right", "bi-arrow-down-up",
        "bi-megaphone", "bi-chat-left-text", "bi-globe", "bi-briefcase", "bi-clipboard-check",
        "bi-cash-coin", "bi-graph-up", "bi-bar-chart", "bi-tools", "bi-bell", "bi-grid",
        "bi-hdd-stack", "bi-app"
    };

    /// <summary>
    /// Resuelve una clave almacenada a la clase Bootstrap Icons que se debe pintar. Acepta ya sea
    /// una clase "bi-*", una clave corta heredada, o nada (icono neutro). Solo deja pasar
    /// caracteres de clase CSS: la clave viene de base de datos y termina en un atributo class.
    /// </summary>
    public static string Resolve(string? key)
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return ClaveGenerica;
        }

        var k = key.Trim();
        if (Alias.TryGetValue(k, out var alias))
        {
            return alias;
        }

        if (!k.StartsWith("bi-", StringComparison.OrdinalIgnoreCase))
        {
            return ClaveGenerica;
        }

        foreach (var c in k)
        {
            if (!char.IsAsciiLetterOrDigit(c) && c != '-')
            {
                return ClaveGenerica;
            }
        }

        return k.ToLowerInvariant();
    }

    /// <summary>True si la clave se reconoce (es decir, NO cae en el icono generico).</summary>
    public static bool IsKnown(string? key) => Resolve(key) != ClaveGenerica;

    /// <summary>Etiqueta legible para el tooltip del selector (ASCII).</summary>
    public static string Label(string key)
    {
        var k = Resolve(key);
        return k.StartsWith("bi-", StringComparison.Ordinal) ? k[3..].Replace('-', ' ') : k;
    }

    /// <summary>Icono para una clave. Reutilizado por sidebar, arbol, selector y preview.</summary>
    public static RenderFragment Render(string? key) => @<i class="bi @Resolve(key) tronox-mi" aria-hidden="true"></i>;
}
