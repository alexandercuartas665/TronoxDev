    <bpmn2:startEvent id="Event_09gcxpb" name="Requerimiento">
      <bpmn2:outgoing>Flow_0wlkxd6</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:task id="Activity_1wx9i90" name="Cotización a Proveedores Y Prepara cotización">
      <bpmn2:incoming>Flow_0wlkxd6</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1ro0roy</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="Flow_0wlkxd6" sourceRef="Event_09gcxpb" targetRef="Activity_1wx9i90" />
    <bpmn2:task id="Activity_1pmyxmp" name="Se aprueba proveedor y cotizacion">
      <bpmn2:incoming>Flow_1qznjcs</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1aag64r</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:exclusiveGateway id="Gateway_0fzrd52" name="Aprobación de cliente">
      <bpmn2:incoming>Flow_1aag64r</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1shvar6</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_0lakcz3</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="Flow_1aag64r" sourceRef="Activity_1pmyxmp" targetRef="Gateway_0fzrd52" />
    <bpmn2:task id="Activity_16toqtl" name="Se aprueba compra por el cliente">
      <bpmn2:incoming>Flow_1shvar6</bpmn2:incoming>
      <bpmn2:outgoing>Flow_01ogjlk</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_1y0d6pi</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_1j5nxeu</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_02gcu84</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="Flow_1shvar6" sourceRef="Gateway_0fzrd52" targetRef="Activity_16toqtl" />
    <bpmn2:task id="Activity_08z4h2i" name="Generar Factura">
      <bpmn2:incoming>Flow_1j5nxeu</bpmn2:incoming>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="Flow_01ogjlk" sourceRef="Activity_16toqtl" targetRef="Activity_07rk77s" />
    <bpmn2:task id="Activity_1gv8bbv" name="Entrega para gestión de pago">
      <bpmn2:incoming>Flow_1y0d6pi</bpmn2:incoming>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="Flow_1y0d6pi" sourceRef="Activity_16toqtl" targetRef="Activity_1gv8bbv" />
    <bpmn2:task id="Activity_07rk77s" name="Recibe producto y gestiona entrega a cliente">
      <bpmn2:incoming>Flow_01ogjlk</bpmn2:incoming>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="Flow_1j5nxeu" sourceRef="Activity_16toqtl" targetRef="Activity_08z4h2i" />
    <bpmn2:task id="Activity_0hzp97e" name="Ingreso de la compra al sistema alegra">
      <bpmn2:incoming>Flow_02gcu84</bpmn2:incoming>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="Flow_02gcu84" sourceRef="Activity_16toqtl" targetRef="Activity_0hzp97e" />
    <bpmn2:exclusiveGateway id="Gateway_0g4aqmo" name="El cliente rechaza regresa a se aprueba proveedor y cotización GENERAL">
      <bpmn2:incoming>Flow_0lakcz3</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0youhcj</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_0e7fp7u</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="Flow_0lakcz3" sourceRef="Gateway_0fzrd52" targetRef="Gateway_0g4aqmo" />
    <bpmn2:task id="Activity_09bb9i7" name="Negocio Perdido">
      <bpmn2:incoming>Flow_0youhcj</bpmn2:incoming>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="Flow_0youhcj" sourceRef="Gateway_0g4aqmo" targetRef="Activity_09bb9i7" />
    <bpmn2:exclusiveGateway id="Gateway_1011av8" name="Se aprueba oferta de proveedores">
      <bpmn2:incoming>Flow_1ro0roy</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1qznjcs</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_10zjmfr</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="Flow_1ro0roy" sourceRef="Activity_1wx9i90" targetRef="Gateway_1011av8" />
    <bpmn2:sequenceFlow id="Flow_1qznjcs" sourceRef="Gateway_1011av8" targetRef="Activity_1pmyxmp" />
    <bpmn2:endEvent id="Event_1dnond2" name="Reiniciar">
      <bpmn2:incoming>Flow_10zjmfr</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="Flow_10zjmfr" sourceRef="Gateway_1011av8" targetRef="Event_1dnond2" />
    <bpmn2:endEvent id="Event_032qjxx" name="Reiniciar a Proveedor">
      <bpmn2:incoming>Flow_0e7fp7u</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="Flow_0e7fp7u" sourceRef="Gateway_0g4aqmo" targetRef="Event_032qjxx" />
    <bpmn2:textAnnotation id="TextAnnotation_0278pfh">
      <bpmn2:text>Coordinado de infraestructura cotiza diferentes opciones de compra</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_1d276pk" sourceRef="Activity_1wx9i90" targetRef="TextAnnotation_0278pfh" />
    <bpmn2:textAnnotation id="TextAnnotation_13lnlj2">
      <bpmn2:text>También se crea la cotización para enviar al cliente</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_1vhxihd" sourceRef="Activity_1pmyxmp" targetRef="TextAnnotation_13lnlj2" />
    <bpmn2:textAnnotation id="TextAnnotation_1joqf29">
      <bpmn2:text>Debe llenar formulario de cotizacion y establecer % de incremento al cliente</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_0g8scwd" sourceRef="Activity_1wx9i90" targetRef="TextAnnotation_1joqf29" />
    <bpmn2:textAnnotation id="TextAnnotation_1tjuev4">
      <bpmn2:text>Se solicita producto al proveedor con orden de compra igual a la tarea, se solicita la guia al proveedor</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_0p6j9by" sourceRef="Activity_16toqtl" targetRef="TextAnnotation_1tjuev4" />
    <bpmn2:textAnnotation id="TextAnnotation_0bixx89">
      <bpmn2:text>Debe apuntar numero de la tarea, debe coordinar si la factura es anticipada</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_1gnhkw4" sourceRef="Activity_08z4h2i" targetRef="TextAnnotation_0bixx89" />
    <bpmn2:textAnnotation id="TextAnnotation_0vuhidw">
      <bpmn2:text>debe apuntar el numero de la tarea</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_01ztsww" sourceRef="Activity_0hzp97e" targetRef="TextAnnotation_0vuhidw" />
    <bpmn2:textAnnotation id="TextAnnotation_0f38vw4">
      <bpmn2:text>Se prepara, alista y entrega producto y se llena formato de entrega de producto con firma recibido de cliente</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_1ia0ek2" sourceRef="Activity_07rk77s" targetRef="TextAnnotation_0f38vw4" />
  </bpmn2:process>
