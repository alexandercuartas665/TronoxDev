<Window x:Class="Ecorex.Agent.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:Ecorex.Agent.Gui.Controls"
        Title="ECOREX - Agente Conector"
        Width="520" Height="580"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Window.InputBindings>
        <!-- Atajos ocultos: Ctrl+D corre la DEMO (Ola A); Ctrl+K abre/cierra Configuracion. -->
        <KeyBinding Modifiers="Control" Key="D" Command="{Binding RunDemoCommand}" />
        <KeyBinding Modifiers="Control" Key="K" Command="{Binding ToggleConfigCommand}" />
    </Window.InputBindings>

    <!-- Marco translucido oscuro con esquinas redondeadas y borde tenue. Todo MONOCROMO. -->
    <Border CornerRadius="18"
            Background="{StaticResource HivePanel}"
            BorderBrush="{StaticResource HiveStroke}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.55" Color="#000000" />
        </Border.Effect>

        <Grid Margin="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Barra superior (zona de arrastre) + minimizar/cerrar propios. -->
            <Grid Grid.Row="0" Margin="18,14,12,4" Background="Transparent"
                  MouseLeftButtonDown="OnDragBackground">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="26" Height="26" CornerRadius="8" Background="{StaticResource HiveFill}">
                        <TextBlock Text="E" FontWeight="Bold" FontSize="14" Foreground="#161618"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Agente Conector" Foreground="{StaticResource HiveInk}"
                                   FontSize="13.5" FontWeight="SemiBold" />
                        <TextBlock Text="ECOREX - colmena on-prem" Foreground="{StaticResource HiveInkDim}"
                                   FontSize="10.5" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button x:Name="MinButton" Content="&#x2013;" Click="OnMinimize"
                            Style="{DynamicResource ChromeButton}" />
                    <Button x:Name="CloseButton" Content="&#x2715;" Click="OnClose"
                            Style="{DynamicResource ChromeButton}" />
                </StackPanel>
            </Grid>

            <!-- Area del panal + flyout de configuracion superpuesto. -->
            <Grid Grid.Row="1">
                <ItemsControl ItemsSource="{Binding Cells}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Margin="18,6,18,6">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ctl:HoneycombPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ctl:HexTile Cursor="Hand" MouseLeftButtonUp="OnCellClick" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Flyout de configuracion (se muestra al hacer clic en la celda Configuracion). -->
                <Border Background="#F21B1B1E" CornerRadius="14" Margin="14"
                        Width="472" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                        BorderBrush="{StaticResource HiveStroke}" BorderThickness="1"
                        Visibility="{Binding IsConfigOpen, Converter={StaticResource BoolToVis}}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.6" Color="#000000" />
                    </Border.Effect>
                    <StackPanel Margin="20,18,20,18">
                        <Grid>
                            <TextBlock Text="Configuracion del agente" Foreground="{StaticResource HiveInk}"
                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Content="&#x2715;" Command="{Binding ToggleConfigCommand}"
                                    HorizontalAlignment="Right" Style="{DynamicResource ChromeButton}" />
                        </Grid>

                        <TextBlock Text="Client ID" Style="{DynamicResource FieldLabel}" Margin="0,16,0,0" />
                        <TextBox Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource InkTextBox}" />

                        <TextBlock Text="URL del Hub (SignalR)" Style="{DynamicResource FieldLabel}" Margin="0,12,0,0" />
                        <TextBox Text="{Binding HubUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource InkTextBox}" />

                        <TextBlock Text="Secreto del cliente (opcional)" Style="{DynamicResource FieldLabel}" Margin="0,12,0,0" />
                        <TextBox Text="{Binding Secret, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource InkTextBox}" />

                        <!-- Estado de conexion. -->
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0" VerticalAlignment="Center">
                            <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                                     Fill="{Binding IsOnline, Converter={StaticResource BoolToStatusBrush}}" />
                            <TextBlock Text="Estado:" Foreground="{StaticResource HiveInkDim}"
                                       Margin="8,0,6,0" VerticalAlignment="Center" FontSize="12" />
                            <TextBlock Text="{Binding ConnectionLabel}" Foreground="{StaticResource HiveInk}"
                                       VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Right">
                            <Button Content="Guardar" Command="{Binding SaveConfigCommand}"
                                    Style="{DynamicResource GhostButton}" />
                            <Button Content="Probar conexion" Command="{Binding TestConnectionCommand}"
                                    Style="{DynamicResource PrimaryButton}" Margin="8,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Flyout POR capacidad (Navegador/Archivos): consentimiento local + allow-list (doc 06 s4). -->
                <Border Background="#F21B1B1E" CornerRadius="14" Margin="14"
                        Width="472" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                        BorderBrush="{StaticResource HiveStroke}" BorderThickness="1"
                        Visibility="{Binding IsCapConfigOpen, Converter={StaticResource BoolToVis}}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.6" Color="#000000" />
                    </Border.Effect>
                    <StackPanel Margin="20,18,20,18">
                        <Grid>
                            <TextBlock Text="{Binding CapTitle}" Foreground="{StaticResource HiveInk}"
                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Content="&#x2715;" Command="{Binding CloseCapabilityCommand}"
                                    HorizontalAlignment="Right" Style="{DynamicResource ChromeButton}" />
                        </Grid>

                        <CheckBox Content="Habilitada por mi (el operador)" IsChecked="{Binding CapEnabled}"
                                  Foreground="{StaticResource HiveInk}" FontSize="12.5" Margin="0,16,0,0" />
                        <TextBlock Text="Sin habilitar, esta capacidad se rechaza aunque la nube la pida."
                                   Foreground="{StaticResource HiveInkDim}" FontSize="10.5" Margin="0,4,0,0" TextWrapping="Wrap" />

                        <TextBlock Text="Allow-list" Style="{DynamicResource FieldLabel}" Margin="0,14,0,0" />
                        <TextBox Text="{Binding CapAllowText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource InkTextBox}" AcceptsReturn="True" TextWrapping="NoWrap"
                                 VerticalContentAlignment="Top" Height="110"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" />
                        <TextBlock Text="{Binding CapHint}" Foreground="{StaticResource HiveInkDim}"
                                   FontSize="10.5" Margin="0,4,0,0" TextWrapping="Wrap" />

                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0" HorizontalAlignment="Right">
                            <Button Content="Cerrar" Command="{Binding CloseCapabilityCommand}"
                                    Style="{DynamicResource GhostButton}" />
                            <Button Content="Guardar" Command="{Binding SaveCapabilityCommand}"
                                    Style="{DynamicResource PrimaryButton}" Margin="8,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Barra de estado inferior: conexion global + pista de demo. -->
            <Grid Grid.Row="2" Margin="18,4,18,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding IsOnline, Converter={StaticResource BoolToStatusBrush}}" />
                    <TextBlock Text="{Binding ConnectionLabel}" Foreground="{StaticResource HiveInkDim}"
                               Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11" />
                </StackPanel>
                <TextBlock Text="Ctrl+D: demo" Foreground="{StaticResource HiveInkDim}" Opacity="0.6"
                           HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10.5" />
            </Grid>
        </Grid>
    </Border>

    <Window.Resources>
        <!-- Botones de la barra (minimizar/cerrar): planos, monocromos, hover tenue. -->
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Foreground" Value="{StaticResource HiveInkDim}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1FFFFFFF" />
                                <Setter Property="Foreground" Value="{StaticResource HiveInk}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Etiqueta de campo. -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource HiveInkDim}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <!-- Caja de texto monocroma. -->
        <Style x:Key="InkTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource HiveInk}" />
            <Setter Property="CaretBrush" Value="{StaticResource HiveInk}" />
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource HiveStroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Boton primario (relleno claro). -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="#161618" />
            <Setter Property="Background" Value="{StaticResource HiveFill}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="9" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Boton fantasma (borde tenue). -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource HiveInk}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="9" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource HiveStroke}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#14FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>
