# Plantilla de configuracion del stack local de TRONOX SGDEA.
#
# Copia este archivo a .env y pon valores propios. El .env NO se versiona: el repositorio
# es PUBLICO y ninguna credencial puede entrar en el.
#
#   cp .env.example .env
#
# Los puertos son el BLOQUE DEDICADO de TRONOX, verificado libre contra los ~30 contenedores
# de los stacks hermanos (ecorex-tareas, doktrino, cubot, cubot-travels, cubotrm, visal,
# propia, traiding). Si necesitas moverlos, cambialos aqui y vuelve a correr preflight.ps1;
# no hace falta tocar el docker-compose.yml.

# ---- Puertos del host ----
POSTGRES_PORT=5443
REDIS_PORT=6390
RABBITMQ_PORT=5683
RABBITMQ_MGMT_PORT=15683
MINIO_PORT=9004
MINIO_CONSOLE_PORT=9005
ADMINER_PORT=8093
API_PORT=8094
WEB_PORT=8095

# ---- PostgreSQL (motor unico de TRONOX) ----
POSTGRES_DB=tronox_dev
POSTGRES_USER=tronox
POSTGRES_PASSWORD=cambia-esta-clave

# ---- Redis (cache de KPIs y de menu resuelto) ----
REDIS_PASSWORD=cambia-esta-clave

# ---- RabbitMQ (colas: motor SLA, OCR, workflow, notificaciones) ----
RABBITMQ_DEFAULT_USER=tronox
RABBITMQ_DEFAULT_PASS=cambia-esta-clave

# ---- MinIO (object storage S3: binarios, nunca BLOB en base de datos) ----
MINIO_ROOT_USER=tronox
MINIO_ROOT_PASSWORD=cambia-esta-clave

# ---- Cadena de conexion que consumen las apps ----
# Host localhost porque en desarrollo las apps corren FUERA de docker.
TRONOX_DB_CONNECTION=Host=localhost;Port=5443;Database=tronox_dev;Username=tronox;Password=cambia-esta-clave
