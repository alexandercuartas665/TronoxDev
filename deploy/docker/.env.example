# ECOREX.tareas - variables locales para docker compose
# Copiar este archivo como `.env` y ajustar contrasenas antes de levantar la pila.
# Este archivo es plantilla y puede versionarse; el `.env` real esta en .gitignore.
#
# Bloque de puertos DEDICADO de ECOREX Tareas (no chocar con doktrino/cubot/visal):
#   Postgres 5442 | SQL Server 1443 | Redis 6389 | RabbitMQ 5682/15682 | Adminer 8092

# --- PostgreSQL ---
POSTGRES_DB=ecorex_dev
POSTGRES_USER=ecorex
POSTGRES_PASSWORD=cambiar-en-local
POSTGRES_PORT=5442

# --- SQL Server 2022 (DAL dual) ---
# La clave SA debe cumplir la politica de complejidad de SQL Server
# (mayusculas + minusculas + digitos, minimo 8 caracteres).
SQLSERVER_SA_PASSWORD=Cambiar-En-Local1
SQLSERVER_PORT=1443

# --- Redis ---
REDIS_PASSWORD=cambiar-en-local
REDIS_PORT=6389

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=ecorex
RABBITMQ_DEFAULT_PASS=cambiar-en-local
RABBITMQ_PORT=5682
RABBITMQ_MGMT_PORT=15682

# --- Adminer (Postgres y SQL Server) ---
ADMINER_PORT=8092
