# Plantilla del .env de PRODUCCION de TRONOX. Se copia a /opt/tronox/.env EN EL HOST
# y se rellena con valores reales ALLI. NUNCA se versiona ni se pega en un chat.
#
# Generar claves fuertes en el propio host, por ejemplo:
#   openssl rand -base64 24
#
# Base de datos (Postgres interno del stack).
POSTGRES_DB=tronox_prod
POSTGRES_USER=tronox
POSTGRES_PASSWORD=<generar-en-el-host>
