# =========================================================================
#  ECOREX.tareas - configuracion de PRODUCCION (docker-compose.from-git.yml)
#  Copia este archivo a .env (sin .example) EN EL SERVER y edita los valores.
#  NUNCA versionar el .env real (esta en .gitignore).
# =========================================================================

# ---------- Rama del repo a construir ----------
# El server clona y construye esta ref. Acepta branch, tag (v1.2.3) o commit sha.
# Hoy la rama viva es fase-0/clon-backbone (main aun no mergeado).
ECOREX_BRANCH=fase-0/clon-backbone

# ---------- Puerto del host ----------
# Puerto publico donde queda ecorex-app (HTTP plano, sin TLS), igual que las
# demas apps del box (Visal usa 5380). DEBE ser distinto a los ya usados
# (5380, 6875, 8200, 9090). 5480 esta libre. Verifica: ss -tlnp | grep 5480
ECOREX_PORT=5480

# ---------- Postgres (interno, no expuesto) ----------
POSTGRES_DB=ecorex
POSTGRES_USER=ecorex
# CAMBIA esta clave por una larga y aleatoria ANTES del primer arranque.
# Sugerencia en Linux: openssl rand -base64 32
POSTGRES_PASSWORD=CAMBIAR_ESTA_CLAVE_LARGA_Y_ALEATORIA

# ---------- Bootstrap del Super Admin ----------
# Clave del primer operador de plataforma (admin@ecorex.local) que se crea
# al arrancar en Production. CAMBIALA. Sin esto no puedes entrar la 1a vez.
ECOREX_SEED_ADMIN_PASSWORD=CAMBIAR_ESTA_CLAVE_DE_ADMIN

# ---------- Dominio (solo si usas el Caddy incluido) ----------
# Subdominio publico de ECOREX. Requiere registro A apuntando al server y
# puertos 80/443 libres. Si tu server ya tiene un proxy global, IGNORA esto
# y enruta desde ese proxy hacia 127.0.0.1:${ECOREX_PORT}.
ECOREX_DOMAIN=ecorex.tudominio.com
